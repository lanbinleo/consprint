            <outline text="治疗：边缘型人格障碍 BPD、抑郁、焦虑、PTSD、进食障碍" _mubu_text="%3Cspan%3E%E6%B2%BB%E7%96%97%EF%BC%9A%E8%BE%B9%E7%BC%98%E5%9E%8B%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20BPD%E3%80%81%E6%8A%91%E9%83%81%E3%80%81%E7%84%A6%E8%99%91%E3%80%81PTSD%E3%80%81%E8%BF%9B%E9%A3%9F%E9%9A%9C%E7%A2%8D%3C/span%3E" _note="" _mubu_note=""/>
