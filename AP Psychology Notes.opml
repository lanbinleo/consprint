            <outline text="判断-知觉 Judging-Perceiving" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E5%88%A4%E6%96%AD-%E7%9F%A5%E8%A7%89%3C/span%3E%3Cspan%3E%20Judging-Perceiving%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="无条件积极关注 Unconditional Positive Regard 人本主义心理学概念，" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%97%A0%E6%9D%A1%E4%BB%B6%E7%A7%AF%E6%9E%81%E5%85%B3%E6%B3%A8%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EUnconditional%20Positive%20Regard%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BA%BA%E6%9C%AC%E4%B8%BB%E4%B9%89%3C/span%3E%3Cspan%3E%E5%BF%83%E7%90%86%E5%AD%A6%E6%A6%82%E5%BF%B5%EF%BC%8C%3C/span%3E" _note="" _mubu_note="">
            <outline text="指治疗师对来访者保持温暖、接受的态度，无论其行为如何都不予评判「来访者说出任何想法都不会被批评或否定」" _mubu_text="%3Cspan%3E%E6%8C%87%E6%B2%BB%E7%96%97%E5%B8%88%E5%AF%B9%E6%9D%A5%E8%AE%BF%E8%80%85%E4%BF%9D%E6%8C%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%B8%A9%E6%9A%96%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8E%A5%E5%8F%97%3C/span%3E%3Cspan%3E%E7%9A%84%E6%80%81%E5%BA%A6%EF%BC%8C%E6%97%A0%E8%AE%BA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%85%B6%E8%A1%8C%E4%B8%BA%E5%A6%82%E4%BD%95%E9%83%BD%E4%B8%8D%E4%BA%88%E8%AF%84%E5%88%A4%3C/span%3E%3Cspan%3E%E3%80%8C%E6%9D%A5%E8%AE%BF%E8%80%85%E8%AF%B4%E5%87%BA%E4%BB%BB%E4%BD%95%E6%83%B3%E6%B3%95%E9%83%BD%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%8D%E4%BC%9A%E8%A2%AB%E6%89%B9%E8%AF%84%E6%88%96%E5%90%A6%E5%AE%9A%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
