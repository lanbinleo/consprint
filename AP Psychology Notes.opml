          <outline text="精神分析：揭露潜意识内容，缓解心理Tension；传统疗法每周2-3次，持续长达7年" _mubu_text="%3Cspan%3E%E7%B2%BE%E7%A5%9E%E5%88%86%E6%9E%90%EF%BC%9A%E6%8F%AD%E9%9C%B2%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%BD%9C%E6%84%8F%E8%AF%86%3C/span%3E%3Cspan%3E%E5%86%85%E5%AE%B9%EF%BC%8C%E7%BC%93%E8%A7%A3%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%83%E7%90%86Tension%3C/span%3E%3Cspan%3E%EF%BC%9B%E4%BC%A0%E7%BB%9F%E7%96%97%E6%B3%95%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%AF%8F%E5%91%A82-3%E6%AC%A1%EF%BC%8C%E6%8C%81%E7%BB%AD%E9%95%BF%E8%BE%BE7%E5%B9%B4%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="自由联想 Free Association 患者自由表达脑中浮现的想法、感受与记忆，挖掘潜意识冲突" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E7%94%B1%E8%81%94%E6%83%B3%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EFree%20Association%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E6%82%A3%E8%80%85%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%87%AA%E7%94%B1%E8%A1%A8%E8%BE%BE%E8%84%91%3C/span%3E%3Cspan%3E%E4%B8%AD%E6%B5%AE%E7%8E%B0%E7%9A%84%E6%83%B3%E6%B3%95%E3%80%81%E6%84%9F%E5%8F%97%E4%B8%8E%E8%AE%B0%E5%BF%86%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8C%96%E6%8E%98%E6%BD%9C%E6%84%8F%E8%AF%86%E5%86%B2%E7%AA%81%3C/span%3E" _note="" _mubu_note="">
