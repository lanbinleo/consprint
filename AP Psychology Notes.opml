            <outline text="Behavioral observations, Situational assessment, " _mubu_text="%3Cspan%3EBehavioral%20observations,%20Situational%20assessment,%20%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Questionnaires, Interviews, Case Studies；" _mubu_text="%3Cspan%3EQuestionnaires,%20Interviews,%20Case%20Studies%EF%BC%9B%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="全方位评价三者之间的关系" _mubu_text="%3Cspan%3E%E5%85%A8%E6%96%B9%E4%BD%8D%E8%AF%84%E4%BB%B7%E4%B8%89%E8%80%85%E4%B9%8B%E9%97%B4%E7%9A%84%E5%85%B3%E7%B3%BB%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
