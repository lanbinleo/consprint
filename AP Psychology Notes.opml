<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>AP Psychology</title>
  </head>
  <body>
    <outline text="文档介绍" _mubu_text="%3Cspan%3E%E6%96%87%E6%A1%A3%E4%BB%8B%E7%BB%8D%3C/span%3E" _note="" _mubu_note="">
      <outline text="这是 AP Psychology Ultimate Review 文档，包含了Leo全部的 Well Designed 笔记和一些帮助你复习 AP Psych 的资料。" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AF%20AP%20Psychology%20Ultimate%20Review%20%E6%96%87%E6%A1%A3%EF%BC%8C%E5%8C%85%E5%90%AB%E4%BA%86Leo%E5%85%A8%E9%83%A8%E7%9A%84%20Well%20Designed%20%E7%AC%94%E8%AE%B0%E5%92%8C%E4%B8%80%E4%BA%9B%E5%B8%AE%E5%8A%A9%E4%BD%A0%E5%A4%8D%E4%B9%A0%20AP%20Psych%20%E7%9A%84%E8%B5%84%E6%96%99%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
      <outline text="祝你在 Mock Exam 和 AP 考试中取得好成绩！" _mubu_text="%3Cspan%3E%E7%A5%9D%E4%BD%A0%E5%9C%A8%20Mock%20Exam%20%E5%92%8C%20AP%20%E8%80%83%E8%AF%95%E4%B8%AD%E5%8F%96%E5%BE%97%E5%A5%BD%E6%88%90%E7%BB%A9%EF%BC%81%3C/span%3E" _note="" _mubu_note=""/>
      <outline text="字体颜色说明" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E5%AD%97%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%BD%93%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%A2%9C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%89%B2%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E8%AF%B4%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%98%8E%3C/span%3E" _note="" _mubu_note="">
        <outline text="正常「叙述」，普通解释、过渡语、背景说明（不需要强行记忆的句子）" _mubu_text="%3Cspan%3E%E6%AD%A3%E5%B8%B8%E3%80%8C%E5%8F%99%E8%BF%B0%E3%80%8D%EF%BC%8C%E6%99%AE%E9%80%9A%E8%A7%A3%E9%87%8A%E3%80%81%E8%BF%87%E6%B8%A1%E8%AF%AD%E3%80%81%E8%83%8C%E6%99%AF%E8%AF%B4%E6%98%8E%EF%BC%88%E4%B8%8D%E9%9C%80%E8%A6%81%E5%BC%BA%E8%A1%8C%E8%AE%B0%E5%BF%86%E7%9A%84%E5%8F%A5%E5%AD%90%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="红色「必背核心 / 考试触发词」看到就要反应（最重要的关键词）" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E7%BA%A2%E8%89%B2%3C/span%3E%3Cspan%3E%E3%80%8C%E5%BF%85%E8%83%8C%E6%A0%B8%E5%BF%83%20/%20%E8%80%83%E8%AF%95%E8%A7%A6%E5%8F%91%E8%AF%8D%E3%80%8D%E7%9C%8B%E5%88%B0%E5%B0%B1%E8%A6%81%E5%8F%8D%E5%BA%94%EF%BC%88%E6%9C%80%E9%87%8D%E8%A6%81%E7%9A%84%E5%85%B3%E9%94%AE%E8%AF%8D%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="黄色「易错 / 易混」这里容易掉进坑里" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E9%BB%84%E8%89%B2%3C/span%3E%3Cspan%3E%E3%80%8C%E6%98%93%E9%94%99%20/%20%E6%98%93%E6%B7%B7%E3%80%8D%E8%BF%99%E9%87%8C%E5%AE%B9%E6%98%93%E6%8E%89%E8%BF%9B%E5%9D%91%E9%87%8C%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="绿色「例子 / 应用 / 情景题」用例子🌰理解概念" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E7%BB%BF%E8%89%B2%3C/span%3E%3Cspan%3E%E3%80%8C%E4%BE%8B%E5%AD%90%20/%20%E5%BA%94%E7%94%A8%20/%20%E6%83%85%E6%99%AF%E9%A2%98%E3%80%8D%E7%94%A8%E4%BE%8B%E5%AD%90%F0%9F%8C%B0%E7%90%86%E8%A7%A3%E6%A6%82%E5%BF%B5%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="蓝色「方法 / 结构 / 流程」How it works" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E8%93%9D%E8%89%B2%3C/span%3E%3Cspan%3E%E3%80%8C%E6%96%B9%E6%B3%95%20/%20%E7%BB%93%E6%9E%84%20/%20%E6%B5%81%E7%A8%8B%E3%80%8DHow%20it%20works%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="紫色「思维升级 / 考官视角」串联知识、对概念的高阶理解" _mubu_text="%3Cspan%20class=%22text-color-purple%22%3E%E7%B4%AB%E8%89%B2%3C/span%3E%3Cspan%3E%E3%80%8C%E6%80%9D%E7%BB%B4%E5%8D%87%E7%BA%A7%20/%20%E8%80%83%E5%AE%98%E8%A7%86%E8%A7%92%E3%80%8D%E4%B8%B2%E8%81%94%E7%9F%A5%E8%AF%86%E3%80%81%E5%AF%B9%E6%A6%82%E5%BF%B5%E7%9A%84%E9%AB%98%E9%98%B6%E7%90%86%E8%A7%A3%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="加粗「仅限红蓝」该颜色中的核心点" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8A%A0%E7%B2%97%3C/span%3E%3Cspan%3E%E3%80%8C%E4%BB%85%E9%99%90%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E7%BA%A2%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%93%9D%3C/span%3E%3Cspan%3E%E3%80%8D%E8%AF%A5%E9%A2%9C%E8%89%B2%E4%B8%AD%E7%9A%84%E6%A0%B8%E5%BF%83%E7%82%B9%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="下划线「仅限黄色」不能忽略的坑！" _mubu_text="%3Cspan%20class=%22underline%22%3E%E4%B8%8B%E5%88%92%E7%BA%BF%3C/span%3E%3Cspan%3E%E3%80%8C%E4%BB%85%E9%99%90%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%BB%84%E8%89%B2%3C/span%3E%3Cspan%3E%E3%80%8D%E4%B8%8D%E8%83%BD%E5%BF%BD%E7%95%A5%E7%9A%84%E5%9D%91%EF%BC%81%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="斜体「仅限紫色」思路，不是事实，不一定正确" _mubu_text="%3Cspan%20class=%22italic%22%3E%E6%96%9C%E4%BD%93%3C/span%3E%3Cspan%3E%E3%80%8C%E4%BB%85%E9%99%90%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E7%B4%AB%E8%89%B2%3C/span%3E%3Cspan%3E%E3%80%8D%E6%80%9D%E8%B7%AF%EF%BC%8C%E4%B8%8D%E6%98%AF%E4%BA%8B%E5%AE%9E%EF%BC%8C%E4%B8%8D%E4%B8%80%E5%AE%9A%E6%AD%A3%E7%A1%AE%3C/span%3E" _note="" _mubu_note=""/>
      </outline>
    </outline>
    <outline text="Unit 0（2550字）" _mubu_text="%3Cspan%3EUnit%200%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E2550%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
      <outline text="定位：心理学为什么是一门科学 + 科学研究的方法" _mubu_text="%3Cspan%3E%E5%AE%9A%E4%BD%8D%EF%BC%9A%E5%BF%83%E7%90%86%E5%AD%A6%E4%B8%BA%E4%BB%80%E4%B9%88%E6%98%AF%E4%B8%80%E9%97%A8%E7%A7%91%E5%AD%A6%20+%20%E7%A7%91%E5%AD%A6%E7%A0%94%E7%A9%B6%E7%9A%84%E6%96%B9%E6%B3%95%3C/span%3E" _note="" _mubu_note=""/>
      <outline text="0.0 心理学视角 / Psych Schools（Mr. Sinn，250字）" _mubu_text="%3Cspan%3E0.0%20%E5%BF%83%E7%90%86%E5%AD%A6%E8%A7%86%E8%A7%92%20/%20Psych%20Schools%EF%BC%88Mr.%20Sinn%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E250%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="Psychodynamic Perspective 心理动力学视角" _mubu_text="%3Cspan%3EPsychodynamic%20Perspective%20%E5%BF%83%E7%90%86%E5%8A%A8%E5%8A%9B%E5%AD%A6%E8%A7%86%E8%A7%92%3C/span%3E" _note="" _mubu_note="">
          <outline text="Sigmund Freud 弗洛伊德" _mubu_text="%3Cspan%3ESigmund%20Freud%20%E5%BC%97%E6%B4%9B%E4%BC%8A%E5%BE%B7%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="过去的经历影响了我们现在的人格" _mubu_text="%3Cspan%3E%E8%BF%87%E5%8E%BB%E7%9A%84%E7%BB%8F%E5%8E%86%E5%BD%B1%E5%93%8D%E4%BA%86%E6%88%91%E4%BB%AC%E7%8E%B0%E5%9C%A8%E7%9A%84%E4%BA%BA%E6%A0%BC%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Behaviorism 行为主义" _mubu_text="%3Cspan%3EBehaviorism%20%E8%A1%8C%E4%B8%BA%E4%B8%BB%E4%B9%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="反驳心理动力学，内心无法观测" _mubu_text="%3Cspan%3E%E5%8F%8D%E9%A9%B3%E5%BF%83%E7%90%86%E5%8A%A8%E5%8A%9B%E5%AD%A6%EF%BC%8C%E5%86%85%E5%BF%83%E6%97%A0%E6%B3%95%E8%A7%82%E6%B5%8B%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="从行为出发：奖励和惩罚（Skinner）" _mubu_text="%3Cspan%3E%E4%BB%8E%E8%A1%8C%E4%B8%BA%E5%87%BA%E5%8F%91%EF%BC%9A%E5%A5%96%E5%8A%B1%E5%92%8C%E6%83%A9%E7%BD%9A%EF%BC%88Skinner%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Sociocultural 社会文化视角" _mubu_text="%3Cspan%3ESociocultural%20%E7%A4%BE%E4%BC%9A%E6%96%87%E5%8C%96%E8%A7%86%E8%A7%92%3C/span%3E" _note="" _mubu_note="">
          <outline text="人是社会和文化的产物，社会塑造了我们" _mubu_text="%3Cspan%3E%E4%BA%BA%E6%98%AF%E7%A4%BE%E4%BC%9A%E5%92%8C%E6%96%87%E5%8C%96%E7%9A%84%E4%BA%A7%E7%89%A9%EF%BC%8C%E7%A4%BE%E4%BC%9A%E5%A1%91%E9%80%A0%E4%BA%86%E6%88%91%E4%BB%AC%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Lev Vygotsky和他的ZPD就是其中之一（Expectations &amp; Norms）" _mubu_text="%3Cspan%3ELev%20Vygotsky%E5%92%8C%E4%BB%96%E7%9A%84ZPD%E5%B0%B1%E6%98%AF%E5%85%B6%E4%B8%AD%E4%B9%8B%E4%B8%80%EF%BC%88Expectations%20&amp;amp;%20Norms%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Humanistic Perspective 人本主义" _mubu_text="%3Cspan%3EHumanistic%20Perspective%20%E4%BA%BA%E6%9C%AC%E4%B8%BB%E4%B9%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="个人成长、自由意志和自我实现" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BA%BA%E6%88%90%E9%95%BF%E3%80%81%E8%87%AA%E7%94%B1%E6%84%8F%E5%BF%97%E5%92%8C%E8%87%AA%E6%88%91%E5%AE%9E%E7%8E%B0%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Cognitive Perspective 认知视角" _mubu_text="%3Cspan%3ECognitive%20Perspective%20%E8%AE%A4%E7%9F%A5%E8%A7%86%E8%A7%92%3C/span%3E" _note="" _mubu_note="">
          <outline text="如何处理储存信息，以及如何影响我们的心理" _mubu_text="%3Cspan%3E%E5%A6%82%E4%BD%95%E5%A4%84%E7%90%86%E5%82%A8%E5%AD%98%E4%BF%A1%E6%81%AF%EF%BC%8C%E4%BB%A5%E5%8F%8A%E5%A6%82%E4%BD%95%E5%BD%B1%E5%93%8D%E6%88%91%E4%BB%AC%E7%9A%84%E5%BF%83%E7%90%86%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="CBT疗法" _mubu_text="%3Cspan%3ECBT%E7%96%97%E6%B3%95%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Biological Perspective 生物视角" _mubu_text="%3Cspan%3EBiological%20Perspective%20%E7%94%9F%E7%89%A9%E8%A7%86%E8%A7%92%3C/span%3E" _note="" _mubu_note="">
          <outline text="神经递质、激素、大脑结构等如何影响我们的心理" _mubu_text="%3Cspan%3E%E7%A5%9E%E7%BB%8F%E9%80%92%E8%B4%A8%E3%80%81%E6%BF%80%E7%B4%A0%E3%80%81%E5%A4%A7%E8%84%91%E7%BB%93%E6%9E%84%E7%AD%89%E5%A6%82%E4%BD%95%E5%BD%B1%E5%93%8D%E6%88%91%E4%BB%AC%E7%9A%84%E5%BF%83%E7%90%86%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Biopsychosocial perspective 生物‑心理‑社会整体视角" _mubu_text="%3Cspan%3EBiopsychosocial%20perspective%20%E7%94%9F%E7%89%A9%E2%80%91%E5%BF%83%E7%90%86%E2%80%91%E7%A4%BE%E4%BC%9A%E6%95%B4%E4%BD%93%E8%A7%86%E8%A7%92%3C/span%3E" _note="" _mubu_note="">
          <outline text="综合多个方面来看问题，认为行为是生物、心理、社会因素一起作用的结果。" _mubu_text="%3Cspan%3E%E7%BB%BC%E5%90%88%E5%A4%9A%E4%B8%AA%E6%96%B9%E9%9D%A2%E6%9D%A5%E7%9C%8B%E9%97%AE%E9%A2%98%EF%BC%8C%E8%AE%A4%E4%B8%BA%E8%A1%8C%E4%B8%BA%E6%98%AF%E7%94%9F%E7%89%A9%E3%80%81%E5%BF%83%E7%90%86%E3%80%81%E7%A4%BE%E4%BC%9A%E5%9B%A0%E7%B4%A0%E4%B8%80%E8%B5%B7%E4%BD%9C%E7%94%A8%E7%9A%84%E7%BB%93%E6%9E%9C%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Evolutionary perspective" _mubu_text="%3Cspan%3EEvolutionary%20perspective%3C/span%3E" _note="" _mubu_note="">
          <outline text="从自然选择的角度解释行为，认为某些行为可能是为了提高生存和繁衍概率而进化出来的" _mubu_text="%3Cspan%3E%E4%BB%8E%E8%87%AA%E7%84%B6%E9%80%89%E6%8B%A9%E7%9A%84%E8%A7%92%E5%BA%A6%E8%A7%A3%E9%87%8A%E8%A1%8C%E4%B8%BA%EF%BC%8C%E8%AE%A4%E4%B8%BA%E6%9F%90%E4%BA%9B%E8%A1%8C%E4%B8%BA%E5%8F%AF%E8%83%BD%E6%98%AF%E4%B8%BA%E4%BA%86%E6%8F%90%E9%AB%98%E7%94%9F%E5%AD%98%E5%92%8C%E7%B9%81%E8%A1%8D%E6%A6%82%E7%8E%87%E8%80%8C%E8%BF%9B%E5%8C%96%E5%87%BA%E6%9D%A5%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
      <outline text="0.1 心理学是一门科学（可证伪，50字）" _mubu_text="%3Cspan%3E0.1%20%E5%BF%83%E7%90%86%E5%AD%A6%E6%98%AF%E4%B8%80%E9%97%A8%E7%A7%91%E5%AD%A6%EF%BC%88%E5%8F%AF%E8%AF%81%E4%BC%AA%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E50%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="Psychology is a science because it relies on empirical evidence (observational and experimentation)" _mubu_text="%3Cspan%3EPsychology%20is%20a%20science%20because%20it%20%3C/span%3E%3Cspan%20class=%22bold%22%3Erelies%20on%20empirical%20evidence%3C/span%3E%3Cspan%3E%20(observational%20and%20experimentation)%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="人们凭感觉猜测有可能出错：Overconfidence, Confirmation Bias, Hindsight Bias" _mubu_text="%3Cspan%3E%E4%BA%BA%E4%BB%AC%E5%87%AD%E6%84%9F%E8%A7%89%E7%8C%9C%E6%B5%8B%E6%9C%89%E5%8F%AF%E8%83%BD%E5%87%BA%E9%94%99%EF%BC%9AOverconfidence,%20Confirmation%20Bias,%20Hindsight%20Bias%3C/span%3E" _note="" _mubu_note=""/>
      </outline>
      <outline text="0.2-0.3 科学研究的方法（Big 5 Methods，1000字）" _mubu_text="%3Cspan%3E0.2-0.3%20%E7%A7%91%E5%AD%A6%E7%A0%94%E7%A9%B6%E7%9A%84%E6%96%B9%E6%B3%95%EF%BC%88Big%205%20Methods%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E1000%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="Theory vs. Hypothesis" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ETheory%20vs.%20Hypothesis%3C/span%3E" _note="" _mubu_note="">
          <outline text="Theory 理论" _mubu_text="%3Cspan%3ETheory%20%E7%90%86%E8%AE%BA%3C/span%3E" _note="" _mubu_note="">
            <outline text="被大量研究反复检验" _mubu_text="%3Cspan%3E%E8%A2%AB%E5%A4%A7%E9%87%8F%E7%A0%94%E7%A9%B6%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%8F%8D%E5%A4%8D%E6%A3%80%E9%AA%8C%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="能组织和解释多个研究结果" _mubu_text="%3Cspan%3E%E8%83%BD%E7%BB%84%E7%BB%87%E5%92%8C%E8%A7%A3%E9%87%8A%E5%A4%9A%E4%B8%AA%E7%A0%94%E7%A9%B6%E7%BB%93%E6%9E%9C%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="用来预测行为和现象" _mubu_text="%3Cspan%3E%E7%94%A8%E6%9D%A5%E9%A2%84%E6%B5%8B%E8%A1%8C%E4%B8%BA%E5%92%8C%E7%8E%B0%E8%B1%A1%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Hypothesis 假设" _mubu_text="%3Cspan%3EHypothesis%20%E5%81%87%E8%AE%BE%3C/span%3E" _note="" _mubu_note="">
            <outline text="具体的，可测试的预测" _mubu_text="%3Cspan%3E%E5%85%B7%E4%BD%93%E7%9A%84%EF%BC%8C%E5%8F%AF%E6%B5%8B%E8%AF%95%E7%9A%84%E9%A2%84%E6%B5%8B%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="还没有被验证" _mubu_text="%3Cspan%3E%E8%BF%98%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%B2%A1%E6%9C%89%E8%A2%AB%E9%AA%8C%E8%AF%81%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="被称为科学，必须要Falsifiability（世界被一只无敌小蜜蜂蛋糕控制🐝）" _mubu_text="%3Cspan%3E%E8%A2%AB%E7%A7%B0%E4%B8%BA%E7%A7%91%E5%AD%A6%EF%BC%8C%E5%BF%85%E9%A1%BB%E8%A6%81%3C/span%3E%3Cspan%20class=%22text-color-red%22%3EFalsifiability%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%96%E7%95%8C%E8%A2%AB%E4%B8%80%E5%8F%AA%E6%97%A0%E6%95%8C%E5%B0%8F%E8%9C%9C%E8%9C%82%E8%9B%8B%E7%B3%95%E6%8E%A7%E5%88%B6%F0%9F%90%9D%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Population &amp; Sampling" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EPopulation%20&amp;amp;%20Sampling%3C/span%3E" _note="" _mubu_note="">
          <outline text="Population 总体" _mubu_text="%3Cspan%3EPopulation%20%E6%80%BB%E4%BD%93%3C/span%3E" _note="" _mubu_note="">
            <outline text="可能被研究的所有人" _mubu_text="%3Cspan%3E%E5%8F%AF%E8%83%BD%E8%A2%AB%E7%A0%94%E7%A9%B6%E7%9A%84%E6%89%80%E6%9C%89%E4%BA%BA%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Sample 样本" _mubu_text="%3Cspan%3ESample%20%E6%A0%B7%E6%9C%AC%3C/span%3E" _note="" _mubu_note="">
            <outline text="实际被研究的那一部分人" _mubu_text="%3Cspan%3E%E5%AE%9E%E9%99%85%E8%A2%AB%E7%A0%94%E7%A9%B6%E7%9A%84%E9%82%A3%E4%B8%80%E9%83%A8%E5%88%86%E4%BA%BA%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="抽样方法 Sampling Methods" _mubu_text="%3Cspan%3E%E6%8A%BD%E6%A0%B7%E6%96%B9%E6%B3%95%20Sampling%20Methods%3C/span%3E" _note="" _mubu_note="">
            <outline text="Convenience Sampling 便利抽样" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3EConvenience%20%3C/span%3E%3Cspan%3ESampling%20%E4%BE%BF%E5%88%A9%E6%8A%BD%E6%A0%B7%3C/span%3E" _note="" _mubu_note="">
              <outline text="好找好做，身边的同学" _mubu_text="%3Cspan%3E%E5%A5%BD%E6%89%BE%E5%A5%BD%E5%81%9A%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%BA%AB%E8%BE%B9%E7%9A%84%E5%90%8C%E5%AD%A6%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="容易Sampling Bias，结果不容易Generalize" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%AE%B9%E6%98%93%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESampling%20Bias%3C/span%3E%3Cspan%3E%EF%BC%8C%E7%BB%93%E6%9E%9C%E4%B8%8D%E5%AE%B9%E6%98%93%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EGeneralize%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="去食堂门口调研是否喜欢食堂的饭（有些人讨厌到根本不来吃！）" _mubu_text="%3Cspan%3E%E5%8E%BB%E9%A3%9F%E5%A0%82%E9%97%A8%E5%8F%A3%E8%B0%83%E7%A0%94%E6%98%AF%E5%90%A6%E5%96%9C%E6%AC%A2%E9%A3%9F%E5%A0%82%E7%9A%84%E9%A5%AD%EF%BC%88%E6%9C%89%E4%BA%9B%E4%BA%BA%E8%AE%A8%E5%8E%8C%E5%88%B0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%A0%B9%E6%9C%AC%E4%B8%8D%E6%9D%A5%E5%90%83%3C/span%3E%3Cspan%3E%EF%BC%81%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Random Sampling 随机抽样" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3ERandom%20%3C/span%3E%3Cspan%3ESampling%20%E9%9A%8F%E6%9C%BA%E6%8A%BD%E6%A0%B7%3C/span%3E" _note="" _mubu_note="">
              <outline text="每个人都有相同的机会被选中（SRS）" _mubu_text="%3Cspan%3E%E6%AF%8F%E4%B8%AA%E4%BA%BA%E9%83%BD%E6%9C%89%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%9B%B8%E5%90%8C%E7%9A%84%E6%9C%BA%E4%BC%9A%3C/span%3E%3Cspan%3E%E8%A2%AB%E9%80%89%E4%B8%AD%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-green%22%3ESRS%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="更可能得到Representative Sample" _mubu_text="%3Cspan%3E%E6%9B%B4%E5%8F%AF%E8%83%BD%E5%BE%97%E5%88%B0%3C/span%3E%3Cspan%20class=%22text-color-red%22%3ERepresentative%20%3C/span%3E%3Cspan%3ESample%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="大样本 👉 代表性更强" _mubu_text="%3Cspan%3E%E5%A4%A7%E6%A0%B7%E6%9C%AC%20%F0%9F%91%89%20%E4%BB%A3%E8%A1%A8%E6%80%A7%E6%9B%B4%E5%BC%BA%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Stratified Sampling 分层抽样" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3EStratified%20%3C/span%3E%3Cspan%3ESampling%20%E5%88%86%E5%B1%82%E6%8A%BD%E6%A0%B7%3C/span%3E" _note="" _mubu_note="">
              <outline text="按照特征分组，然后从其每一层抽样" _mubu_text="%3Cspan%3E%E6%8C%89%E7%85%A7%E7%89%B9%E5%BE%81%E5%88%86%E7%BB%84%EF%BC%8C%E7%84%B6%E5%90%8E%E4%BB%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%85%B6%E6%AF%8F%E4%B8%80%E5%B1%82%E6%8A%BD%E6%A0%B7%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="确保每个子群体都有代表（按照年级、性别、收入分组）" _mubu_text="%3Cspan%3E%E7%A1%AE%E4%BF%9D%E6%AF%8F%E4%B8%AA%E5%AD%90%E7%BE%A4%E4%BD%93%E9%83%BD%E6%9C%89%E4%BB%A3%E8%A1%A8%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%8C%89%E7%85%A7%E5%B9%B4%E7%BA%A7%E3%80%81%E6%80%A7%E5%88%AB%E3%80%81%E6%94%B6%E5%85%A5%E5%88%86%E7%BB%84%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="Big Five Research Design" _mubu_text="%3Cspan%3EBig%20Five%20Research%20Design%3C/span%3E" _note="" _mubu_note="">
          <outline text="Case Study" _mubu_text="%3Cspan%20class=%22text-color-red%22%3ECase%20Study%3C/span%3E" _note="" _mubu_note="">
            <outline text="深度研究一个或少数个体" _mubu_text="%3Cspan%3E%E6%B7%B1%E5%BA%A6%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%A0%94%E7%A9%B6%E4%B8%80%E4%B8%AA%E6%88%96%E5%B0%91%E6%95%B0%E4%B8%AA%E4%BD%93%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="适合罕见的情况、伦理上无法进行实验的情况（残疾研究）" _mubu_text="%3Cspan%3E%E9%80%82%E5%90%88%E7%BD%95%E8%A7%81%E7%9A%84%E6%83%85%E5%86%B5%E3%80%81%E4%BC%A6%E7%90%86%E4%B8%8A%E6%97%A0%E6%B3%95%E8%BF%9B%E8%A1%8C%E5%AE%9E%E9%AA%8C%E7%9A%84%E6%83%85%E5%86%B5%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%AE%8B%E7%96%BE%E7%A0%94%E7%A9%B6%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Naturalistic Observation" _mubu_text="%3Cspan%20class=%22text-color-red%22%3ENaturalistic%20Observation%3C/span%3E" _note="" _mubu_note="">
            <outline text="在自然情景中观察，不操纵变量！" _mubu_text="%3Cspan%3E%E5%9C%A8%E8%87%AA%E7%84%B6%E6%83%85%E6%99%AF%E4%B8%AD%E8%A7%82%E5%AF%9F%EF%BC%8C%3C/span%3E%3Cspan%20class=%22underline%20text-color-yellow%22%3E%E4%B8%8D%E6%93%8D%E7%BA%B5%E5%8F%98%E9%87%8F%EF%BC%81%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Observer Effect 被观察者效应" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EObserver%20Effect%20%3C/span%3E%3Cspan%3E%E8%A2%AB%E8%A7%82%E5%AF%9F%E8%80%85%E6%95%88%E5%BA%94%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Survey 问卷方法" _mubu_text="%3Cspan%3ESurvey%20%E9%97%AE%E5%8D%B7%E6%96%B9%E6%B3%95%3C/span%3E" _note="" _mubu_note="">
              <outline text="Self-report 数据" _mubu_text="%3Cspan%3ESelf-report%20%E6%95%B0%E6%8D%AE%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Likert Scale (1-5, 1-7) 里克特量表" _mubu_text="%3Cspan%3ELikert%20Scale%20(1-5,%201-7)%20%E9%87%8C%E5%85%8B%E7%89%B9%E9%87%8F%E8%A1%A8%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="局限：Wording Effects, Social Desirability Bias" _mubu_text="%3Cspan%3E%E5%B1%80%E9%99%90%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EWording%20Effects,%20Social%20Desirability%20Bias%3C/span%3E" _note="" _mubu_note="">
                <outline text="你身上应该感觉到难受对吧？vs. 你身上是否感受到难受" _mubu_text="%3Cspan%3E%E4%BD%A0%E8%BA%AB%E4%B8%8A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BA%94%E8%AF%A5%3C/span%3E%3Cspan%3E%E6%84%9F%E8%A7%89%E5%88%B0%E9%9A%BE%E5%8F%97%E5%AF%B9%E5%90%A7%EF%BC%9Fvs.%20%E4%BD%A0%E8%BA%AB%E4%B8%8A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%98%AF%E5%90%A6%3C/span%3E%3Cspan%3E%E6%84%9F%E5%8F%97%E5%88%B0%E9%9A%BE%E5%8F%97%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="你酗酒吗？你抽烟吗？你出轨过吗？" _mubu_text="%3Cspan%3E%E4%BD%A0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%85%97%E9%85%92%3C/span%3E%3Cspan%3E%E5%90%97%EF%BC%9F%E4%BD%A0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%8A%BD%E7%83%9F%3C/span%3E%3Cspan%3E%E5%90%97%EF%BC%9F%E4%BD%A0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%87%BA%E8%BD%A8%3C/span%3E%3Cspan%3E%E8%BF%87%E5%90%97%EF%BC%9F%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
          </outline>
          <outline text="Correlation" _mubu_text="%3Cspan%20class=%22text-color-red%22%3ECorrelation%3C/span%3E" _note="" _mubu_note="">
            <outline text="Describe the relationship between two variables" _mubu_text="%3Cspan%3EDescribe%20the%20relationship%20between%20two%20variables%3C/span%3E" _note="" _mubu_note="">
              <outline text="Relationship 关系，不是成因" _mubu_text="%3Cspan%3ERelationship%20%E5%85%B3%E7%B3%BB%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%B8%8D%E6%98%AF%E6%88%90%E5%9B%A0%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Two Variables 两个变量" _mubu_text="%3Cspan%3ETwo%20Variables%20%E4%B8%A4%E4%B8%AA%E5%8F%98%E9%87%8F%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Describes 描述，不是操纵！" _mubu_text="%3Cspan%3EDescribes%20%E6%8F%8F%E8%BF%B0%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%B8%8D%E6%98%AF%E6%93%8D%E7%BA%B5%EF%BC%81%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Correlation Coefficient（r值）" _mubu_text="%3Cspan%3ECorrelation%20Coefficient%EF%BC%88r%E5%80%BC%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
              <outline text="Range：-1 to 1 指定有人得纠结这里" _mubu_text="%3Cspan%20class=%22bold%20underline%20text-color-yellow%22%3ERange%EF%BC%9A-1%20to%201%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%8C%87%E5%AE%9A%E6%9C%89%E4%BA%BA%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E5%BE%97%E7%BA%A0%E7%BB%93%E8%BF%99%E9%87%8C%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="r &gt; 0 → 正相关" _mubu_text="%3Cspan%20class=%22codespan%22%3Er%20&amp;gt;%200%3C/span%3E%3Cspan%3E%20%E2%86%92%20%E6%AD%A3%E7%9B%B8%E5%85%B3%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="r &lt; 0 → 负相关" _mubu_text="%3Cspan%20class=%22codespan%22%3Er%20&amp;lt;%200%3C/span%3E%3Cspan%3E%20%E2%86%92%20%E8%B4%9F%E7%9B%B8%E5%85%B3%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="r = 0 → 无相关" _mubu_text="%3Cspan%20class=%22codespan%22%3Er%20=%200%3C/span%3E%3Cspan%3E%20%E2%86%92%20%E6%97%A0%E7%9B%B8%E5%85%B3%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="正相关 &amp; 负相关" _mubu_text="%3Cspan%3E%E6%AD%A3%E7%9B%B8%E5%85%B3%20&amp;amp;%20%E8%B4%9F%E7%9B%B8%E5%85%B3%3C/span%3E" _note="" _mubu_note="">
              <outline text="Positive Correlation：同加同减" _mubu_text="%3Cspan%3EPositive%20Correlation%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%90%8C%E5%8A%A0%E5%90%8C%E5%87%8F%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Negative Correlation：一个加，一个减" _mubu_text="%3Cspan%3ENegative%20Correlation%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%80%E4%B8%AA%E5%8A%A0%EF%BC%8C%E4%B8%80%E4%B8%AA%E5%87%8F%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="正负不代表好坏，Positive不是好，Negative也不一定坏" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E6%AD%A3%E8%B4%9F%E4%B8%8D%E4%BB%A3%E8%A1%A8%E5%A5%BD%E5%9D%8F%EF%BC%8CPositive%E4%B8%8D%E6%98%AF%E5%A5%BD%EF%BC%8CNegative%E4%B9%9F%E4%B8%8D%E4%B8%80%E5%AE%9A%E5%9D%8F%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="强度 / 方向" _mubu_text="%3Cspan%3E%E5%BC%BA%E5%BA%A6%20/%20%E6%96%B9%E5%90%91%3C/span%3E" _note="" _mubu_note="">
              <outline text="强度看绝对值（Closer to 1, stronger）" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E5%BC%BA%E5%BA%A6%3C/span%3E%3Cspan%3E%E7%9C%8B%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%BB%9D%E5%AF%B9%E5%80%BC%3C/span%3E%3Cspan%3E%EF%BC%88Closer%20to%201,%20stronger%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="方向看正负号（+函数向上，-函数向下）" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E6%96%B9%E5%90%91%3C/span%3E%3Cspan%3E%E7%9C%8B%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%AD%A3%E8%B4%9F%E5%8F%B7%3C/span%3E%3Cspan%3E%EF%BC%88+%E5%87%BD%E6%95%B0%E5%90%91%E4%B8%8A%EF%BC%8C-%E5%87%BD%E6%95%B0%E5%90%91%E4%B8%8B%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Correlation ≠ Causation" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3ECorrelation%20%E2%89%A0%20Causation%3C/span%3E" _note="" _mubu_note="">
              <outline text="就算r=0.9, 这也绝对不是Causation！" _mubu_text="%3Cspan%3E%E5%B0%B1%E7%AE%97r=0.9,%20%E8%BF%99%E4%B9%9F%E7%BB%9D%E5%AF%B9%E4%B8%8D%E6%98%AFCausation%EF%BC%81%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Correlation does NOT prove causation." _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3ECorrelation%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3Edoes%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ENOT%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3Eprove%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3Ecausation%3C/span%3E%3Cspan%20class=%22bold%22%3E.%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Confounding Variable 第三变量" _mubu_text="%3Cspan%3EConfounding%20Variable%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%AC%AC%E4%B8%89%E5%8F%98%E9%87%8F%3C/span%3E" _note="" _mubu_note="">
              <outline text="冰淇淋销量增加，溺水死亡的数量也增加" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E5%86%B0%E6%B7%87%E6%B7%8B%3C/span%3E%3Cspan%3E%E9%94%80%E9%87%8F%E5%A2%9E%E5%8A%A0%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%BA%BA%E6%B0%B4%3C/span%3E%3Cspan%3E%E6%AD%BB%E4%BA%A1%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%95%B0%E9%87%8F%3C/span%3E%3Cspan%3E%E4%B9%9F%E5%A2%9E%E5%8A%A0%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="冰淇淋不是杀手！有一个Confounding Variable：温度" _mubu_text="%3Cspan%3E%E5%86%B0%E6%B7%87%E6%B7%8B%E4%B8%8D%E6%98%AF%E6%9D%80%E6%89%8B%EF%BC%81%E6%9C%89%E4%B8%80%E4%B8%AAConfounding%20Variable%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%B8%A9%E5%BA%A6%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="If a question only describes a relationship and no variables are manipulated, the correct answer is correlation, not causation." _mubu_text="%3Cspan%3EIf%20a%20question%20only%20describes%20a%20%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3Erelationship%20and%20no%20variables%20are%20manipulated%3C/span%3E%3Cspan%3E,%20the%20correct%20answer%20is%20%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3Ecorrelation%3C/span%3E%3Cspan%3E,%20not%20causation.%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Scatter plots 散点图" _mubu_text="%3Cspan%3EScatter%20plots%20%E6%95%A3%E7%82%B9%E5%9B%BE%3C/span%3E" _note="" _mubu_note="">
              <outline text="确认方向和强度（Pos/Neg + Strength）" _mubu_text="%3Cspan%3E%E7%A1%AE%E8%AE%A4%E6%96%B9%E5%90%91%E5%92%8C%E5%BC%BA%E5%BA%A6%EF%BC%88Pos/Neg%20+%20Strength%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Outliers can exaggerate correlations" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EOutliers%20%3C/span%3E%3Cspan%3Ecan%20exaggerate%20correlations%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="Experiment" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EExperiment%3C/span%3E" _note="" _mubu_note="">
            <outline text="三要素" _mubu_text="%3Cspan%3E%E4%B8%89%E8%A6%81%E7%B4%A0%3C/span%3E" _note="" _mubu_note="">
              <outline text="Manipulation of the independent variable" _mubu_text="%3Cspan%20class=%22bold%22%3EManipulation%3C/span%3E%3Cspan%3E%20of%20the%20independent%20variable%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Control of other variables" _mubu_text="%3Cspan%20class=%22bold%22%3EControl%3C/span%3E%3Cspan%3E%20of%20other%20variables%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Random assignment of participants" _mubu_text="%3Cspan%20class=%22bold%22%3ERandom%20assignment%3C/span%3E%3Cspan%3E%20of%20participants%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="缺一不可！需要操作一个变量，管住其他变量（随机分配避免Confounding Variables）" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E7%BC%BA%E4%B8%80%E4%B8%8D%E5%8F%AF%EF%BC%81%3C/span%3E%3Cspan%3E%E9%9C%80%E8%A6%81%E6%93%8D%E4%BD%9C%E4%B8%80%E4%B8%AA%E5%8F%98%E9%87%8F%EF%BC%8C%E7%AE%A1%E4%BD%8F%E5%85%B6%E4%BB%96%E5%8F%98%E9%87%8F%EF%BC%88%E9%9A%8F%E6%9C%BA%E5%88%86%E9%85%8D%E9%81%BF%E5%85%8DConfounding%20Variables%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="IV &amp; DV 不要搞混啦！" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EIV%20&amp;amp;%20DV%20%3C/span%3E%3Cspan%20class=%22underline%20text-color-yellow%22%3E%E4%B8%8D%E8%A6%81%E6%90%9E%E6%B7%B7%E5%95%A6%EF%BC%81%3C/span%3E" _note="" _mubu_note="">
              <outline text="Independent Variable (IV) 研究者会操作的，独立的变量" _mubu_text="%3Cspan%3EIndependent%20Variable%20(IV)%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%A0%94%E7%A9%B6%E8%80%85%E4%BC%9A%E6%93%8D%E4%BD%9C%E7%9A%84%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%8B%AC%E7%AB%8B%3C/span%3E%3Cspan%3E%E7%9A%84%E5%8F%98%E9%87%8F%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Dependent Variable (DV) 研究者测量的，因为IV改变而变化的变量" _mubu_text="%3Cspan%3EDependent%20Variable%20(DV)%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%A0%94%E7%A9%B6%E8%80%85%E6%B5%8B%E9%87%8F%E7%9A%84%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%9B%A0%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EIV%E6%94%B9%E5%8F%98%E8%80%8C%E5%8F%98%E5%8C%96%3C/span%3E%3Cspan%3E%E7%9A%84%E5%8F%98%E9%87%8F%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Does sleep deprivation affect memory? IV: hours of sleep, DV: memory test performance" _mubu_text="%3Cspan%20class=%22text-color-green%22%3EDoes%20sleep%20deprivation%20affect%20memory?%3C/span%3E%3Cspan%3E%20IV:%20hours%20of%20sleep,%20DV:%20memory%20test%20performance%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Control Group &amp; Experimental Group" _mubu_text="%3Cspan%3EControl%20Group%20&amp;amp;%20Experimental%20Group%3C/span%3E" _note="" _mubu_note="">
              <outline text="对照组和实验组，一组收到Placebo，一组收到treatment" _mubu_text="%3Cspan%3E%E5%AF%B9%E7%85%A7%E7%BB%84%E5%92%8C%E5%AE%9E%E9%AA%8C%E7%BB%84%EF%BC%8C%E4%B8%80%E7%BB%84%E6%94%B6%E5%88%B0Placebo%EF%BC%8C%E4%B8%80%E7%BB%84%E6%94%B6%E5%88%B0treatment%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Random Assignment（区分Correlation和Experiment的关键）" _mubu_text="%3Cspan%20class=%22text-color-red%22%3ERandom%20Assignment%3C/span%3E%3Cspan%3E%EF%BC%88%E5%8C%BA%E5%88%86Correlation%E5%92%8CExperiment%E7%9A%84%E5%85%B3%E9%94%AE%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
                <outline text="Each participant has an equal chance of being assigned to any group." _mubu_text="%3Cspan%3EEach%20participant%20has%20an%20%3C/span%3E%3Cspan%20class=%22bold%22%3Eequal%20chance%3C/span%3E%3Cspan%3E%20of%20being%20assigned%20to%20any%20group.%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="避免Confounding Variable破坏实验的Causation" _mubu_text="%3Cspan%3E%E9%81%BF%E5%85%8DConfounding%20Variable%E7%A0%B4%E5%9D%8F%E5%AE%9E%E9%AA%8C%E7%9A%84Causation%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="Random Sampling vs. Random Assignment" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ERandom%20Sampling%3C/span%3E%3Cspan%3E%20vs.%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3ERandom%20Assignment%3C/span%3E" _note="" _mubu_note="">
                <outline text="❗ Random assignment ≠ Random sampling" _mubu_text="%3Cspan%3E%E2%9D%97%20Random%20assignment%20%E2%89%A0%20Random%20sampling%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="Assignment是分配到不同组，Sampling是从Population中选择参与者" _mubu_text="%3Cspan%3EAssignment%E6%98%AF%E5%88%86%E9%85%8D%E5%88%B0%E4%B8%8D%E5%90%8C%E7%BB%84%EF%BC%8CSampling%E6%98%AF%E4%BB%8EPopulation%E4%B8%AD%E9%80%89%E6%8B%A9%E5%8F%82%E4%B8%8E%E8%80%85%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="Operational Definition" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EOperational%20Definition%3C/span%3E" _note="" _mubu_note="">
              <outline text="清楚写出How a variable is measured or manipulated." _mubu_text="%3Cspan%3E%E6%B8%85%E6%A5%9A%E5%86%99%E5%87%BAHow%20a%20variable%20is%20measured%20or%20manipulated.%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="方便复现实验 AAQ要考" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E6%96%B9%E4%BE%BF%E5%A4%8D%E7%8E%B0%E5%AE%9E%E9%AA%8C%3C/span%3E%3Cspan%3E%20AAQ%E8%A6%81%E8%80%83%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Placebo &amp; Placebo Effect" _mubu_text="%3Cspan%3EPlacebo%20&amp;amp;%20Placebo%20Effect%3C/span%3E" _note="" _mubu_note="">
              <outline text="看起来像 treatment，但没有 active ingredient" _mubu_text="%3Cspan%3E%E7%9C%8B%E8%B5%B7%E6%9D%A5%E5%83%8F%20treatment%EF%BC%8C%E4%BD%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%B2%A1%E6%9C%89%20active%20ingredient%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="因为“相信有效”而产生改善（Expectations）" _mubu_text="%3Cspan%3E%E5%9B%A0%E4%B8%BA%E2%80%9C%E7%9B%B8%E4%BF%A1%E6%9C%89%E6%95%88%E2%80%9D%E8%80%8C%E4%BA%A7%E7%94%9F%E6%94%B9%E5%96%84%EF%BC%88Expectations%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="用Placebo可以分离治疗效果 和 期待效应" _mubu_text="%3Cspan%3E%E7%94%A8Placebo%E5%8F%AF%E4%BB%A5%E5%88%86%E7%A6%BB%E6%B2%BB%E7%96%97%E6%95%88%E6%9E%9C%20%E5%92%8C%20%E6%9C%9F%E5%BE%85%E6%95%88%E5%BA%94%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Blind Designs" _mubu_text="%3Cspan%3EBlind%20Designs%3C/span%3E" _note="" _mubu_note="">
              <outline text="Single-blind study - 被试不知道在哪一组（防止Participant bias）" _mubu_text="%3Cspan%3ESingle-blind%20study%20-%20%E8%A2%AB%E8%AF%95%E4%B8%8D%E7%9F%A5%E9%81%93%E5%9C%A8%E5%93%AA%E4%B8%80%E7%BB%84%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%98%B2%E6%AD%A2Participant%20bias%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Double-blind study - 被试和实验者都不知道分组（防止Researcher Bias）" _mubu_text="%3Cspan%3EDouble-blind%20study%20-%20%E8%A2%AB%E8%AF%95%E5%92%8C%E5%AE%9E%E9%AA%8C%E8%80%85%E9%83%BD%E4%B8%8D%E7%9F%A5%E9%81%93%E5%88%86%E7%BB%84%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%98%B2%E6%AD%A2Researcher%20Bias%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="Meta-analysis" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EMeta-analysis%3C/span%3E" _note="" _mubu_note="">
            <outline text="整合多个研究的结果，给出总体结论" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E6%95%B4%E5%90%88%E5%A4%9A%E4%B8%AA%E7%A0%94%E7%A9%B6%E7%9A%84%E7%BB%93%E6%9E%9C%3C/span%3E%3Cspan%3E%EF%BC%8C%E7%BB%99%E5%87%BA%E6%80%BB%E4%BD%93%E7%BB%93%E8%AE%BA%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="不是Experiment，是分析" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E4%B8%8D%E6%98%AFExperiment%EF%BC%8C%E6%98%AF%E5%88%86%E6%9E%90%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="读很多论文，使用effect size，提高结论的可靠性" _mubu_text="%3Cspan%3E%E8%AF%BB%E5%BE%88%E5%A4%9A%E8%AE%BA%E6%96%87%EF%BC%8C%E4%BD%BF%E7%94%A8effect%20size%EF%BC%8C%E6%8F%90%E9%AB%98%E7%BB%93%E8%AE%BA%E7%9A%84%E5%8F%AF%E9%9D%A0%E6%80%A7%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Reliability vs Validity" _mubu_text="%3Cspan%3EReliability%20vs%20Validity%3C/span%3E" _note="" _mubu_note="">
          <outline text="Reliability = Consistency 一致性" _mubu_text="%3Cspan%3EReliability%20=%20Consistency%20%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E4%B8%80%E8%87%B4%E6%80%A7%3C/span%3E" _note="" _mubu_note="">
            <outline text="重复测量是否得到相似结果" _mubu_text="%3Cspan%3E%E9%87%8D%E5%A4%8D%E6%B5%8B%E9%87%8F%E6%98%AF%E5%90%A6%E5%BE%97%E5%88%B0%E7%9B%B8%E4%BC%BC%E7%BB%93%E6%9E%9C%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="高 Reliability 说明复现效果相似，但不一定是有效的" _mubu_text="%3Cspan%3E%E9%AB%98%20Reliability%20%E8%AF%B4%E6%98%8E%E5%A4%8D%E7%8E%B0%E6%95%88%E6%9E%9C%E7%9B%B8%E4%BC%BC%EF%BC%8C%E4%BD%86%E4%B8%8D%E4%B8%80%E5%AE%9A%E6%98%AF%E6%9C%89%E6%95%88%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Validity = Accuracy 准确性" _mubu_text="%3Cspan%3EValidity%20=%20Accuracy%20%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E5%87%86%E7%A1%AE%E6%80%A7%3C/span%3E" _note="" _mubu_note="">
            <outline text="是否真正测量了想测量的概念" _mubu_text="%3Cspan%3E%E6%98%AF%E5%90%A6%E7%9C%9F%E6%AD%A3%E6%B5%8B%E9%87%8F%E4%BA%86%E6%83%B3%E6%B5%8B%E9%87%8F%E7%9A%84%E6%A6%82%E5%BF%B5%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="示意图" _mubu_text="%3Cspan%3E%E7%A4%BA%E6%84%8F%E5%9B%BE%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22elVFwInJ2F%22%2C%22oh%22%3A547%2C%22ow%22%3A583%2C%22uri%22%3A%22document_image%2F33585682_65ee30fb-2513-48ca-ebcf-b13ce0126b73.png%22%2C%22w%22%3A262%7D%5D"/>
        </outline>
      </outline>
      <outline text="0.4 统计学 Statistics（3M，SD、Range，550字）" _mubu_text="%3Cspan%3E0.4%20%E7%BB%9F%E8%AE%A1%E5%AD%A6%20Statistics%EF%BC%883M%EF%BC%8CSD%E3%80%81Range%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E550%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="Stat的两大分支" _mubu_text="%3Cspan%3EStat%E7%9A%84%E4%B8%A4%E5%A4%A7%E5%88%86%E6%94%AF%3C/span%3E" _note="" _mubu_note="">
          <outline text="Descriptive Statistics 描述统计" _mubu_text="%3Cspan%3EDescriptive%20Statistics%20%E6%8F%8F%E8%BF%B0%E7%BB%9F%E8%AE%A1%3C/span%3E" _note="" _mubu_note="">
            <outline text="把 raw data 变成有意义的信息" _mubu_text="%3Cspan%3E%E6%8A%8A%20raw%20data%20%E5%8F%98%E6%88%90%E6%9C%89%E6%84%8F%E4%B9%89%E7%9A%84%E4%BF%A1%E6%81%AF%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Center + Variability" _mubu_text="%3Cspan%20class=%22text-color-red%22%3ECenter%20%3C/span%3E%3Cspan%3E+%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20Variability%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Inferential Statistics 推断统计" _mubu_text="%3Cspan%3EInferential%20Statistics%20%E6%8E%A8%E6%96%AD%E7%BB%9F%E8%AE%A1%3C/span%3E" _note="" _mubu_note="">
            <outline text="从 Sample 到 Population" _mubu_text="%3Cspan%3E%E4%BB%8E%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3ESample%3C/span%3E%3Cspan%3E%20%E5%88%B0%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EPopulation%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="差异是随机产生，还是我们的方法有效" _mubu_text="%3Cspan%3E%E5%B7%AE%E5%BC%82%E6%98%AF%E9%9A%8F%E6%9C%BA%E4%BA%A7%E7%94%9F%EF%BC%8C%E8%BF%98%E6%98%AF%E6%88%91%E4%BB%AC%E7%9A%84%E6%96%B9%E6%B3%95%E6%9C%89%E6%95%88%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Statistical Significance + P-value + effect size" _mubu_text="%3Cspan%3EStatistical%20Significance%20+%20P-value%20+%20effect%20size%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Central Tendency 集中趋势（其实就是3M）" _mubu_text="%3Cspan%3ECentral%20Tendency%20%E9%9B%86%E4%B8%AD%E8%B6%8B%E5%8A%BF%EF%BC%88%E5%85%B6%E5%AE%9E%E5%B0%B1%E6%98%AF3M%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="Mean" _mubu_text="%3Cspan%3EMean%3C/span%3E" _note="" _mubu_note="">
            <outline text="Sum / Num" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3ESum%20/%20Num%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="容易被Outlier影响" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E5%AE%B9%E6%98%93%E8%A2%ABOutlier%E5%BD%B1%E5%93%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="适合：数据对称分布，无极端值" _mubu_text="%3Cspan%3E%E9%80%82%E5%90%88%EF%BC%9A%E6%95%B0%E6%8D%AE%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%AF%B9%E7%A7%B0%E5%88%86%E5%B8%83%EF%BC%8C%E6%97%A0%E6%9E%81%E7%AB%AF%E5%80%BC%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Median" _mubu_text="%3Cspan%3EMedian%3C/span%3E" _note="" _mubu_note="">
            <outline text="排序后最中间的数（or 中间两个的平均值）" _mubu_text="%3Cspan%3E%E6%8E%92%E5%BA%8F%E5%90%8E%E6%9C%80%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%AD%E9%97%B4%E7%9A%84%E6%95%B0%3C/span%3E%3Cspan%3E%EF%BC%88or%20%E4%B8%AD%E9%97%B4%E4%B8%A4%E4%B8%AA%E7%9A%84%E5%B9%B3%E5%9D%87%E5%80%BC%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="对outlier不敏感" _mubu_text="%3Cspan%3E%E5%AF%B9outlier%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E4%B8%8D%E6%95%8F%E6%84%9F%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="适合：有极端值时代表typical" _mubu_text="%3Cspan%3E%E9%80%82%E5%90%88%EF%BC%9A%E6%9C%89%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%9E%81%E7%AB%AF%E5%80%BC%3C/span%3E%3Cspan%3E%E6%97%B6%E4%BB%A3%E8%A1%A8typical%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="和Mean区分使用场景，就看有没有极端值或者分布是否Skewed" _mubu_text="%3Cspan%3E%E5%92%8CMean%E5%8C%BA%E5%88%86%E4%BD%BF%E7%94%A8%E5%9C%BA%E6%99%AF%EF%BC%8C%E5%B0%B1%E7%9C%8B%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%9C%89%E6%B2%A1%E6%9C%89%E6%9E%81%E7%AB%AF%E5%80%BC%3C/span%3E%3Cspan%3E%E6%88%96%E8%80%85%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%88%86%E5%B8%83%E6%98%AF%E5%90%A6Skewed%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Mode" _mubu_text="%3Cspan%3EMode%3C/span%3E" _note="" _mubu_note="">
            <outline text="出现次数最多的数" _mubu_text="%3Cspan%3E%E5%87%BA%E7%8E%B0%E6%AC%A1%E6%95%B0%E6%9C%80%E5%A4%9A%E7%9A%84%E6%95%B0%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="不好用，因为可能没有mode或者有很多mode" _mubu_text="%3Cspan%3E%E4%B8%8D%E5%A5%BD%E7%94%A8%EF%BC%8C%E5%9B%A0%E4%B8%BA%E5%8F%AF%E8%83%BD%E6%B2%A1%E6%9C%89mode%E6%88%96%E8%80%85%E6%9C%89%E5%BE%88%E5%A4%9Amode%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="拉完了…… 好吧其实适合catagorical数据，比如最常见的血型，或者MBTI星座啥的" _mubu_text="%3Cspan%3E%E6%8B%89%E5%AE%8C%E4%BA%86%E2%80%A6%E2%80%A6%20%E5%A5%BD%E5%90%A7%E5%85%B6%E5%AE%9E%E9%80%82%E5%90%88catagorical%E6%95%B0%E6%8D%AE%EF%BC%8C%E6%AF%94%E5%A6%82%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%9C%80%E5%B8%B8%E8%A7%81%E7%9A%84%E8%A1%80%E5%9E%8B%EF%BC%8C%E6%88%96%E8%80%85MBTI%E6%98%9F%E5%BA%A7%E5%95%A5%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Variability 变异性（SD和Range）" _mubu_text="%3Cspan%3EVariability%20%E5%8F%98%E5%BC%82%E6%80%A7%EF%BC%88SD%E5%92%8CRange%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="Range" _mubu_text="%3Cspan%3ERange%3C/span%3E" _note="" _mubu_note="">
            <outline text="Max - Min" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3EMax%20-%20Min%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="粗略估计，被Outlier影响" _mubu_text="%3Cspan%3E%E7%B2%97%E7%95%A5%E4%BC%B0%E8%AE%A1%EF%BC%8C%E8%A2%ABOutlier%E5%BD%B1%E5%93%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Standard Deviation" _mubu_text="%3Cspan%3EStandard%20Deviation%3C/span%3E" _note="" _mubu_note="">
            <outline text="数据点 how far from the average" _mubu_text="%3Cspan%3E%E6%95%B0%E6%8D%AE%E7%82%B9%20how%20far%20from%20the%20average%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="学Stat后自然就懂了嘻嘻 😁" _mubu_text="%3Cspan%20class=%22text-color-purple%22%3E%E5%AD%A6Stat%E5%90%8E%E8%87%AA%E7%84%B6%E5%B0%B1%E6%87%82%E4%BA%86%E5%98%BB%E5%98%BB%20%F0%9F%98%81%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="SD大 数据更分散" _mubu_text="%3Cspan%3ESD%E5%A4%A7%20%E6%95%B0%E6%8D%AE%E6%9B%B4%E5%88%86%E6%95%A3%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="SD小 数据更集中" _mubu_text="%3Cspan%3ESD%E5%B0%8F%20%E6%95%B0%E6%8D%AE%E6%9B%B4%E9%9B%86%E4%B8%AD%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Normal Distribution 正态分布" _mubu_text="%3Cspan%3ENormal%20Distribution%20%E6%AD%A3%E6%80%81%E5%88%86%E5%B8%83%3C/span%3E" _note="" _mubu_note="">
          <outline text="对称（Symmetrical）" _mubu_text="%3Cspan%3E%E5%AF%B9%E7%A7%B0%EF%BC%88Symmetrical%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Mean = Median = Mode" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EMean%20=%20Median%20=%20Mode%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Bell-shaped curve" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3EBell-shaped%20curve%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="68-95-997" _mubu_text="%3Cspan%3E68-95-997%3C/span%3E" _note="" _mubu_note="">
            <outline text="±1 SD = 68%" _mubu_text="%3Cspan%3E%C2%B11%20SD%20=%2068%25%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="±2 SD = 95%" _mubu_text="%3Cspan%3E%C2%B12%20SD%20=%2095%25%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="±3 SD = 99.7%" _mubu_text="%3Cspan%3E%C2%B13%20SD%20=%2099.7%25%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="超过3SD就太罕见了，妥妥的Outliers" _mubu_text="%3Cspan%3E%E8%B6%85%E8%BF%873SD%E5%B0%B1%E5%A4%AA%E7%BD%95%E8%A7%81%E4%BA%86%EF%BC%8C%E5%A6%A5%E5%A6%A5%E7%9A%84Outliers%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Mean = 100, SD = 15，那么，最小哪个数在2SD内，2SD占比多少？70，95%" _mubu_text="%3Cspan%3EMean%20=%20100,%20SD%20=%2015%EF%BC%8C%E9%82%A3%E4%B9%88%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%9C%80%E5%B0%8F%E5%93%AA%E4%B8%AA%E6%95%B0%E5%9C%A82SD%E5%86%85%EF%BC%8C2SD%E5%8D%A0%E6%AF%94%E5%A4%9A%E5%B0%91%EF%BC%9F%3C/span%3E%3Cspan%3E70%EF%BC%8C95%25%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Percentile（百分位）" _mubu_text="%3Cspan%3EPercentile%EF%BC%88%E7%99%BE%E5%88%86%E4%BD%8D%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="90th percentile -&gt; 打败90%的人，位于top 10%" _mubu_text="%3Cspan%3E90th%20percentile%20-&amp;gt;%20%E6%89%93%E8%B4%A590%25%E7%9A%84%E4%BA%BA%EF%BC%8C%E4%BD%8D%E4%BA%8Etop%2010%25%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="以此类推" _mubu_text="%3Cspan%3E%E4%BB%A5%E6%AD%A4%E7%B1%BB%E6%8E%A8%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="❗Percentile ≠ Percentage Score" _mubu_text="%3Cspan%20class=%22underline%20text-color-yellow%22%3E%E2%9D%97Percentile%20%E2%89%A0%20Percentage%20Score%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Skewed Distributions" _mubu_text="%3Cspan%3ESkewed%20Distributions%3C/span%3E" _note="" _mubu_note="">
          <outline text="Skew的名字，看尾巴方向" _mubu_text="%3Cspan%3ESkew%E7%9A%84%E5%90%8D%E5%AD%97%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%9C%8B%E5%B0%BE%E5%B7%B4%E6%96%B9%E5%90%91%3C/span%3E" _note="" _mubu_note="">
            <outline text="Left（也就是负方向「Negative」）就是左边尾巴，" _mubu_text="%3Cspan%3ELeft%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E4%B9%9F%E5%B0%B1%E6%98%AF%E8%B4%9F%E6%96%B9%E5%90%91%E3%80%8CNegative%E3%80%8D%3C/span%3E%3Cspan%3E%EF%BC%89%E5%B0%B1%E6%98%AF%E5%B7%A6%E8%BE%B9%E5%B0%BE%E5%B7%B4%EF%BC%8C%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Right（就是正方向「Positive」）就是右边尾巴" _mubu_text="%3Cspan%3ERight%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E5%B0%B1%E6%98%AF%E6%AD%A3%E6%96%B9%E5%90%91%E3%80%8CPositive%E3%80%8D%3C/span%3E%3Cspan%3E%EF%BC%89%E5%B0%B1%E6%98%AF%E5%8F%B3%E8%BE%B9%E5%B0%BE%E5%B7%B4%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Positive Skew (右偏)" _mubu_text="%3Cspan%3EPositive%20Skew%20(%E5%8F%B3%E5%81%8F)%3C/span%3E" _note="" _mubu_note="">
            <outline text="尾巴在右侧，少数很大的数字" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B0%BE%E5%B7%B4%E5%9C%A8%E5%8F%B3%E4%BE%A7%EF%BC%8C%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%B0%91%E6%95%B0%E5%BE%88%E5%A4%A7%E7%9A%84%E6%95%B0%E5%AD%97%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Mean &gt; Median &gt; Mode（大头在左边）" _mubu_text="%3Cspan%3EMean%20&amp;gt;%20Median%20&amp;gt;%20Mode%EF%BC%88%E5%A4%A7%E5%A4%B4%E5%9C%A8%E5%B7%A6%E8%BE%B9%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="比如，income（😭，穷苦的大多数）" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%EF%BC%8Cincome%EF%BC%88%F0%9F%98%AD%EF%BC%8C%E7%A9%B7%E8%8B%A6%E7%9A%84%E5%A4%A7%E5%A4%9A%E6%95%B0%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Negative Skew（左偏）" _mubu_text="%3Cspan%3ENegative%20Skew%EF%BC%88%E5%B7%A6%E5%81%8F%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="尾巴在左侧，少数很小的数字" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B0%BE%E5%B7%B4%E5%9C%A8%E5%B7%A6%E4%BE%A7%EF%BC%8C%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%B0%91%E6%95%B0%E5%BE%88%E5%B0%8F%E7%9A%84%E6%95%B0%E5%AD%97%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Mean &lt; Median &lt; Mode" _mubu_text="%3Cspan%3EMean%20&amp;lt;%20Median%20&amp;lt;%20Mode%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Bimodal Distribution" _mubu_text="%3Cspan%3EBimodal%20Distribution%3C/span%3E" _note="" _mubu_note="">
            <outline text="双峰，一般是两个不同群体" _mubu_text="%3Cspan%3E%E5%8F%8C%E5%B3%B0%EF%BC%8C%E4%B8%80%E8%88%AC%E6%98%AF%E4%B8%A4%E4%B8%AA%E4%B8%8D%E5%90%8C%E7%BE%A4%E4%BD%93%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="推断统计" _mubu_text="%3Cspan%3E%E6%8E%A8%E6%96%AD%E7%BB%9F%E8%AE%A1%3C/span%3E" _note="" _mubu_note="">
          <outline text="p-value" _mubu_text="%3Cspan%3Ep-value%3C/span%3E" _note="" _mubu_note="">
            <outline text="不太清楚的可能需要恶补一下AP Stat" _mubu_text="%3Cspan%20class=%22text-color-purple%22%3E%E4%B8%8D%E5%A4%AA%E6%B8%85%E6%A5%9A%E7%9A%84%E5%8F%AF%E8%83%BD%E9%9C%80%E8%A6%81%E6%81%B6%E8%A1%A5%E4%B8%80%E4%B8%8BAP%20Stat%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="p &lt; .05（α = 0.05）" _mubu_text="%3Cspan%3Ep%20&amp;lt;%20.05%EF%BC%88%CE%B1%20=%200.05%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
              <outline text="说明H0（p1 = p2）不成立" _mubu_text="%3Cspan%3E%E8%AF%B4%E6%98%8EH0%EF%BC%88p1%20=%20p2%EF%BC%89%E4%B8%8D%E6%88%90%E7%AB%8B%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="也就是说明随机造成差别的概率小于5%" _mubu_text="%3Cspan%3E%E4%B9%9F%E5%B0%B1%E6%98%AF%E8%AF%B4%E6%98%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%9A%8F%E6%9C%BA%E9%80%A0%E6%88%90%E5%B7%AE%E5%88%AB%E7%9A%84%E6%A6%82%E7%8E%87%E5%B0%8F%E4%BA%8E5%25%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="所以Statistically Significant" _mubu_text="%3Cspan%3E%E6%89%80%E4%BB%A5%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EStatistically%20Significant%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="p &gt; .05（α = 0.05）" _mubu_text="%3Cspan%3Ep%20&amp;gt;%20.05%EF%BC%88%CE%B1%20=%200.05%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
              <outline text="说明，可能是随机造成的" _mubu_text="%3Cspan%3E%E8%AF%B4%E6%98%8E%EF%BC%8C%E5%8F%AF%E8%83%BD%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%9A%8F%E6%9C%BA%E9%80%A0%E6%88%90%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Statistically Insignificant" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EStatistically%20Insignificant%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="Effect Size 效应量" _mubu_text="%3Cspan%3EEffect%20Size%20%E6%95%88%E5%BA%94%E9%87%8F%3C/span%3E" _note="" _mubu_note="">
            <outline text="自变量对因变量影响的强度" _mubu_text="%3Cspan%3E%E8%87%AA%E5%8F%98%E9%87%8F%E5%AF%B9%E5%9B%A0%E5%8F%98%E9%87%8F%E5%BD%B1%E5%93%8D%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%BC%BA%E5%BA%A6%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="另一种让我们判断这个Factor的影响强度的指标" _mubu_text="%3Cspan%3E%E5%8F%A6%E4%B8%80%E7%A7%8D%E8%AE%A9%E6%88%91%E4%BB%AC%E5%88%A4%E6%96%AD%E8%BF%99%E4%B8%AAFactor%E7%9A%84%E5%BD%B1%E5%93%8D%E5%BC%BA%E5%BA%A6%E7%9A%84%E6%8C%87%E6%A0%87%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="不受样本量影响（不像 P-value）" _mubu_text="%3Cspan%3E%E4%B8%8D%E5%8F%97%E6%A0%B7%E6%9C%AC%E9%87%8F%E5%BD%B1%E5%93%8D%EF%BC%88%E4%B8%8D%E5%83%8F%20P-value%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
      </outline>
      <outline text="0.5 伦理 Ethics（Informed、Withdraw、Debriefing、IRB，550字）" _mubu_text="%3Cspan%3E0.5%20%E4%BC%A6%E7%90%86%20Ethics%EF%BC%88Informed%E3%80%81Withdraw%E3%80%81Debriefing%E3%80%81IRB%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E550%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="为什么要Ethics？" _mubu_text="%3Cspan%3E%E4%B8%BA%E4%BB%80%E4%B9%88%E8%A6%81Ethics%EF%BC%9F%3C/span%3E" _note="" _mubu_note="">
          <outline text="研究对象是人类和动物" _mubu_text="%3Cspan%3E%E7%A0%94%E7%A9%B6%E5%AF%B9%E8%B1%A1%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BA%BA%E7%B1%BB%E5%92%8C%E5%8A%A8%E7%89%A9%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="需要心理安全和身体安全" _mubu_text="%3Cspan%3E%E9%9C%80%E8%A6%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%83%E7%90%86%E5%AE%89%E5%85%A8%E5%92%8C%E8%BA%AB%E4%BD%93%E5%AE%89%E5%85%A8%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="APA（American Psychological Association）制定伦理规范" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EAPA%3C/span%3E%3Cspan%3E%EF%BC%88American%20Psychological%20Association%EF%BC%89%E5%88%B6%E5%AE%9A%E4%BC%A6%E7%90%86%E8%A7%84%E8%8C%83%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="IRB（Institutional Review Board）" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EIRB%3C/span%3E%3Cspan%3E%EF%BC%88Institutional%20Review%20Board%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="IRB是什么？" _mubu_text="%3Cspan%3EIRB%E6%98%AF%E4%BB%80%E4%B9%88%EF%BC%9F%3C/span%3E" _note="" _mubu_note="">
            <outline text="审核所有涉及人类的心理研究" _mubu_text="%3Cspan%3E%E5%AE%A1%E6%A0%B8%E6%89%80%E6%9C%89%E6%B6%89%E5%8F%8A%E4%BA%BA%E7%B1%BB%E7%9A%84%E5%BF%83%E7%90%86%E7%A0%94%E7%A9%B6%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="作用" _mubu_text="%3Cspan%3E%E4%BD%9C%E7%94%A8%3C/span%3E" _note="" _mubu_note="">
              <outline text="评估风险&amp;收益" _mubu_text="%3Cspan%3E%E8%AF%84%E4%BC%B0%E9%A3%8E%E9%99%A9&amp;amp;%E6%94%B6%E7%9B%8A%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="决定是否可以进行研究" _mubu_text="%3Cspan%3E%E5%86%B3%E5%AE%9A%E6%98%AF%E5%90%A6%E5%8F%AF%E4%BB%A5%E8%BF%9B%E8%A1%8C%E7%A0%94%E7%A9%B6%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="监督研究进行过程中是否合规" _mubu_text="%3Cspan%3E%E7%9B%91%E7%9D%A3%E7%A0%94%E7%A9%B6%E8%BF%9B%E8%A1%8C%E8%BF%87%E7%A8%8B%E4%B8%AD%E6%98%AF%E5%90%A6%E5%90%88%E8%A7%84%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="没有IRB，实验不能开始" _mubu_text="%3Cspan%3E%E6%B2%A1%E6%9C%89IRB%EF%BC%8C%E5%AE%9E%E9%AA%8C%E4%B8%8D%E8%83%BD%E5%BC%80%E5%A7%8B%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Protect From Harm" _mubu_text="%3Cspan%3EProtect%20From%20Harm%3C/span%3E" _note="" _mubu_note="">
          <outline text="尽量不伤害" _mubu_text="%3Cspan%3E%E5%B0%BD%E9%87%8F%E4%B8%8D%E4%BC%A4%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="提供支持" _mubu_text="%3Cspan%3E%E6%8F%90%E4%BE%9B%E6%94%AF%E6%8C%81%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="即使研究很重要，也不能对被试者造成（长期或者不可逆的）伤害" _mubu_text="%3Cspan%3E%E5%8D%B3%E4%BD%BF%E7%A0%94%E7%A9%B6%E5%BE%88%E9%87%8D%E8%A6%81%EF%BC%8C%E4%B9%9F%E4%B8%8D%E8%83%BD%E5%AF%B9%E8%A2%AB%E8%AF%95%E8%80%85%E9%80%A0%E6%88%90%EF%BC%88%E9%95%BF%E6%9C%9F%E6%88%96%E8%80%85%E4%B8%8D%E5%8F%AF%E9%80%86%E7%9A%84%EF%BC%89%E4%BC%A4%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Informed Consent &amp; Assent 注意哪个是成人的，哪个是儿童的" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EInformed%20Consent%20&amp;amp;%20Assent%3C/span%3E%3Cspan%3E%20%E6%B3%A8%E6%84%8F%E5%93%AA%E4%B8%AA%E6%98%AF%E6%88%90%E4%BA%BA%E7%9A%84%EF%BC%8C%E5%93%AA%E4%B8%AA%E6%98%AF%E5%84%BF%E7%AB%A5%E7%9A%84%3C/span%3E" _note="" _mubu_note="">
          <outline text="Informed Consent（成年人）" _mubu_text="%3Cspan%3EInformed%20Consent%EF%BC%88%E6%88%90%E5%B9%B4%E4%BA%BA%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="研究前" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A0%94%E7%A9%B6%E5%89%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="提供书面说明" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E6%8F%90%E4%BE%9B%E4%B9%A6%E9%9D%A2%E8%AF%B4%E6%98%8E%3C/span%3E" _note="" _mubu_note="">
              <outline text="研究目的" _mubu_text="%3Cspan%3E%E7%A0%94%E7%A9%B6%E7%9B%AE%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="流程" _mubu_text="%3Cspan%3E%E6%B5%81%E7%A8%8B%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="风险 &amp; 影响" _mubu_text="%3Cspan%3E%E9%A3%8E%E9%99%A9%20&amp;amp;%20%E5%BD%B1%E5%93%8D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="被试 签字同意" _mubu_text="%3Cspan%3E%E8%A2%AB%E8%AF%95%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%AD%BE%E5%AD%97%E5%90%8C%E6%84%8F%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Informed Assent（儿童 / 无完全决策能力者）" _mubu_text="%3Cspan%3EInformed%20Assent%EF%BC%88%E5%84%BF%E7%AB%A5%20/%20%E6%97%A0%E5%AE%8C%E5%85%A8%E5%86%B3%E7%AD%96%E8%83%BD%E5%8A%9B%E8%80%85%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="适用于" _mubu_text="%3Cspan%3E%E9%80%82%E7%94%A8%E4%BA%8E%3C/span%3E" _note="" _mubu_note="">
              <outline text="未成年人" _mubu_text="%3Cspan%3E%E6%9C%AA%E6%88%90%E5%B9%B4%E4%BA%BA%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="认知障碍者" _mubu_text="%3Cspan%3E%E8%AE%A4%E7%9F%A5%E9%9A%9C%E7%A2%8D%E8%80%85%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="用 他们能理解的方式解释" _mubu_text="%3Cspan%3E%E7%94%A8%20%E4%BB%96%E4%BB%AC%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%83%BD%E7%90%86%E8%A7%A3%E7%9A%84%E6%96%B9%E5%BC%8F%E8%A7%A3%E9%87%8A%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="通常 同时需要家长/监护人 consent 不是说只要孩子/家长一方同意就行" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%80%9A%E5%B8%B8%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E5%90%8C%E6%97%B6%E9%9C%80%E8%A6%81%E5%AE%B6%E9%95%BF/%E7%9B%91%E6%8A%A4%E4%BA%BA%20consent%20%3C/span%3E%3Cspan%20class=%22bold%20underline%22%3E%E4%B8%8D%E6%98%AF%E8%AF%B4%E5%8F%AA%E8%A6%81%E5%AD%A9%E5%AD%90/%E5%AE%B6%E9%95%BF%E4%B8%80%E6%96%B9%E5%90%8C%E6%84%8F%E5%B0%B1%E8%A1%8C%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Right to Withdraw（No Coercion）" _mubu_text="%3Cspan%3ERight%20to%20Withdraw%EF%BC%88No%20Coercion%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="随时退出实验" _mubu_text="%3Cspan%3E%E9%9A%8F%E6%97%B6%E9%80%80%E5%87%BA%E5%AE%9E%E9%AA%8C%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="不需要解释为什么退出" _mubu_text="%3Cspan%3E%E4%B8%8D%E9%9C%80%E8%A6%81%E8%A7%A3%E9%87%8A%E4%B8%BA%E4%BB%80%E4%B9%88%E9%80%80%E5%87%BA%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="不应该有惩罚被试者或者压力给到被试者" _mubu_text="%3Cspan%3E%E4%B8%8D%E5%BA%94%E8%AF%A5%E6%9C%89%E6%83%A9%E7%BD%9A%E8%A2%AB%E8%AF%95%E8%80%85%E6%88%96%E8%80%85%E5%8E%8B%E5%8A%9B%E7%BB%99%E5%88%B0%E8%A2%AB%E8%AF%95%E8%80%85%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="强迫 = 违反伦理" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%BC%BA%E8%BF%AB%3C/span%3E%3Cspan%20class=%22bold%22%3E%20=%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E8%BF%9D%E5%8F%8D%E4%BC%A6%E7%90%86%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Confidentiality（≠ Anonymity）" _mubu_text="%3Cspan%3EConfidentiality%EF%BC%88%E2%89%A0%20Anonymity%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="保密：数据不会泄露，身份被保护，研究者知道是谁，但不会公开" _mubu_text="%3Cspan%3E%E4%BF%9D%E5%AF%86%EF%BC%9A%E6%95%B0%E6%8D%AE%E4%B8%8D%E4%BC%9A%E6%B3%84%E9%9C%B2%EF%BC%8C%E8%BA%AB%E4%BB%BD%E8%A2%AB%E4%BF%9D%E6%8A%A4%EF%BC%8C%E7%A0%94%E7%A9%B6%E8%80%85%E7%9F%A5%E9%81%93%E6%98%AF%E8%B0%81%EF%BC%8C%E4%BD%86%E4%B8%8D%E4%BC%9A%E5%85%AC%E5%BC%80%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="匿名：研究者也不知道是谁" _mubu_text="%3Cspan%3E%E5%8C%BF%E5%90%8D%EF%BC%9A%E7%A0%94%E7%A9%B6%E8%80%85%E4%B9%9F%E4%B8%8D%E7%9F%A5%E9%81%93%E6%98%AF%E8%B0%81%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="常见手法：编号代替名字 = Confidentiality" _mubu_text="%3Cspan%3E%E5%B8%B8%E8%A7%81%E6%89%8B%E6%B3%95%EF%BC%9A%E7%BC%96%E5%8F%B7%E4%BB%A3%E6%9B%BF%E5%90%8D%E5%AD%97%20=%20Confidentiality%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Debriefing 结束后的解释" _mubu_text="%3Cspan%20class=%22bold%20underline%20text-color-red%22%3EDebriefing%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%BB%93%E6%9D%9F%E5%90%8E%E7%9A%84%E8%A7%A3%E9%87%8A%3C/span%3E" _note="" _mubu_note="">
          <outline text="实验结束后向被试解释" _mubu_text="%3Cspan%3E%E5%AE%9E%E9%AA%8C%E7%BB%93%E6%9D%9F%E5%90%8E%E5%90%91%E8%A2%AB%E8%AF%95%E8%A7%A3%E9%87%8A%3C/span%3E" _note="" _mubu_note="">
            <outline text="真正目的" _mubu_text="%3Cspan%3E%E7%9C%9F%E6%AD%A3%E7%9B%AE%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="使用了什么方法" _mubu_text="%3Cspan%3E%E4%BD%BF%E7%94%A8%E4%BA%86%E4%BB%80%E4%B9%88%E6%96%B9%E6%B3%95%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="为什么这样做" _mubu_text="%3Cspan%3E%E4%B8%BA%E4%BB%80%E4%B9%88%E8%BF%99%E6%A0%B7%E5%81%9A%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="使用 deception 的研究必须 debrief" _mubu_text="%3Cspan%20class=%22bold%20underline%20text-color-red%22%3E%E4%BD%BF%E7%94%A8%20deception%20%E7%9A%84%E7%A0%94%E7%A9%B6%E5%BF%85%E9%A1%BB%20debrief%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Deception 欺骗" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EDeception%3C/span%3E%3Cspan%3E%20%E6%AC%BA%E9%AA%97%3C/span%3E" _note="" _mubu_note="">
          <outline text="对研究目的 / 流程 / 结果进行误导" _mubu_text="%3Cspan%3E%E5%AF%B9%E7%A0%94%E7%A9%B6%E7%9B%AE%E7%9A%84%20/%20%E6%B5%81%E7%A8%8B%20/%20%E7%BB%93%E6%9E%9C%E8%BF%9B%E8%A1%8C%E8%AF%AF%E5%AF%BC%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Why？如果提前告知会 bias results（observer effect）" _mubu_text="%3Cspan%3EWhy%EF%BC%9F%E5%A6%82%E6%9E%9C%E6%8F%90%E5%89%8D%E5%91%8A%E7%9F%A5%E4%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%20bias%20results%3C/span%3E%3Cspan%3E%EF%BC%88observer%20effect%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="前提" _mubu_text="%3Cspan%3E%E5%89%8D%E6%8F%90%3C/span%3E" _note="" _mubu_note="">
            <outline text="不造成长期伤害" _mubu_text="%3Cspan%3E%E4%B8%8D%E9%80%A0%E6%88%90%E9%95%BF%E6%9C%9F%E4%BC%A4%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="必须 debrief" _mubu_text="%3Cspan%3E%E5%BF%85%E9%A1%BB%20debrief%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="IRB同意" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EIRB%E5%90%8C%E6%84%8F%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Animal Testing（理解即可）" _mubu_text="%3Cspan%3EAnimal%20Testing%EF%BC%88%E7%90%86%E8%A7%A3%E5%8D%B3%E5%8F%AF%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="为什么用动物？有些研究对人类不Ethical" _mubu_text="%3Cspan%3E%E4%B8%BA%E4%BB%80%E4%B9%88%E7%94%A8%E5%8A%A8%E7%89%A9%EF%BC%9F%E6%9C%89%E4%BA%9B%E7%A0%94%E7%A9%B6%E5%AF%B9%E4%BA%BA%E7%B1%BB%E4%B8%8DEthical%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="注意：最小化痛苦，减少疾病、感染、压力" _mubu_text="%3Cspan%3E%E6%B3%A8%E6%84%8F%EF%BC%9A%E6%9C%80%E5%B0%8F%E5%8C%96%E7%97%9B%E8%8B%A6%EF%BC%8C%E5%87%8F%E5%B0%91%E7%96%BE%E7%97%85%E3%80%81%E6%84%9F%E6%9F%93%E3%80%81%E5%8E%8B%E5%8A%9B%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="| 情境关键词 | 对应伦理 |
| --- | --- |
| 签字前说明研究 | Informed Consent |
| 儿童同意 | Informed Assent |
| 研究后解释目的 | Debriefing |
| 可随时退出 | Right to Withdraw |
| 编号、不公开身份 | Confidentiality |
| 减少心理/生理伤害 | Protection from Harm |
| 研究前审核 | IRB |
| 隐瞒真实目的 | Deception |" _mubu_text="%3Cdiv%20class=%22table-container%22%3E%3Ctable%20class=%22auto-table%22%20border=%221%22%20cellspacing=%220%22%20style=%22border-collapse:%20collapse;%22%3E%3Cthead%3E%3Ctr%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%220%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%220%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cb%3E%E6%83%85%E5%A2%83%E5%85%B3%E9%94%AE%E8%AF%8D%3C/b%3E%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%221%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cb%3E%E5%AF%B9%E5%BA%94%E4%BC%A6%E7%90%86%3C/b%3E%3C/span%3E%3C/th%3E%3C/tr%3E%3C/thead%3E%3Ctbody%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%221%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E7%AD%BE%E5%AD%97%E5%89%8D%E8%AF%B4%E6%98%8E%E7%A0%94%E7%A9%B6%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3EInformed%20Consent%3C/span%3E%3C/td%3E%3C/tr%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%222%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E5%84%BF%E7%AB%A5%E5%90%8C%E6%84%8F%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3EInformed%20Assent%3C/span%3E%3C/td%3E%3C/tr%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%223%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E7%A0%94%E7%A9%B6%E5%90%8E%E8%A7%A3%E9%87%8A%E7%9B%AE%E7%9A%84%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cu%3EDebriefing%3C/u%3E%3C/span%3E%3C/td%3E%3C/tr%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%224%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E5%8F%AF%E9%9A%8F%E6%97%B6%E9%80%80%E5%87%BA%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3ERight%20to%20Withdraw%3C/span%3E%3C/td%3E%3C/tr%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%225%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E7%BC%96%E5%8F%B7%E3%80%81%E4%B8%8D%E5%85%AC%E5%BC%80%E8%BA%AB%E4%BB%BD%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3EConfidentiality%3C/span%3E%3C/td%3E%3C/tr%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%226%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E5%87%8F%E5%B0%91%E5%BF%83%E7%90%86/%E