          <outline text="思想介于事件与情绪反应之间——「Thinking colors our feelings」" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E6%80%9D%E6%83%B3%3C/span%3E%3Cspan%3E%E4%BB%8B%E4%BA%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BA%8B%E4%BB%B6%3C/span%3E%3Cspan%3E%E4%B8%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E7%BB%AA%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%3E%E4%B9%8B%E9%97%B4%E2%80%94%E2%80%94%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EThinking%20colors%20our%20feelings%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
