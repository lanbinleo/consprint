            <outline text="Agonist 激动剂" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EAgonist%20%3C/span%3E%3Cspan%3E%E6%BF%80%E5%8A%A8%E5%89%82%3C/span%3E" _note="" _mubu_note="">
              <outline text="模拟或增强神经递质的效果 反正就是增强效果就行" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E6%A8%A1%E6%8B%9F%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E5%A2%9E%E5%BC%BA%3C/span%3E%3Cspan%3E%E7%A5%9E%E7%BB%8F%E9%80%92%E8%B4%A8%E7%9A%84%E6%95%88%E6%9E%9C%20%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E5%8F%8D%E6%AD%A3%E5%B0%B1%E6%98%AF%E5%A2%9E%E5%BC%BA%E6%95%88%E6%9E%9C%E5%B0%B1%E8%A1%8C%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="直接激动剂：模拟" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E7%9B%B4%E6%8E%A5%3C/span%3E%3Cspan%3E%E6%BF%80%E5%8A%A8%E5%89%82%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%A8%A1%E6%8B%9F%3C/span%3E" _note="" _mubu_note="">
                <outline text="e.g. Heroin 海洛因模拟 endorphins 内啡肽" _mubu_text="%3Cspan%20class=%22text-color-green%22%3Ee.g.%20Heroin%20%3C/span%3E%3Cspan%3E%E6%B5%B7%E6%B4%9B%E5%9B%A0%E6%A8%A1%E6%8B%9F%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%20endorphins%20%3C/span%3E%3Cspan%3E%E5%86%85%E5%95%A1%E8%82%BD%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="间接激动剂：影响" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E9%97%B4%E6%8E%A5%3C/span%3E%3Cspan%3E%E6%BF%80%E5%8A%A8%E5%89%82%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BD%B1%E5%93%8D%3C/span%3E" _note="" _mubu_note="">
                <outline text="e.g. Cocaine 抑制 Dopamine 的 reuptake，使其刺激接收端更久" _mubu_text="%3Cspan%20class=%22text-color-green%22%3Ee.g.%20Cocaine%20%3C/span%3E%3Cspan%3E%E6%8A%91%E5%88%B6%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%20Dopamine%20%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%20reuptake%EF%BC%8C%3C/span%3E%3Cspan%3E%E4%BD%BF%E5%85%B6%E5%88%BA%E6%BF%80%E6%8E%A5%E6%94%B6%E7%AB%AF%E6%9B%B4%E4%B9%85%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="Antagonist 拮抗剂 反正是减弱效果，也别管原来的刺激是积极还是消极" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EAntagonist%20%3C/span%3E%3Cspan%3E%E6%8B%AE%E6%8A%97%E5%89%82%20%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E5%8F%8D%E6%AD%A3%E6%98%AF%E5%87%8F%E5%BC%B1%E6%95%88%E6%9E%9C%EF%BC%8C%E4%B9%9F%E5%88%AB%E7%AE%A1%E5%8E%9F%E6%9D%A5%E7%9A%84%E5%88%BA%E6%BF%80%E6%98%AF%E7%A7%AF%E6%9E%81%E8%BF%98%E6%98%AF%E6%B6%88%E6%9E%81%3C/span%3E" _note="" _mubu_note="">
