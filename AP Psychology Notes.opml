        <outline text="人本主义疗法 Humanistic / Person-Centered Therapy" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BA%BA%E6%9C%AC%E4%B8%BB%E4%B9%89%E7%96%97%E6%B3%95%20Humanistic%20/%20Person-Centered%20Therapy%3C/span%3E" _note="" _mubu_note="">
          <outline text="提供支持性环境，促进自我发现与个人成长；现在和未来比过去更重要" _mubu_text="%3Cspan%3E%E6%8F%90%E4%BE%9B%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%94%AF%E6%8C%81%E6%80%A7%E7%8E%AF%E5%A2%83%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BF%83%E8%BF%9B%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%87%AA%E6%88%91%E5%8F%91%E7%8E%B0%3C/span%3E%3Cspan%3E%E4%B8%8E%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%B8%AA%E4%BA%BA%E6%88%90%E9%95%BF%3C/span%3E%3Cspan%3E%EF%BC%9B%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E7%8E%B0%E5%9C%A8%E5%92%8C%E6%9C%AA%E6%9D%A5%E6%AF%94%E8%BF%87%E5%8E%BB%E6%9B%B4%E9%87%8D%E8%A6%81%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="无条件积极关注 Unconditional Positive Regard 无论来访者说什么做什么，治疗师都给予完全接纳与支持" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%97%A0%E6%9D%A1%E4%BB%B6%E7%A7%AF%E6%9E%81%E5%85%B3%E6%B3%A8%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EUnconditional%20Positive%20Regard%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E6%97%A0%E8%AE%BA%E6%9D%A5%E8%AE%BF%E8%80%85%E8%AF%B4%E4%BB%80%E4%B9%88%E5%81%9A%E4%BB%80%E4%B9%88%EF%BC%8C%E6%B2%BB%E7%96%97%E5%B8%88%E9%83%BD%E7%BB%99%E4%BA%88%3C/span%3E%3Cspan%20class=%22underline%20text-color-blue%22%3E%E5%AE%8C%E5%85%A8%E6%8E%A5%E7%BA%B3%3C/span%3E%3Cspan%3E%E4%B8%8E%E6%94%AF%E6%8C%81%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="积极倾听 Active Listening 治疗师全神贯注地理解、回应并记忆来访者所表达的内容，以验证其感受" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A7%AF%E6%9E%81%E5%80%BE%E5%90%AC%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EActive%20Listening%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E6%B2%BB%E7%96%97%E5%B8%88%E5%85%A8%E7%A5%9E%E8%B4%AF%E6%B3%A8%E5%9C%B0%3C/span%3E%3Cspan%20class=%22underline%20text-color-blue%22%3E%E7%90%86%E8%A7%A3%E3%80%81%E5%9B%9E%E5%BA%94%E5%B9%B6%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%E6%9D%A5%E8%AE%BF%E8%80%85%E6%89%80%E8%A1%A8%E8%BE%BE%E7%9A%84%E5%86%85%E5%AE%B9%EF%BC%8C%E4%BB%A5%E9%AA%8C%E8%AF%81%E5%85%B6%E6%84%9F%E5%8F%97%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="团体疗法 Group Therapy" _mubu_text="%3Cspan%3E%E5%9B%A2%E4%BD%93%E7%96%97%E6%B3%95%20Group%20Therapy%3C/span%3E" _note="" _mubu_note="">
          <outline text="|  | 团体治疗 Group Therapy | 个体治疗 Individual Therapy |
| --- | --- | --- |
| 优势 | 共同经历、成员支持、减少孤独感、多元视角 | 个性化关注、深度探索个人问题 |
| 劣势 | 个体关注较少、分享时可能不适 | 缺乏同伴支持、费用较高 |" _mubu_text="%3Cdiv%20class=%22table-container%22%3E%3Ctable%20class=%22auto-table%22%20border=%221%22%20cellspacing=%220%22%20style=%22border-collapse:%20collapse;%22%3E%3Cthead%3E%3Ctr%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%220%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%220%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%221%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cb%3E%E5%9B%A2%E4%BD%93%E6%B2%BB%E7%96%97%20Group%20Therapy%3C/b%3E%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%222%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cb%3E%E4%B8%AA%E4%BD%93%E6%B2%BB%E7%96%97%20Individual%20Therapy%3C/b%3E%3C/span%3E%3C/th%3E%3C/tr%3E%3C/thead%3E%3Ctbody%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%221%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cb%3E%E4%BC%98%E5%8A%BF%3C/b%3E%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E5%85%B1%E5%90%8C%E7%BB%8F%E5%8E%86%E3%80%81%E6%88%90%E5%91%98%E6%94%AF%E6%8C%81%E3%80%81%E5%87%8F%E5%B0%91%E5%AD%A4%E7%8B%AC%E6%84%9F%E3%80%81%E5%A4%9A%E5%85%83%E8%A7%86%E8%A7%92%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E4%B8%AA%E6%80%A7%E5%8C%96%E5%85%B3%E6%B3%A8%E3%80%81%E6%B7%B1%E5%BA%A6%E6%8E%A2%E7%B4%A2%E4%B8%AA%E4%BA%BA%E9%97%AE%E9%A2%98%3C/span%3E%3C/td%3E%3C/tr%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%222%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cb%3E%E5%8A%A3%E5%8A%BF%3C/b%3E%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E4%B8%AA%E4%BD%93%E5%85%B3%E6%B3%A8%E8%BE%83%E5%B0%91%E3%80%81%E5%88%86%E4%BA%AB%E6%97%B6%E5%8F%AF%E8%83%BD%E4%B8%8D%E9%80%82%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E7%BC%BA%E4%B9%8F%E5%90%8C%E4%BC%B4%E6%94%AF%E6%8C%81%E3%80%81%E8%B4%B9%E7%94%A8%E8%BE%83%E9%AB%98%3C/span%3E%3C/td%3E%3C/tr%3E%3C/tbody%3E%3C/table%3E%3C/div%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="催眠疗法 Hypnosis" _mubu_text="%3Cspan%3E%E5%82%AC%E7%9C%A0%E7%96%97%E6%B3%95%20Hypnosis%3C/span%3E" _note="" _mubu_note="">
          <outline text="患者意识抵抗降低，对治疗性语言暗示更易接受，增强对潜意识的访问" _mubu_text="%3Cspan%3E%E6%82%A3%E8%80%85%E6%84%8F%E8%AF%86%E6%8A%B5%E6%8A%97%E9%99%8D%E4%BD%8E%EF%BC%8C%E5%AF%B9%E6%B2%BB%E7%96%97%E6%80%A7%E8%AF%AD%E8%A8%80%E6%9A%97%E7%A4%BA%E6%9B%B4%E6%98%93%E6%8E%A5%E5%8F%97%EF%BC%8C%E5%A2%9E%E5%BC%BA%E5%AF%B9%E6%BD%9C%E6%84%8F%E8%AF%86%E7%9A%84%E8%AE%BF%E9%97%AE%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="有效：治疗疼痛与焦虑" _mubu_text="%3Cspan%3E%E6%9C%89%E6%95%88%EF%BC%9A%E6%B2%BB%E7%96%97%E7%96%BC%E7%97%9B%E4%B8%8E%E7%84%A6%E8%99%91%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="无效：提取准确记忆或年龄回归（研究不支持）" _mubu_text="%3Cspan%3E%E6%97%A0%E6%95%88%EF%BC%9A%E6%8F%90%E5%8F%96%E5%87%86%E7%A1%AE%E8%AE%B0%E5%BF%86%E6%88%96%E5%B9%B4%E9%BE%84%E5%9B%9E%E5%BD%92%EF%BC%88%E7%A0%94%E7%A9%B6%E4%B8%8D%E6%94%AF%E6%8C%81%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="精神药物治疗 Psychotropic Medication Therapy" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B2%BE%E7%A5%9E%E8%8D%AF%E7%89%A9%E6%B2%BB%E7%96%97%20Psychotropic%20Medication%20Therapy%3C/span%3E" _note="" _mubu_note="">
          <outline text="基本前提：许多心理障碍涉及生物因素，药物或医学程序可用于治疗" _mubu_text="%3Cspan%3E%E5%9F%BA%E6%9C%AC%E5%89%8D%E6%8F%90%EF%BC%9A%E8%AE%B8%E5%A4%9A%E5%BF%83%E7%90%86%E9%9A%9C%E7%A2%8D%E6%B6%89%E5%8F%8A%E7%94%9F%E7%89%A9%E5%9B%A0%E7%B4%A0%EF%BC%8C%E8%8D%AF%E7%89%A9%E6%88%96%E5%8C%BB%E5%AD%A6%E7%A8%8B%E5%BA%8F%E5%8F%AF%E7%94%A8%E4%BA%8E%E6%B2%BB%E7%96%97%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="抗焦虑药 Antianxiety Drugs" _mubu_text="%3Cspan%3E%E6%8A%97%E7%84%A6%E8%99%91%E8%8D%AF%20Antianxiety%20Drugs%3C/span%3E" _note="" _mubu_note="">
            <outline text="降低大脑交感活动，促进放松，减少过度焦虑" _mubu_text="%3Cspan%3E%E9%99%8D%E4%BD%8E%E5%A4%A7%E8%84%91%E4%BA%A4%E6%84%9F%E6%B4%BB%E5%8A%A8%EF%BC%8C%E4%BF%83%E8%BF%9B%E6%94%BE%E6%9D%BE%EF%BC%8C%E5%87%8F%E5%B0%91%E8%BF%87%E5%BA%A6%E7%84%A6%E8%99%91%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="常见类型：苯二氮䓬类 Benzodiazepines（Xanax、Valium、Ativan、Klonopin）——起效快，有成瘾风险；阿扎哌隆类 Azapirones（Buspar）——非镇静性，依赖风险低但起效慢" _mubu_text="%3Cspan%3E%E5%B8%B8%E8%A7%81%E7%B1%BB%E5%9E%8B%EF%BC%9A%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%8B%AF%E4%BA%8C%E6%B0%AE%E4%93%AC%E7%B1%BB%20Benzodiazepines%3C/span%3E%3Cspan%3E%EF%BC%88Xanax%E3%80%81Valium%E3%80%81Ativan%E3%80%81Klonopin%EF%BC%89%E2%80%94%E2%80%94%E8%B5%B7%E6%95%88%E5%BF%AB%EF%BC%8C%E6%9C%89%E6%88%90%E7%98%BE%E9%A3%8E%E9%99%A9%EF%BC%9B%3C/span%3E%3Cspan%20class=%22bold%22%3E%E9%98%BF%E6%89%8E%E5%93%8C%E9%9A%86%E7%B1%BB%20Azapirones%3C/span%3E%3Cspan%3E%EF%BC%88Buspar%EF%BC%89%E2%80%94%E2%80%94%E9%9D%9E%E9%95%87%E9%9D%99%E6%80%A7%EF%BC%8C%E4%BE%9D%E8%B5%96%E9%A3%8E%E9%99%A9%E4%BD%8E%E4%BD%86%E8%B5%B7%E6%95%88%E6%85%A2%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="抗抑郁药 Antidepressant Drugs" _mubu_text="%3Cspan%3E%E6%8A%97%E6%8A%91%E9%83%81%E8%8D%AF%20Antidepressant%20Drugs%3C/span%3E" _note="" _mubu_note="">
            <outline text="通过影响神经递质（主要是血清素 Serotonin）提升情绪" _mubu_text="%3Cspan%3E%E9%80%9A%E8%BF%87%E5%BD%B1%E5%93%8D%E7%A5%9E%E7%BB%8F%E9%80%92%E8%B4%A8%EF%BC%88%E4%B8%BB%E8%A6%81%E6%98%AF%E8%A1%80%E6%B8%85%E7%B4%A0%20Serotonin%EF%BC%89%E6%8F%90%E5%8D%87%E6%83%85%E7%BB%AA%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="SSRI（选择性血清素再摄取抑制剂）：阻断血清素再摄取，如 Prozac、Zoloft、Lexapro" _mubu_text="%3Cspan%20class=%22bold%22%3ESSRI%3C/span%3E%3Cspan%3E%EF%BC%88%E9%80%89%E6%8B%A9%E6%80%A7%E8%A1%80%E6%B8%85%E7%B4%A0%E5%86%8D%E6%91%84%E5%8F%96%E6%8A%91%E5%88%B6%E5%89%82%EF%BC%89%EF%BC%9A%E9%98%BB%E6%96%AD%E8%A1%80%E6%B8%85%E7%B4%A0%E5%86%8D%E6%91%84%E5%8F%96%EF%BC%8C%E5%A6%82%20Prozac%E3%80%81Zoloft%E3%80%81Lexapro%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="SNRI：增加血清素和去甲肾上腺素，如 Effexor（适合重度抑郁）" _mubu_text="%3Cspan%20class=%22bold%22%3ESNRI%3C/span%3E%3Cspan%3E%EF%BC%9A%E5%A2%9E%E5%8A%A0%E8%A1%80%E6%B8%85%E7%B4%A0%E5%92%8C%E5%8E%BB%E7%94%B2%E8%82%BE%E4%B8%8A%E8%85%BA%E7%B4%A0%EF%BC%8C%E5%A6%82%20Effexor%EF%BC%88%E9%80%82%E5%90%88%E9%87%8D%E5%BA%A6%E6%8A%91%E9%83%81%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="NDRI：增加去甲肾上腺素和多巴胺，如 Wellbutrin（性副作用较少）" _mubu_text="%3Cspan%20class=%22bold%22%3ENDRI%3C/span%3E%3Cspan%3E%EF%BC%9A%E5%A2%9E%E5%8A%A0%E5%8E%BB%E7%94%B2%E8%82%BE%E4%B8%8A%E8%85%BA%E7%B4%A0%E5%92%8C%E5%A4%9A%E5%B7%B4%E8%83%BA%EF%BC%8C%E5%A6%82%20Wellbutrin%EF%BC%88%E6%80%A7%E5%89%AF%E4%BD%9C%E7%94%A8%E8%BE%83%E5%B0%91%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="抗精神病药 Antipsychotic Drugs" _mubu_text="%3Cspan%3E%E6%8A%97%E7%B2%BE%E7%A5%9E%E7%97%85%E8%8D%AF%20Antipsychotic%20Drugs%3C/span%3E" _note="" _mubu_note="">
            <outline text="消除精神分裂症阳性症状（幻觉、妄想），通过减少多巴胺受体活动起效" _mubu_text="%3Cspan%3E%E6%B6%88%E9%99%A4%E7%B2%BE%E7%A5%9E%E5%88%86%E8%A3%82%E7%97%87%E9%98%B3%E6%80%A7%E7%97%87%E7%8A%B6%EF%BC%88%E5%B9%BB%E8%A7%89%E3%80%81%E5%A6%84%E6%83%B3%EF%BC%89%EF%BC%8C%E9%80%9A%E8%BF%87%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%87%8F%E5%B0%91%E5%A4%9A%E5%B7%B4%E8%83%BA%E5%8F%97%E4%BD%93%E6%B4%BB%E5%8A%A8%3C/span%3E%3Cspan%3E%E8%B5%B7%E6%95%88%3C/span%3E" _note="" _mubu_note="">
              <outline text="典型/第一代 Typical Antipsychotics（如 Haldol）：对阳性症状有效，运动副作用风险高" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%85%B8%E5%9E%8B/%E7%AC%AC%E4%B8%80%E4%BB%A3%20Typical%20Antipsychotics%3C/span%3E%3Cspan%3E%EF%BC%88%E5%A6%82%20Haldol%EF%BC%89%EF%BC%9A%E5%AF%B9%E9%98%B3%E6%80%A7%E7%97%87%E7%8A%B6%E6%9C%89%E6%95%88%EF%BC%8C%E8%BF%90%E5%8A%A8%E5%89%AF%E4%BD%9C%E7%94%A8%E9%A3%8E%E9%99%A9%E9%AB%98%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="非典型/第二代 Atypical Antipsychotics（如 Risperdal、Zyprexa、Abilify）：对阳性和阴性症状均有效，运动副作用较少" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%9D%9E%E5%85%B8%E5%9E%8B/%E7%AC%AC%E4%BA%8C%E4%BB%A3%20Atypical%20Antipsychotics%3C/span%3E%3Cspan%3E%EF%BC%88%E5%A6%82%20Risperdal%E3%80%81Zyprexa%E3%80%81Abilify%EF%BC%89%EF%BC%9A%E5%AF%B9%E9%98%B3%E6%80%A7%E5%92%8C%E9%98%B4%E6%80%A7%E7%97%87%E7%8A%B6%E5%9D%87%E6%9C%89%E6%95%88%EF%BC%8C%E8%BF%90%E5%8A%A8%E5%89%AF%E4%BD%9C%E7%94%A8%E8%BE%83%E5%B0%91%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="迟发性运动障碍 Tardive Dyskinesia：长期使用抗精神病药的潜在副作用，表现为面部、下颌、肢体的不自主重复运动，与多巴胺调节相关" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%BF%9F%E5%8F%91%E6%80%A7%E8%BF%90%E5%8A%A8%E9%9A%9C%E7%A2%8D%20Tardive%20Dyskinesia%3C/span%3E%3Cspan%3E%EF%BC%9A%E9%95%BF%E6%9C%9F%E4%BD%BF%E7%94%A8%E6%8A%97%E7%B2%BE%E7%A5%9E%E7%97%85%E8%8D%AF%E7%9A%84%E6%BD%9C%E5%9C%A8%E5%89%AF%E4%BD%9C%E7%94%A8%EF%BC%8C%E8%A1%A8%E7%8E%B0%E4%B8%BA%E9%9D%A2%E9%83%A8%E3%80%81%E4%B8%8B%E9%A2%8C%E3%80%81%E8%82%A2%E4%BD%93%E7%9A%84%E4%B8%8D%E8%87%AA%E4%B8%BB%E9%87%8D%E5%A4%8D%E8%BF%90%E5%8A%A8%EF%BC%8C%E4%B8%8E%E5%A4%9A%E5%B7%B4%E8%83%BA%E8%B0%83%E8%8A%82%E7%9B%B8%E5%85%B3%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="情绪稳定剂 Mood-Stabilizing Drugs" _mubu_text="%3Cspan%3E%E6%83%85%E7%BB%AA%E7%A8%B3%E5%AE%9A%E5%89%82%20Mood-Stabilizing%20Drugs%3C/span%3E" _note="" _mubu_note="">
            <outline text="锂盐 Lithium：常用于治疗双相情感障碍 Bipolar Disorder，稳定情绪波动，降低躁狂和抑郁发作的频率与严重程度" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%94%82%E7%9B%90%20Lithium%3C/span%3E%3Cspan%3E%EF%BC%9A%E5%B8%B8%E7%94%A8%E4%BA%8E%E6%B2%BB%E7%96%97%E5%8F%8C%E7%9B%B8%E6%83%85%E6%84%9F%E9%9A%9C%E7%A2%8D%20Bipolar%20Disorder%EF%BC%8C%E7%A8%B3%E5%AE%9A%E6%83%85%E7%BB%AA%E6%B3%A2%E5%8A%A8%EF%BC%8C%E9%99%8D%E4%BD%8E%E8%BA%81%E7%8B%82%E5%92%8C%E6%8A%91%E9%83%81%E5%8F%91%E4%BD%9C%E7%9A%84%E9%A2%91%E7%8E%87%E4%B8%8E%E4%B8%A5%E9%87%8D%E7%A8%8B%E5%BA%A6%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="外科/侵入性干预 Surgical / Invasive Interventions" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%A4%96%E7%A7%91/%E4%BE%B5%E5%85%A5%E6%80%A7%E5%B9%B2%E9%A2%84%20Surgical%20/%20Invasive%20Interventions%3C/span%3E" _note="" _mubu_note="">
          <outline text="精神外科手术 Psychosurgery：手术改变脑组织，用于其他治疗失败后的最后手段；不可逆，由精神科医生与神经外科医生合作 " _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B2%BE%E7%A5%9E%E5%A4%96%E7%A7%91%E6%89%8B%E6%9C%AF%20Psychosurgery%3C/span%3E%3Cspan%3E%EF%BC%9A%E6%89%8B%E6%9C%AF%E6%94%B9%E5%8F%98%E8%84%91%E7%BB%84%E7%BB%87%EF%BC%8C%E7%94%A8%E4%BA%8E%E5%85%B6%E4%BB%96%E6%B2%BB%E7%96%97%E5%A4%B1%E8%B4%A5%E5%90%8E%E7%9A%84%E6%9C%80%E5%90%8E%E6%89%8B%E6%AE%B5%EF%BC%9B%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%B8%8D%E5%8F%AF%E9%80%86%3C/span%3E%3Cspan%3E%EF%BC%8C%E7%94%B1%E7%B2%BE%E7%A5%9E%E7%A7%91%E5%8C%BB%E7%94%9F%E4%B8%8E%E7%A5%9E%E7%BB%8F%E5%A4%96%E7%A7%91%E5%8C%BB%E7%94%9F%E5%90%88%E4%BD%9C%20%3C/span%3E" _note="" _mubu_note="">
            <outline text="损毁术 Lesioning：对特定脑区进行小范围靶向损伤" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%8D%9F%E6%AF%81%E6%9C%AF%20Lesioning%3C/span%3E%3Cspan%3E%EF%BC%9A%E5%AF%B9%E7%89%B9%E5%AE%9A%E8%84%91%E5%8C%BA%E8%BF%9B%E8%A1%8C%E5%B0%8F%E8%8C%83%E5%9B%B4%E9%9D%B6%E5%90%91%E6%8D%9F%E4%BC%A4%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="前脑叶切断术 Lobotomy：切断前额叶皮层连接，现已基本废弃，副作用严重" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%89%8D%E8%84%91%E5%8F%B6%E5%88%87%E6%96%AD%E6%9C%AF%20Lobotomy%3C/span%3E%3Cspan%3E%EF%BC%9A%E5%88%87%E6%96%AD%E5%89%8D%E9%A2%9D%E5%8F%B6%E7%9A%AE%E5%B1%82%E8%BF%9E%E6%8E%A5%EF%BC%8C%E7%8E%B0%E5%B7%B2%E5%9F%BA%E6%9C%AC%E5%BA%9F%E5%BC%83%EF%BC%8C%E5%89%AF%E4%BD%9C%E7%94%A8%E4%B8%A5%E9%87%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="电休克疗法 ECT (Electroconvulsive Therapy)：向大脑传送小电流，诱发短暂癫痫发作；用于其他治疗无效的重度抑郁 「可能导致短暂记忆丧失」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%94%B5%E4%BC%91%E5%85%8B%E7%96%97%E6%B3%95%20ECT%20(Electroconvulsive%20Therapy)%3C/span%3E%3Cspan%3E%EF%BC%9A%E5%90%91%E5%A4%A7%E8%84%91%E4%BC%A0%E9%80%81%E5%B0%8F%E7%94%B5%E6%B5%81%EF%BC%8C%E8%AF%B1%E5%8F%91%E7%9F%AD%E6%9A%82%E7%99%AB%E7%97%AB%E5%8F%91%E4%BD%9C%EF%BC%9B%E7%94%A8%E4%BA%8E%E5%85%B6%E4%BB%96%E6%B2%BB%E7%96%97%E6%97%A0%E6%95%88%E7%9A%84%E9%87%8D%E5%BA%A6%E6%8A%91%E9%83%81%20%E3%80%8C%E5%8F%AF%E8%83%BD%E5%AF%BC%E8%87%B4%E7%9F%AD%E6%9A%82%E8%AE%B0%E5%BF%86%E4%B8%A7%E5%A4%B1%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="经颅磁刺激 TMS (Transcranial Magnetic Stimulation)：非侵入性，将脉冲磁线圈置于前额叶区域上方，用磁场刺激神经细胞，治疗抑郁，副作用小" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%BB%8F%E9%A2%85%E7%A3%81%E5%88%BA%E6%BF%80%20TMS%20(Transcranial%20Magnetic%20Stimulation)%3C/span%3E%3Cspan%3E%EF%BC%9A%E9%9D%9E%E4%BE%B5%E5%85%A5%E6%80%A7%EF%BC%8C%E5%B0%86%E8%84%89%E5%86%B2%E7%A3%81%E7%BA%BF%E5%9C%88%E7%BD%AE%E4%BA%8E%E5%89%8D%E9%A2%9D%E5%8F%B6%E5%8C%BA%E5%9F%9F%E4%B8%8A%E6%96%B9%EF%BC%8C%E7%94%A8%E7%A3%81%E5%9C%BA%E5%88%BA%E6%BF%80%E7%A5%9E%E7%BB%8F%E7%BB%86%E8%83%9E%EF%BC%8C%E6%B2%BB%E7%96%97%E6%8A%91%E9%83%81%EF%BC%8C%E5%89%AF%E4%BD%9C%E7%94%A8%E5%B0%8F%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
    </outline>
  </body>
