            <outline text="大脑皮层负责编故事 / 合理化 Cerebral Cortex 大脑皮层" _mubu_text="%3Cspan%3E%E5%A4%A7%E8%84%91%E7%9A%AE%E5%B1%82%E8%B4%9F%E8%B4%A3%E7%BC%96%E6%95%85%E4%BA%8B%20/%20%E5%90%88%E7%90%86%E5%8C%96%20%3C/span%3E%3Cspan%20class=%22node-mention%22%20id=%22QGsY9LTLmH%22%20spellcheck=%22false%22%20contenteditable=%22false%22%20data-doc=%221qN74cOm072%22%20data-node=%2274uPFigonL%22%20data-text=%22%255B%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Cerebral%2520Cortex%2520%25E5%25A4%25A7%25E8%2584%2591%25E7%259A%25AE%25E5%25B1%2582%2522%252C%2522style%2522%253A%257B%257D%257D%255D%22%3E%3Cspan%3ECerebral%20Cortex%20%E5%A4%A7%E8%84%91%E7%9A%AE%E5%B1%82%3C/span%3E%3C/span%3E%3Cspan%3E%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="7. 睡眠障碍" _mubu_text="%3Cspan%3E7.%20%E7%9D%A1%E7%9C%A0%E9%9A%9C%E7%A2%8D%3C/span%3E" _note="" _mubu_note="">
          <outline text="Insomnia 失眠" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EInsomnia%20%3C/span%3E%3Cspan%3E%E5%A4%B1%E7%9C%A0%3C/span%3E" _note="" _mubu_note="">
            <outline text="入睡困难 / 易醒来 / 睡眠质量差" _mubu_text="%3Cspan%3E%E5%85%A5%E7%9D%A1%E5%9B%B0%E9%9A%BE%20/%20%E6%98%93%E9%86%92%E6%9D%A5%20/%20%E7%9D%A1%E7%9C%A0%E8%B4%A8%E9%87%8F%E5%B7%AE%3C/span%3E" _note="" _mubu_note=""/>
