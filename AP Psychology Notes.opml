            <outline text="暴露疗法 Exposure Therapy 在受控环境中逐步、反复暴露于恐惧对象/情境，降低焦虑" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%9A%B4%E9%9C%B2%E7%96%97%E6%B3%95%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EExposure%20Therapy%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%8F%97%E6%8E%A7%E7%8E%AF%E5%A2%83%3C/span%3E%3Cspan%3E%E4%B8%AD%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%80%90%E6%AD%A5%E3%80%81%E5%8F%8D%E5%A4%8D%E6%9A%B4%E9%9C%B2%3C/span%3E%3Cspan%3E%E4%BA%8E%E6%81%90%E6%83%A7%E5%AF%B9%E8%B1%A1/%E6%83%85%E5%A2%83%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%99%8D%E4%BD%8E%E7%84%A6%E8%99%91%3C/span%3E" _note="" _mubu_note="">
              <outline text="适用：Phobias、Panic Disorder、Social Anxiety、OCD、PTSD、GAD" _mubu_text="%3Cspan%3E%E9%80%82%E7%94%A8%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EPhobias%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EPanic%20Disorder%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3ESocial%20Anxiety%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EOCD%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EPTSD%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EGAD%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="系统脱敏 Systematic Desensitization 恐惧层级，渐进式放松训练，逐步推进「想蜘蛛、摸蜘蛛」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B3%BB%E7%BB%9F%E8%84%B1%E6%95%8F%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESystematic%20Desensitization%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%81%90%E6%83%A7%E5%B1%82%E7%BA%A7%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%B8%90%E8%BF%9B%E5%BC%8F%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%94%BE%E6%9D%BE%E8%AE%AD%E7%BB%83%3C/span%3E%3Cspan%3E%EF%BC%8C%E9%80%90%E6%AD%A5%E6%8E%A8%E8%BF%9B%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%83%B3%E8%9C%98%E8%9B%9B%E3%80%81%E6%91%B8%E8%9C%98%E8%9B%9B%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="拮抗抑制——你不可能在极度放松的同时感到极度恐惧。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%8B%AE%E6%8A%97%E6%8A%91%E5%88%B6%3C/span%3E%3Cspan%3E%E2%80%94%E2%80%94%E4%BD%A0%E4%B8%8D%E5%8F%AF%E8%83%BD%E5%9C%A8%E6%9E%81%E5%BA%A6%E6%94%BE%E6%9D%BE%E7%9A%84%E5%90%8C%E6%97%B6%E6%84%9F%E5%88%B0%E6%9E%81%E5%BA%A6%E6%81%90%E6%83%A7%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="厌恶疗法 Aversion Therapy 将不良行为与不愉快刺激配对，建立负面联结；操作不当可能有害" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8E%8C%E6%81%B6%E7%96%97%E6%B3%95%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EAversion%20Therapy%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%B0%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%8D%E8%89%AF%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%E4%B8%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%8D%E6%84%89%E5%BF%AB%E5%88%BA%E6%BF%80%3C/span%3E%3Cspan%3E%E9%85%8D%E5%AF%B9%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%BB%BA%E7%AB%8B%E8%B4%9F%E9%9D%A2%E8%81%94%E7%BB%93%3C/span%3E%3Cspan%3E%EF%BC%9B%E6%93%8D%E4%BD%9C%E4%B8%8D%E5%BD%93%E5%8F%AF%E8%83%BD%E6%9C%89%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="基于操作条件反射 Operant Conditioning" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%9F%BA%E4%BA%8E%E6%93%8D%E4%BD%9C%E6%9D%A1%E4%BB%B6%E5%8F%8D%E5%B0%84%20Operant%20Conditioning%3C/span%3E" _note="" _mubu_note="">
            <outline text="代币经济 Token Economy 以代币奖励目标行为（自我照料、服药依从等），可兑换奖励" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BB%A3%E5%B8%81%E7%BB%8F%E6%B5%8E%20Token%20Economy%3C/span%3E%3Cspan%3E%20%E4%BB%A5%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BB%A3%E5%B8%81%E5%A5%96%E5%8A%B1%3C/span%3E%3Cspan%3E%E7%9B%AE%E6%A0%87%E8%A1%8C%E4%B8%BA%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%87%AA%E6%88%91%E7%85%A7%E6%96%99%E3%80%81%E6%9C%8D%E8%8D%AF%E4%BE%9D%E4%BB%8E%E7%AD%89%3C/span%3E%3Cspan%3E%EF%BC%89%EF%BC%8C%E5%8F%AF%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%85%91%E6%8D%A2%E5%A5%96%E5%8A%B1%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="生物反馈 Biofeedback 通过电子监测让个体实时了解心率、肌肉张力等生理指标，学习自我调控" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%94%9F%E7%89%A9%E5%8F%8D%E9%A6%88%20Biofeedback%3C/span%3E%3Cspan%3E%20%E9%80%9A%E8%BF%87%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%94%B5%E5%AD%90%E7%9B%91%E6%B5%8B%3C/span%3E%3Cspan%3E%E8%AE%A9%E4%B8%AA%E4%BD%93%E5%AE%9E%E6%97%B6%E4%BA%86%E8%A7%A3%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%83%E7%8E%87%E3%80%81%E8%82%8C%E8%82%89%E5%BC%A0%E5%8A%9B%3C/span%3E%3Cspan%3E%E7%AD%89%E7%94%9F%E7%90%86%E6%8C%87%E6%A0%87%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%AD%A6%E4%B9%A0%E8%87%AA%E6%88%91%E8%B0%83%E6%8E%A7%3C/span%3E" _note="" _mubu_note="">
              <outline text="适用于压力管理" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E9%80%82%E7%94%A8%E4%BA%8E%E5%8E%8B%E5%8A%9B%E7%AE%A1%E7%90%86%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="认知行为疗法 Cognitive-Behavioral Therapy" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AE%A4%E7%9F%A5%E8%A1%8C%E4%B8%BA%E7%96%97%E6%B3%95%20Cognitive-Behavioral%20Therapy%3C/span%3E" _note="" _mubu_note="">
