          <outline text="认知三角 Cognitive Triad 对自我、世界、未来的负面思维「抑郁的核心」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AE%A4%E7%9F%A5%E4%B8%89%E8%A7%92%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3ECognitive%20Triad%3C/span%3E%3Cspan%3E%20%E5%AF%B9%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%87%AA%E6%88%91%E3%80%81%E4%B8%96%E7%95%8C%E3%80%81%E6%9C%AA%E6%9D%A5%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%B4%9F%E9%9D%A2%E6%80%9D%E7%BB%B4%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%8A%91%E9%83%81%E7%9A%84%E6%A0%B8%E5%BF%83%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="认知重构 Cognitive Restructuring 识别并尝试改变负面信念，以更积极、现实的想法替代" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AE%A4%E7%9F%A5%E9%87%8D%E6%9E%84%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3ECognitive%20Restructuring%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E8%AF%86%E5%88%AB%E5%B9%B6%E5%B0%9D%E8%AF%95%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%94%B9%E5%8F%98%E8%B4%9F%E9%9D%A2%E4%BF%A1%E5%BF%B5%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BB%A5%E6%9B%B4%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%A7%AF%E6%9E%81%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%8E%B0%E5%AE%9E%3C/span%3E%3Cspan%3E%E7%9A%84%E6%83%B3%E6%B3%95%E6%9B%BF%E4%BB%A3%3C/span%3E" _note="" _mubu_note=""/>
