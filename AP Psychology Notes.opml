          <outline text="迈尔斯-布里格斯类型指标 MBTI 基于16种人格类型的自陈式量表，涵盖四个维度：" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%BF%88%E5%B0%94%E6%96%AF-%E5%B8%83%E9%87%8C%E6%A0%BC%E6%96%AF%E7%B1%BB%E5%9E%8B%E6%8C%87%E6%A0%87%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EMBTI%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E5%9F%BA%E4%BA%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E16%E7%A7%8D%E4%BA%BA%E6%A0%BC%E7%B1%BB%E5%9E%8B%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%87%AA%E9%99%88%E5%BC%8F%3C/span%3E%3Cspan%3E%E9%87%8F%E8%A1%A8%EF%BC%8C%E6%B6%B5%E7%9B%96%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%9B%9B%E4%B8%AA%E7%BB%B4%E5%BA%A6%3C/span%3E%3Cspan%3E%EF%BC%9A%3C/span%3E" _note="" _mubu_note="">
            <outline text="外向-内向 Extroversion-Introversion" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E5%A4%96%E5%90%91-%E5%86%85%E5%90%91%3C/span%3E%3Cspan%3E%20Extroversion-Introversion%3C/span%3E" _note="" _mubu_note=""/>
