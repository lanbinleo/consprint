        <outline text="行为疗法 Behavior Therapy / Applied Behavior Analysis" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A1%8C%E4%B8%BA%E7%96%97%E6%B3%95%20Behavior%20Therapy%20/%20Applied%20Behavior%20Analysis%3C/span%3E" _note="" _mubu_note="">
