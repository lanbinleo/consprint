      <outline text="4.6 Motivation" _mubu_text="%3Cspan%3E4.6%20Motivation%3C/span%3E" _note="" _mubu_note="">
        <outline text="动机基础 Motivation Basics" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8A%A8%E6%9C%BA%E5%9F%BA%E7%A1%80%20Motivation%20Basics%3C/span%3E" _note="" _mubu_note="">
          <outline text="Motivation 动机 引导行为指向目标的需要、欲望、情感和想法，是一种为了满足某些条件而行动的冲动「想要升职加薪所以努力工作」" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EMotivation%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%8A%A8%E6%9C%BA%3C/span%3E%3Cspan%3E%20%E5%BC%95%E5%AF%BC%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A1%8C%E4%B8%BA%E6%8C%87%E5%90%91%E7%9B%AE%E6%A0%87%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%9C%80%E8%A6%81%E3%80%81%E6%AC%B2%E6%9C%9B%E3%80%81%E6%83%85%E6%84%9F%3C/span%3E%3Cspan%3E%E5%92%8C%E6%83%B3%E6%B3%95%EF%BC%8C%E6%98%AF%E4%B8%80%E7%A7%8D%E4%B8%BA%E4%BA%86%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E6%BB%A1%E8%B6%B3%E6%9F%90%E4%BA%9B%E6%9D%A1%E4%BB%B6%3C/span%3E%3Cspan%3E%E8%80%8C%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E8%A1%8C%E5%8A%A8%3C/span%3E%3Cspan%3E%E7%9A%84%E5%86%B2%E5%8A%A8%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%83%B3%E8%A6%81%E5%8D%87%E8%81%8C%E5%8A%A0%E8%96%AA%E6%89%80%E4%BB%A5%E5%8A%AA%E5%8A%9B%E5%B7%A5%E4%BD%9C%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="动机类型" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8A%A8%E6%9C%BA%E7%B1%BB%E5%9E%8B%3C/span%3E" _note="" _mubu_note="">
            <outline text="内在动机 Intrinsic Motivation 出于兴趣或价值观自发行动「因为喜欢画画而画画，不为获奖」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%86%85%E5%9C%A8%E5%8A%A8%E6%9C%BA%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EIntrinsic%20Motivation%3C/span%3E%3Cspan%3E%20%E5%87%BA%E4%BA%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%85%B4%E8%B6%A3%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BB%B7%E5%80%BC%E8%A7%82%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%87%AA%E5%8F%91%3C/span%3E%3Cspan%3E%E8%A1%8C%E5%8A%A8%E3%80%8C%E5%9B%A0%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%96%9C%E6%AC%A2%E7%94%BB%E7%94%BB%E8%80%8C%E7%94%BB%E7%94%BB%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%B8%8D%E4%B8%BA%E8%8E%B7%E5%A5%96%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="外在动机 Extrinsic Motivation 由外部奖励驱动的行为「为了奖金完成销售目标」（金钱、名声、成绩、赞扬）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%A4%96%E5%9C%A8%E5%8A%A8%E6%9C%BA%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EExtrinsic%20Motivation%3C/span%3E%3Cspan%3E%20%E7%94%B1%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%96%E9%83%A8%E5%A5%96%E5%8A%B1%3C/span%3E%3Cspan%3E%E9%A9%B1%E5%8A%A8%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%E3%80%8C%E4%B8%BA%E4%BA%86%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A5%96%E9%87%91%E5%AE%8C%E6%88%90%E9%94%80%E5%94%AE%E7%9B%AE%E6%A0%87%3C/span%3E%3Cspan%3E%E3%80%8D%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E9%87%91%E9%92%B1%E3%80%81%E5%90%8D%E5%A3%B0%E3%80%81%E6%88%90%E7%BB%A9%E3%80%81%E8%B5%9E%E6%89%AC%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="五大核心动机理论 Five Key Theories" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BA%94%E5%A4%A7%E6%A0%B8%E5%BF%83%E5%8A%A8%E6%9C%BA%E7%90%86%E8%AE%BA%20Five%20Key%20Theories%3C/span%3E" _note="" _mubu_note="">
          <outline text="本能理论 Instinct Theory 源自进化视角，认为行为由先天、固定的模式驱动「母性本能」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%9C%AC%E8%83%BD%E7%90%86%E8%AE%BA%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EInstinct%20Theory%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E6%BA%90%E8%87%AA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%BF%9B%E5%8C%96%E8%A7%86%E8%A7%92%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%AE%A4%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A1%8C%E4%B8%BA%E7%94%B1%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%85%88%E5%A4%A9%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%9B%BA%E5%AE%9A%3C/span%3E%3Cspan%3E%E7%9A%84%E6%A8%A1%E5%BC%8F%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%A9%B1%E5%8A%A8%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%AF%8D%E6%80%A7%E6%9C%AC%E8%83%BD%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="驱力降低理论 Drive Reduction Theory 核心目标是维持稳态 Homeostasis（身体保持内部平衡）。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%A9%B1%E5%8A%9B%E9%99%8D%E4%BD%8E%E7%90%86%E8%AE%BA%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EDrive%20Reduction%20Theory%3C/span%3E%3Cspan%3E%20%E6%A0%B8%E5%BF%83%E7%9B%AE%E6%A0%87%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%BB%B4%E6%8C%81%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E7%A8%B3%E6%80%81%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3EHomeostasis%3C/span%3E%3Cspan%3E%EF%BC%88%E8%BA%AB%E4%BD%93%E4%BF%9D%E6%8C%81%E5%86%85%E9%83%A8%E5%B9%B3%E8%A1%A1%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note="">
            <outline text="过程：生理缺陷产生需要 Need → 产生驱力 Drive → 产生降低驱力的行为「口渴→想喝水→喝水」" _mubu_text="%3Cspan%3E%E8%BF%87%E7%A8%8B%EF%BC%9A%E7%94%9F%E7%90%86%E7%BC%BA%E9%99%B7%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BA%A7%E7%94%9F%3C/span%3E%3Cspan%3E%E9%9C%80%E8%A6%81%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3ENeed%20%3C/span%3E%3Cspan%3E%E2%86%92%20%E4%BA%A7%E7%94%9F%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%A9%B1%E5%8A%9B%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EDrive%20%3C/span%3E%3Cspan%3E%E2%86%92%20%E4%BA%A7%E7%94%9F%3C/span%3E%3Cspan%20class=%22underline%22%3E%E9%99%8D%E4%BD%8E%E9%A9%B1%E5%8A%9B%3C/span%3E%3Cspan%3E%E7%9A%84%E8%A1%8C%E4%B8%BA%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%8F%A3%E6%B8%B4%E2%86%92%E6%83%B3%E5%96%9D%E6%B0%B4%E2%86%92%E5%96%9D%E6%B0%B4%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="唤醒理论 Arousal Theory 个体被激发出维持最佳唤醒水平 Optimal level of arousal" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%94%A4%E9%86%92%E7%90%86%E8%AE%BA%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EArousal%20Theory%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E4%B8%AA%E4%BD%93%E8%A2%AB%E6%BF%80%E5%8F%91%E5%87%BA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%BB%B4%E6%8C%81%3C/span%3E%3Cspan%20class=%22bold%20underline%22%3E%E6%9C%80%E4%BD%B3%E5%94%A4%E9%86%92%E6%B0%B4%E5%B9%B3%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3EOptimal%20level%20of%20arousal%3C/span%3E" _note="" _mubu_note="">
            <outline text="唤醒太低会寻求增加，太高则寻求减少" _mubu_text="%3Cspan%3E%E5%94%A4%E9%86%92%E5%A4%AA%E4%BD%8E%E4%BC%9A%E5%AF%BB%E6%B1%82%E5%A2%9E%E5%8A%A0%EF%BC%8C%E5%A4%AA%E9%AB%98%E5%88%99%E5%AF%BB%E6%B1%82%E5%87%8F%E5%B0%91%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="耶克斯-多德森定律 Yerkes-Dodson Law 表现随唤醒增加而提升，但仅限于一定限度。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%80%B6%E5%85%8B%E6%96%AF-%E5%A4%9A%E5%BE%B7%E6%A3%AE%E5%AE%9A%E5%BE%8B%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EYerkes-Dodson%20Law%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A1%A8%E7%8E%B0%3C/span%3E%3Cspan%3E%E9%9A%8F%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%94%A4%E9%86%92%E5%A2%9E%E5%8A%A0%3C/span%3E%3Cspan%3E%E8%80%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8F%90%E5%8D%87%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BD%86%E4%BB%85%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%99%90%E4%BA%8E%E4%B8%80%E5%AE%9A%E9%99%90%E5%BA%A6%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note="">
              <outline text="困难/新任务在较低唤醒水平下表现更好；" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E5%9B%B0%E9%9A%BE/%E6%96%B0%E4%BB%BB%E5%8A%A1%3C/span%3E%3Cspan%3E%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%BE%83%E4%BD%8E%E5%94%A4%E9%86%92%3C/span%3E%3Cspan%3E%E6%B0%B4%E5%B9%B3%E4%B8%8B%3C/span%3E%3Cspan%20class=%22underline%22%3E%E8%A1%A8%E7%8E%B0%E6%9B%B4%E5%A5%BD%3C/span%3E%3Cspan%3E%EF%BC%9B%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="简单/熟练任务在较高唤醒水平下表现更好" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E7%AE%80%E5%8D%95/%E7%86%9F%E7%BB%83%E4%BB%BB%E5%8A%A1%3C/span%3E%3Cspan%3E%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%BE%83%E9%AB%98%E5%94%A4%E9%86%92%3C/span%3E%3Cspan%3E%E6%B0%B4%E5%B9%B3%E4%B8%8B%3C/span%3E%3Cspan%20class=%22underline%22%3E%E8%A1%A8%E7%8E%B0%E6%9B%B4%E5%A5%BD%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="「考试适度紧张有助于发挥，但过度紧张会失常」" _mubu_text="%3Cspan%3E%E3%80%8C%E8%80%83%E8%AF%95%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%80%82%E5%BA%A6%E7%B4%A7%E5%BC%A0%3C/span%3E%3Cspan%3E%E6%9C%89%E5%8A%A9%E4%BA%8E%E5%8F%91%E6%8C%A5%EF%BC%8C%E4%BD%86%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%BF%87%E5%BA%A6%E7%B4%A7%E5%BC%A0%3C/span%3E%3Cspan%3E%E4%BC%9A%E5%A4%B1%E5%B8%B8%E3%80%8D%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22auBwSgpHVJ%22%2C%22oh%22%3A575%2C%22ow%22%3A916%2C%22uri%22%3A%22document_image%2F33585682_c6f50241-76e8-4347-a5ed-eebf05b07af6.png%22%2C%22w%22%3A400%7D%5D"/>
            </outline>
          </outline>
          <outline text="寻求刺激理论 Sensation-Seeking Theory 每个人对新颖、复杂和强烈刺激的需求水平不同" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%AF%BB%E6%B1%82%E5%88%BA%E6%BF%80%E7%90%86%E8%AE%BA%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESensation-Seeking%20Theory%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E6%AF%8F%E4%B8%AA%E4%BA%BA%E5%AF%B9%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%96%B0%E9%A2%96%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%8D%E6%9D%82%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BC%BA%E7%83%88%E5%88%BA%E6%BF%80%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%9C%80%E6%B1%82%E6%B0%B4%E5%B9%B3%E4%B8%8D%E5%90%8C%3C/span%3E" _note="" _mubu_note="">
            <outline text="经验寻求 Experience-Seeking 享受多样化和新颖的身体活动及生活探索「旅行」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%BB%8F%E9%AA%8C%E5%AF%BB%E6%B1%82%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EExperience-Seeking%3C/span%3E%3Cspan%3E%20%E4%BA%AB%E5%8F%97%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%9A%E6%A0%B7%E5%8C%96%E5%92%8C%E6%96%B0%E9%A2%96%3C/span%3E%3Cspan%3E%E7%9A%84%E8%BA%AB%E4%BD%93%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%B4%BB%E5%8A%A8%3C/span%3E%3Cspan%3E%E5%8F%8A%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%94%9F%E6%B4%BB%3C/span%3E%3Cspan%3E%E6%8E%A2%E7%B4%A2%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%97%85%E8%A1%8C%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="惊险与冒险寻求 Thrill and Adventure Seeking 参与令人兴奋的、通常涉及风险的体验 「跳伞」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%83%8A%E9%99%A9%E4%B8%8E%E5%86%92%E9%99%A9%E5%AF%BB%E6%B1%82%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EThrill%20and%20Adventure%20Seeking%3C/span%3E%3Cspan%3E%20%E5%8F%82%E4%B8%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BB%A4%E4%BA%BA%E5%85%B4%E5%A5%8B%3C/span%3E%3Cspan%3E%E7%9A%84%E3%80%81%E9%80%9A%E5%B8%B8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%B6%89%E5%8F%8A%E9%A3%8E%E9%99%A9%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%BD%93%E9%AA%8C%3C/span%3E%3Cspan%3E%20%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%B7%B3%E4%BC%9E%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="去抑制 Disinhibition 通过参与通常受社会规范约束的行为来寻求社交刺激 「派对」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8E%BB%E6%8A%91%E5%88%B6%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EDisinhibition%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E9%80%9A%E8%BF%87%E5%8F%82%E4%B8%8E%E9%80%9A%E5%B8%B8%E5%8F%97%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%A4%BE%E4%BC%9A%E8%A7%84%E8%8C%83%E7%BA%A6%3C/span%3E%3Cspan%3E%E6%9D%9F%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%E6%9D%A5%E5%AF%BB%E6%B1%82%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%A4%BE%E4%BA%A4%E5%88%BA%E6%BF%80%3C/span%3E%3Cspan%3E%20%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B4%BE%E5%AF%B9%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="枯燥敏感性 Boredom Susceptibility 对重复、单调或可预测情况的不耐受「辞去稳定工作」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%9E%AF%E7%87%A5%E6%95%8F%E6%84%9F%E6%80%A7%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EBoredom%20Susceptibility%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E5%AF%B9%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%87%8D%E5%A4%8D%E3%80%81%E5%8D%95%E8%B0%83%3C/span%3E%3Cspan%3E%E6%88%96%E5%8F%AF%E9%A2%84%E6%B5%8B%E6%83%85%E5%86%B5%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%B8%8D%E8%80%90%E5%8F%97%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%BE%9E%E5%8E%BB%E7%A8%B3%E5%AE%9A%E5%B7%A5%E4%BD%9C%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="自我决定理论 Self-Determination Theory 关注人类行为的动机，强调诱因 Incentive 的作用，外部环境刺激吸引我们采取行动「看到美食图片而产生食欲」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E6%88%91%E5%86%B3%E5%AE%9A%E7%90%86%E8%AE%BA%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESelf-Determination%20Theory%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%85%B3%E6%B3%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BA%BA%E7%B1%BB%E8%A1%8C%E4%B8%BA%E7%9A%84%E5%8A%A8%E6%9C%BA%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%BC%BA%E8%B0%83%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%AF%B1%E5%9B%A0%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22underline%22%3EIncentive%3C/span%3E%3Cspan%3E%20%E7%9A%84%E4%BD%9C%E7%94%A8%EF%BC%8C%E5%A4%96%E9%83%A8%E7%8E%AF%E5%A2%83%E5%88%BA%E6%BF%80%E5%90%B8%E5%BC%95%E6%88%91%E4%BB%AC%E9%87%87%E5%8F%96%E8%A1%8C%E5%8A%A8%E3%80%8C%E7%9C%8B%E5%88%B0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%BE%8E%E9%A3%9F%E5%9B%BE%E7%89%87%3C/span%3E%3Cspan%3E%E8%80%8C%E4%BA%A7%E7%94%9F%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%A3%9F%E6%AC%B2%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="动机冲突 Motivational Conflicts" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8A%A8%E6%9C%BA%E5%86%B2%E7%AA%81%20Motivational%20Conflicts%3C/span%3E" _note="" _mubu_note="">
          <outline text="双趋冲突 Approach-Approach Conflict 在两个同样吸引人的目标之间做选择「清华还是北大」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8F%8C%E8%B6%8B%E5%86%B2%E7%AA%81%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EApproach-Approach%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EConflict%3C/span%3E%3Cspan%3E%20%E5%9C%A8%E4%B8%A4%E4%B8%AA%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%90%8C%E6%A0%B7%E5%90%B8%E5%BC%95%E4%BA%BA%3C/span%3E%3Cspan%3E%E7%9A%84%E7%9B%AE%E6%A0%87%E4%B9%8B%E9%97%B4%E5%81%9A%E9%80%89%E6%8B%A9%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B8%85%E5%8D%8E%E8%BF%98%E6%98%AF%E5%8C%97%E5%A4%A7%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="双避冲突 Avoidance-Avoidance Conflict 在两个同样不想要的选择之间做决定「补作业还是请家长」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8F%8C%E9%81%BF%E5%86%B2%E7%AA%81%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EAvoidance-Avoidance%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EConflict%3C/span%3E%3Cspan%3E%20%E5%9C%A8%E4%B8%A4%E4%B8%AA%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%90%8C%E6%A0%B7%E4%B8%8D%E6%83%B3%E8%A6%81%3C/span%3E%3Cspan%3E%E7%9A%84%E9%80%89%E6%8B%A9%E4%B9%8B%E9%97%B4%E5%81%9A%E5%86%B3%E5%AE%9A%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%A1%A5%E4%BD%9C%E4%B8%9A%3C/span%3E%3Cspan%3E%E8%BF%98%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%AF%B7%E5%AE%B6%E9%95%BF%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="趋避冲突 Approach-Avoidance Conflict 面对同一个既有优点又有缺点的目标时产生的纠结「既想减肥又想吃甜食」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%B6%8B%E9%81%BF%E5%86%B2%E7%AA%81%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EApproach-Avoidance%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EConflict%3C/span%3E%3Cspan%3E%20%E9%9D%A2%E5%AF%B9%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-yellow%22%3E%E5%90%8C%E4%B8%80%E4%B8%AA%3C/span%3E%3Cspan%3E%E6%97%A2%E6%9C%89%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BC%98%E7%82%B9%E5%8F%88%E6%9C%89%E7%BC%BA%E7%82%B9%3C/span%3E%3Cspan%3E%E7%9A%84%E7%9B%AE%E6%A0%87%E6%97%B6%E4%BA%A7%E7%94%9F%E7%9A%84%E7%BA%A0%E7%BB%93%E3%80%8C%E6%97%A2%E6%83%B3%E5%87%8F%E8%82%A5%E5%8F%88%E6%83%B3%E5%90%83%E7%94%9C%E9%A3%9F%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="饥饿动机 Hunger Motivation" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%A5%A5%E9%A5%BF%E5%8A%A8%E6%9C%BA%20Hunger%20Motivation%3C/span%3E" _note="" _mubu_note="">
          <outline text="生理因素" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%94%9F%E7%90%86%E5%9B%A0%E7%B4%A0%3C/span%3E" _note="" _mubu_note="">
            <outline text="下丘脑 Hypothalamus 大部分饥饿感源于此，控制脑垂体分泌激素" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%B8%8B%E4%B8%98%E8%84%91%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EHypothalamus%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%A4%A7%E9%83%A8%E5%88%86%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%A5%A5%E9%A5%BF%E6%84%9F%3C/span%3E%3Cspan%3E%E6%BA%90%E4%BA%8E%E6%AD%A4%EF%BC%8C%E6%8E%A7%E5%88%B6%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%84%91%E5%9E%82%E4%BD%93%E5%88%86%E6%B3%8C%E6%BF%80%E7%B4%A0%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="饥饿素 Ghrelin 由空胃分泌，向大脑发送&quot;我饿了&quot;的信号" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%A5%A5%E9%A5%BF%E7%B4%A0%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EGhrelin%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E7%94%B1%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%A9%BA%E8%83%83%3C/span%3E%3Cspan%3E%E5%88%86%E6%B3%8C%EF%BC%8C%E5%90%91%E5%A4%A7%E8%84%91%E5%8F%91%E9%80%81%22%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%88%91%E9%A5%BF%E4%BA%86%3C/span%3E%3Cspan%3E%22%E7%9A%84%E4%BF%A1%E5%8F%B7%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="瘦素 Leptin 由脂肪细胞产生，抑制饥饿感，调节能量平衡" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%98%A6%E7%B4%A0%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ELeptin%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E7%94%B1%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%84%82%E8%82%AA%E7%BB%86%E8%83%9E%3C/span%3E%3Cspan%3E%E4%BA%A7%E7%94%9F%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8A%91%E5%88%B6%E9%A5%A5%E9%A5%BF%E6%84%9F%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%B0%83%E8%8A%82%E8%83%BD%E9%87%8F%E5%B9%B3%E8%A1%A1%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="心理与环境因素" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BF%83%E7%90%86%E4%B8%8E%E7%8E%AF%E5%A2%83%E5%9B%A0%E7%B4%A0%3C/span%3E" _note="" _mubu_note="">
            <outline text="奖励中心 Reward Center 进食等行为促使腹侧被盖区 VTA 释放多巴胺 Dopamine，产生愉悦感，驱动我们再次寻求该体验「心情不好时想吃甜食」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%A5%96%E5%8A%B1%E4%B8%AD%E5%BF%83%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EReward%20Center%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E8%BF%9B%E9%A3%9F%E7%AD%89%E8%A1%8C%E4%B8%BA%E4%BF%83%E4%BD%BF%E8%85%B9%E4%BE%A7%E8%A2%AB%E7%9B%96%E5%8C%BA%20VTA%20%E9%87%8A%E6%94%BE%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%A4%9A%E5%B7%B4%E8%83%BA%20Dopamine%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BA%A7%E7%94%9F%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%84%89%E6%82%A6%E6%84%9F%3C/span%3E%3Cspan%3E%EF%BC%8C%E9%A9%B1%E5%8A%A8%E6%88%91%E4%BB%AC%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E5%86%8D%E6%AC%A1%E5%AF%BB%E6%B1%82%E8%AF%A5%E4%BD%93%E9%AA%8C%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BF%83%E6%83%85%E4%B8%8D%E5%A5%BD%E6%97%B6%E6%83%B3%E5%90%83%E7%94%9C%E9%A3%9F%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="外部线索 External Cues 一天中的时间、食物气味、文化背景和宗教价值观等「到饭点就饿」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%A4%96%E9%83%A8%E7%BA%BF%E7%B4%A2%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EExternal%20Cues%3C/span%3E%3Cspan%3E%20%E4%B8%80%E5%A4%A9%E4%B8%AD%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%97%B6%E9%97%B4%3C/span%3E%3Cspan%3E%E3%80%81%E9%A3%9F%E7%89%A9%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%B0%94%E5%91%B3%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%96%87%E5%8C%96%E8%83%8C%E6%99%AF%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%AE%97%E6%95%99%E4%BB%B7%E5%80%BC%E8%A7%82%3C/span%3E%3Cspan%3E%E7%AD%89%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%88%B0%E9%A5%AD%E7%82%B9%E5%B0%B1%E9%A5%BF%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
      </outline>
      <outline text="4.7 Emotion" _mubu_text="%3Cspan%3E4.7%20Emotion%3C/span%3E" _note="" _mubu_note="">
        <outline text="情绪基础 Emotion Basics" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%83%85%E7%BB%AA%E5%9F%BA%E7%A1%80%20Emotion%20Basics%3C/span%3E" _note="" _mubu_note="">
          <outline text="情绪/情感 Emotion / Affect 整个有机体的反应，涉及生理唤醒、表达行为和意识体验" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%83%85%E7%BB%AA/%E6%83%85%E6%84%9F%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%20Emotion%20/%20Affect%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E6%95%B4%E4%B8%AA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9C%89%E6%9C%BA%E4%BD%93%3C/span%3E%3Cspan%3E%E7%9A%84%E5%8F%8D%E5%BA%94%EF%BC%8C%E6%B6%89%E5%8F%8A%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%94%9F%E7%90%86%E5%94%A4%E9%86%92%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%A1%A8%E8%BE%BE%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%84%8F%E8%AF%86%E4%BD%93%E9%AA%8C%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="情绪的三大成分 Components of Emotion：" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%83%85%E7%BB%AA%E7%9A%84%E4%B8%89%E5%A4%A7%E6%88%90%E5%88%86%20Components%20of%20Emotion%3C/span%3E%3Cspan%3E%EF%BC%9A%3C/span%3E" _note="" _mubu_note="">
            <outline text="生理唤醒 Physiological arousal 如心跳加快、出汗「身体的自动反应」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%94%9F%E7%90%86%E5%94%A4%E9%86%92%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EPhysiological%20arousal%3C/span%3E%3Cspan%3E%20%E5%A6%82%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BF%83%E8%B7%B3%E5%8A%A0%E5%BF%AB%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%87%BA%E6%B1%97%3C/span%3E%3Cspan%3E%E3%80%8C%E8%BA%AB%E4%BD%93%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E8%87%AA%E5%8A%A8%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="表达行为 Expressive behaviors 如快步走、面部表情「外在的行为表现」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A1%A8%E8%BE%BE%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EExpressive%20behaviors%3C/span%3E%3Cspan%3E%20%E5%A6%82%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BF%AB%E6%AD%A5%E8%B5%B0%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%9D%A2%E9%83%A8%E8%A1%A8%E6%83%85%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E5%A4%96%E5%9C%A8%E7%9A%84%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%E8%A1%A8%E7%8E%B0%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="意识体验 Conscious experience 包括想法（“我在危险中”）和感觉（恐惧）「主观的心理觉察」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%84%8F%E8%AF%86%E4%BD%93%E9%AA%8C%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EConscious%20experience%3C/span%3E%3Cspan%3E%20%E5%8C%85%E6%8B%AC%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%B3%E6%B3%95%3C/span%3E%3Cspan%3E%EF%BC%88%E2%80%9C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%88%91%E5%9C%A8%E5%8D%B1%E9%99%A9%E4%B8%AD%3C/span%3E%3Cspan%3E%E2%80%9D%EF%BC%89%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%84%9F%E8%A7%89%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%81%90%E6%83%A7%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%8C%E4%B8%BB%E8%A7%82%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E5%BF%83%E7%90%86%E8%A7%89%E5%AF%9F%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text=" 普遍情绪与诱因 Universal Emotions &amp; Elicitors" _mubu_text="%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%99%AE%E9%81%8D%E6%83%85%E7%BB%AA%E4%B8%8E%E8%AF%B1%E5%9B%A0%20Universal%20Emotions%20&amp;amp;%20Elicitors%3C/span%3E" _note="" _mubu_note="">
          <outline text="普遍情绪 Universal Emotions 跨文化通用的基本情绪表达「无论在哪个国家，笑容都代表快乐」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%99%AE%E9%81%8D%E6%83%85%E7%BB%AA%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EUniversal%20Emotions%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%B7%A8%E6%96%87%E5%8C%96%3C/span%3E%3Cspan%3E%E9%80%9A%E7%94%A8%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%9F%BA%E6%9C%AC%E6%83%85%E7%BB%AA%E8%A1%A8%E8%BE%BE%3C/span%3E%3Cspan%3E%E3%80%8C%E6%97%A0%E8%AE%BA%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%93%AA%E4%B8%AA%E5%9B%BD%E5%AE%B6%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%AC%91%E5%AE%B9%3C/span%3E%3Cspan%3E%E9%83%BD%E4%BB%A3%E8%A1%A8%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BF%AB%E4%B9%90%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="愤怒 Anger、恐惧 Fear、厌恶 Disgust、快乐 Happiness、悲伤 Sadness、惊讶 Surprise。" _mubu_text="%3Cspan%3E%E6%84%A4%E6%80%92%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EAnger%3C/span%3E%3Cspan%3E%E3%80%81%E6%81%90%E6%83%A7%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EFear%3C/span%3E%3Cspan%3E%E3%80%81%E5%8E%8C%E6%81%B6%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EDisgust%3C/span%3E%3Cspan%3E%E3%80%81%E5%BF%AB%E4%B9%90%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EHappiness%3C/span%3E%3Cspan%3E%E3%80%81%E6%82%B2%E4%BC%A4%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3ESadness%3C/span%3E%3Cspan%3E%E3%80%81%E6%83%8A%E8%AE%B6%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3ESurprise%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="情绪诱因 Emotion Elicitors 触发情绪反应的刺激或事件「蛇是恐惧的诱因；礼物是快乐的诱因」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%83%85%E7%BB%AA%E8%AF%B1%E5%9B%A0%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EEmotion%20Elicitors%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E8%A7%A6%E5%8F%91%E6%83%85%E7%BB%AA%E5%8F%8D%E5%BA%94%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%88%BA%E6%BF%80%E6%88%96%E4%BA%8B%E4%BB%B6%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%9B%87%3C/span%3E%3Cspan%3E%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%81%90%E6%83%A7%3C/span%3E%3Cspan%3E%E7%9A%84%E8%AF%B1%E5%9B%A0%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%A4%BC%E7%89%A9%3C/span%3E%3Cspan%3E%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BF%AB%E4%B9%90%3C/span%3E%3Cspan%3E%E7%9A%84%E8%AF%B1%E5%9B%A0%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="诱因会受到性别、年龄和文化背景的影响，调节人们如何展示和解读情绪。" _mubu_text="%3Cspan%3E%E8%AF%B1%E5%9B%A0%E4%BC%9A%E5%8F%97%E5%88%B0%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%80%A7%E5%88%AB%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%B9%B4%E9%BE%84%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%96%87%E5%8C%96%3C/span%3E%3Cspan%3E%E8%83%8C%E6%99%AF%E7%9A%84%E5%BD%B1%E5%93%8D%EF%BC%8C%E8%B0%83%E8%8A%82%E4%BA%BA%E4%BB%AC%E5%A6%82%E4%BD%95%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%B1%95%E7%A4%BA%E5%92%8C%E8%A7%A3%E8%AF%BB%E6%83%85%E7%BB%AA%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="核心情绪理论 Theories of Emotion 争论的焦点" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A0%B8%E5%BF%83%E6%83%85%E7%BB%AA%E7%90%86%E8%AE%BA%20Theories%20of%20Emotion%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22underline%22%3E%E4%BA%89%E8%AE%BA%E7%9A%84%E7%84%A6%E7%82%B9%3C/span%3E" _note="" _mubu_note="">
          <outline text="詹姆斯-兰格理论 James-Lange Theory" _mubu_text="%3Cspan%20class=%22bold%20strikethrough%22%3E%E8%A9%B9%E5%A7%86%E6%96%AF-%E5%85%B0%E6%A0%BC%E7%90%86%E8%AE%BA%20James-Lange%20Theory%3C/span%3E" _note="" _mubu_note="">
            <outline text="观点：生理唤醒先于情绪产生，情绪是对生理反应的觉知。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A7%82%E7%82%B9%3C/span%3E%3Cspan%3E%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%94%9F%E7%90%86%E5%94%A4%E9%86%92%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E5%85%88%E4%BA%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E7%BB%AA%E4%BA%A7%E7%94%9F%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%83%85%E7%BB%AA%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%AF%B9%E7%94%9F%E7%90%86%E5%8F%8D%E5%BA%94%E7%9A%84%E8%A7%89%E7%9F%A5%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="逻辑：刺激 → 生理唤醒 → 情绪「因为哭泣所以感到悲伤；因为发抖所以感到害怕」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%80%BB%E8%BE%91%3C/span%3E%3Cspan%3E%EF%BC%9A%3C/span%3E%3Cspan%20class=%22underline%22%3E%E5%88%BA%E6%BF%80%20%E2%86%92%20%E7%94%9F%E7%90%86%E5%94%A4%E9%86%92%20%E2%86%92%20%E6%83%85%E7%BB%AA%3C/span%3E%3Cspan%3E%E3%80%8C%E5%9B%A0%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%93%AD%E6%B3%A3%E6%89%80%E4%BB%A5%E6%84%9F%E5%88%B0%E6%82%B2%E4%BC%A4%3C/span%3E%3Cspan%3E%EF%BC%9B%E5%9B%A0%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%8F%91%E6%8A%96%E6%89%80%E4%BB%A5%E6%84%9F%E5%88%B0%E5%AE%B3%E6%80%95%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="坎农-巴德理论 Cannon-Bard Theory" _mubu_text="%3Cspan%20class=%22bold%20strikethrough%22%3E%E5%9D%8E%E5%86%9C-%E5%B7%B4%E5%BE%B7%E7%90%86%E8%AE%BA%20Cannon-Bard%20Theory%3C/span%3E" _note="" _mubu_note="">
            <outline text="观点：生理唤醒与情绪体验是同时发生且相互独立的。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A7%82%E7%82%B9%3C/span%3E%3Cspan%3E%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%94%9F%E7%90%86%E5%94%A4%E9%86%92%3C/span%3E%3Cspan%3E%E4%B8%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E7%BB%AA%E4%BD%93%E9%AA%8C%3C/span%3E%3Cspan%3E%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E5%90%8C%E6%97%B6%E5%8F%91%E7%94%9F%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%B8%94%E7%9B%B8%E4%BA%92%E7%8B%AC%E7%AB%8B%3C/span%3E%3Cspan%3E%E7%9A%84%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="逻辑：刺激 → 丘脑发送信号 → 生理唤醒 + 情绪体验（同步进行）「看到熊时，心跳加速和感到恐惧是同时发生的，两者没有先后之分」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%80%BB%E8%BE%91%3C/span%3E%3Cspan%3E%EF%BC%9A%3C/span%3E%3Cspan%20class=%22underline%22%3E%E5%88%BA%E6%BF%80%20%E2%86%92%20%E4%B8%98%E8%84%91%E5%8F%91%E9%80%81%E4%BF%A1%E5%8F%B7%20%E2%86%92%20%E7%94%9F%E7%90%86%E5%94%A4%E9%86%92%20+%20%E6%83%85%E7%BB%AA%E4%BD%93%E9%AA%8C%3C/span%3E%3Cspan%3E%EF%BC%88%E5%90%8C%E6%AD%A5%E8%BF%9B%E8%A1%8C%EF%BC%89%E3%80%8C%E7%9C%8B%E5%88%B0%E7%86%8A%E6%97%B6%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BF%83%E8%B7%B3%E5%8A%A0%E9%80%9F%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%84%9F%E5%88%B0%E6%81%90%E6%83%A7%E6%98%AF%E5%90%8C%E6%97%B6%E5%8F%91%E7%94%9F%3C/span%3E%3Cspan%3E%E7%9A%84%EF%BC%8C%E4%B8%A4%E8%80%85%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E6%B2%A1%E6%9C%89%E5%85%88%E5%90%8E%E4%B9%8B%E5%88%86%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="沙赫特-辛格双因素理论 Schachter-Singer Two-Factor Theory" _mubu_text="%3Cspan%20class=%22bold%20strikethrough%22%3E%E6%B2%99%E8%B5%AB%E7%89%B9-%E8%BE%9B%E6%A0%BC%E5%8F%8C%E5%9B%A0%E7%B4%A0%E7%90%86%E8%AE%BA%20Schachter-Singer%20Two-Factor%20Theory%3C/span%3E" _note="" _mubu_note="">
            <outline text="观点：情绪由生理唤醒和认知标签 Cognitive Label 共同决定。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A7%82%E7%82%B9%3C/span%3E%3Cspan%3E%EF%BC%9A%E6%83%85%E7%BB%AA%E7%94%B1%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%94%9F%E7%90%86%E5%94%A4%E9%86%92%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E8%AE%A4%E7%9F%A5%E6%A0%87%E7%AD%BE%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-yellow%22%3ECognitive%20Label%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%85%B1%E5%90%8C%E5%86%B3%E5%AE%9A%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="逻辑：刺激 → 生理唤醒 + 认知解释 → 情绪「同样是心跳加速，考场=焦虑，过山车=兴奋」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%80%BB%E8%BE%91%3C/span%3E%3Cspan%3E%EF%BC%9A%3C/span%3E%3Cspan%20class=%22underline%22%3E%E5%88%BA%E6%BF%80%20%E2%86%92%20%E7%94%9F%E7%90%86%E5%94%A4%E9%86%92%20+%20%E8%AE%A4%E7%9F%A5%E8%A7%A3%E9%87%8A%20%E2%86%92%20%E6%83%85%E7%BB%AA%3C/span%3E%3Cspan%3E%E3%80%8C%E5%90%8C%E6%A0%B7%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BF%83%E8%B7%B3%E5%8A%A0%E9%80%9F%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%80%83%E5%9C%BA%3C/span%3E%3Cspan%3E=%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%84%A6%E8%99%91%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%BF%87%E5%B1%B1%E8%BD%A6%3C/span%3E%3Cspan%3E=%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%85%B4%E5%A5%8B%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="扎荣茨/勒杜理论 Zajonc / LeDoux Theory" _mubu_text="%3Cspan%20class=%22bold%20strikethrough%22%3E%E6%89%8E%E8%8D%A3%E8%8C%A8/%E5%8B%92%E6%9D%9C%E7%90%86%E8%AE%BA%20Zajonc%20/%20LeDoux%20Theory%3C/span%3E" _note="" _mubu_note="">
            <outline text="观点：某些情绪反应（尤其是恐惧）是瞬时的，不需要经过意识思考。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A7%82%E7%82%B9%3C/span%3E%3Cspan%3E%EF%BC%9A%E6%9F%90%E4%BA%9B%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E7%BB%AA%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%3E%EF%BC%88%E5%B0%A4%E5%85%B6%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%81%90%E6%83%A7%3C/span%3E%3Cspan%3E%EF%BC%89%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%9E%AC%E6%97%B6%3C/span%3E%3Cspan%3E%E7%9A%84%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E4%B8%8D%E9%9C%80%E8%A6%81%E7%BB%8F%E8%BF%87%E6%84%8F%E8%AF%86%E6%80%9D%E8%80%83%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="情绪路径：" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%83%85%E7%BB%AA%E8%B7%AF%E5%BE%84%3C/span%3E%3Cspan%3E%EF%BC%9A%3C/span%3E" _note="" _mubu_note="">
              <outline text="高路 High Road 刺激 → 丘脑 → 大脑皮层 → 杏仁核 涉及复杂的认知评价「那个人在嘲笑我？」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%AB%98%E8%B7%AF%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EHigh%20Road%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%20%3C/span%3E%3Cspan%20class=%22underline%22%3E%E5%88%BA%E6%BF%80%20%E2%86%92%20%E4%B8%98%E8%84%91%20%E2%86%92%20%E5%A4%A7%E8%84%91%E7%9A%AE%E5%B1%82%20%E2%86%92%20%E6%9D%8F%E4%BB%81%E6%A0%B8%3C/span%3E%3Cspan%3E%20%E6%B6%89%E5%8F%8A%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%A4%8D%E6%9D%82%E7%9A%84%E8%AE%A4%E7%9F%A5%E8%AF%84%E4%BB%B7%3C/span%3E%3Cspan%3E%E3%80%8C%E9%82%A3%E4%B8%AA%E4%BA%BA%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%98%B2%E7%AC%91%E6%88%91%3C/span%3E%3Cspan%3E%EF%BC%9F%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="低路 Low Road 刺激 → 丘脑 → 杏仁核 跳过皮层直接反应「看到草丛里的绳子先跳开」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BD%8E%E8%B7%AF%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3ELow%20Road%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%20%3C/span%3E%3Cspan%20class=%22underline%22%3E%E5%88%BA%E6%BF%80%20%E2%86%92%20%E4%B8%98%E8%84%91%20%E2%86%92%20%E6%9D%8F%E4%BB%81%E6%A0%B8%3C/span%3E%3Cspan%3E%20%E8%B7%B3%E8%BF%87%E7%9A%AE%E5%B1%82%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%9B%B4%E6%8E%A5%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%3E%E3%80%8C%E7%9C%8B%E5%88%B0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%8D%89%E4%B8%9B%E9%87%8C%E7%9A%84%E7%BB%B3%E5%AD%90%3C/span%3E%3Cspan%3E%E5%85%88%E8%B7%B3%E5%BC%80%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="拉扎勒斯认知评价理论 Lazarus Cognitive Appraisal Theory" _mubu_text="%3Cspan%20class=%22bold%20strikethrough%22%3E%E6%8B%89%E6%89%8E%E5%8B%92%E6%96%AF%E8%AE%A4%E7%9F%A5%E8%AF%84%E4%BB%B7%E7%90%86%E8%AE%BA%20Lazarus%20Cognitive%20Appraisal%20Theory%3C/span%3E" _note="" _mubu_note="">
            <outline text="观点：认知评价（判断事件对我们的意义）发生在情绪和生理反应之前。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A7%82%E7%82%B9%3C/span%3E%3Cspan%3E%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%AE%A4%E7%9F%A5%E8%AF%84%E4%BB%B7%3C/span%3E%3Cspan%3E%EF%BC%88%E5%88%A4%E6%96%AD%E4%BA%8B%E4%BB%B6%E5%AF%B9%E6%88%91%E4%BB%AC%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E6%84%8F%E4%B9%89%3C/span%3E%3Cspan%3E%EF%BC%89%E5%8F%91%E7%94%9F%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E7%BB%AA%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%94%9F%E7%90%86%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%B9%8B%E5%89%8D%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="逻辑：刺激 → 认知评价 → 情绪 + 生理唤醒「你对考试的定义是‘威胁’还是‘挑战’，决定了你后续的情绪反应」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%80%BB%E8%BE%91%3C/span%3E%3Cspan%3E%EF%BC%9A%3C/span%3E%3Cspan%20class=%22underline%22%3E%E5%88%BA%E6%BF%80%20%E2%86%92%20%E8%AE%A4%E7%9F%A5%E8%AF%84%E4%BB%B7%20%E2%86%92%20%E6%83%85%E7%BB%AA%20+%20%E7%94%9F%E7%90%86%E5%94%A4%E9%86%92%3C/span%3E%3Cspan%3E%E3%80%8C%E4%BD%A0%E5%AF%B9%E8%80%83%E8%AF%95%E7%9A%84%E5%AE%9A%E4%B9%89%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E2%80%98%E5%A8%81%E8%83%81%E2%80%99%E8%BF%98%E6%98%AF%E2%80%98%E6%8C%91%E6%88%98%E2%80%99%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%86%B3%E5%AE%9A%E4%BA%86%E4%BD%A0%E5%90%8E%E7%BB%AD%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%83%85%E7%BB%AA%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="情绪的生物学与表达 Biology &amp; Expression" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%83%85%E7%BB%AA%E7%9A%84%E7%94%9F%E7%89%A9%E5%AD%A6%E4%B8%8E%E8%A1%A8%E8%BE%BE%20Biology%20&amp;amp;%20Expression%3C/span%3E" _note="" _mubu_note="">
          <outline text="杏仁核 Amygdala 大脑中处理情绪（尤其是恐惧和攻击性）的关键中心「大脑的‘报警系统’」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%9D%8F%E4%BB%81%E6%A0%B8%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EAmygdala%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%A4%A7%E8%84%91%E4%B8%AD%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%84%E7%90%86%E6%83%85%E7%BB%AA%3C/span%3E%3Cspan%3E%EF%BC%88%E5%B0%A4%E5%85%B6%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%81%90%E6%83%A7%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%94%BB%E5%87%BB%E6%80%A7%3C/span%3E%3Cspan%3E%EF%BC%89%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%85%B3%E9%94%AE%E4%B8%AD%E5%BF%83%3C/span%3E%3Cspan%3E%E3%80%8C%E5%A4%A7%E8%84%91%E7%9A%84%E2%80%98%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E6%8A%A5%E8%AD%A6%E7%B3%BB%E7%BB%9F%3C/span%3E%3Cspan%3E%E2%80%99%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="非言语交流 Nonverbal Communication 通过面部表情、手势、语调和身体语言传递情感「虽然嘴上说没事，但紧锁的眉头暴露了情绪」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%9D%9E%E8%A8%80%E8%AF%AD%E4%BA%A4%E6%B5%81%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ENonverbal%20Communication%3C/span%3E%3Cspan%3E%20%E9%80%9A%E8%BF%87%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%9D%A2%E9%83%A8%E8%A1%A8%E6%83%85%E3%80%81%E6%89%8B%E5%8A%BF%E3%80%81%E8%AF%AD%E8%B0%83%E5%92%8C%E8%BA%AB%E4%BD%93%E8%AF%AD%E8%A8%80%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%BC%A0%E9%80%92%E6%83%85%E6%84%9F%3C/span%3E%3Cspan%3E%E3%80%8C%E8%99%BD%E7%84%B6%E5%98%B4%E4%B8%8A%E8%AF%B4%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B2%A1%E4%BA%8B%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BD%86%E7%B4%A7%E9%94%81%E7%9A%84%E7%9C%89%E5%A4%B4%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%9A%B4%E9%9C%B2%E4%BA%86%E6%83%85%E7%BB%AA%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="显示规则 Display Rules 不同文化对于在何时、何地、向谁展示情绪的社会规范「有些文化提倡喜形于色，有些则提倡情绪内敛」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%98%BE%E7%A4%BA%E8%A7%84%E5%88%99%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EDisplay%20Rules%3C/span%3E%3Cspan%3E%20%E4%B8%8D%E5%90%8C%E6%96%87%E5%8C%96%E5%AF%B9%E4%BA%8E%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BD%95%E6%97%B6%E3%80%81%E4%BD%95%E5%9C%B0%E3%80%81%E5%90%91%E8%B0%81%3C/span%3E%3Cspan%3E%E5%B1%95%E7%A4%BA%E6%83%85%E7%BB%AA%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%A4%BE%E4%BC%9A%E8%A7%84%E8%8C%83%3C/span%3E%3Cspan%3E%E3%80%8C%E6%9C%89%E4%BA%9B%E6%96%87%E5%8C%96%E6%8F%90%E5%80%A1%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%96%9C%E5%BD%A2%E4%BA%8E%E8%89%B2%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%9C%89%E4%BA%9B%E5%88%99%E6%8F%90%E5%80%A1%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%83%85%E7%BB%AA%E5%86%85%E6%95%9B%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="面部反馈假设 Facial Feedback Hypothesis 肌肉运动可以触发相应的情绪「即使心情一般，强迫自己微笑也会让你感觉好一点」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%9D%A2%E9%83%A8%E5%8F%8D%E9%A6%88%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-yellow%22%3E%E5%81%87%E8%AE%BE%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EFacial%20Feedback%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-yellow%22%3EHypothesis%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%82%8C%E8%82%89%E8%BF%90%E5%8A%A8%3C/span%3E%3Cspan%3E%E5%8F%AF%E4%BB%A5%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A7%A6%E5%8F%91%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%9B%B8%E5%BA%94%E7%9A%84%E6%83%85%E7%BB%AA%3C/span%3E%3Cspan%3E%E3%80%8C%E5%8D%B3%E4%BD%BF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BF%83%E6%83%85%E4%B8%80%E8%88%AC%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%BC%BA%E8%BF%AB%E8%87%AA%E5%B7%B1%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BE%AE%E7%AC%91%3C/span%3E%3Cspan%3E%E4%B9%9F%E4%BC%9A%E8%AE%A9%E4%BD%A0%E6%84%9F%E8%A7%89%E5%A5%BD%E4%B8%80%E7%82%B9%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
    </outline>
    <outline text="Unit 5" _mubu_text="%3Cspan%3EUnit%205%3C/span%3E" _note="" _mubu_note="">
      <outline text="5.1 Introduction to Health Psychology" _mubu_text="%3Cspan%3E5.1%20Introduction%20to%20Health%20Psychology%3C/span%3E" _note="" _mubu_note="">
        <outline text="健康心理学 Health Psychology 专注于促进健康、预防和治疗疾病的心理学分支" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%81%A5%E5%BA%B7%E5%BF%83%E7%90%86%E5%AD%A6%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EHealth%20Psychology%3C/span%3E%3Cspan%3E%20%E4%B8%93%E6%B3%A8%E4%BA%8E%E4%BF%83%E8%BF%9B%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%81%A5%E5%BA%B7%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%A2%84%E9%98%B2%E5%92%8C%E6%B2%BB%E7%96%97%3C/span%3E%3Cspan%3E%E7%96%BE%E7%97%85%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%BF%83%E7%90%86%E5%AD%A6%E5%88%86%E6%94%AF%3C/span%3E" _note="" _mubu_note="">
          <outline text="关心身体的同时还研究人们在生病时的心理反应、应对方式以及如何改善整个医疗系统" _mubu_text="%3Cspan%3E%E5%85%B3%E5%BF%83%E8%BA%AB%E4%BD%93%E7%9A%84%E5%90%8C%E6%97%B6%E8%BF%98%E7%A0%94%E7%A9%B6%E4%BA%BA%E4%BB%AC%E5%9C%A8%E7%94%9F%E7%97%85%E6%97%B6%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BF%83%E7%90%86%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BA%94%E5%AF%B9%E6%96%B9%E5%BC%8F%3C/span%3E%3Cspan%3E%E4%BB%A5%E5%8F%8A%E5%A6%82%E4%BD%95%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%94%B9%E5%96%84%E6%95%B4%E4%B8%AA%E5%8C%BB%E7%96%97%E7%B3%BB%E7%BB%9F%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="压力 Stress 由 压力源 Stressor 导致的生理和心理紧张状态 长期压力削弱免疫系统" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8E%8B%E5%8A%9B%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EStress%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E7%94%B1%3C/span%3E%3Cspan%20class=%22underline%22%3E%20%E5%8E%8B%E5%8A%9B%E6%BA%90%20Stressor%3C/span%3E%3Cspan%3E%20%E5%AF%BC%E8%87%B4%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%94%9F%E7%90%86%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%83%E7%90%86%3C/span%3E%3Cspan%3E%E7%B4%A7%E5%BC%A0%E7%8A%B6%E6%80%81%20%E9%95%BF%E6%9C%9F%E5%8E%8B%E5%8A%9B%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%89%8A%E5%BC%B1%E5%85%8D%E7%96%AB%E7%B3%BB%E7%BB%9F%3C/span%3E" _note="" _mubu_note="">
          <outline text="良性压力 Eustress 好的压力，由积极事件引起，提供动力，促进幸福「结婚、升职」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%89%AF%E6%80%A7%E5%8E%8B%E5%8A%9B%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EEustress%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22underline%22%3E%E5%A5%BD%E7%9A%84%E5%8E%8B%E5%8A%9B%3C/span%3E%3Cspan%3E%EF%BC%8C%E7%94%B1%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%A7%AF%E6%9E%81%E4%BA%8B%E4%BB%B6%3C/span%3E%3Cspan%3E%E5%BC%95%E8%B5%B7%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8F%90%E4%BE%9B%E5%8A%A8%E5%8A%9B%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BF%83%E8%BF%9B%E5%B9%B8%E7%A6%8F%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%BB%93%E5%A9%9A%E3%80%81%E5%8D%87%E8%81%8C%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="恶性压力 Distress 坏的压力，削弱动力、损害表现、导致情绪身体问题「琐事、变故、灾难」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%81%B6%E6%80%A7%E5%8E%8B%E5%8A%9B%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EDistress%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22underline%22%3E%E5%9D%8F%E7%9A%84%E5%8E%8B%E5%8A%9B%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%89%8A%E5%BC%B1%E5%8A%A8%E5%8A%9B%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8D%9F%E5%AE%B3%E8%A1%A8%E7%8E%B0%3C/span%3E%3Cspan%3E%E3%80%81%E5%AF%BC%E8%87%B4%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E7%BB%AA%E8%BA%AB%E4%BD%93%3C/span%3E%3Cspan%3E%E9%97%AE%E9%A2%98%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%90%90%E4%BA%8B%E3%80%81%E5%8F%98%E6%95%85%E3%80%81%E7%81%BE%E9%9A%BE%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="童年逆境经历 Adverse Childhood Experiences 18岁前发生的潜在创伤性事件「酗酒」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%AB%A5%E5%B9%B4%E9%80%86%E5%A2%83%E7%BB%8F%E5%8E%86%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EAdverse%20Childhood%20Experiences%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E18%E5%B2%81%E5%89%8D%E5%8F%91%E7%94%9F%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%BD%9C%E5%9C%A8%E5%88%9B%E4%BC%A4%E6%80%A7%E4%BA%8B%E4%BB%B6%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%85%97%E9%85%92%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="压力反应模型 Stress Response Models" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8E%8B%E5%8A%9B%E5%8F%8D%E5%BA%94%E6%A8%A1%E5%9E%8B%20Stress%20Response%20Models%3C/span%3E" _note="" _mubu_note="">
          <outline text="战逃反应 Fight-or-Flight Response 交感神经系统被激活，心跳加速、肾上腺素和皮质醇等激素飙升，为战斗或逃跑做准备" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%88%98%E9%80%83%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EFight-or-Flight%20Response%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BA%A4%E6%84%9F%E7%A5%9E%E7%BB%8F%3C/span%3E%3Cspan%3E%E7%B3%BB%E7%BB%9F%E8%A2%AB%E6%BF%80%E6%B4%BB%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%BF%83%E8%B7%B3%E5%8A%A0%E9%80%9F%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%82%BE%E4%B8%8A%E8%85%BA%E7%B4%A0%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%9A%AE%E8%B4%A8%E9%86%87%3C/span%3E%3Cspan%3E%E7%AD%89%E6%BF%80%E7%B4%A0%E9%A3%99%E5%8D%87%EF%BC%8C%3C/span%3E%3Cspan%20class=%22underline%22%3E%E4%B8%BA%3C/span%3E%3Cspan%20class=%22underline%20text-color-yellow%22%3E%E6%88%98%E6%96%97%E6%88%96%E9%80%83%E8%B7%91%E5%81%9A%E5%87%86%E5%A4%87%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="照顾和结盟反应 Tend-and-Befriend Response 寻求社会支持和保护他人的反应" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%85%A7%E9%A1%BE%E5%92%8C%E7%BB%93%E7%9B%9F%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ETend-and-Befriend%20Response%3C/span%3E%3Cspan%3E%20%E5%AF%BB%E6%B1%82%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%A4%BE%E4%BC%9A%E6%94%AF%E6%8C%81%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BF%9D%E6%8A%A4%E4%BB%96%E4%BA%BA%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%8F%8D%E5%BA%94%3C/span%3E" _note="" _mubu_note="">
            <outline text="照顾 Tend 指的是保护自己和后代「母亲安抚受惊的孩子」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%85%A7%E9%A1%BE%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3ETend%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E6%8C%87%E7%9A%84%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BF%9D%E6%8A%A4%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%87%AA%E5%B7%B1%E5%92%8C%E5%90%8E%E4%BB%A3%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%AF%8D%E4%BA%B2%E5%AE%89%E6%8A%9A%E5%8F%97%E6%83%8A%3C/span%3E%3Cspan%3E%E7%9A%84%E5%AD%A9%E5%AD%90%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="结盟 Befriend 创建和维护社交网络以获得支持 「联系亲友并安慰孩子」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%BB%93%E7%9B%9F%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EBefriend%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E5%88%9B%E5%BB%BA%E5%92%8C%E7%BB%B4%E6%8A%A4%E7%A4%BE%E4%BA%A4%E7%BD%91%E7%BB%9C%E4%BB%A5%E8%8E%B7%E5%BE%97%E6%94%AF%E6%8C%81%20%E3%80%8C%E8%81%94%E7%B3%BB%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%BA%B2%E5%8F%8B%3C/span%3E%3Cspan%3E%E5%B9%B6%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%AE%89%E6%85%B0%E5%AD%A9%E5%AD%90%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="⭐全身适应综合征 General Adaptation Syndrome（GAS）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E2%AD%90%E5%85%A8%E8%BA%AB%E9%80%82%E5%BA%94%E7%BB%BC%E5%90%88%E5%BE%81%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EGeneral%20Adaptation%20Syndrome%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%88GAS%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="由汉斯·斯莱 Hans Selye 提出，描述了身体在持续压力下的三个阶段性反应" _mubu_text="%3Cspan%3E%E7%94%B1%E6%B1%89%E6%96%AF%C2%B7%E6%96%AF%E8%8E%B1%20Hans%20Selye%20%E6%8F%90%E5%87%BA%EF%BC%8C%E6%8F%8F%E8%BF%B0%E4%BA%86%E8%BA%AB%E4%BD%93%E5%9C%A8%E6%8C%81%E7%BB%AD%E5%8E%8B%E5%8A%9B%E4%B8%8B%E7%9A%84%E4%B8%89%E4%B8%AA%E9%98%B6%E6%AE%B5%E6%80%A7%E5%8F%8D%E5%BA%94%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="警觉期 Alarm 身体对压力源的初始反应，激活战逃模式「心跳加速、肌肉紧张、头痛」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AD%A6%E8%A7%89%E6%9C%9F%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EAlarm%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E8%BA%AB%E4%BD%93%E5%AF%B9%E5%8E%8B%E5%8A%9B%E6%BA%90%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%88%9D%E5%A7%8B%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%BF%80%E6%B4%BB%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%88%98%E9%80%83%E6%A8%A1%E5%BC%8F%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BF%83%E8%B7%B3%E5%8A%A0%E9%80%9F%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%82%8C%E8%82%89%E7%B4%A7%E5%BC%A0%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A4%B4%E7%97%9B%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="抵抗期 Resistance 压力持续存在，身体会进入抵抗期，试图应对压力「看起来适应」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%8A%B5%E6%8A%97%E6%9C%9F%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EResistance%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E5%8E%8B%E5%8A%9B%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8C%81%E7%BB%AD%E5%AD%98%E5%9C%A8%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%BA%AB%E4%BD%93%E4%BC%9A%E8%BF%9B%E5%85%A5%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%8A%B5%E6%8A%97%E6%9C%9F%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E8%AF%95%E5%9B%BE%E5%BA%94%E5%AF%B9%E5%8E%8B%E5%8A%9B%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%9C%8B%E8%B5%B7%E6%9D%A5%E9%80%82%E5%BA%94%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="衰竭期 Exhaustion 压力长期存在，身体资源被耗尽时，就会进入衰竭期 「免疫功能下降、易生病，职业倦怠 burnout 或极度疲劳」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A1%B0%E7%AB%AD%E6%9C%9F%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EExhaustion%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E5%8E%8B%E5%8A%9B%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%95%BF%E6%9C%9F%E5%AD%98%E5%9C%A8%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%BA%AB%E4%BD%93%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%B5%84%E6%BA%90%E8%A2%AB%E8%80%97%E5%B0%BD%3C/span%3E%3Cspan%3E%E6%97%B6%EF%BC%8C%E5%B0%B1%E4%BC%9A%E8%BF%9B%E5%85%A5%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%A1%B0%E7%AB%AD%E6%9C%9F%3C/span%3E%3Cspan%3E%20%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%85%8D%E7%96%AB%E5%8A%9F%E8%83%BD%E4%B8%8B%E9%99%8D%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%98%93%E7%94%9F%E7%97%85%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%81%8C%E4%B8%9A%E5%80%A6%E6%80%A0%20burnout%20%E6%88%96%E6%9E%81%E5%BA%A6%E7%96%B2%E5%8A%B3%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="应对策略 Coping Strategies" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BA%94%E5%AF%B9%E7%AD%96%E7%95%A5%20Coping%20Strategies%3C/span%3E" _note="" _mubu_note="">
          <outline text="Adaptive 积极的 维持好的身心状态 实践放松技巧" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EAdaptive%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%A7%AF%E6%9E%81%E7%9A%84%3C/span%3E%3Cspan%3E%20%E7%BB%B4%E6%8C%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A5%BD%E7%9A%84%E8%BA%AB%E5%BF%83%E7%8A%B6%E6%80%81%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%AE%9E%E8%B7%B5%E6%94%BE%E6%9D%BE%E6%8A%80%E5%B7%A7%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Maladaptive 消极的 放纵自己 攻击行为，沉溺于饮食、饮酒、吸烟、吸毒" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EMaladaptive%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%B6%88%E6%9E%81%E7%9A%84%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%94%BE%E7%BA%B5%3C/span%3E%3Cspan%3E%E8%87%AA%E5%B7%B1%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%94%BB%E5%87%BB%3C/span%3E%3Cspan%3E%E8%A1%8C%E4%B8%BA%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%B2%89%E6%BA%BA%3C/span%3E%3Cspan%3E%E4%BA%8E%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%A5%AE%E9%A3%9F%E3%80%81%E9%A5%AE%E9%85%92%E3%80%81%E5%90%B8%E7%83%9F%E3%80%81%E5%90%B8%E6%AF%92%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="问题中心应对 Problem-Focused Coping 直接解决问题，通过改变压力源或改变我们与它的互动方式来减轻压力「制定详细计划」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%97%AE%E9%A2%98%E4%B8%AD%E5%BF%83%E5%BA%94%E5%AF%B9%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EProblem-Focused%20Coping%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E7%9B%B4%E6%8E%A5%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A7%A3%E5%86%B3%E9%97%AE%E9%A2%98%3C/span%3E%3Cspan%3E%EF%BC%8C%E9%80%9A%E8%BF%87%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%94%B9%E5%8F%98%E5%8E%8B%E5%8A%9B%E6%BA%90%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%94%B9%E5%8F%98%E6%88%91%E4%BB%AC%E4%B8%8E%E5%AE%83%E7%9A%84%E4%BA%92%E5%8A%A8%E6%96%B9%E5%BC%8F%3C/span%3E%3Cspan%3E%E6%9D%A5%E5%87%8F%E8%BD%BB%E5%8E%8B%E5%8A%9B%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%88%B6%E5%AE%9A%E8%AF%A6%E7%BB%86%E8%AE%A1%E5%88%92%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="情绪中心应对 Emotion-Focused Coping 压力源无法改变时，这种策略旨在管理我们的情绪反应 让我们感觉好一些「深呼吸、冥想、出门吃好吃的」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%83%85%E7%BB%AA%E4%B8%AD%E5%BF%83%E5%BA%94%E5%AF%B9%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EEmotion-Focused%20Coping%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%8E%8B%E5%8A%9B%E6%BA%90%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%97%A0%E6%B3%95%E6%94%B9%E5%8F%98%3C/span%3E%3Cspan%3E%E6%97%B6%EF%BC%8C%E8%BF%99%E7%A7%8D%E7%AD%96%E7%95%A5%E6%97%A8%E5%9C%A8%E7%AE%A1%E7%90%86%E6%88%91%E4%BB%AC%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E7%BB%AA%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%3E%20%E8%AE%A9%E6%88%91%E4%BB%AC%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%84%9F%E8%A7%89%E5%A5%BD%E4%B8%80%E4%BA%9B%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B7%B1%E5%91%BC%E5%90%B8%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%86%A5%E6%83%B3%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%87%BA%E9%97%A8%E5%90%83%E5%A5%BD%E5%90%83%E7%9A%84%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
      <outline text="5.2 Positive Psychology" _mubu_text="%3Cspan%3E5.2%20Positive%20Psychology%3C/span%3E" _note="" _mubu_note="">
        <outline text="积极心理学 Positive Psychology 用科学方法研究人类最佳功能的学科" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A7%AF%E6%9E%81%E5%BF%83%E7%90%86%E5%AD%A6%20Positive%20Psychology%20%3C/span%3E%3Cspan%3E%E7%94%A8%E7%A7%91%E5%AD%A6%E6%96%B9%E6%B3%95%E7%A0%94%E7%A9%B6%E4%BA%BA%E7%B1%BB%E6%9C%80%E4%BD%B3%E5%8A%9F%E8%83%BD%E7%9A%84%E5%AD%A6%E7%A7%91%3C/span%3E" _note="" _mubu_note="">
          <outline text="由心理学家马丁·塞利格曼 Martin Seligman 提倡，它的目标是发现和推广那些能帮助个人和社区茁壮成长的优势和美德 strengths and virtues" _mubu_text="%3Cspan%3E%E7%94%B1%E5%BF%83%E7%90%86%E5%AD%A6%E5%AE%B6%E9%A9%AC%E4%B8%81%C2%B7%E5%A1%9E%E5%88%A9%E6%A0%BC%E6%9B%BC%20Martin%20Seligman%20%E6%8F%90%E5%80%A1%EF%BC%8C%E5%AE%83%E7%9A%84%E7%9B%AE%E6%A0%87%E6%98%AF%E5%8F%91%E7%8E%B0%E5%92%8C%E6%8E%A8%E5%B9%BF%E9%82%A3%E4%BA%9B%E8%83%BD%E5%B8%AE%E5%8A%A9%E4%B8%AA%E4%BA%BA%E5%92%8C%E7%A4%BE%E5%8C%BA%E8%8C%81%E5%A3%AE%E6%88%90%E9%95%BF%E7%9A%84%E4%BC%98%E5%8A%BF%E5%92%8C%E7%BE%8E%E5%BE%B7%20strengths%20and%20virtues%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="主观幸福感 Subjective Well-Being 这是指一个人对自己生活的满意度和幸福感的自我评估" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%B8%BB%E8%A7%82%E5%B9%B8%E7%A6%8F%E6%84%9F%20Subjective%20Well-Being%20%3C/span%3E%3Cspan%3E%E8%BF%99%E6%98%AF%E6%8C%87%E4%B8%80%E4%B8%AA%E4%BA%BA%E5%AF%B9%E8%87%AA%E5%B7%B1%E7%94%9F%E6%B4%BB%E7%9A%84%E6%BB%A1%E6%84%8F%E5%BA%A6%E5%92%8C%E5%B9%B8%E7%A6%8F%E6%84%9F%E7%9A%84%E8%87%AA%E6%88%91%E8%AF%84%E4%BC%B0%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="感恩 Gratitude PP强调感恩的力量，" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%84%9F%E6%81%A9%20Gratitude%3C/span%3E%3Cspan%3E%20PP%E5%BC%BA%E8%B0%83%E6%84%9F%E6%81%A9%E7%9A%84%E5%8A%9B%E9%87%8F%EF%BC%8C%3C/span%3E" _note="" _mubu_note="">
          <outline text="研究发现，经常表达感恩可以显著提高你的长期幸福感。" _mubu_text="%3Cspan%3E%E7%A0%94%E7%A9%B6%E5%8F%91%E7%8E%B0%EF%BC%8C%E7%BB%8F%E5%B8%B8%E8%A1%A8%E8%BE%BE%E6%84%9F%E6%81%A9%E5%8F%AF%E4%BB%A5%E6%98%BE%E8%91%97%E6%8F%90%E9%AB%98%E4%BD%A0%E7%9A%84%E9%95%BF%E6%9C%9F%E5%B9%B8%E7%A6%8F%E6%84%9F%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="个人优势 (Signature Strengths):" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%B8%AA%E4%BA%BA%E4%BC%98%E5%8A%BF%20(Signature%20Strengths)%3C/span%3E%3Cspan%3E:%3C/span%3E" _note="" _mubu_note="">
          <outline text="这些是你性格中最突出、最核心的优势。积极心理学将它们归纳为六大类美德 (Virtues)：" _mubu_text="%3Cspan%3E%E8%BF%99%E4%BA%9B%E6%98%AF%E4%BD%A0%E6%80%A7%E6%A0%BC%E4%B8%AD%E6%9C%80%E7%AA%81%E5%87%BA%E3%80%81%E6%9C%80%E6%A0%B8%E5%BF%83%E7%9A%84%E4%BC%98%E5%8A%BF%E3%80%82%E7%A7%AF%E6%9E%81%E5%BF%83%E7%90%86%E5%AD%A6%E5%B0%86%E5%AE%83%E4%BB%AC%E5%BD%92%E7%BA%B3%E4%B8%BA%E5%85%AD%E5%A4%A7%E7%B1%BB%E7%BE%8E%E5%BE%B7%20(Virtues)%EF%BC%9A%3C/span%3E" _note="" _mubu_note="">
            <outline text="智慧 (Wisdom): 如创造力、好奇心。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%99%BA%E6%85%A7%20(Wisdom)%3C/span%3E%3Cspan%3E:%20%E5%A6%82%E5%88%9B%E9%80%A0%E5%8A%9B%E3%80%81%E5%A5%BD%E5%A5%87%E5%BF%83%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="勇气 (Courage): 如勇敢、毅力。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8B%87%E6%B0%94%20(Courage)%3C/span%3E%3Cspan%3E:%20%E5%A6%82%E5%8B%87%E6%95%A2%E3%80%81%E6%AF%85%E5%8A%9B%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="人道 (Humanity): 如爱、善良。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BA%BA%E9%81%93%20(Humanity)%3C/span%3E%3Cspan%3E:%20%E5%A6%82%E7%88%B1%E3%80%81%E5%96%84%E8%89%AF%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="正义 (Justice): 如公平、领导力。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%AD%A3%E4%B9%89%20(Justice)%3C/span%3E%3Cspan%3E:%20%E5%A6%82%E5%85%AC%E5%B9%B3%E3%80%81%E9%A2%86%E5%AF%BC%E5%8A%9B%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="节制 (Temperance): 如宽恕、自我控制。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%8A%82%E5%88%B6%20(Temperance)%3C/span%3E%3Cspan%3E:%20%E5%A6%82%E5%AE%BD%E6%81%95%E3%80%81%E8%87%AA%E6%88%91%E6%8E%A7%E5%88%B6%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="超越 (Transcendence): 如感恩、希望、欣赏美。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%B6%85%E8%B6%8A%20(Transcendence)%3C/span%3E%3Cspan%3E:%20%E5%A6%82%E6%84%9F%E6%81%A9%E3%80%81%E5%B8%8C%E6%9C%9B%E3%80%81%E6%AC%A3%E8%B5%8F%E7%BE%8E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="了解并运用自己的个人优势是提升幸福感的重要途径。" _mubu_text="%3Cspan%3E%E4%BA%86%E8%A7%A3%E5%B9%B6%E8%BF%90%E7%94%A8%E8%87%AA%E5%B7%B1%E7%9A%84%E4%B8%AA%E4%BA%BA%E4%BC%98%E5%8A%BF%E6%98%AF%E6%8F%90%E5%8D%87%E5%B9%B8%E7%A6%8F%E6%84%9F%E7%9A%84%E9%87%8D%E8%A6%81%E9%80%94%E5%BE%84%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="思维模式 (Mindset):" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%80%9D%E7%BB%B4%E6%A8%A1%E5%BC%8F%20(Mindset)%3C/span%3E%3Cspan%3E:%3C/span%3E" _note="" _mubu_note="">
          <outline text="固定型思维 (Fixed Mindset): 认为自己的智力和才能是天生的、固定不变的。这种思维模式的人在面对失败时更容易放弃。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%9B%BA%E5%AE%9A%E5%9E%8B%E6%80%9D%E7%BB%B4%20(Fixed%20Mindset)%3C/span%3E%3Cspan%3E:%20%E8%AE%A4%E4%B8%BA%E8%87%AA%E5%B7%B1%E7%9A%84%E6%99%BA%E5%8A%9B%E5%92%8C%E6%89%8D%E8%83%BD%E6%98%AF%E5%A4%A9%E7%94%9F%E7%9A%84%E3%80%81%E5%9B%BA%E5%AE%9A%E4%B8%8D%E5%8F%98%E7%9A%84%E3%80%82%E8%BF%99%E7%A7%8D%E6%80%9D%E7%BB%B4%E6%A8%A1%E5%BC%8F%E7%9A%84%E4%BA%BA%E5%9C%A8%E9%9D%A2%E5%AF%B9%E5%A4%B1%E8%B4%A5%E6%97%B6%E6%9B%B4%E5%AE%B9%E6%98%93%E6%94%BE%E5%BC%83%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="成长型思维 (Growth Mindset): 相信智力和才能可以通过努力、学习和坚持来发展和提高。这种思维模式的人更有韧性，更能从挑战中成长。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%88%90%E9%95%BF%E5%9E%8B%E6%80%9D%E7%BB%B4%20(Growth%20Mindset)%3C/span%3E%3Cspan%3E:%20%E7%9B%B8%E4%BF%A1%E6%99%BA%E5%8A%9B%E5%92%8C%E6%89%8D%E8%83%BD%E5%8F%AF%E4%BB%A5%E9%80%9A%E8%BF%87%E5%8A%AA%E5%8A%9B%E3%80%81%E5%AD%A6%E4%B9%A0%E5%92%8C%E5%9D%9A%E6%8C%81%E6%9D%A5%E5%8F%91%E5%B1%95%E5%92%8C%E6%8F%90%E9%AB%98%E3%80%82%E8%BF%99%E7%A7%8D%E6%80%9D%E7%BB%B4%E6%A8%A1%E5%BC%8F%E7%9A%84%E4%BA%BA%E6%9B%B4%E6%9C%89%E9%9F%A7%E6%80%A7%EF%BC%8C%E6%9B%B4%E8%83%BD%E4%BB%8E%E6%8C%91%E6%88%98%E4%B8%AD%E6%88%90%E9%95%BF%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="创伤后成长 (Post-traumatic Growth - PTG):" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%88%9B%E4%BC%A4%E5%90%8E%E6%88%90%E9%95%BF%20(Post-traumatic%20Growth%20-%20PTG)%3C/span%3E%3Cspan%3E:%3C/span%3E" _note="" _mubu_note="">
          <outline text="这是一个非常深刻的概念，指的是一些人在经历重大创伤或危机后，不仅恢复了过来，还在心理上获得了积极的成长。" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AF%E4%B8%80%E4%B8%AA%E9%9D%9E%E5%B8%B8%E6%B7%B1%E5%88%BB%E7%9A%84%E6%A6%82%E5%BF%B5%EF%BC%8C%E6%8C%87%E7%9A%84%E6%98%AF%E4%B8%80%E4%BA%9B%E4%BA%BA%E5%9C%A8%E7%BB%8F%E5%8E%86%E9%87%8D%E5%A4%A7%E5%88%9B%E4%BC%A4%E6%88%96%E5%8D%B1%E6%9C%BA%E5%90%8E%EF%BC%8C%E4%B8%8D%E4%BB%85%E6%81%A2%E5%A4%8D%E4%BA%86%E8%BF%87%E6%9D%A5%EF%BC%8C%E8%BF%98%E5%9C%A8%E5%BF%83%E7%90%86%E4%B8%8A%E8%8E%B7%E5%BE%97%E4%BA%86%E7%A7%AF%E6%9E%81%E7%9A%84%E6%88%90%E9%95%BF%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="这种成长可能体现在对生活的更深刻理解、人际关系的改善、个人力量感的增强等方面。它证明了逆境也能成为成长的催化剂。" _mubu_text="%3Cspan%3E%E8%BF%99%E7%A7%8D%E6%88%90%E9%95%BF%E5%8F%AF%E8%83%BD%E4%BD%93%E7%8E%B0%E5%9C%A8%E5%AF%B9%E7%94%9F%E6%B4%BB%E7%9A%84%E6%9B%B4%E6%B7%B1%E5%88%BB%E7%90%86%E8%A7%A3%E3%80%81%E4%BA%BA%E9%99%85%E5%85%B3%E7%B3%BB%E7%9A%84%E6%94%B9%E5%96%84%E3%80%81%E4%B8%AA%E4%BA%BA%E5%8A%9B%E9%87%8F%E6%84%9F%E7%9A%84%E5%A2%9E%E5%BC%BA%E7%AD%89%E6%96%B9%E9%9D%A2%E3%80%82%E5%AE%83%E8%AF%81%E6%98%8E%E4%BA%86%E9%80%86%E5%A2%83%E4%B9%9F%E8%83%BD%E6%88%90%E4%B8%BA%E6%88%90%E9%95%BF%E7%9A%84%E5%82%AC%E5%8C%96%E5%89%82%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
      <outline text="5.3 Explaining and Classifying Psychological Disorders" _mubu_text="%3Cspan%3E5.3%20Explaining%20and%20Classifying%20Psychological%20Disorders%3C/span%3E" _note="" _mubu_note="">
        <outline text="引言与核心概念 Introduction and Core Concepts" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BC%95%E8%A8%80%E4%B8%8E%E6%A0%B8%E5%BF%83%E6%A6%82%E5%BF%B5%20Introduction%20and%20Core%20Concepts%3C/span%3E" _note="" _mubu_note="">
          <outline text="医学生综合征 Medical Students Syndrome (MSS) 学习疾病知识时误将自身症状对号入座的健康焦虑「心理学初学者缺乏专业资质时随意给他人&quot;诊断&quot;的风险」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8C%BB%E5%AD%A6%E7%94%9F%E7%BB%BC%E5%90%88%E5%BE%81%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EMedical%20Students%20Syndrome%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(MSS)%3C/span%3E%3Cspan%3E%20%E5%AD%A6%E4%B9%A0%E7%96%BE%E7%97%85%E7%9F%A5%E8%AF%86%E6%97%B6%E8%AF%AF%E5%B0%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%87%AA%E8%BA%AB%E7%97%87%E7%8A%B6%3C/span%3E%3Cspan%3E%E5%AF%B9%E5%8F%B7%E5%85%A5%E5%BA%A7%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%81%A5%E5%BA%B7%E7%84%A6%E8%99%91%3C/span%3E%3Cspan%3E%E3%80%8C%E5%BF%83%E7%90%86%E5%AD%A6%E5%88%9D%E5%AD%A6%E8%80%85%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%BC%BA%E4%B9%8F%E4%B8%93%E4%B8%9A%E8%B5%84%E8%B4%A8%3C/span%3E%3Cspan%3E%E6%97%B6%E9%9A%8F%E6%84%8F%E7%BB%99%E4%BB%96%E4%BA%BA%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%22%E8%AF%8A%E6%96%AD%22%3C/span%3E%3Cspan%3E%E7%9A%84%E9%A3%8E%E9%99%A9%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="变态心理学 Abnormal Psychology 对异常行为进行科学描述、预测、解释和改变的学科" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8F%98%E6%80%81%E5%BF%83%E7%90%86%E5%AD%A6%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EAbnormal%20Psychology%3C/span%3E%3Cspan%3E%20%E5%AF%B9%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BC%82%E5%B8%B8%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%E8%BF%9B%E8%A1%8C%E7%A7%91%E5%AD%A6%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%8F%8F%E8%BF%B0%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%A2%84%E6%B5%8B%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%A7%A3%E9%87%8A%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%94%B9%E5%8F%98%3C/span%3E%3Cspan%3E%E7%9A%84%E5%AD%A6%E7%A7%91%3C/span%3E" _note="" _mubu_note="">
            <outline text="normality 因文化、时代、地域而异，无绝对客观标准" _mubu_text="%3Cspan%3Enormality%20%E5%9B%A0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%96%87%E5%8C%96%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%97%B6%E4%BB%A3%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%9C%B0%E5%9F%9F%3C/span%3E%3Cspan%3E%E8%80%8C%E5%BC%82%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%97%A0%E7%BB%9D%E5%AF%B9%E5%AE%A2%E8%A7%82%E6%A0%87%E5%87%86%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="临床心理学 Clinical Psychology 评估与治疗心理问题的应用领域" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%B8%B4%E5%BA%8A%E5%BF%83%E7%90%86%E5%AD%A6%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EClinical%20Psychology%3C/span%3E%3Cspan%3E%20%E8%AF%84%E4%BC%B0%E4%B8%8E%E6%B2%BB%E7%96%97%E5%BF%83%E7%90%86%E9%97%AE%E9%A2%98%E7%9A%84%E5%BA%94%E7%94%A8%E9%A2%86%E5%9F%9F%3C/span%3E" _note="" _mubu_note="">
