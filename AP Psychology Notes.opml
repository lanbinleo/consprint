          </outline>
          <outline text="Associative Learning 联想学习 - 建立练习，通过一个刺激预测另一个刺激的出现" _mubu_text="%3Cspan%3EAssociative%20Learning%20%E8%81%94%E6%83%B3%E5%AD%A6%E4%B9%A0%20-%20%E5%BB%BA%E7%AB%8B%E7%BB%83%E4%B9%A0%EF%BC%8C%E9%80%9A%E8%BF%87%E4%B8%80%E4%B8%AA%E5%88%BA%E6%BF%80%E9%A2%84%E6%B5%8B%E5%8F%A6%E4%B8%80%E4%B8%AA%E5%88%BA%E6%BF%80%E7%9A%84%E5%87%BA%E7%8E%B0%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Habituation 习惯化，对于重复出现的无关紧要的刺激逐渐降低反应；不是Sensory Adaptation！SA是生理层面的，HB是CNS层面的「学会忽略」" _mubu_text="%3Cspan%3EHabituation%20%E4%B9%A0%E6%83%AF%E5%8C%96%EF%BC%8C%E5%AF%B9%E4%BA%8E%E9%87%8D%E5%A4%8D%E5%87%BA%E7%8E%B0%E7%9A%84%E6%97%A0%E5%85%B3%E7%B4%A7%E8%A6%81%E7%9A%84%E5%88%BA%E6%BF%80%E9%80%90%E6%B8%90%E9%99%8D%E4%BD%8E%E5%8F%8D%E5%BA%94%EF%BC%9B%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E4%B8%8D%E6%98%AFSensory%20Adaptation%EF%BC%81%3C/span%3E%3Cspan%3ESA%E6%98%AF%E7%94%9F%E7%90%86%E5%B1%82%E9%9D%A2%E7%9A%84%EF%BC%8CHB%E6%98%AFCNS%E5%B1%82%E9%9D%A2%E7%9A%84%E3%80%8C%E5%AD%A6%E4%BC%9A%E5%BF%BD%E7%95%A5%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Classical Conditioning" _mubu_text="%3Cspan%3EClassical%20Conditioning%3C/span%3E" _note="" _mubu_note="">
          <outline text="Ivan Pavlov " _mubu_text="%3Cspan%3EIvan%20Pavlov%20%3C/span%3E" _note="" _mubu_note="">
            <outline text="巴普洛夫发现狗分泌唾液的行为 可以根据环境变化而改变" _mubu_text="%3Cspan%3E%E5%B7%B4%E6%99%AE%E6%B4%9B%E5%A4%AB%E5%8F%91%E7%8E%B0%E7%8B%97%E5%88%86%E6%B3%8C%E5%94%BE%E6%B6%B2%E7%9A%84%E8%A1%8C%E4%B8%BA%20%E5%8F%AF%E4%BB%A5%E6%A0%B9%E6%8D%AE%E7%8E%AF%E5%A2%83%E5%8F%98%E5%8C%96%E8%80%8C%E6%94%B9%E5%8F%98%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="可以对信号本身产生反应" _mubu_text="%3Cspan%3E%E5%8F%AF%E4%BB%A5%E5%AF%B9%E4%BF%A1%E5%8F%B7%E6%9C%AC%E8%BA%AB%E4%BA%A7%E7%94%9F%E5%8F%8D%E5%BA%94%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="NS与US刺激形成联结的学习过程" _mubu_text="%3Cspan%20class=%22text-color-green%22%3ENS%3C/span%3E%3Cspan%3E%E4%B8%8E%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EUS%3C/span%3E%3Cspan%3E%E5%88%BA%E6%BF%80%E5%BD%A2%E6%88%90%E8%81%94%E7%BB%93%E7%9A%84%E5%AD%A6%E4%B9%A0%E8%BF%87%E7%A8%8B%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22RVBF1oniKv%22%2C%22oh%22%3A444%2C%22ow%22%3A742%2C%22uri%22%3A%22document_image%2F33585682_bbc467f5-629c-4c05-9a1c-bd9572756ec3.png%22%2C%22w%22%3A400%7D%5D"/>
          </outline>
          <outline text="核心要素" _mubu_text="%3Cspan%3E%E6%A0%B8%E5%BF%83%E8%A6%81%E7%B4%A0%3C/span%3E" _note="" _mubu_note="">
            <outline text="US UR NS CS CR" _mubu_text="%3Cspan%20class=%22text-color-green%22%3EUS%20UR%20NS%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3ECS%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3ECR%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Phase 1 Before Conditioning" _mubu_text="%3Cspan%20class=%22text-color-green%22%3EPhase%201%3C/span%3E%3Cspan%3E%20Before%20Conditioning%3C/span%3E" _note="" _mubu_note="">
              <outline text="Unconditioned Stimulus, US/UCS 无条件刺激" _mubu_text="%3Cspan%20class=%22bold%22%3EUnconditioned%20Stimulus,%20US/UCS%3C/span%3E%3Cspan%3E%20%E6%97%A0%E6%9D%A1%E4%BB%B6%E5%88%BA%E6%BF%80%3C/span%3E" _note="" _mubu_note="">
                <outline text="能自动引发的天生反射性反应的刺激（巨响）" _mubu_text="%3Cspan%3E%E8%83%BD%E8%87%AA%E5%8A%A8%E5%BC%95%E5%8F%91%E7%9A%84%E5%A4%A9%E7%94%9F%E5%8F%8D%E5%B0%84%E6%80%A7%E5%8F%8D%E5%BA%94%E7%9A%84%E5%88%BA%E6%BF%80%EF%BC%88%E5%B7%A8%E5%93%8D%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="Unconditioned Response, UR/UCR 无条件反应" _mubu_text="%3Cspan%20class=%22bold%22%3EUnconditioned%20Response,%20UR/UCR%3C/span%3E%3Cspan%3E%20%E6%97%A0%E6%9D%A1%E4%BB%B6%E5%8F%8D%E5%BA%94%3C/span%3E" _note="" _mubu_note="">
                <outline text="被自动引发的天生反射性反应的反应（自然、自动反应）" _mubu_text="%3Cspan%3E%E8%A2%AB%E8%87%AA%E5%8A%A8%E5%BC%95%E5%8F%91%E7%9A%84%E5%A4%A9%E7%94%9F%E5%8F%8D%E5%B0%84%E6%80%A7%E5%8F%8D%E5%BA%94%E7%9A%84%E5%8F%8D%E5%BA%94%EF%BC%88%E8%87%AA%E7%84%B6%E3%80%81%E8%87%AA%E5%8A%A8%E5%8F%8D%E5%BA%94%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="Phase 2 During Conditioning" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EPhase%202%3C/span%3E%3Cspan%3E%20During%20Conditioning%3C/span%3E" _note="" _mubu_note="">
              <outline text="Neutral Stimulus, NS 中性刺激 " _mubu_text="%3Cspan%20class=%22bold%22%3ENeutral%20Stimulus,%20NS%3C/span%3E%3Cspan%3E%20%E4%B8%AD%E6%80%A7%E5%88%BA%E6%BF%80%20%3C/span%3E" _note="" _mubu_note="">
                <outline text="在条件作用之前，不会引发目标反应（UR）的刺激" _mubu_text="%3Cspan%3E%E5%9C%A8%E6%9D%A1%E4%BB%B6%E4%BD%9C%E7%94%A8%E4%B9%8B%E5%89%8D%EF%BC%8C%E4%B8%8D%E4%BC%9A%E5%BC%95%E5%8F%91%E7%9B%AE%E6%A0%87%E5%8F%8D%E5%BA%94%EF%BC%88UR%EF%BC%89%E7%9A%84%E5%88%BA%E6%BF%80%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="它只是一个普通的信号或物体，如铃声、白大褂" _mubu_text="%3Cspan%3E%E5%AE%83%E5%8F%AA%E6%98%AF%E4%B8%80%E4%B8%AA%E6%99%AE%E9%80%9A%E7%9A%84%E4%BF%A1%E5%8F%B7%E6%88%96%E7%89%A9%E4%BD%93%EF%BC%8C%E5%A6%82%E9%93%83%E5%A3%B0%E3%80%81%E7%99%BD%E5%A4%A7%E8%A4%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="Conditioned Stimulus, CS 条件刺激 " _mubu_text="%3Cspan%20class=%22bold%22%3EConditioned%20Stimulus,%20CS%3C/span%3E%3Cspan%3E%20%E6%9D%A1%E4%BB%B6%E5%88%BA%E6%BF%80%20%3C/span%3E" _note="" _mubu_note="">
                <outline text="NS在和US反复配对后，导致NS有了US的效果" _mubu_text="%3Cspan%3ENS%E5%9C%A8%E5%92%8CUS%E5%8F%8D%E5%A4%8D%E9%85%8D%E5%AF%B9%E5%90%8E%EF%BC%8C%E5%AF%BC%E8%87%B4NS%E6%9C%89%E4%BA%86US%E7%9A%84%E6%95%88%E6%9E%9C%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="能独自引发习得性反应的先前的中性刺激。" _mubu_text="%3Cspan%3E%E8%83%BD%E7%8B%AC%E8%87%AA%E5%BC%95%E5%8F%91%E4%B9%A0%E5%BE%97%E6%80%A7%E5%8F%8D%E5%BA%94%E7%9A%84%E5%85%88%E5%89%8D%E7%9A%84%E4%B8%AD%E6%80%A7%E5%88%BA%E6%BF%80%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="Phase 3 After Conditioning" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3EPhase%203%3C/span%3E%3Cspan%3E%20After%20Conditioning%3C/span%3E" _note="" _mubu_note="">
              <outline text="Conditioned Response, CR 条件反应" _mubu_text="%3Cspan%20class=%22bold%22%3EConditioned%20Response,%20CR%3C/span%3E%3Cspan%3E%20%E6%9D%A1%E4%BB%B6%E5%8F%8D%E5%BA%94%3C/span%3E" _note="" _mubu_note="">
                <outline text="CR是由CS引发的、通过学习获得的反应，通常与UR相似。" _mubu_text="%3Cspan%3ECR%E6%98%AF%E7%94%B1CS%E5%BC%95%E5%8F%91%E7%9A%84%E3%80%81%E9%80%9A%E8%BF%87%E5%AD%A6%E4%B9%A0%E8%8E%B7%E5%BE%97%E7%9A%84%E5%8F%8D%E5%BA%94%EF%BC%8C%E9%80%9A%E5%B8%B8%E4%B8%8EUR%E7%9B%B8%E4%BC%BC%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="“小时候，穿白大褂的医生给我打针（疼），我哭了。现在，一看到穿白大褂的医生我就想哭。”" _mubu_text="%3Cspan%3E%E2%80%9C%E5%B0%8F%E6%97%B6%E5%80%99%EF%BC%8C%E7%A9%BF%E7%99%BD%E5%A4%A7%E8%A4%82%E7%9A%84%E5%8C%BB%E7%94%9F%E7%BB%99%E6%88%91%E6%89%93%E9%92%88%EF%BC%88%E7%96%BC%EF%BC%89%EF%BC%8C%E6%88%91%E5%93%AD%E4%BA%86%E3%80%82%E7%8E%B0%E5%9C%A8%EF%BC%8C%E4%B8%80%E7%9C%8B%E5%88%B0%E7%A9%BF%E7%99%BD%E5%A4%A7%E8%A4%82%E7%9A%84%E5%8C%BB%E7%94%9F%E6%88%91%E5%B0%B1%E6%83%B3%E5%93%AD%E3%80%82%E2%80%9D%3C/span%3E" _note="" _mubu_note="">
              <outline text="US - 疼" _mubu_text="%3Cspan%3EUS%20-%20%E7%96%BC%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="UR - 哭了" _mubu_text="%3Cspan%3EUR%20-%20%E5%93%AD%E4%BA%86%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="NS - 白大褂" _mubu_text="%3Cspan%3ENS%20-%20%E7%99%BD%E5%A4%A7%E8%A4%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="CS - 白大褂（后来的）" _mubu_text="%3Cspan%3ECS%20-%20%E7%99%BD%E5%A4%A7%E8%A4%82%EF%BC%88%E5%90%8E%E6%9D%A5%E7%9A%84%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="CR - 见到白大褂就会哭（习得的）" _mubu_text="%3Cspan%3ECR%20-%20%E8%A7%81%E5%88%B0%E7%99%BD%E5%A4%A7%E8%A4%82%E5%B0%B1%E4%BC%9A%E5%93%AD%EF%BC%88%E4%B9%A0%E5%BE%97%E7%9A%84%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="呈现顺序" _mubu_text="%3Cspan%3E%E5%91%88%E7%8E%B0%E9%A1%BA%E5%BA%8F%3C/span%3E" _note="" _mubu_note="">
            <outline text="CS（白大褂）最好在US（疼痛）到来之前（0.5s-1s最佳）" _mubu_text="%3Cspan%3ECS%EF%BC%88%E7%99%BD%E5%A4%A7%E8%A4%82%EF%BC%89%E6%9C%80%E5%A5%BD%E5%9C%A8US%EF%BC%88%E7%96%BC%E7%97%9B%EF%BC%89%E5%88%B0%E6%9D%A5%E4%B9%8B%E5%89%8D%EF%BC%880.5s-1s%E6%9C%80%E4%BD%B3%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
              <outline text="可靠信号" _mubu_text="%3Cspan%3E%E5%8F%AF%E9%9D%A0%E4%BF%A1%E5%8F%B7%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="Higher Order Conditioning" _mubu_text="%3Cspan%3EHigher%20Order%20Conditioning%3C/span%3E" _note="" _mubu_note="">
            <outline text="用CS作为US，让另一个NS变成CS的过程" _mubu_text="%3Cspan%3E%E7%94%A8CS%E4%BD%9C%E4%B8%BAUS%EF%BC%8C%E8%AE%A9%E5%8F%A6%E4%B8%80%E4%B8%AANS%E5%8F%98%E6%88%90CS%E7%9A%84%E8%BF%87%E7%A8%8B%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="僵尸病毒同化这一块" _mubu_text="%3Cspan%3E%E5%83%B5%E5%B0%B8%E7%97%85%E6%AF%92%E5%90%8C%E5%8C%96%E8%BF%99%E4%B8%80%E5%9D%97%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="白大褂现在会让我哭，而白大褂登场伴随着邪恶BGM，听到邪恶BGM也会让我哭" _mubu_text="%3Cspan%3E%E7%99%BD%E5%A4%A7%E8%A4%82%E7%8E%B0%E5%9C%A8%E4%BC%9A%E8%AE%A9%E6%88%91%E5%93%AD%EF%BC%8C%E8%80%8C%E7%99%BD%E5%A4%A7%E8%A4%82%E7%99%BB%E5%9C%BA%E4%BC%B4%E9%9A%8F%E7%9D%80%E9%82%AA%E6%81%B6BGM%EF%BC%8C%E5%90%AC%E5%88%B0%E9%82%AA%E6%81%B6BGM%E4%B9%9F%E4%BC%9A%E8%AE%A9%E6%88%91%E5%93%AD%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="过程和现象" _mubu_text="%3Cspan%3E%E8%BF%87%E7%A8%8B%E5%92%8C%E7%8E%B0%E8%B1%A1%3C/span%3E" _note="" _mubu_note="">
            <outline text="Acquisition 习得" _mubu_text="%3Cspan%3EAcquisition%20%E4%B9%A0%E5%BE%97%3C/span%3E" _note="" _mubu_note="">
              <outline text="小猫学会在听到罐头打开的声音后跑到厨房。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B0%8F%E7%8C%AB%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%AD%A6%E4%BC%9A%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%9C%A8%E5%90%AC%E5%88%B0%E7%BD%90%E5%A4%B4%E6%89%93%E5%BC%80%E7%9A%84%E5%A3%B0%E9%9F%B3%E5%90%8E%E8%B7%91%E5%88%B0%E5%8E%A8%E6%88%BF%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="小猫起初对罐头打开的声音没有反应，但主人每次打开罐头后都会给它喂食。经过多次重复，小猫学会了将罐头打开的声音和食物联系在一起，于是每当听到这个声音就跑到厨房。" _mubu_text="%3Cspan%3E%E5%B0%8F%E7%8C%AB%E8%B5%B7%E5%88%9D%E5%AF%B9%E7%BD%90%E5%A4%B4%E6%89%93%E5%BC%80%E7%9A%84%E5%A3%B0%E9%9F%B3%E6%B2%A1%E6%9C%89%E5%8F%8D%E5%BA%94%EF%BC%8C%E4%BD%86%E4%B8%BB%E4%BA%BA%E6%AF%8F%E6%AC%A1%E6%89%93%E5%BC%80%E7%BD%90%E5%A4%B4%E5%90%8E%E9%83%BD%E4%BC%9A%E7%BB%99%E5%AE%83%E5%96%82%E9%A3%9F%E3%80%82%E7%BB%8F%E8%BF%87%E5%A4%9A%E6%AC%A1%E9%87%8D%E5%A4%8D%EF%BC%8C%E5%B0%8F%E7%8C%AB%E5%AD%A6%E4%BC%9A%E4%BA%86%E5%B0%86%E7%BD%90%E5%A4%B4%E6%89%93%E5%BC%80%E7%9A%84%E5%A3%B0%E9%9F%B3%E5%92%8C%E9%A3%9F%E7%89%A9%E8%81%94%E7%B3%BB%E5%9C%A8%E4%B8%80%E8%B5%B7%EF%BC%8C%E4%BA%8E%E6%98%AF%E6%AF%8F%E5%BD%93%E5%90%AC%E5%88%B0%E8%BF%99%E4%B8%AA%E5%A3%B0%E9%9F%B3%E5%B0%B1%E8%B7%91%E5%88%B0%E5%8E%A8%E6%88%BF%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Extinction 消退" _mubu_text="%3Cspan%3EExtinction%20%E6%B6%88%E9%80%80%3C/span%3E" _note="" _mubu_note="">
              <outline text="小猫不再对罐头声有反应，因为没有食物。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B0%8F%E7%8C%AB%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E4%B8%8D%E5%86%8D%E5%AF%B9%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%BD%90%E5%A4%B4%E5%A3%B0%E6%9C%89%E5%8F%8D%E5%BA%94%EF%BC%8C%E5%9B%A0%E4%B8%BA%E6%B2%A1%E6%9C%89%E9%A3%9F%E7%89%A9%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="如果主人开始打开罐头但不再给小猫食物，经过几次这种情况后，小猫开始不再对罐头的声音有反应。罐头声和食物之间的联系被打破，导致反应消退。" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E4%B8%BB%E4%BA%BA%E5%BC%80%E5%A7%8B%E6%89%93%E5%BC%80%E7%BD%90%E5%A4%B4%E4%BD%86%E4%B8%8D%E5%86%8D%E7%BB%99%E5%B0%8F%E7%8C%AB%E9%A3%9F%E7%89%A9%EF%BC%8C%E7%BB%8F%E8%BF%87%E5%87%A0%E6%AC%A1%E8%BF%99%E7%A7%8D%E6%83%85%E5%86%B5%E5%90%8E%EF%BC%8C%E5%B0%8F%E7%8C%AB%E5%BC%80%E5%A7%8B%E4%B8%8D%E5%86%8D%E5%AF%B9%E7%BD%90%E5%A4%B4%E7%9A%84%E5%A3%B0%E9%9F%B3%E6%9C%89%E5%8F%8D%E5%BA%94%E3%80%82%E7%BD%90%E5%A4%B4%E5%A3%B0%E5%92%8C%E9%A3%9F%E7%89%A9%E4%B9%8B%E9%97%B4%E7%9A%84%E8%81%94%E7%B3%BB%E8%A2%AB%E6%89%93%E7%A0%B4%EF%BC%8C%E5%AF%BC%E8%87%B4%E5%8F%8D%E5%BA%94%E6%B6%88%E9%80%80%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Spontaneous Recovery 自然恢复" _mubu_text="%3Cspan%3ESpontaneous%20Recovery%20%E8%87%AA%E7%84%B6%E6%81%A2%E5%A4%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="小猫突然又对罐头声有反应。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B0%8F%E7%8C%AB%E7%AA%81%E7%84%B6%E5%8F%88%E5%AF%B9%E7%BD%90%E5%A4%B4%E5%A3%B0%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E6%9C%89%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="在消退一段时间后，主人突然又开始在打开罐头后给小猫食物。即使消退已经发生，小猫可能会突然又对罐头声有反应，这就是自然恢复。" _mubu_text="%3Cspan%3E%E5%9C%A8%E6%B6%88%E9%80%80%E4%B8%80%E6%AE%B5%E6%97%B6%E9%97%B4%E5%90%8E%EF%BC%8C%E4%B8%BB%E4%BA%BA%E7%AA%81%E7%84%B6%E5%8F%88%E5%BC%80%E5%A7%8B%E5%9C%A8%E6%89%93%E5%BC%80%E7%BD%90%E5%A4%B4%E5%90%8E%E7%BB%99%E5%B0%8F%E7%8C%AB%E9%A3%9F%E7%89%A9%E3%80%82%E5%8D%B3%E4%BD%BF%E6%B6%88%E9%80%80%E5%B7%B2%E7%BB%8F%E5%8F%91%E7%94%9F%EF%BC%8C%E5%B0%8F%E7%8C%AB%E5%8F%AF%E8%83%BD%E4%BC%9A%E7%AA%81%E7%84%B6%E5%8F%88%E5%AF%B9%E7%BD%90%E5%A4%B4%E5%A3%B0%E6%9C%89%E5%8F%8D%E5%BA%94%EF%BC%8C%E8%BF%99%E5%B0%B1%E6%98%AF%E8%87%AA%E7%84%B6%E6%81%A2%E5%A4%8D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Stimulus Generation 刺激泛化" _mubu_text="%3Cspan%3EStimulus%20Generation%20%E5%88%BA%E6%BF%80%E6%B3%9B%E5%8C%96%3C/span%3E" _note="" _mubu_note="">
              <outline text="小猫听到类似罐头的声音也会跑到厨房。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B0%8F%E7%8C%AB%E5%90%AC%E5%88%B0%3C/span%3E%3Cspan%20class=%22bold%20text-color-purple%22%3E%E7%B1%BB%E4%BC%BC%E7%BD%90%E5%A4%B4%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%9A%84%E5%A3%B0%E9%9F%B3%E4%B9%9F%E4%BC%9A%E8%B7%91%E5%88%B0%E5%8E%A8%E6%88%BF%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="小猫不仅对罐头的声音有反应，对其他类似的声音也会有反应，比如饮料罐打开的声音。小猫把类似的声音都联系到食物上，这就是刺激泛化。" _mubu_text="%3Cspan%3E%E5%B0%8F%E7%8C%AB%E4%B8%8D%E4%BB%85%E5%AF%B9%E7%BD%90%E5%A4%B4%E7%9A%84%E5%A3%B0%E9%9F%B3%E6%9C%89%E5%8F%8D%E5%BA%94%EF%BC%8C%E5%AF%B9%E5%85%B6%E4%BB%96%E7%B1%BB%E4%BC%BC%E7%9A%84%E5%A3%B0%E9%9F%B3%E4%B9%9F%E4%BC%9A%E6%9C%89%E5%8F%8D%E5%BA%94%EF%BC%8C%E6%AF%94%E5%A6%82%E9%A5%AE%E6%96%99%E7%BD%90%E6%89%93%E5%BC%80%E7%9A%84%E5%A3%B0%E9%9F%B3%E3%80%82%E5%B0%8F%E7%8C%AB%E6%8A%8A%E7%B1%BB%E4%BC%BC%E7%9A%84%E5%A3%B0%E9%9F%B3%E9%83%BD%E8%81%94%E7%B3%BB%E5%88%B0%E9%A3%9F%E7%89%A9%E4%B8%8A%EF%BC%8C%E8%BF%99%E5%B0%B1%E6%98%AF%E5%88%BA%E6%BF%80%E6%B3%9B%E5%8C%96%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Stimulus Discrimination 刺激辨别" _mubu_text="%3Cspan%3EStimulus%20Discrimination%20%E5%88%BA%E6%BF%80%E8%BE%A8%E5%88%AB%3C/span%3E" _note="" _mubu_note="">
              <outline text="小猫只对特定罐头声有反应。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B0%8F%E7%8C%AB%E5%8F%AA%E5%AF%B9%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E7%89%B9%E5%AE%9A%E7%BD%90%E5%A4%B4%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%A3%B0%E6%9C%89%E5%8F%8D%E5%BA%94%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="经过一段时间，小猫开始只对主人特定罐头的声音有反应，而不再对其他类似的声音有反应。这是因为它能够辨别出哪种声音真正代表食物将出现，这就是刺激辨别。" _mubu_text="%3Cspan%3E%E7%BB%8F%E8%BF%87%E4%B8%80%E6%AE%B5%E6%97%B6%E9%97%B4%EF%BC%8C%E5%B0%8F%E7%8C%AB%E5%BC%80%E5%A7%8B%E5%8F%AA%E5%AF%B9%E4%B8%BB%E4%BA%BA%E7%89%B9%E5%AE%9A%E7%BD%90%E5%A4%B4%E7%9A%84%E5%A3%B0%E9%9F%B3%E6%9C%89%E5%8F%8D%E5%BA%94%EF%BC%8C%E8%80%8C%E4%B8%8D%E5%86%8D%E5%AF%B9%E5%85%B6%E4%BB%96%E7%B1%BB%E4%BC%BC%E7%9A%84%E5%A3%B0%E9%9F%B3%E6%9C%89%E5%8F%8D%E5%BA%94%E3%80%82%E8%BF%99%E6%98%AF%E5%9B%A0%E4%B8%BA%E5%AE%83%E8%83%BD%E5%A4%9F%E8%BE%A8%E5%88%AB%E5%87%BA%E5%93%AA%E7%A7%8D%E5%A3%B0%E9%9F%B3%E7%9C%9F%E6%AD%A3%E4%BB%A3%E8%A1%A8%E9%A3%9F%E7%89%A9%E5%B0%86%E5%87%BA%E7%8E%B0%EF%BC%8C%E8%BF%99%E5%B0%B1%E6%98%AF%E5%88%BA%E6%BF%80%E8%BE%A8%E5%88%AB%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="特殊案例" _mubu_text="%3Cspan%3E%E7%89%B9%E6%AE%8A%E6%A1%88%E4%BE%8B%3C/span%3E" _note="" _mubu_note="">
            <outline text="味觉厌恶 (Taste Aversion)" _mubu_text="%3Cspan%3E%E5%91%B3%E8%A7%89%E5%8E%8C%E6%81%B6%20(Taste%20Aversion)%3C/span%3E" _note="" _mubu_note="">
              <outline text="我有一次生病的时候吃了豆花，然后现在再也不喜欢吃以前最喜欢的豆花了" _mubu_text="%3Cspan%3E%E6%88%91%E6%9C%89%E4%B8%80%E6%AC%A1%E7%94%9F%E7%97%85%E7%9A%84%E6%97%B6%E5%80%99%E5%90%83%E4%BA%86%E8%B1%86%E8%8A%B1%EF%BC%8C%E7%84%B6%E5%90%8E%E7%8E%B0%E5%9C%A8%E5%86%8D%E4%B9%9F%E4%B8%8D%E5%96%9C%E6%AC%A2%E5%90%83%E4%BB%A5%E5%89%8D%E6%9C%80%E5%96%9C%E6%AC%A2%E7%9A%84%E8%B1%86%E8%8A%B1%E4%BA%86%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="通常只需要一次NS（特定味道）与UCS（恶心/生病）的配对就能形成。" _mubu_text="%3Cspan%3E%E9%80%9A%E5%B8%B8%E5%8F%AA%E9%9C%80%E8%A6%81%E4%B8%80%E6%AC%A1NS%EF%BC%88%E7%89%B9%E5%AE%9A%E5%91%B3%E9%81%93%EF%BC%89%E4%B8%8EUCS%EF%BC%88%E6%81%B6%E5%BF%83/%E7%94%9F%E7%97%85%EF%BC%89%E7%9A%84%E9%85%8D%E5%AF%B9%E5%B0%B1%E8%83%BD%E5%BD%A2%E6%88%90%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Biological Preparedness 生物预备性" _mubu_text="%3Cspan%3EBiological%20Preparedness%20%E7%94%9F%E7%89%A9%E9%A2%84%E5%A4%87%E6%80%A7%3C/span%3E" _note="" _mubu_note="">
              <outline text="巨响就是更可怕，打雷就是很可怕" _mubu_text="%3Cspan%3E%E5%B7%A8%E5%93%8D%E5%B0%B1%E6%98%AF%E6%9B%B4%E5%8F%AF%E6%80%95%EF%BC%8C%E6%89%93%E9%9B%B7%E5%B0%B1%E6%98%AF%E5%BE%88%E5%8F%AF%E6%80%95%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="由于进化历史，天生就更容易形成某些对生存有重要意义的刺激-反应联结的倾向" _mubu_text="%3Cspan%3E%E7%94%B1%E4%BA%8E%E8%BF%9B%E5%8C%96%E5%8E%86%E5%8F%B2%EF%BC%8C%E5%A4%A9%E7%94%9F%E5%B0%B1%E6%9B%B4%E5%AE%B9%E6%98%93%E5%BD%A2%E6%88%90%E6%9F%90%E4%BA%9B%E5%AF%B9%E7%94%9F%E5%AD%98%E6%9C%89%E9%87%8D%E8%A6%81%E6%84%8F%E4%B9%89%E7%9A%84%E5%88%BA%E6%BF%80-%E5%8F%8D%E5%BA%94%E8%81%94%E7%BB%93%E7%9A%84%E5%80%BE%E5%90%91%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
      </outline>
      <outline text="3.8 Operant Conditioning" _mubu_text="%3Cspan%3E3.8%20Operant%20Conditioning%3C/span%3E" _note="" _mubu_note="">
        <outline text="基础/核心概念" _mubu_text="%3Cspan%3E%E5%9F%BA%E7%A1%80/%E6%A0%B8%E5%BF%83%E6%A6%82%E5%BF%B5%3C/span%3E" _note="" _mubu_note="">
          <outline text="Law of Effect 效果律，效果为王" _mubu_text="%3Cspan%3ELaw%20of%20Effect%20%E6%95%88%E6%9E%9C%E5%BE%8B%EF%BC%8C%E6%95%88%E6%9E%9C%E4%B8%BA%E7%8E%8B%3C/span%3E" _note="" _mubu_note="">
            <outline text="好结果的行为更可能被重复，坏结果的行为更可能被减少" _mubu_text="%3Cspan%3E%E5%A5%BD%E7%BB%93%E6%9E%9C%E7%9A%84%E8%A1%8C%E4%B8%BA%E6%9B%B4%E5%8F%AF%E8%83%BD%E8%A2%AB%E9%87%8D%E5%A4%8D%EF%BC%8C%E5%9D%8F%E7%BB%93%E6%9E%9C%E7%9A%84%E8%A1%8C%E4%B8%BA%E6%9B%B4%E5%8F%AF%E8%83%BD%E8%A2%AB%E5%87%8F%E5%B0%91%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="效果律指出，行为的结果决定了该行为在未来发生的概率。" _mubu_text="%3Cspan%3E%E6%95%88%E6%9E%9C%E5%BE%8B%E6%8C%87%E5%87%BA%EF%BC%8C%E8%A1%8C%E4%B8%BA%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%BB%93%E6%9E%9C%3C/span%3E%3Cspan%3E%E5%86%B3%E5%AE%9A%E4%BA%86%E8%AF%A5%E8%A1%8C%E4%B8%BA%E5%9C%A8%E6%9C%AA%E6%9D%A5%E5%8F%91%E7%94%9F%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%A6%82%E7%8E%87%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="B.F. Skinner &amp; the Skinner Box 斯金纳和他的箱子" _mubu_text="%3Cspan%3EB.F.%20Skinner%20&amp;amp;%20the%20Skinner%20Box%20%E6%96%AF%E9%87%91%E7%BA%B3%E5%92%8C%E4%BB%96%E7%9A%84%E7%AE%B1%E5%AD%90%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22utLQS4vtPF%22%2C%22oh%22%3A512%2C%22ow%22%3A639%2C%22uri%22%3A%22document_image%2F33585682_2e960bce-2add-4f38-a43b-66d2b81affd4.png%22%2C%22w%22%3A308%7D%5D"/>
          <outline text="定义" _mubu_text="%3Cspan%3E%E5%AE%9A%E4%B9%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="强调行为与其后果之间的关系，并认为行为的频率可以通过奖励或惩罚来改变" _mubu_text="%3Cspan%3E%E5%BC%BA%E8%B0%83%E8%A1%8C%E4%B8%BA%E4%B8%8E%E5%85%B6%E5%90%8E%E6%9E%9C%E4%B9%8B%E9%97%B4%E7%9A%84%E5%85%B3%E7%B3%BB%EF%BC%8C%E5%B9%B6%E8%AE%A4%E4%B8%BA%E8%A1%8C%E4%B8%BA%E7%9A%84%E9%A2%91%E7%8E%87%E5%8F%AF%E4%BB%A5%E9%80%9A%E8%BF%87%E5%A5%96%E5%8A%B1%E6%88%96%E6%83%A9%E7%BD%9A%E6%9D%A5%E6%94%B9%E5%8F%98%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Reinforcement 和 Punishment" _mubu_text="%3Cspan%3EReinforcement%20%E5%92%8C%20Punishment%3C/span%3E" _note="" _mubu_note="">
          <outline text="强化 Reinforcement" _mubu_text="%3Cspan%3E%E5%BC%BA%E5%8C%96%20Reinforcement%3C/span%3E" _note="" _mubu_note="">
            <outline text="定义：任何能增加行为未来发生概率的事件。提供强化物的事件就是强化。" _mubu_text="%3Cspan%3E%E5%AE%9A%E4%B9%89%EF%BC%9A%E4%BB%BB%E4%BD%95%E8%83%BD%E5%A2%9E%E5%8A%A0%E8%A1%8C%E4%B8%BA%E6%9C%AA%E6%9D%A5%E5%8F%91%E7%94%9F%E6%A6%82%E7%8E%87%E7%9A%84%E4%BA%8B%E4%BB%B6%E3%80%82%E6%8F%90%E4%BE%9B%E5%BC%BA%E5%8C%96%E7%89%A9%E7%9A%84%E4%BA%8B%E4%BB%B6%E5%B0%B1%E6%98%AF%E5%BC%BA%E5%8C%96%E3%80%82%3C/span%3E" _note="" _mubu_note="">
              <outline text="强化物 (Reinforcer)：能增加行为概率的刺激物本身（如食物、赞美）。" _mubu_text="%3Cspan%3E%E5%BC%BA%E5%8C%96%E7%89%A9%20(Reinforcer)%EF%BC%9A%E8%83%BD%E5%A2%9E%E5%8A%A0%E8%A1%8C%E4%B8%BA%E6%A6%82%E7%8E%87%E7%9A%84%E5%88%BA%E6%BF%80%E7%89%A9%E6%9C%AC%E8%BA%AB%EF%BC%88%E5%A6%82%E9%A3%9F%E7%89%A9%E3%80%81%E8%B5%9E%E7%BE%8E%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="正强化 (Positive Reinforcement)" _mubu_text="%3Cspan%3E%E6%AD%A3%E5%BC%BA%E5%8C%96%20(Positive%20Reinforcement)%3C/span%3E" _note="" _mubu_note="">
              <outline text="“加好”。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E2%80%9C%E5%8A%A0%E5%A5%BD%E2%80%9D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="例如：工作出色得到奖金（加钱）、学习后玩会儿游戏（加娱乐）。" _mubu_text="%3Cspan%3E%E4%BE%8B%E5%A6%82%EF%BC%9A%E5%B7%A5%E4%BD%9C%E5%87%BA%E8%89%B2%E5%BE%97%E5%88%B0%E5%A5%96%E9%87%91%EF%BC%88%E5%8A%A0%E9%92%B1%EF%BC%89%E3%80%81%E5%AD%A6%E4%B9%A0%E5%90%8E%E7%8E%A9%E4%BC%9A%E5%84%BF%E6%B8%B8%E6%88%8F%EF%BC%88%E5%8A%A0%E5%A8%B1%E4%B9%90%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="正强化是通过在行为后呈现令人愉悦的刺激来增加该行为。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%AD%A3%E5%BC%BA%E5%8C%96%E6%98%AF%E9%80%9A%E8%BF%87%E5%9C%A8%E8%A1%8C%E4%B8%BA%E5%90%8E%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%91%88%E7%8E%B0%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BB%A4%E4%BA%BA%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E6%84%89%E6%82%A6%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%9A%84%E5%88%BA%E6%BF%80%E6%9D%A5%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E5%A2%9E%E5%8A%A0%E8%AF%A5%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="负强化 (Negative Reinforcement)" _mubu_text="%3Cspan%3E%E8%B4%9F%E5%BC%BA%E5%8C%96%20(Negative%20Reinforcement)%3C/span%3E" _note="" _mubu_note="">
              <outline text="“减坏”。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E2%80%9C%E5%87%8F%E5%9D%8F%E2%80%9D%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="例如：系好安全带使烦人的警报声停止（移除噪音）、吃止痛药缓解头痛（移除疼痛）。" _mubu_text="%3Cspan%3E%E4%BE%8B%E5%A6%82%EF%BC%9A%E7%B3%BB%E5%A5%BD%E5%AE%89%E5%85%A8%E5%B8%A6%E4%BD%BF%E7%83%A6%E4%BA%BA%E7%9A%84%E8%AD%A6%E6%8A%A5%E5%A3%B0%E5%81%9C%E6%AD%A2%EF%BC%88%E7%A7%BB%E9%99%A4%E5%99%AA%E9%9F%B3%EF%BC%89%E3%80%81%E5%90%83%E6%AD%A2%E7%97%9B%E8%8D%AF%E7%BC%93%E8%A7%A3%E5%A4%B4%E7%97%9B%EF%BC%88%E7%A7%BB%E9%99%A4%E7%96%BC%E7%97%9B%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="负强化是通过在行为后移除或避免令人厌恶的刺激来增加该行为。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%B4%9F%E5%BC%BA%E5%8C%96%E6%98%AF%E9%80%9A%E8%BF%87%E5%9C%A8%E8%A1%8C%E4%B8%BA%E5%90%8E%3C/span%3E%3Cspan%20class=%22bold%20text-color-purple%22%3E%E7%A7%BB%E9%99%A4%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%88%96%E9%81%BF%E5%85%8D%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E4%BB%A4%E4%BA%BA%E5%8E%8C%E6%81%B6%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%9A%84%E5%88%BA%E6%BF%80%E6%9D%A5%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E5%A2%9E%E5%8A%A0%E8%AF%A5%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="⚠️ 重要区分：负强化不是惩罚！它和正强化一样，目的都是增加行为，只是手段不同（一个加好，一个减坏）。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E2%9A%A0%EF%B8%8F%20%E9%87%8D%E8%A6%81%E5%8C%BA%E5%88%86%3C/span%3E%3Cspan%3E%EF%BC%9A%E8%B4%9F%E5%BC%BA%E5%8C%96%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%B8%8D%E6%98%AF%E6%83%A9%E7%BD%9A%3C/span%3E%3Cspan%3E%EF%BC%81%E5%AE%83%E5%92%8C%E6%AD%A3%E5%BC%BA%E5%8C%96%E4%B8%80%E6%A0%B7%EF%BC%8C%E7%9B%AE%E7%9A%84%E9%83%BD%E6%98%AF%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%A2%9E%E5%8A%A0%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%8F%AA%E6%98%AF%E6%89%8B%E6%AE%B5%E4%B8%8D%E5%90%8C%EF%BC%88%E4%B8%80%E4%B8%AA%E5%8A%A0%E5%A5%BD%EF%BC%8C%E4%B8%80%E4%B8%AA%E5%87%8F%E5%9D%8F%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="惩罚 Punishment" _mubu_text="%3Cspan%3E%E6%83%A9%E7%BD%9A%20Punishment%3C/span%3E" _note="" _mubu_note="">
            <outline text="定义：任何能减少行为未来发生概率的事件。" _mubu_text="%3Cspan%3E%E5%AE%9A%E4%B9%89%EF%BC%9A%E4%BB%BB%E4%BD%95%E8%83%BD%E5%87%8F%E5%B0%91%E8%A1%8C%E4%B8%BA%E6%9C%AA%E6%9D%A5%E5%8F%91%E7%94%9F%E6%A6%82%E7%8E%87%E7%9A%84%E4%BA%8B%E4%BB%B6%E3%80%82%3C/span%3E" _note="" _mubu_note="">
              <outline text="惩罚物 (Punisher)：能减少行为概率的刺激物本身（如电击、责骂）。" _mubu_text="%3Cspan%3E%E6%83%A9%E7%BD%9A%E7%89%A9%20(Punisher)%EF%BC%9A%E8%83%BD%E5%87%8F%E5%B0%91%E8%A1%8C%E4%B8%BA%E6%A6%82%E7%8E%87%E7%9A%84%E5%88%BA%E6%BF%80%E7%89%A9%E6%9C%AC%E8%BA%AB%EF%BC%88%E5%A6%82%E7%94%B5%E5%87%BB%E3%80%81%E8%B4%A3%E9%AA%82%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="正惩罚 (Positive Punishment)" _mubu_text="%3Cspan%3E%E6%AD%A3%E6%83%A9%E7%BD%9A%20(Positive%20Punishment)%3C/span%3E" _note="" _mubu_note="">
              <outline text="“加坏”。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E2%80%9C%E5%8A%A0%E5%9D%8F%E2%80%9D%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="例如：孩子打人后被罚站（加不愉快体验）、超速行驶收到罚单（加经济损失）。" _mubu_text="%3Cspan%3E%E4%BE%8B%E5%A6%82%EF%BC%9A%E5%AD%A9%E5%AD%90%E6%89%93%E4%BA%BA%E5%90%8E%E8%A2%AB%E7%BD%9A%E7%AB%99%EF%BC%88%E5%8A%A0%E4%B8%8D%E6%84%89%E5%BF%AB%E4%BD%93%E9%AA%8C%EF%BC%89%E3%80%81%E8%B6%85%E9%80%9F%E8%A1%8C%E9%A9%B6%E6%94%B6%E5%88%B0%E7%BD%9A%E5%8D%95%EF%BC%88%E5%8A%A0%E7%BB%8F%E6%B5%8E%E6%8D%9F%E5%A4%B1%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="正惩罚是通过在行为后呈现令人厌恶的刺激来减少该行为。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%AD%A3%E6%83%A9%E7%BD%9A%E6%98%AF%E9%80%9A%E8%BF%87%E5%9C%A8%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%90%8E%E5%91%88%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%8E%B0%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E4%BB%A4%E4%BA%BA%E5%8E%8C%E6%81%B6%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%9A%84%E5%88%BA%E6%BF%80%E6%9D%A5%3C/span%3E%3Cspan%20class=%22bold%20highlight-cyan%22%3E%E5%87%8F%E5%B0%91%E8%AF%A5%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="负惩罚 (Negative Punishment)" _mubu_text="%3Cspan%3E%E8%B4%9F%E6%83%A9%E7%BD%9A%20(Negative%20Punishment)%3C/span%3E" _note="" _mubu_note="">
              <outline text="“减好”。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E2%80%9C%E5%87%8F%E5%A5%BD%E2%80%9D%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="例如：孩子打架后被没收玩具（移除喜好物）、球员犯规被罚下场（移除比赛机会）。" _mubu_text="%3Cspan%3E%E4%BE%8B%E5%A6%82%EF%BC%9A%E5%AD%A9%E5%AD%90%E6%89%93%E6%9E%B6%E5%90%8E%E8%A2%AB%E6%B2%A1%E6%94%B6%E7%8E%A9%E5%85%B7%EF%BC%88%E7%A7%BB%E9%99%A4%E5%96%9C%E5%A5%BD%E7%89%A9%EF%BC%89%E3%80%81%E7%90%83%E5%91%98%E7%8A%AF%E8%A7%84%E8%A2%AB%E7%BD%9A%E4%B8%8B%E5%9C%BA%EF%BC%88%E7%A7%BB%E9%99%A4%E6%AF%94%E8%B5%9B%E6%9C%BA%E4%BC%9A%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="负惩罚是通过在行为后移除令人愉悦的刺激来减少该行为。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%B4%9F%E6%83%A9%E7%BD%9A%E6%98%AF%E9%80%9A%E8%BF%87%E5%9C%A8%E8%A1%8C%E4%B8%BA%E5%90%8E%3C/span%3E%3Cspan%20class=%22bold%20text-color-purple%22%3E%E7%A7%BB%E9%99%A4%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BB%A4%E4%BA%BA%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E6%84%89%E6%82%A6%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%9A%84%E5%88%BA%E6%BF%80%E6%9D%A5%3C/span%3E%3Cspan%20class=%22bold%20highlight-cyan%22%3E%E5%87%8F%E5%B0%91%E8%AF%A5%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="|  | 目标：增加行为 (Increase) | 目标：减少行为 (Decrease) |
| --- | --- | --- |
| 呈现某物 (Present) | 正强化 (Positive Reinforcement)（加好） | 正惩罚 (Positive Punishment)（加坏） |
| 移除某物 (Remove) | 负强化 (Negative Reinforcement)（减坏） | 负惩罚 (Negative Punishment)（减好） |" _mubu_text="%3Cdiv%20class=%22table-container%22%3E%3Ctable%20class=%22auto-table%22%20border=%221%22%20cellspacing=%220%22%20style=%22border-collapse:%20collapse;%22%3E%3Cthead%3E%3Ctr%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%220%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%220%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%221%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cb%3E%E7%9B%AE%E6%A0%87%EF%BC%9A%E5%A2%9E%E5%8A%A0%E8%A1%8C%E4%B8%BA%20(Increase)%3C/b%3E%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%222%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cb%3E%E7%9B%AE%E6%A0%87%EF%BC%9A%E5%87%8F%E5%B0%91%E8%A1%8C%E4%B8%BA%20(Decrease)%3C/b%3E%3C/span%3E%3C/th%3E%3C/tr%3E%3C/thead%3E%3Ctbody%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%221%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cb%3E%E5%91%88%E7%8E%B0%E6%9F%90%E7%89%A9%20(Present)%3C/b%3E%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E6%AD%A3%E5%BC%BA%E5%8C%96%20(Positive%20Reinforcement)%EF%BC%88%E5%8A%A0%E5%A5%BD%EF%BC%89%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E6%AD%A3%E6%83%A9%E7%BD%9A%20(Positive%20Punishment)%EF%BC%88%E5%8A%A0%E5%9D%8F%EF%BC%89%3C/span%3E%3C/td%3E%3C/tr%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%222%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cb%3E%E7%A7%BB%E9%99%A4%E6%9F%90%E7%89%A9%20(Remove)%3C/b%3E%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E8%B4%9F%E5%BC%BA%E5%8C%96%20(Negative%20Reinforcement)%EF%BC%88%E5%87%8F%E5%9D%8F%EF%BC%89%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E8%B4%9F%E6%83%A9%E7%BD%9A%20(Negative%20Punishment)%EF%BC%88%E5%87%8F%E5%A5%BD%EF%BC%89%3C/span%3E%3C/td%3E%3C/tr%3E%3C/tbody%3E%3C/table%3E%3C/div%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Primary vs. Secondary Reinforcer" _mubu_text="%3Cspan%3EPrimary%20vs.%20Secondary%20Reinforcer%3C/span%3E" _note="" _mubu_note="">
          <outline text="Primary - 食物，水，睡眠，sex；强化作用不用学习" _mubu_text="%3Cspan%3EPrimary%20-%20%E9%A3%9F%E7%89%A9%EF%BC%8C%E6%B0%B4%EF%BC%8C%E7%9D%A1%E7%9C%A0%EF%BC%8Csex%EF%BC%9B%E5%BC%BA%E5%8C%96%E4%BD%9C%E7%94%A8%E4%B8%8D%E7%94%A8%E5%AD%A6%E4%B9%A0%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Secondary - 钱 分数 小红花；带来食物、认可、换成奖励；需要学习" _mubu_text="%3Cspan%3ESecondary%20-%20%E9%92%B1%20%E5%88%86%E6%95%B0%20%E5%B0%8F%E7%BA%A2%E8%8A%B1%EF%BC%9B%E5%B8%A6%E6%9D%A5%E9%A3%9F%E7%89%A9%E3%80%81%E8%AE%A4%E5%8F%AF%E3%80%81%E6%8D%A2%E6%88%90%E5%A5%96%E5%8A%B1%EF%BC%9B%E9%9C%80%E8%A6%81%E5%AD%A6%E4%B9%A0%3C/span%3E" _note="Token Economy" _mubu_note="%3Cspan%3EToken%20Economy%3C/span%3E"/>
        </outline>
        <outline text="复杂行为" _mubu_text="%3Cspan%3E%E5%A4%8D%E6%9D%82%E8%A1%8C%E4%B8%BA%3C/span%3E" _note="" _mubu_note="">
          <outline text="Shaping" _mubu_text="%3Cspan%3EShaping%3C/span%3E" _note="" _mubu_note="">
            <outline text="一步一步，closer and closer" _mubu_text="%3Cspan%3E%E4%B8%80%E6%AD%A5%E4%B8%80%E6%AD%A5%EF%BC%8Ccloser%20and%20closer%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Instinctive Drift" _mubu_text="%3Cspan%3EInstinctive%20Drift%3C/span%3E" _note="" _mubu_note="">
            <outline text="本能漂移" _mubu_text="%3Cspan%3E%E6%9C%AC%E8%83%BD%E6%BC%82%E7%A7%BB%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="有句话怎么说来着：「狗改不了CS的毛病」" _mubu_text="%3Cspan%3E%E6%9C%89%E5%8F%A5%E8%AF%9D%E6%80%8E%E4%B9%88%E8%AF%B4%E6%9D%A5%E7%9D%80%EF%BC%9A%E3%80%8C%E7%8B%97%E6%94%B9%E4%B8%8D%E4%BA%86CS%E7%9A%84%E6%AF%9B%E7%97%85%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Learned Helplessness" _mubu_text="%3Cspan%3ELearned%20Helplessness%3C/span%3E" _note="" _mubu_note="">
            <outline text="习得性无助" _mubu_text="%3Cspan%3E%E4%B9%A0%E5%BE%97%E6%80%A7%E6%97%A0%E5%8A%A9%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="反正努力也没结果，不如摆烂了；可能感受更好 - 以后遇到挑战直接放弃" _mubu_text="%3Cspan%3E%E5%8F%8D%E6%AD%A3%E5%8A%AA%E5%8A%9B%E4%B9%9F%E6%B2%A1%E7%BB%93%E6%9E%9C%EF%BC%8C%E4%B8%8D%E5%A6%82%E6%91%86%E7%83%82%E4%BA%86%EF%BC%9B%E5%8F%AF%E8%83%BD%E6%84%9F%E5%8F%97%E6%9B%B4%E5%A5%BD%20-%20%E4%BB%A5%E5%90%8E%E9%81%87%E5%88%B0%E6%8C%91%E6%88%98%E7%9B%B4%E6%8E%A5%E6%94%BE%E5%BC%83%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Superstitious Behavior" _mubu_text="%3Cspan%3ESuperstitious%20Behavior%3C/span%3E" _note="" _mubu_note="">
            <outline text="迷信 = 强化物偶然跟随某个行为出现，个体误判导致该行为重复出现" _mubu_text="%3Cspan%3E%E8%BF%B7%E4%BF%A1%20=%20%E5%BC%BA%E5%8C%96%E7%89%A9%E5%81%B6%E7%84%B6%E8%B7%9F%E9%9A%8F%E6%9F%90%E4%B8%AA%E8%A1%8C%E4%B8%BA%E5%87%BA%E7%8E%B0%EF%BC%8C%E4%B8%AA%E4%BD%93%E8%AF%AF%E5%88%A4%E5%AF%BC%E8%87%B4%E8%AF%A5%E8%A1%8C%E4%B8%BA%E9%87%8D%E5%A4%8D%E5%87%BA%E7%8E%B0%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Schedules of Reinforcement" _mubu_text="%3Cspan%3ESchedules%20of%20Reinforcement%3C/span%3E" _note="" _mubu_note="">
          <outline text="1. 连续强化 vs. 部分强化 (Continuous vs. Partial Reinforcement)" _mubu_text="%3Cspan%3E1.%20%E8%BF%9E%E7%BB%AD%E5%BC%BA%E5%8C%96%20vs.%20%E9%83%A8%E5%88%86%E5%BC%BA%E5%8C%96%20(Continuous%20vs.%20Partial%20Reinforcement)%3C/span%3E" _note="" _mubu_note="">
            <outline text="连续强化 (Continuous Reinforcement)" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E8%BF%9E%E7%BB%AD%3C/span%3E%3Cspan%3E%E5%BC%BA%E5%8C%96%20(Continuous%20Reinforcement)%3C/span%3E" _note="" _mubu_note="">
              <outline text="每次目标行为出现都给予强化。" _mubu_text="%3Cspan%3E%E6%AF%8F%E6%AC%A1%E7%9B%AE%E6%A0%87%E8%A1%8C%E4%B8%BA%E5%87%BA%E7%8E%B0%E9%83%BD%E7%BB%99%E4%BA%88%E5%BC%BA%E5%8C%96%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="优点：习得新行为最快。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BC%98%E7%82%B9%EF%BC%9A%E4%B9%A0%E5%BE%97%E6%96%B0%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E6%9C%80%E5%BF%AB%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="缺点：消退最快。一旦强化停止，行为迅速消失。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%BC%BA%E7%82%B9%EF%BC%9A%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E6%B6%88%E9%80%80%E6%9C%80%E5%BF%AB%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%82%E4%B8%80%E6%97%A6%E5%BC%BA%E5%8C%96%E5%81%9C%E6%AD%A2%EF%BC%8C%E8%A1%8C%E4%B8%BA%E8%BF%85%E9%80%9F%E6%B6%88%E5%A4%B1%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="（做的真好，每次都奖励你一个小星星）" _mubu_text="%3Cspan%3E%EF%BC%88%E5%81%9A%E7%9A%84%E7%9C%9F%E5%A5%BD%EF%BC%8C%E6%AF%8F%E6%AC%A1%E9%83%BD%E5%A5%96%E5%8A%B1%E4%BD%A0%E4%B8%80%E4%B8%AA%E5%B0%8F%E6%98%9F%E6%98%9F%EF%BC%89%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22iNg5Y5cAxf%22%2C%22oh%22%3A321%2C%22ow%22%3A496%2C%22uri%22%3A%22document_image%2F33585682_e7035302-c7f1-473d-dd68-1070176edee2.png%22%2C%22w%22%3A264%7D%5D"/>
              <outline text="（如投币饮料机，一次不出就再也不用了）。" _mubu_text="%3Cspan%3E%EF%BC%88%E5%A6%82%E6%8A%95%E5%B8%81%E9%A5%AE%E6%96%99%E6%9C%BA%EF%BC%8C%E4%B8%80%E6%AC%A1%E4%B8%8D%E5%87%BA%E5%B0%B1%E5%86%8D%E4%B9%9F%E4%B8%8D%E7%94%A8%E4%BA%86%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="部分强化 (Partial/Intermittent Reinforcement)" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E9%83%A8%E5%88%86%3C/span%3E%3Cspan%3E%E5%BC%BA%E5%8C%96%20(Partial/Intermittent%20Reinforcement)%3C/span%3E" _note="" _mubu_note="">
              <outline text="只对部分出现的目标行为给予强化。" _mubu_text="%3Cspan%3E%E5%8F%AA%E5%AF%B9%E9%83%A8%E5%88%86%E5%87%BA%E7%8E%B0%E7%9A%84%E7%9B%AE%E6%A0%87%E8%A1%8C%E4%B8%BA%E7%BB%99%E4%BA%88%E5%BC%BA%E5%8C%96%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="优点：习得后，行为抗消退能力极强，更持久。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BC%98%E7%82%B9%EF%BC%9A%E4%B9%A0%E5%BE%97%E5%90%8E%EF%BC%8C%E8%A1%8C%E4%B8%BA%E6%8A%97%E6%B6%88%E9%80%80%E8%83%BD%E5%8A%9B%E6%9E%81%E5%BC%BA%EF%BC%8C%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E6%9B%B4%E6%8C%81%E4%B9%85%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="（如老虎机，即使很久不中奖，人们仍会尝试）" _mubu_text="%3Cspan%3E%EF%BC%88%E5%A6%82%E8%80%81%E8%99%8E%E6%9C%BA%EF%BC%8C%E5%8D%B3%E4%BD%BF%E5%BE%88%E4%B9%85%E4%B8%8D%E4%B8%AD%E5%A5%96%EF%BC%8C%E4%BA%BA%E4%BB%AC%E4%BB%8D%E4%BC%9A%E5%B0%9D%E8%AF%95%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="缺点：习得新行为较慢。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%BC%BA%E7%82%B9%EF%BC%9A%E4%B9%A0%E5%BE%97%E6%96%B0%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E8%BE%83%E6%85%A2%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="2. Four Types of Partial Reinforcement 四类部分强化" _mubu_text="%3Cspan%3E2.%20Four%20Types%20of%20Partial%20Reinforcement%20%E5%9B%9B%E7%B1%BB%E9%83%A8%E5%88%86%E5%BC%BA%E5%8C%96%3C/span%3E" _note="" _mubu_note="">
            <outline text="|  | Fixed | Variable |
| --- | --- | --- |
| Ratio | 在固定次数的反应后强化。Control frequency, short pauses；计件工资（每做50个得$20）；买十杯咖啡送一杯。 | 在平均次数但不可预测的反应后强化。几乎无停顿，最能维持行为；赌博（老虎机）；钓鱼；抽卡游戏。 |
| Interval​ | 在固定时间间隔后，第一次反应被强化。强化后反应率很低，接近下次强化时间时，反应率急剧上升。按月发工资；每周/每月测验（考前突击）。 | 在平均时间但不可预测的间隔后，第一次反应被强化。中等但稳定的反应率，反应持久且均匀；随堂测验 (Pop Quiz)；查看社交媒体（不知道何时会收到点赞或回复）；等快递电话。 |" _mubu_text="%3Cdiv%20class=%22table-container%22%3E%3Ctable%20class=%22auto-table%22%20border=%221%22%20cellspacing=%220%22%20style=%22border-collapse:%20collapse;%22%3E%3Cthead%3E%3Ctr%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%220%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%220%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%221%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3EFixed%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%222%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3EVariable%3C/span%3E%3C/th%3E%3C/tr%3E%3C/thead%3E%3Ctbody%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%221%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3ERatio%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E5%9C%A8%E5%9B%BA%E5%AE%9A%E6%AC%A1%E6%95%B0%E7%9A%84%E5%8F%8D%E5%BA%94%E5%90%8E%E5%BC%BA%E5%8C%96%E3%80%82Control%20frequency,%20short%20pauses%EF%BC%9B%E8%AE%A1%E4%BB%B6%E5%B7%A5%E8%B5%84%EF%BC%88%E6%AF%8F%E5%81%9A50%E4%B8%AA%E5%BE%97$20%EF%BC%89%EF%BC%9B%E4%B9%B0%E5%8D%81%E6%9D%AF%E5%92%96%E5%95%A1%E9%80%81%E4%B8%80%E6%9D%AF%E3%80%82%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E5%9C%A8%E5%B9%B3%E5%9D%87%E6%AC%A1%E6%95%B0%E4%BD%86%E4%B8%8D%E5%8F%AF%E9%A2%84%E6%B5%8B%E7%9A%84%E5%8F%8D%E5%BA%94%E5%90%8E%E5%BC%BA%E5%8C%96%E3%80%82%E5%87%A0%E4%B9%8E%E6%97%A0%E5%81%9C%E9%A1%BF%EF%BC%8C%E6%9C%80%E8%83%BD%E7%BB%B4%E6%8C%81%E8%A1%8C%E4%B8%BA%EF%BC%9B%E8%B5%8C%E5%8D%9A%EF%BC%88%E8%80%81%E8%99%8E%E6%9C%BA%EF%BC%89%EF%BC%9B%E9%92%93%E9%B1%BC%EF%BC%9B%E6%8A%BD%E5%8D%A1%E6%B8%B8%E6%88%8F%E3%80%82%3C/span%3E%3C/td%3E%3C/tr%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%222%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3EInterval%E2%80%8B%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E5%9C%A8%E5%9B%BA%E5%AE%9A%E6%97%B6%E9%97%B4%E9%97%B4%E9%9A%94%E5%90%8E%EF%BC%8C%E7%AC%AC%E4%B8%80%E6%AC%A1%E5%8F%8D%E5%BA%94%E8%A2%AB%E5%BC%BA%E5%8C%96%E3%80%82%E5%BC%BA%E5%8C%96%E5%90%8E%E5%8F%8D%E5%BA%94%E7%8E%87%E5%BE%88%E4%BD%8E%EF%BC%8C%E6%8E%A5%E8%BF%91%E4%B8%8B%E6%AC%A1%E5%BC%BA%E5%8C%96%E6%97%B6%E9%97%B4%E6%97%B6%EF%BC%8C%E5%8F%8D%E5%BA%94%E7%8E%87%E6%80%A5%E5%89%A7%E4%B8%8A%E5%8D%87%E3%80%82%E6%8C%89%E6%9C%88%E5%8F%91%E5%B7%A5%E8%B5%84%EF%BC%9B%E6%AF%8F%E5%91%A8/%E6%AF%8F%E6%9C%88%E6%B5%8B%E9%AA%8C%EF%BC%88%E8%80%83%E5%89%8D%E7%AA%81%E5%87%BB%EF%BC%89%E3%80%82%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E5%9C%A8%E5%B9%B3%E5%9D%87%E6%97%B6%E9%97%B4%E4%BD%86%E4%B8%8D%E5%8F%AF%E9%A2%84%E6%B5%8B%E7%9A%84%E9%97%B4%E9%9A%94%E5%90%8E%EF%BC%8C%E7%AC%AC%E4%B8%80%E6%AC%A1%E5%8F%8D%E5%BA%94%E8%A2%AB%E5%BC%BA%E5%8C%96%E3%80%82%E4%B8%AD%E7%AD%89%E4%BD%86%E7%A8%B3%E5%AE%9A%E7%9A%84%E5%8F%8D%E5%BA%94%E7%8E%87%EF%BC%8C%E5%8F%8D%E5%BA%94%E6%8C%81%E4%B9%85%E4%B8%94%E5%9D%87%E5%8C%80%EF%BC%9B%E9%9A%8F%E5%A0%82%E6%B5%8B%E9%AA%8C%20(Pop%20Quiz)%EF%BC%9B%E6%9F%A5%E7%9C%8B%E7%A4%BE%E4%BA%A4%E5%AA%92%E4%BD%93%EF%BC%88%E4%B8%8D%E7%9F%A5%E9%81%93%E4%BD%95%E6%97%B6%E4%BC%9A%E6%94%B6%E5%88%B0%E7%82%B9%E8%B5%9E%E6%88%96%E5%9B%9E%E5%A4%8D%EF%BC%89%EF%BC%9B%E7%AD%89%E5%BF%AB%E9%80%92%E7%94%B5%E8%AF%9D%E3%80%82%3C/span%3E%3C/td%3E%3C/tr%3E%3C/tbody%3E%3C/table%3E%3C/div%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
      </outline>
    </outline>
    <outline text="Unit 4" _mubu_text="%3Cspan%3EUnit%204%3C/span%3E" _note="" _mubu_note="">
      <outline text="4.1 Attribution Theory" _mubu_text="%3Cspan%3E4.1%20Attribution%20Theory%3C/span%3E" _note="" _mubu_note="">
        <outline text="什么是 Attribution" _mubu_text="%3Cspan%3E%E4%BB%80%E4%B9%88%E6%98%AF%20Attribution%3C/span%3E" _note="" _mubu_note="">
          <outline text="我们如何解释事情发生的原因，或者如何解释某人的行为。" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E5%A6%82%E4%BD%95%E8%A7%A3%E9%87%8A%E4%BA%8B%E6%83%85%E5%8F%91%E7%94%9F%E7%9A%84%E5%8E%9F%E5%9B%A0%EF%BC%8C%E6%88%96%E8%80%85%E5%A6%82%E4%BD%95%E8%A7%A3%E9%87%8A%E6%9F%90%E4%BA%BA%E7%9A%84%E8%A1%8C%E4%B8%BA%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="两种方向 Dispositional（性格/内部） &amp; Situational （情景/外部）" _mubu_text="%3Cspan%3E%E4%B8%A4%E7%A7%8D%E6%96%B9%E5%90%91%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3EDispositional%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%80%A7%E6%A0%BC/%E5%86%85%E9%83%A8%3C/span%3E%3Cspan%3E%EF%BC%89%20&amp;amp;%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3ESituational%20%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%83%85%E6%99%AF/%E5%A4%96%E9%83%A8%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="Dispositional Attribution (性格归因/内部归因)" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EDispositional%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EAttribution%3C/span%3E%3Cspan%3E%20(%E6%80%A7%E6%A0%BC%E5%BD%92%E5%9B%A0/%E5%86%85%E9%83%A8%E5%BD%92%E5%9B%A0)%3C/span%3E" _note="" _mubu_note="">
              <outline text="认为行为是由人的内部特质决定的（例如：性格、智商、动机）。" _mubu_text="%3Cspan%3E%E8%AE%A4%E4%B8%BA%E8%A1%8C%E4%B8%BA%E6%98%AF%E7%94%B1%E4%BA%BA%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%86%85%E9%83%A8%E7%89%B9%E8%B4%A8%3C/span%3E%3Cspan%3E%E5%86%B3%E5%AE%9A%E7%9A%84%EF%BC%88%E4%BE%8B%E5%A6%82%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%80%A7%E6%A0%BC%E3%80%81%E6%99%BA%E5%95%86%E3%80%81%E5%8A%A8%E6%9C%BA%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="例子： 他考试考得好，是因为他聪明。" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E4%BE%8B%E5%AD%90%EF%BC%9A%20%3C/span%3E%3Cspan%3E%E4%BB%96%E8%80%83%E8%AF%95%E8%80%83%E5%BE%97%E5%A5%BD%EF%BC%8C%E6%98%AF%E5%9B%A0%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%BB%96%E8%81%AA%E6%98%8E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Situational Attribution (情境归因/外部归因)" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3ESituational%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EAttribution%3C/span%3E%3Cspan%3E%20(%E6%83%85%E5%A2%83%E5%BD%92%E5%9B%A0/%E5%A4%96%E9%83%A8%E5%BD%92%E5%9B%A0)%3C/span%3E" _note="" _mubu_note="">
              <outline text="认为行为是由外部环境决定的。" _mubu_text="%3Cspan%3E%E8%AE%A4%E4%B8%BA%E8%A1%8C%E4%B8%BA%E6%98%AF%E7%94%B1%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%96%E9%83%A8%E7%8E%AF%E5%A2%83%3C/span%3E%3Cspan%3E%E5%86%B3%E5%AE%9A%E7%9A%84%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="例子： 他考试考得好，是因为这次题目简单。" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E4%BE%8B%E5%AD%90%EF%BC%9A%20%3C/span%3E%3Cspan%3E%E4%BB%96%E8%80%83%E8%AF%95%E8%80%83%E5%BE%97%E5%A5%BD%EF%BC%8C%E6%98%AF%E5%9B%A0%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%BF%99%E6%AC%A1%E9%A2%98%E7%9B%AE%E7%AE%80%E5%8D%95%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="归因偏差 Attribution Bias（FAE、AOB、Self-Serving、公平世界）" _mubu_text="%3Cspan%3E%E5%BD%92%E5%9B%A0%E5%81%8F%E5%B7%AE%20Attribution%20Bias%EF%BC%88FAE%E3%80%81AOB%E3%80%81Self-Serving%E3%80%81%E5%85%AC%E5%B9%B3%E4%B8%96%E7%95%8C%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="因为大脑喜欢偷懒，我们在归因时经常会犯错，这就导致了偏差。" _mubu_text="%3Cspan%3E%E5%9B%A0%E4%B8%BA%E5%A4%A7%E8%84%91%E5%96%9C%E6%AC%A2%E5%81%B7%E6%87%92%EF%BC%8C%E6%88%91%E4%BB%AC%E5%9C%A8%E5%BD%92%E5%9B%A0%E6%97%B6%E7%BB%8F%E5%B8%B8%E4%BC%9A%E7%8A%AF%E9%94%99%EF%BC%8C%E8%BF%99%E5%B0%B1%E5%AF%BC%E8%87%B4%E4%BA%86%E5%81%8F%E5%B7%AE%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="FAE Fundamental Attribution Error（高估他人性格，忽视他人困难）" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EFAE%20%3C/span%3E%3Cspan%20class=%22bold%22%3EFundamental%20Attribution%20Error%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%EF%BC%88%E9%AB%98%E4%BC%B0%E4%BB%96%E4%BA%BA%E6%80%A7%E6%A0%BC%EF%BC%8C%E5%BF%BD%E8%A7%86%E4%BB%96%E4%BA%BA%E5%9B%B0%E9%9A%BE%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="看别人时，会高估 Dispositional 因素，低估 Situational 因素。" _mubu_text="%3Cspan%3E%E7%9C%8B%E5%88%AB%E4%BA%BA%E6%97%B6%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%BC%9A%E9%AB%98%E4%BC%B0%20Dispositional%20%E5%9B%A0%E7%B4%A0%EF%BC%8C%E4%BD%8E%E4%BC%B0%20Situational%20%E5%9B%A0%E7%B4%A0%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="如果别人搞砸了，我们通常觉得是“他这个人有问题”，而不是“他遇到了困难”。" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E5%88%AB%E4%BA%BA%E6%90%9E%E7%A0%B8%E4%BA%86%EF%BC%8C%E6%88%91%E4%BB%AC%E9%80%9A%E5%B8%B8%E8%A7%89%E5%BE%97%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E2%80%9C%E4%BB%96%E8%BF%99%E4%B8%AA%E4%BA%BA%E6%9C%89%E9%97%AE%E9%A2%98%E2%80%9D%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%80%8C%E4%B8%8D%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E2%80%9C%E4%BB%96%E9%81%87%E5%88%B0%E4%BA%86%E5%9B%B0%E9%9A%BE%E2%80%9D%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="行动-观察偏差 Actor-Observer Bias（双标）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A1%8C%E5%8A%A8-%E8%A7%82%E5%AF%9F%E5%81%8F%E5%B7%AE%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EActor-Observer%3C/span%3E%3Cspan%20class=%22bold%22%3E%20Bias%3C/span%3E%3Cspan%20class=%22bold%20text-color-purple%22%3E%EF%BC%88%E5%8F%8C%E6%A0%87%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="我们是行动者——归因环境；我们是观察者——归因性格" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%A1%8C%E5%8A%A8%E8%80%85%3C/span%3E%3Cspan%3E%E2%80%94%E2%80%94%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BD%92%E5%9B%A0%E7%8E%AF%E5%A2%83%3C/span%3E%3Cspan%3E%EF%BC%9B%E6%88%91%E4%BB%AC%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%A7%82%E5%AF%9F%E8%80%85%3C/span%3E%3Cspan%3E%E2%80%94%E2%80%94%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BD%92%E5%9B%A0%E6%80%A7%E6%A0%BC%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="迟到的是自己「堵车」，迟到的是别人「没有时间观念」" _mubu_text="%3Cspan%3E%E8%BF%9F%E5%88%B0%E7%9A%84%E6%98%AF%E8%87%AA%E5%B7%B1%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E3%80%8C%E5%A0%B5%E8%BD%A6%E3%80%8D%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%BF%9F%E5%88%B0%E7%9A%84%E6%98%AF%E5%88%AB%E4%BA%BA%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E3%80%8C%E6%B2%A1%E6%9C%89%E6%97%B6%E9%97%B4%E8%A7%82%E5%BF%B5%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="你自己迟到（Actor）：是因为前面那辆车开太慢了（环境）。" _mubu_text="%3Cspan%3E%E4%BD%A0%E8%87%AA%E5%B7%B1%E8%BF%9F%E5%88%B0%EF%BC%88Actor%EF%BC%89%EF%BC%9A%E6%98%AF%E5%9B%A0%E4%B8%BA%E5%89%8D%E9%9D%A2%E9%82%A3%E8%BE%86%E8%BD%A6%E5%BC%80%E5%A4%AA%E6%85%A2%E4%BA%86%EF%BC%88%E7%8E%AF%E5%A2%83%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="同学迟到（Observer）：是因为他懒，没时间观念（性格）。" _mubu_text="%3Cspan%3E%E5%90%8C%E5%AD%A6%E8%BF%9F%E5%88%B0%EF%BC%88Observer%EF%BC%89%EF%BC%9A%E6%98%AF%E5%9B%A0%E4%B8%BA%E4%BB%96%E6%87%92%EF%BC%8C%E6%B2%A1%E6%97%B6%E9%97%B4%E8%A7%82%E5%BF%B5%EF%BC%88%E6%80%A7%E6%A0%BC%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="区别 FAE：FAE讲的是怎么看别人，AOB讲的是自己的双标" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E5%8C%BA%E5%88%AB%20FAE%EF%BC%9A%3C/span%3E%3Cspan%20class=%22bold%22%3EFAE%E8%AE%B2%E7%9A%84%E6%98%AF%E6%80%8E%E4%B9%88%E7%9C%8B%E5%88%AB%E4%BA%BA%EF%BC%8CAOB%E8%AE%B2%E7%9A%84%E6%98%AF%E8%87%AA%E5%B7%B1%E7%9A%84%E5%8F%8C%E6%A0%87%3C/span%3E" _note="" _mubu_note="">
              <outline text="FAE 专注讲“怎么看别人”，Actor-Observer 专注讲“看自己和看别人的双标”。" _mubu_text="%3Cspan%3EFAE%20%E4%B8%93%E6%B3%A8%E8%AE%B2%E2%80%9C%E6%80%8E%E4%B9%88%E7%9C%8B%E5%88%AB%E4%BA%BA%E2%80%9D%EF%BC%8CActor-Observer%20%E4%B8%93%E6%B3%A8%E8%AE%B2%E2%80%9C%E7%9C%8B%E8%87%AA%E5%B7%B1%E5%92%8C%E7%9C%8B%E5%88%AB%E4%BA%BA%E7%9A%84%E5%8F%8C%E6%A0%87%E2%80%9D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="自利偏见 Self-Serving Bias（我成功是因为我厉害，我失败是因为被人害）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E5%88%A9%E5%81%8F%E8%A7%81%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESelf-Serving%20Bias%3C/span%3E%3Cspan%3E%EF%BC%88%E6%88%91%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%88%90%E5%8A%9F%3C/span%3E%3Cspan%3E%E6%98%AF%E5%9B%A0%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%88%91%E5%8E%89%E5%AE%B3%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%88%91%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%A4%B1%E8%B4%A5%3C/span%3E%3Cspan%3E%E6%98%AF%E5%9B%A0%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A2%AB%E4%BA%BA%E5%AE%B3%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="成功时：归因于自己（我很棒，我努力）。" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E6%88%90%E5%8A%9F%E6%97%B6%3C/span%3E%3Cspan%3E%EF%BC%9A%E5%BD%92%E5%9B%A0%E4%BA%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%87%AA%E5%B7%B1%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%88%91%E5%BE%88%E6%A3%92%EF%BC%8C%E6%88%91%E5%8A%AA%E5%8A%9B%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="失败时：归因于外界（老师教得烂，运气不好）。" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E5%A4%B1%E8%B4%A5%E6%97%B6%3C/span%3E%3Cspan%3E%EF%BC%9A%E5%BD%92%E5%9B%A0%E4%BA%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%96%E7%95%8C%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%80%81%E5%B8%88%E6%95%99%E5%BE%97%E7%83%82%EF%BC%8C%E8%BF%90%E6%B0%94%E4%B8%8D%E5%A5%BD%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="比如AP考试中" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E6%AF%94%E5%A6%82AP%E8%80%83%E8%AF%95%E4%B8%AD%3C/span%3E" _note="" _mubu_note="">
              <outline text="AP考了5分：“哎呀，我这学期真是太刻苦了，我是天才。”" _mubu_text="%3Cspan%3EAP%E8%80%83%E4%BA%865%E5%88%86%EF%BC%9A%E2%80%9C%E5%93%8E%E5%91%80%EF%BC%8C%E6%88%91%E8%BF%99%E5%AD%A6%E6%9C%9F%E7%9C%9F%E6%98%AF%E5%A4%AA%E5%88%BB%E8%8B%A6%E4%BA%86%EF%BC%8C%E6%88%91%E6%98%AF%E5%A4%A9%E6%89%8D%E3%80%82%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="考了2分：“这题目出得太偏了，而且那天考场空调太冷。”" _mubu_text="%3Cspan%3E%E8%80%83%E4%BA%862%E5%88%86%EF%BC%9A%E2%80%9C%E8%BF%99%E9%A2%98%E7%9B%AE%E5%87%BA%E5%BE%97%E5%A4%AA%E5%81%8F%E4%BA%86%EF%BC%8C%E8%80%8C%E4%B8%94%E9%82%A3%E5%A4%A9%E8%80%83%E5%9C%BA%E7%A9%BA%E8%B0%83%E5%A4%AA%E5%86%B7%E3%80%82%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="保护自尊心" _mubu_text="%3Cspan%20class=%22text-color-purple%22%3E%E4%BF%9D%E6%8A%A4%E8%87%AA%E5%B0%8A%E5%BF%83%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="善有善报 Just-World Phenomenon" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%96%84%E6%9C%89%E5%96%84%E6%8A%A5%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EJust-World%20Phenomenon%3C/span%3E" _note="" _mubu_note="">
            <outline text="如果一个人遭遇不幸，人们倾向于认为是他“活该”或做错了什么。" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E4%B8%80%E4%B8%AA%E4%BA%BA%E9%81%AD%E9%81%87%E4%B8%8D%E5%B9%B8%EF%BC%8C%E4%BA%BA%E4%BB%AC%E5%80%BE%E5%90%91%E4%BA%8E%E8%AE%A4%E4%B8%BA%E6%98%AF%E4%BB%96%E2%80%9C%E6%B4%BB%E8%AF%A5%E2%80%9D%E6%88%96%E5%81%9A%E9%94%99%E4%BA%86%E4%BB%80%E4%B9%88%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="这通常会导致 Blaming the victim 受害者有罪论。" _mubu_text="%3Cspan%3E%E8%BF%99%E9%80%9A%E5%B8%B8%E4%BC%9A%E5%AF%BC%E8%87%B4%20Blaming%20the%20victim%20%E5%8F%97%E5%AE%B3%E8%80%85%E6%9C%89%E7%BD%AA%E8%AE%BA%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="看到路边的乞丐，你会想：“他肯定是年轻时不努力工作，或者吸毒了”，而不是想他可能遭遇了经济危机。以此来让自己觉得世界是公平的，自己很安全。" _mubu_text="%3Cspan%3E%E7%9C%8B%E5%88%B0%E8%B7%AF%E8%BE%B9%E7%9A%84%E4%B9%9E%E4%B8%90%EF%BC%8C%E4%BD%A0%E4%BC%9A%E6%83%B3%EF%BC%9A%E2%80%9C%E4%BB%96%E8%82%AF%E5%AE%9A%E6%98%AF%E5%B9%B4%E8%BD%BB%E6%97%B6%E4%B8%8D%E5%8A%AA%E5%8A%9B%E5%B7%A5%E4%BD%9C%EF%BC%8C%E6%88%96%E8%80%85%E5%90%B8%E6%AF%92%E4%BA%86%E2%80%9D%EF%BC%8C%E8%80%8C%E4%B8%8D%E6%98%AF%E6%83%B3%E4%BB%96%E5%8F%AF%E8%83%BD%E9%81%AD%E9%81%87%E4%BA%86%E7%BB%8F%E6%B5%8E%E5%8D%B1%E6%9C%BA%E3%80%82%E4%BB%A5%E6%AD%A4%E6%9D%A5%E8%AE%A9%E8%87%AA%E5%B7%B1%E8%A7%89%E5%BE%97%E4%B8%96%E7%95%8C%E6%98%AF%E5%85%AC%E5%B9%B3%E7%9A%84%EF%BC%8C%E8%87%AA%E5%B7%B1%E5%BE%88%E5%AE%89%E5%85%A8%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="解释风格 Explanatory Style （乐观 vs. 悲观）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A7%A3%E9%87%8A%E9%A3%8E%E6%A0%BC%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EExplanatory%20Style%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%EF%BC%88%E4%B9%90%E8%A7%82%3C/span%3E%3Cspan%3E%20vs.%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%82%B2%E8%A7%82%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="Optimistic 乐观：坏事是暂时的、外部的。「考试考好是能力，考不好是运气」" _mubu_text="%3Cspan%3EOptimistic%20%E4%B9%90%E8%A7%82%EF%BC%9A%E5%9D%8F%E4%BA%8B%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%9A%82%E6%97%B6%E7%9A%84%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%A4%96%E9%83%A8%E7%9A%84%3C/span%3E%3Cspan%3E%E3%80%82%E3%80%8C%E8%80%83%E8%AF%95%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%80%83%E5%A5%BD%E6%98%AF%E8%83%BD%E5%8A%9B%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%80%83%E4%B8%8D%E5%A5%BD%E6%98%AF%E8%BF%90%E6%B0%94%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Pessimistic 悲观：坏事是永久的、内部的。「考试考好是运气，考不好就反思吧，能力不行！」" _mubu_text="%3Cspan%3EPessimistic%20%E6%82%B2%E8%A7%82%EF%BC%9A%E5%9D%8F%E4%BA%8B%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%B0%B8%E4%B9%85%E7%9A%84%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%86%85%E9%83%A8%E7%9A%84%3C/span%3E%3Cspan%3E%E3%80%82%E3%80%8C%E8%80%83%E8%AF%95%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%80%83%E5%A5%BD%E6%98%AF%E8%BF%90%E6%B0%94%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%80%83%E4%B8%8D%E5%A5%BD%E5%B0%B1%E5%8F%8D%E6%80%9D%E5%90%A7%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%83%BD%E5%8A%9B%E4%B8%8D%E8%A1%8C%3C/span%3E%3Cspan%3E%EF%BC%81%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="控制关注点 Locus of Control（内部 vs. 外部）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%8E%A7%E5%88%B6%E5%85%B3%E6%B3%A8%E7%82%B9%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ELocus%20of%20Control%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%EF%BC%88%E5%86%85%E9%83%A8%3C/span%3E%3Cspan%3E%20vs.%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%A4%96%E9%83%A8%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="内控 Internal：我命由我不由天。「考前刷题」" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E5%86%85%E6%8E%A7%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3EInternal%3C/span%3E%3Cspan%3E%EF%BC%9A%E6%88%91%E5%91%BD%E7%94%B1%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%88%91%3C/span%3E%3Cspan%3E%E4%B8%8D%E7%94%B1%E5%A4%A9%E3%80%82%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E3%80%8C%E8%80%83%E5%89%8D%E5%88%B7%E9%A2%98%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="我相信我的努力能改变结果。" _mubu_text="%3Cspan%3E%E6%88%91%E7%9B%B8%E4%BF%A1%E6%88%91%E7%9A%84%E5%8A%AA%E5%8A%9B%E8%83%BD%E6%94%B9%E5%8F%98%E7%BB%93%E6%9E%9C%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="外控 External：听天由命。「考前求锦鲤，摆烂」" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E5%A4%96%E6%8E%A7%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3EExternal%3C/span%3E%3Cspan%3E%EF%BC%9A%E5%90%AC%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%A9%3C/span%3E%3Cspan%3E%E7%94%B1%E5%91%BD%E3%80%82%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E3%80%8C%E8%80%83%E5%89%8D%E6%B1%82%E9%94%A6%E9%B2%A4%EF%BC%8C%E6%91%86%E7%83%82%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="结果由运气、命运或他人决定（可能导致习得性无助）。" _mubu_text="%3Cspan%3E%E7%BB%93%E6%9E%9C%E7%94%B1%E8%BF%90%E6%B0%94%E3%80%81%E5%91%BD%E8%BF%90%E6%88%96%E4%BB%96%E4%BA%BA%E5%86%B3%E5%AE%9A%EF%BC%88%E5%8F%AF%E8%83%BD%E5%AF%BC%E8%87%B4%E4%B9%A0%E5%BE%97%E6%80%A7%E6%97%A0%E5%8A%A9%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="多看你一眼效应 Mere Exposure Effect（见得多了就顺眼了）「多听新歌、广告洗脑」" _mubu_text="%3Cspan%20class=%22bold%20text-color-purple%22%3E%E5%A4%9A%E7%9C%8B%E4%BD%A0%E4%B8%80%E7%9C%BC%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%95%88%E5%BA%94%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%20Mere%20Exposure%3C/span%3E%3Cspan%20class=%22bold%22%3E%20Effect%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A7%81%E5%BE%97%E5%A4%9A%E4%BA%86%E5%B0%B1%E9%A1%BA%E7%9C%BC%E4%BA%86%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A4%9A%E5%90%AC%E6%96%B0%E6%AD%8C%E3%80%81%E5%B9%BF%E5%91%8A%E6%B4%97%E8%84%91%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
          <outline text="仅仅因为熟悉，就会增加喜欢的程度。" _mubu_text="%3Cspan%3E%E4%BB%85%E4%BB%85%E5%9B%A0%E4%B8%BA%E7%86%9F%E6%82%89%EF%BC%8C%E5%B0%B1%E4%BC%9A%E5%A2%9E%E5%8A%A0%E5%96%9C%E6%AC%A2%E7%9A%84%E7%A8%8B%E5%BA%A6%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="见的次数多了，就觉得顺眼了。" _mubu_text="%3Cspan%3E%E8%A7%81%E7%9A%84%E6%AC%A1%E6%95%B0%E5%A4%9A%E4%BA%86%EF%BC%8C%E5%B0%B1%E8%A7%89%E5%BE%97%E9%A1%BA%E7%9C%BC%E4%BA%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="例子：" _mubu_text="%3Cspan%3E%E4%BE%8B%E5%AD%90%EF%BC%9A%3C/span%3E" _note="" _mubu_note="">
            <outline text="一首新歌刚听觉得一般，在大街小巷听了十遍之后，突然觉得“哎，还挺上头的”。" _mubu_text="%3Cspan%3E%E4%B8%80%E9%A6%96%E6%96%B0%E6%AD%8C%E5%88%9A%E5%90%AC%E8%A7%89%E5%BE%97%E4%B8%80%E8%88%AC%EF%BC%8C%E5%9C%A8%E5%A4%A7%E8%A1%97%E5%B0%8F%E5%B7%B7%E5%90%AC%E4%BA%86%E5%8D%81%E9%81%8D%E4%B9%8B%E5%90%8E%EF%BC%8C%E7%AA%81%E7%84%B6%E8%A7%89%E5%BE%97%E2%80%9C%E5%93%8E%EF%BC%8C%E8%BF%98%E6%8C%BA%E4%B8%8A%E5%A4%B4%E7%9A%84%E2%80%9D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="广告狂轰滥炸就是利用这个原理。" _mubu_text="%3Cspan%3E%E5%B9%BF%E5%91%8A%E7%8B%82%E8%BD%B0%E6%BB%A5%E7%82%B8%E5%B0%B1%E6%98%AF%E5%88%A9%E7%94%A8%E8%BF%99%E4%B8%AA%E5%8E%9F%E7%90%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="自证预言 Self-Fulfilling Prophecy （信念改变行为，行为改变结果） 「成为好学生」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E8%AF%81%E9%A2%84%E8%A8%80%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESelf-Fulfilling%20Prophecy%3C/span%3E%3Cspan%3E%20%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BF%A1%E5%BF%B5%E6%94%B9%E5%8F%98%E8%A1%8C%E4%B8%BA%EF%BC%8C%E8%A1%8C%E4%B8%BA%E6%94%B9%E5%8F%98%E7%BB%93%E6%9E%9C%3C/span%3E%3Cspan%3E%EF%BC%89%20%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%88%90%E4%B8%BA%E5%A5%BD%E5%AD%A6%E7%94%9F%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
          <outline text="信念 -&gt; 行为 -&gt; 结果。" _mubu_text="%3Cspan%3E%E4%BF%A1%E5%BF%B5%20-&amp;gt;%20%E8%A1%8C%E4%B8%BA%20-&amp;gt;%20%E7%BB%93%E6%9E%9C%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="老师认为Leo是好学生（信念），Leo开始努力（行为改变），Leo考好，Leo成为好学生（结果成真）" _mubu_text="%3Cspan%3E%E8%80%81%E5%B8%88%E8%AE%A4%E4%B8%BALeo%E6%98%AF%E5%A5%BD%E5%AD%A6%E7%94%9F%EF%BC%88%E4%BF%A1%E5%BF%B5%EF%BC%89%EF%BC%8CLeo%E5%BC%80%E5%A7%8B%E5%8A%AA%E5%8A%9B%EF%BC%88%E8%A1%8C%E4%B8%BA%E6%94%B9%E5%8F%98%EF%BC%89%EF%BC%8CLeo%E8%80%83%E5%A5%BD%EF%BC%8CLeo%E6%88%90%E4%B8%BA%E5%A5%BD%E5%AD%A6%E7%94%9F%EF%BC%88%E7%BB%93%E6%9E%9C%E6%88%90%E7%9C%9F%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="社会比较 Social Comparison（向上、向下和相对剥夺感）" _mubu_text="%3Cspan%3E%E7%A4%BE%E4%BC%9A%E6%AF%94%E8%BE%83%20Social%20Comparison%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%90%91%E4%B8%8A%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%90%91%E4%B8%8B%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%9B%B8%E5%AF%B9%E5%89%A5%E5%A4%BA%E6%84%9F%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="Upward Comparison 向上比较: 和比自己强的人比——激励自己或感到自卑（差距过大）。" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EUpward%20%3C/span%3E%3Cspan%20class=%22bold%22%3EComparison%20%E5%90%91%E4%B8%8A%E6%AF%94%E8%BE%83%3C/span%3E%3Cspan%3E:%20%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%AF%94%E8%87%AA%E5%B7%B1%E5%BC%BA%3C/span%3E%3Cspan%3E%E7%9A%84%E4%BA%BA%E6%AF%94%E2%80%94%E2%80%94%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%BF%80%E5%8A%B1%E8%87%AA%E5%B7%B1%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%84%9F%E5%88%B0%E8%87%AA%E5%8D%91%3C/span%3E%3Cspan%3E%EF%BC%88%E5%B7%AE%E8%B7%9D%E8%BF%87%E5%A4%A7%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Downward Comparison 向下比较: 和比自己差的人比——感觉良好，减少激励，提升自尊。" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EDownward%20%3C/span%3E%3Cspan%20class=%22bold%22%3EComparison%20%E5%90%91%E4%B8%8B%E6%AF%94%E8%BE%83%3C/span%3E%3Cspan%3E:%20%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%AF%94%E8%87%AA%E5%B7%B1%E5%B7%AE%3C/span%3E%3Cspan%3E%E7%9A%84%E4%BA%BA%E6%AF%94%E2%80%94%E2%80%94%E6%84%9F%E8%A7%89%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%89%AF%E5%A5%BD%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%87%8F%E5%B0%91%E6%BF%80%E5%8A%B1%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%8F%90%E5%8D%87%E8%87%AA%E5%B0%8A%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Relative Deprivation 相对剥夺感: 人比人气死人 本来很开心，和别人一比就不开心了" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ERelative%20Deprivation%3C/span%3E%3Cspan%20class=%22bold%22%3E%20%E7%9B%B8%E5%AF%B9%E5%89%A5%E5%A4%BA%E6%84%9F%3C/span%3E%3Cspan%3E:%20%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E4%BA%BA%E6%AF%94%E4%BA%BA%E6%B0%94%E6%AD%BB%E4%BA%BA%3C/span%3E%3Cspan%3E%20%E6%9C%AC%E6%9D%A5%E5%BE%88%E5%BC%80%E5%BF%83%EF%BC%8C%E5%92%8C%E5%88%AB%E4%BA%BA%E4%B8%80%E6%AF%94%E5%B0%B1%E4%B8%8D%E5%BC%80%E5%BF%83%E4%BA%86%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
      <outline text="4.2 Attribution Formation and Change" _mubu_text="%3Cspan%3E4.2%20Attribution%20Formation%20and%20Change%3C/span%3E" _note="" _mubu_note="">
        <outline text="Attitude 态度（习得且会改变的）「对潮流的态度」" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EAttitude%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%80%81%E5%BA%A6%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B9%A0%E5%BE%97%E4%B8%94%E4%BC%9A%E6%94%B9%E5%8F%98%E7%9A%84%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%AF%B9%E6%BD%AE%E6%B5%81%E7%9A%84%E6%80%81%E5%BA%A6%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
          <outline text="Thinks Feels Behaves towards another person idea or situation" _mubu_text="%3Cspan%3EThinks%20Feels%20Behaves%20towards%20another%20person%20idea%20or%20situation%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Group Bias &amp; Ethnocentrism" _mubu_text="%3Cspan%20class=%22bold%22%3EGroup%20Bias%20&amp;amp;%20Ethnocentrism%3C/span%3E" _note="" _mubu_note="">
          <outline text="Out-Group Homogeneity Bias 外国人效应 （外国人他们都一样）「重金属、朋克、独立摇滚」" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EOut-%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EGroup%20Homogeneity%20Bias%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-purple%22%3E%E5%A4%96%E5%9B%BD%E4%BA%BA%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%95%88%E5%BA%94%3C/span%3E%3Cspan%3E%20%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%96%E5%9B%BD%E4%BA%BA%E4%BB%96%E4%BB%AC%E9%83%BD%E4%B8%80%E6%A0%B7%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%87%8D%E9%87%91%E5%B1%9E%E3%80%81%E6%9C%8B%E5%85%8B%E3%80%81%E7%8B%AC%E7%AB%8B%E6%91%87%E6%BB%9A%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="觉得“他们”长得都一样，或者性格都一样；而觉得“我们”每个人都很有个性，很多元。" _mubu_text="%3Cspan%3E%E8%A7%89%E5%BE%97%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E2%80%9C%E4%BB%96%E4%BB%AC%E2%80%9D%E9%95%BF%E5%BE%97%E9%83%BD%E4%B8%80%E6%A0%B7%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%88%96%E8%80%85%E6%80%A7%E6%A0%BC%E9%83%BD%E4%B8%80%E6%A0%B7%EF%BC%9B%E8%80%8C%E8%A7%89%E5%BE%97%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E2%80%9C%E6%88%91%E4%BB%AC%E2%80%9D%E6%AF%8F%E4%B8%AA%E4%BA%BA%E9%83%BD%E5%BE%88%E6%9C%89%E4%B8%AA%E6%80%A7%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%BE%88%E5%A4%9A%E5%85%83%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="你作为一个摇滚乐迷（In-group），你能分清重金属、朋克、独立摇滚的区别。" _mubu_text="%3Cspan%3E%E4%BD%A0%E4%BD%9C%E4%B8%BA%E4%B8%80%E4%B8%AA%E6%91%87%E6%BB%9A%E4%B9%90%E8%BF%B7%EF%BC%88In-group%EF%BC%89%EF%BC%8C%E4%BD%A0%E8%83%BD%E5%88%86%E6%B8%85%E9%87%8D%E9%87%91%E5%B1%9E%E3%80%81%E6%9C%8B%E5%85%8B%E3%80%81%E7%8B%AC%E7%AB%8B%E6%91%87%E6%BB%9A%E7%9A%84%E5%8C%BA%E5%88%AB%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="但你看那些听K-pop的人（Out-group），你可能会觉得：“他们听的歌怎么听起来全是一个调子？他们的偶像怎么长得都一样？”" _mubu_text="%3Cspan%3E%E4%BD%86%E4%BD%A0%E7%9C%8B%E9%82%A3%E4%BA%9B%E5%90%ACK-pop%E7%9A%84%E4%BA%BA%EF%BC%88Out-group%EF%BC%89%EF%BC%8C%E4%BD%A0%E5%8F%AF%E8%83%BD%E4%BC%9A%E8%A7%89%E5%BE%97%EF%BC%9A%E2%80%9C%E4%BB%96%E4%BB%AC%E5%90%AC%E7%9A%84%E6%AD%8C%E6%80%8E%E4%B9%88%E5%90%AC%E8%B5%B7%E6%9D%A5%E5%85%A8%E6%98%AF%E4%B8%80%E4%B8%AA%E8%B0%83%E5%AD%90%EF%BC%9F%E4%BB%96%E4%BB%AC%E7%9A%84%E5%81%B6%E5%83%8F%E6%80%8E%E4%B9%88%E9%95%BF%E5%BE%97%E9%83%BD%E4%B8%80%E6%A0%B7%EF%BC%9F%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="In-group Bias 我们最棒了（偏袒自己所属的群体）「只有我们才能骂母校！」" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EIn-%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3Egroup%20Bias%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%88%91%E4%BB%AC%E6%9C%80%E6%A3%92%E4%BA%86%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%81%8F%E8%A2%92%E8%87%AA%E5%B7%B1%E6%89%80%E5%B1%9E%E7%9A%84%E7%BE%A4%E4%BD%93%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%8F%AA%E6%9C%89%E6%88%91%E4%BB%AC%E6%89%8D%E8%83%BD%E9%AA%82%E6%AF%8D%E6%A0%A1%EF%BC%81%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="我们倾向于偏袒自己所属的群体（“我们”），认为“我们”更优秀。" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E5%80%BE%E5%90%91%E4%BA%8E%E5%81%8F%E8%A2%92%E8%87%AA%E5%B7%B1%E6%89%80%E5%B1%9E%E7%9A%84%E7%BE%A4%E4%BD%93%EF%BC%88%E2%80%9C%E6%88%91%E4%BB%AC%E2%80%9D%EF%BC%89%EF%BC%8C%E8%AE%A4%E4%B8%BA%E2%80%9C%E6%88%91%E4%BB%AC%E2%80%9D%E6%9B%B4%E4%BC%98%E7%A7%80%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="学校比赛时，哪怕你平时吐槽自己学校，但对着外校时，你一定会觉得“我校是最棒的”。" _mubu_text="%3Cspan%3E%E5%AD%A6%E6%A0%A1%E6%AF%94%E8%B5%9B%E6%97%B6%EF%BC%8C%E5%93%AA%E6%80%95%E4%BD%A0%E5%B9%B3%E6%97%B6%E5%90%90%E6%A7%BD%E8%87%AA%E5%B7%B1%E5%AD%A6%E6%A0%A1%EF%BC%8C%E4%BD%86%E5%AF%B9%E7%9D%80%E5%A4%96%E6%A0%A1%E6%97%B6%EF%BC%8C%E4%BD%A0%E4%B8%80%E5%AE%9A%E4%BC%9A%E8%A7%89%E5%BE%97%E2%80%9C%E6%88%91%E6%A0%A1%E6%98%AF%E6%9C%80%E6%A3%92%E7%9A%84%E2%80%9D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Ethnocentrism 民族优越感 从立场上认为自己优越，而批判其他文化" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EEthnocentrism%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%B0%91%E6%97%8F%E4%BC%98%E8%B6%8A%E6%84%9F%3C/span%3E%3Cspan%3E%20%E4%BB%8E%E7%AB%8B%E5%9C%BA%E4%B8%8A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%AE%A4%E4%B8%BA%E8%87%AA%E5%B7%B1%E4%BC%98%E8%B6%8A%EF%BC%8C%3C/span%3E%3Cspan%3E%E8%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%89%B9%E5%88%A4%E5%85%B6%E4%BB%96%E6%96%87%E5%8C%96%3C/span%3E" _note="" _mubu_note="">
            <outline text="认为自己的文化/民族是优越的，并以自己的文化为标准去评判其他文化（通常是负面的）。" _mubu_text="%3Cspan%3E%E8%AE%A4%E4%B8%BA%E8%87%AA%E5%B7%B1%E7%9A%84%E6%96%87%E5%8C%96/%E6%B0%91%E6%97%8F%E6%98%AF%E4%BC%98%E8%B6%8A%E7%9A%84%EF%BC%8C%E5%B9%B6%E4%BB%A5%E8%87%AA%E5%B7%B1%E7%9A%84%E6%96%87%E5%8C%96%E4%B8%BA%E6%A0%87%E5%87%86%E5%8E%BB%E8%AF%84%E5%88%A4%E5%85%B6%E4%BB%96%E6%96%87%E5%8C%96%EF%BC%88%E9%80%9A%E5%B8%B8%E6%98%AF%E8%B4%9F%E9%9D%A2%E7%9A%84%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="例子" _mubu_text="%3Cspan%3E%E4%BE%8B%E5%AD%90%3C/span%3E" _note="" _mubu_note="">
              <outline text="看到别人用手吃饭，觉得“真脏、真落后”，而不是认为“这是不同的文化习俗”。" _mubu_text="%3Cspan%3E%E7%9C%8B%E5%88%B0%E5%88%AB%E4%BA%BA%E7%94%A8%E6%89%8B%E5%90%83%E9%A5%AD%EF%BC%8C%E8%A7%89%E5%BE%97%E2%80%9C%E7%9C%9F%E8%84%8F%E3%80%81%E7%9C%9F%E8%90%BD%E5%90%8E%E2%80%9D%EF%BC%8C%E8%80%8C%E4%B8%8D%E6%98%AF%E8%AE%A4%E4%B8%BA%E2%80%9C%E8%BF%99%E6%98%AF%E4%B8%8D%E5%90%8C%E7%9A%84%E6%96%87%E5%8C%96%E4%B9%A0%E4%BF%97%E2%80%9D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="Stubborn 固执（Belief Perseverance vs. Confirmation Bias） " _mubu_text="%3Cspan%3EStubborn%20%E5%9B%BA%E6%89%A7%EF%BC%88Belief%20Perseverance%20vs.%20Confirmation%20Bias%EF%BC%89%20%3C/span%3E" _note="" _mubu_note="">
          <outline text="Belief Perseverance 信念固执 被打脸仍坚持 「你看，地球就是圆的」「不！伪造的！」" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EBelief%20Perseverance%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BF%A1%E5%BF%B5%E5%9B%BA%E6%89%A7%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A2%AB%E6%89%93%E8%84%B8%E4%BB%8D%E5%9D%9A%E6%8C%81%3C/span%3E%3Cspan%3E%20%E3%80%8C%E4%BD%A0%E7%9C%8B%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%9C%B0%E7%90%83%E5%B0%B1%E6%98%AF%E5%9C%86%E7%9A%84%3C/span%3E%3Cspan%3E%E3%80%8D%E3%80%8C%E4%B8%8D%EF%BC%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%BC%AA%E9%80%A0%E7%9A%84%3C/span%3E%3Cspan%3E%EF%BC%81%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="概念: 即使已经被证据打脸（discredited），证明你是错的，你依然坚持原来的看法。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A6%82%E5%BF%B5%3C/span%3E%3Cspan%3E:%20%E5%8D%B3%E4%BD%BF%E5%B7%B2%E7%BB%8F%E8%A2%AB%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%AF%81%E6%8D%AE%E6%89%93%E8%84%B8%3C/span%3E%3Cspan%3E%EF%BC%88discredited%EF%BC%89%EF%BC%8C%E8%AF%81%E6%98%8E%E4%BD%A0%E6%98%AF%E9%94%99%E7%9A%84%EF%BC%8C%E4%BD%A0%E4%BE%9D%E7%84%B6%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%9D%9A%E6%8C%81%3C/span%3E%3Cspan%3E%E5%8E%9F%E6%9D%A5%E7%9A%84%E7%9C%8B%E6%B3%95%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="例子: 阴谋论者。你把科学证据摆在他面前证明地球是圆的，他看都不看，说：“这都是伪造的，地球就是平的。”" _mubu_text="%3Cspan%20class=%22italic%22%3E%E4%BE%8B%E5%AD%90%3C/span%3E%3Cspan%3E:%20%E9%98%B4%E8%B0%8B%E8%AE%BA%E8%80%85%E3%80%82%E4%BD%A0%E6%8A%8A%E7%A7%91%E5%AD%A6%E8%AF%81%E6%8D%AE%E6%91%86%E5%9C%A8%E4%BB%96%E9%9D%A2%E5%89%8D%E8%AF%81%E6%98%8E%E5%9C%B0%E7%90%83%E6%98%AF%E5%9C%86%E7%9A%84%EF%BC%8C%E4%BB%96%E7%9C%8B%E9%83%BD%E4%B8%8D%E7%9C%8B%EF%BC%8C%E8%AF%B4%EF%BC%9A%E2%80%9C%E8%BF%99%E9%83%BD%E6%98%AF%E4%BC%AA%E9%80%A0%E7%9A%84%EF%BC%8C%E5%9C%B0%E7%90%83%E5%B0%B1%E6%98%AF%E5%B9%B3%E7%9A%84%E3%80%82%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Confirmation Bias 确认偏差 找对自己有力的证据，选择性忽略「每次洗车后都下雨」" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EConfirmation%20%3C/span%3E%3Cspan%20class=%22bold%22%3EBias%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%A1%AE%E8%AE%A4%E5%81%8F%E5%B7%AE%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%89%BE%E5%AF%B9%E8%87%AA%E5%B7%B1%E6%9C%89%E5%8A%9B%E7%9A%84%E8%AF%81%E6%8D%AE%EF%BC%8C%E9%80%89%E6%8B%A9%E6%80%A7%E5%BF%BD%E7%95%A5%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%AF%8F%E6%AC%A1%E6%B4%97%E8%BD%A6%E5%90%8E%E9%83%BD%E4%B8%8B%E9%9B%A8%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Stereotype, Prejudice and Discrimination " _mubu_text="%3Cspan%20class=%22bold%22%3EStereotype,%20Prejudice%20and%20Discrimination%20%3C/span%3E" _note="" _mubu_note="">
          <outline text="Stereotype 刻板印象（Heuristics 快速分类人，不一定是坏的，过度概括）「法国人都很浪漫」" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EStereotype%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%88%BB%E6%9D%BF%E5%8D%B0%E8%B1%A1%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EHeuristics%20%E5%BF%AB%E9%80%9F%E5%88%86%E7%B1%BB%E4%BA%BA%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E4%B8%8D%E4%B8%80%E5%AE%9A%E6%98%AF%E5%9D%8F%E7%9A%84%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%BF%87%E5%BA%A6%E6%A6%82%E6%8B%AC%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B3%95%E5%9B%BD%E4%BA%BA%E9%83%BD%E5%BE%88%E6%B5%AA%E6%BC%AB%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="对一群人的过度概括的信念 (Generalized Belief)。" _mubu_text="%3Cspan%3E%E5%AF%B9%E4%B8%80%E7%BE%A4%E4%BA%BA%E7%9A%84%E8%BF%87%E5%BA%A6%E6%A6%82%E6%8B%AC%E7%9A%84%E4%BF%A1%E5%BF%B5%20(Generalized%20Belief)%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="它是一种心理捷径（Heuristic），用来快速分类人。" _mubu_text="%3Cspan%3E%E5%AE%83%E6%98%AF%E4%B8%80%E7%A7%8D%E5%BF%83%E7%90%86%E6%8D%B7%E5%BE%84%EF%BC%88Heuristic%EF%BC%89%EF%BC%8C%E7%94%A8%E6%9D%A5%E5%BF%AB%E9%80%9F%E5%88%86%E7%B1%BB%E4%BA%BA%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="例子" _mubu_text="%3Cspan%3E%E4%BE%8B%E5%AD%90%3C/span%3E" _note="" _mubu_note="">
              <outline text="“亚洲人都擅长数学。”" _mubu_text="%3Cspan%3E%E2%80%9C%E4%BA%9A%E6%B4%B2%E4%BA%BA%E9%83%BD%E6%93%85%E9%95%BF%E6%95%B0%E5%AD%A6%E3%80%82%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="“法国人都很浪漫。”" _mubu_text="%3Cspan%3E%E2%80%9C%E6%B3%95%E5%9B%BD%E4%BA%BA%E9%83%BD%E5%BE%88%E6%B5%AA%E6%BC%AB%E3%80%82%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="注意: 刻板印象不一定是坏的（比如擅长数学），但它忽视了个体差异。" _mubu_text="%3Cspan%3E%E6%B3%A8%E6%84%8F:%20%E5%88%BB%E6%9D%BF%E5%8D%B0%E8%B1%A1%E4%B8%8D%E4%B8%80%E5%AE%9A%E6%98%AF%E5%9D%8F%E7%9A%84%EF%BC%88%E6%AF%94%E5%A6%82%E6%93%85%E9%95%BF%E6%95%B0%E5%AD%A6%EF%BC%89%EF%BC%8C%E4%BD%86%E5%AE%83%E5%BF%BD%E8%A7%86%E4%BA%86%E4%B8%AA%E4%BD%93%E5%B7%AE%E5%BC%82%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Prejudice 偏见（情感层，不公正的负面态度）「我不喜欢吃榴莲的人」" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EPrejudice%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%81%8F%E8%A7%81%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E6%84%9F%E5%B1%82%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%B8%8D%E5%85%AC%E6%AD%A3%E7%9A%84%E8%B4%9F%E9%9D%A2%3C/span%3E%3Cspan%3E%E6%80%81%E5%BA%A6%EF%BC%89%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%88%91%E4%B8%8D%E5%96%9C%E6%AC%A2%E5%90%83%E6%A6%B4%E8%8E%B2%E7%9A%84%E4%BA%BA%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Discrimination 歧视（行为层，不公正的待遇，Prejudice引起）「我欺负吃榴莲的人」" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EDiscrimination%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%AD%A7%E8%A7%86%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A1%8C%E4%B8%BA%E5%B1%82%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%B8%8D%E5%85%AC%E6%AD%A3%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%BE%85%E9%81%87%3C/span%3E%3Cspan%3E%EF%BC%8CPrejudice%E5%BC%95%E8%B5%B7%EF%BC%89%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%88%91%E6%AC%BA%E8%B4%9F%E5%90%83%E6%A6%B4%E8%8E%B2%E7%9A%84%E4%BA%BA%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="认知失调 Cognitive Dissonance" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AE%A4%E7%9F%A5%E5%A4%B1%E8%B0%83%20Cognitive%20Dissonance%3C/span%3E" _note="" _mubu_note="">
          <outline text="当我们的态度和行为不一致时，会有不舒服的紧张感，由于冲突（不稳定）导致的。" _mubu_text="%3Cspan%3E%E5%BD%93%E6%88%91%E4%BB%AC%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E6%80%81%E5%BA%A6%E5%92%8C%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%E4%B8%8D%E4%B8%80%E8%87%B4%E6%97%B6%EF%BC%8C%E4%BC%9A%E6%9C%89%E4%B8%8D%E8%88%92%E6%9C%8D%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%B4%A7%E5%BC%A0%E6%84%9F%3C/span%3E%3Cspan%3E%EF%BC%8C%E7%94%B1%E4%BA%8E%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%86%B2%E7%AA%81%EF%BC%88%E4%B8%8D%E7%A8%B3%E5%AE%9A%EF%BC%89%3C/span%3E%3Cspan%3E%E5%AF%BC%E8%87%B4%E7%9A%84%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="为了消除这种不舒服（回到稳定状态），我们必须改变，以回到稳定状态。" _mubu_text="%3Cspan%3E%E4%B8%BA%E4%BA%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%B6%88%E9%99%A4%E8%BF%99%E7%A7%8D%E4%B8%8D%E8%88%92%E6%9C%8D%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%9B%9E%E5%88%B0%E7%A8%B3%E5%AE%9A%E7%8A%B6%E6%80%81%3C/span%3E%3Cspan%3E%EF%BC%89%EF%BC%8C%E6%88%91%E4%BB%AC%E5%BF%85%E9%A1%BB%E6%94%B9%E5%8F%98%EF%BC%8C%E4%BB%A5%E5%9B%9E%E5%88%B0%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%A8%B3%E5%AE%9A%E7%8A%B6%E6%80%81%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="如果改变行为很难，我们会改变态度来合理化这种行为。" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E6%94%B9%E5%8F%98%E8%A1%8C%E4%B8%BA%E5%BE%88%E9%9A%BE%EF%BC%8C%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%88%91%E4%BB%AC%E4%BC%9A%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E6%94%B9%E5%8F%98%E6%80%81%E5%BA%A6%E6%9D%A5%E5%90%88%E7%90%86%E5%8C%96%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%BF%99%E7%A7%8D%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="吃不到葡萄说葡萄酸。" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E5%90%83%E4%B8%8D%E5%88%B0%E8%91%A1%E8%90%84%E8%AF%B4%E8%91%A1%E8%90%84%E9%85%B8%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
      <outline text="4.3 Psychology of Social Situations" _mubu_text="%3Cspan%3E4.3%20Psychology%20of%20Social%20Situations%3C/span%3E" _note="" _mubu_note="">
        <outline text="Fitting In" _mubu_text="%3Cspan%3EFitting%20In%3C/span%3E" _note="" _mubu_note="">
          <outline text="从众 Conformity 符合群体标准，从而调整自己的行为或想法 「奇怪的电梯」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BB%8E%E4%BC%97%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EConformity%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E7%AC%A6%E5%90%88%E7%BE%A4%E4%BD%93%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%A0%87%E5%87%86%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BB%8E%E8%80%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%B0%83%E6%95%B4%E8%87%AA%E5%B7%B1%E7%9A%84%E8%A1%8C%E4%B8%BA%E6%88%96%E6%83%B3%E6%B3%95%3C/span%3E%3Cspan%3E%20%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A5%87%E6%80%AA%E7%9A%84%E7%94%B5%E6%A2%AF%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="为了符合群体的标准，调整自己的行为或想法。" _mubu_text="%3Cspan%3E%E4%B8%BA%E4%BA%86%E7%AC%A6%E5%90%88%E7%BE%A4%E4%BD%93%E7%9A%84%E6%A0%87%E5%87%86%EF%BC%8C%E8%B0%83%E6%95%B4%E8%87%AA%E5%B7%B1%E7%9A%84%E8%A1%8C%E4%B8%BA%E6%88%96%E6%83%B3%E6%B3%95%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="影响因素：Group Size（人数），Unanimity of the Group（组内动作一致性），Group Cohesion（归属感），Authority（权威），Cultural Factors（合作文化 Collectivist Culture / 独狼文化 Individualistic Culture / 文化融合 Multiculturalism）" _mubu_text="%3Cspan%3E%E5%BD%B1%E5%93%8D%E5%9B%A0%E7%B4%A0%EF%BC%9AGroup%20Size%EF%BC%88%E4%BA%BA%E6%95%B0%EF%BC%89%EF%BC%8CUnanimity%20of%20the%20Group%EF%BC%88%E7%BB%84%E5%86%85%E5%8A%A8%E4%BD%9C%E4%B8%80%E8%87%B4%E6%80%A7%EF%BC%89%EF%BC%8CGroup%20Cohesion%EF%BC%88%E5%BD%92%E5%B1%9E%E6%84%9F%EF%BC%89%EF%BC%8CAuthority%EF%BC%88%E6%9D%83%E5%A8%81%EF%BC%89%EF%BC%8CCultural%20Factors%EF%BC%88%E5%90%88%E4%BD%9C%E6%96%87%E5%8C%96%20Collectivist%20Culture%20/%20%E7%8B%AC%E7%8B%BC%E6%96%87%E5%8C%96%20Individualistic%20Culture%20/%20%E6%96%87%E5%8C%96%E8%9E%8D%E5%90%88%20Multiculturalism%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="服从 Obedience 服从权威人物的命令（服从上级，从众平辈）「警察，不许动！」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%9C%8D%E4%BB%8E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EObedience%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E6%9C%8D%E4%BB%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9D%83%E5%A8%81%E4%BA%BA%E7%89%A9%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%91%BD%E4%BB%A4%3C/span%3E%3Cspan%3E%EF%BC%88%E6%9C%8D%E4%BB%8E%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E4%B8%8A%E7%BA%A7%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BB%8E%E4%BC%97%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E5%B9%B3%E8%BE%88%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%AD%A6%E5%AF%9F%EF%BC%8C%E4%B8%8D%E8%AE%B8%E5%8A%A8%EF%BC%81%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="服从权威人物的直接命令。" _mubu_text="%3Cspan%3E%E6%9C%8D%E4%BB%8E%E6%9D%83%E5%A8%81%E4%BA%BA%E7%89%A9%E7%9A%84%E7%9B%B4%E6%8E%A5%E5%91%BD%E4%BB%A4%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Conformity 是跟平辈学，Obedience 是听上级的话。" _mubu_text="%3Cspan%3EConformity%20%E6%98%AF%E8%B7%9F%E5%B9%B3%E8%BE%88%E5%AD%A6%EF%BC%8CObedience%20%E6%98%AF%E5%90%AC%E4%B8%8A%E7%BA%A7%E7%9A%84%E8%AF%9D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="是否是合法的权威人物？是否更亲近权威人物？" _mubu_text="%3Cspan%3E%E6%98%AF%E5%90%A6%E6%98%AF%E5%90%88%E6%B3%95%E7%9A%84%E6%9D%83%E5%A8%81%E4%BA%BA%E7%89%A9%EF%BC%9F%E6%98%AF%E5%90%A6%E6%9B%B4%E4%BA%B2%E8%BF%91%E6%9D%83%E5%A8%81%E4%BA%BA%E7%89%A9%EF%BC%9F%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="普通人怎么才会做出违反价值观的行为？" _mubu_text="%3Cspan%3E%E6%99%AE%E9%80%9A%E4%BA%BA%E6%80%8E%E4%B9%88%E6%89%8D%E4%BC%9A%E5%81%9A%E5%87%BA%E8%BF%9D%E5%8F%8D%E4%BB%B7%E5%80%BC%E8%A7%82%E7%9A%84%E8%A1%8C%E4%B8%BA%EF%BC%9F%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Social Influence Theory 社会影响理论（Normative vs. Informational）" _mubu_text="%3Cspan%20class=%22bold%22%3ESocial%20Influence%20Theory%20%E7%A4%BE%E4%BC%9A%E5%BD%B1%E5%93%8D%E7%90%86%E8%AE%BA%EF%BC%88Normative%20vs.%20Informational%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="规范社会影响 Normative Social Influence 想被群体接纳，哪怕明知是错的，也跟着做" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A7%84%E8%8C%83%E7%A4%BE%E4%BC%9A%E5%BD%B1%E5%93%8D%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ENormative%20Social%20Influence%3C/span%3E%3Cspan%3E%20%E6%83%B3%E8%A2%AB%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%BE%A4%E4%BD%93%E6%8E%A5%E7%BA%B3%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%93%AA%E6%80%95%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%98%8E%E7%9F%A5%E6%98%AF%E9%94%99%E7%9A%84%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%B9%9F%E8%B7%9F%E7%9D%80%E5%81%9A%3C/span%3E" _note="" _mubu_note="">
              <outline text=" 「一群朋友抽烟，你明知抽烟不好，为了合群你也跟着抽」" _mubu_text="%3Cspan%3E%20%E3%80%8C%E4%B8%80%E7%BE%A4%E6%9C%8B%E5%8F%8B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%8A%BD%E7%83%9F%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BD%A0%E6%98%8E%E7%9F%A5%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%8A%BD%E7%83%9F%E4%B8%8D%E5%A5%BD%EF%BC%8C%3C/span%3E%3Cspan%3E%E4%B8%BA%E4%BA%86%E5%90%88%E7%BE%A4%E4%BD%A0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B9%9F%E8%B7%9F%E7%9D%80%E6%8A%BD%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="信息社会影响 Informational Social Influence 认为别人掌握更准确的信息，为了获取正确信息而跟随别人的行为" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BF%A1%E6%81%AF%E7%A4%BE%E4%BC%9A%E5%BD%B1%E5%93%8D%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EInformational%20Social%20Influence%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E8%AE%A4%E4%B8%BA%E5%88%AB%E4%BA%BA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8E%8C%E6%8F%A1%E6%9B%B4%E5%87%86%E7%A1%AE%E7%9A%84%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%B8%BA%E4%BA%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%8E%B7%E5%8F%96%E6%AD%A3%E7%A1%AE%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%E8%80%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%B7%9F%E9%9A%8F%E5%88%AB%E4%BA%BA%E7%9A%84%E8%A1%8C%E4%B8%BA%3C/span%3E" _note="" _mubu_note="">
              <outline text="「第一次吃西餐不知道怎么用刀叉，偷看隔壁桌」" _mubu_text="%3Cspan%3E%E3%80%8C%E7%AC%AC%E4%B8%80%E6%AC%A1%E5%90%83%E8%A5%BF%E9%A4%90%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%8D%E7%9F%A5%E9%81%93%E6%80%8E%E4%B9%88%E7%94%A8%E5%88%80%E5%8F%89%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%81%B7%E7%9C%8B%3C/span%3E%3Cspan%3E%E9%9A%94%E5%A3%81%E6%A1%8C%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="Persuasion" _mubu_text="%3Cspan%3EPersuasion%3C/span%3E" _note="" _mubu_note="">
          <outline text="精细可能性模型 Elaboration Likelihood Model" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B2%BE%E7%BB%86%E5%8F%AF%E8%83%BD%E6%80%A7%E6%A8%A1%E5%9E%8B%20Elaboration%20Likelihood%20Model%3C/span%3E" _note="" _mubu_note="">
            <outline text="我们是怎么被说服的？有两种路径" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E6%98%AF%E6%80%8E%E4%B9%88%E8%A2%AB%E8%AF%B4%E6%9C%8D%E7%9A%84%EF%BC%9F%E6%9C%89%E4%B8%A4%E7%A7%8D%E8%B7%AF%E5%BE%84%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Central Route 用事实和逻辑说服（走脑子），更持久「买电脑时，仔细分析性能」" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3ECentral%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3ERoute%3C/span%3E%3Cspan%3E%20%E7%94%A8%E4%BA%8B%E5%AE%9E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%80%BB%E8%BE%91%E8%AF%B4%E6%9C%8D%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E8%B5%B0%E8%84%91%E5%AD%90%3C/span%3E%3Cspan%3E%EF%BC%89%EF%BC%8C%E6%9B%B4%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%8C%81%E4%B9%85%3C/span%3E%3Cspan%3E%E3%80%8C%E4%B9%B0%E7%94%B5%E8%84%91%E6%97%B6%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%BB%94%E7%BB%86%E5%88%86%E6%9E%90%E6%80%A7%E8%83%BD%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Peripheral Route 关注表面线索（走肾），暂时的「我家哥哥代言联想电脑！买！」" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EPeripheral%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3ERoute%3C/span%3E%3Cspan%3E%20%E5%85%B3%E6%B3%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A1%A8%E9%9D%A2%E7%BA%BF%E7%B4%A2%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E8%B5%B0%E8%82%BE%3C/span%3E%3Cspan%3E%EF%BC%89%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%9A%82%E6%97%B6%E7%9A%84%3C/span%3E%3Cspan%3E%E3%80%8C%E6%88%91%E5%AE%B6%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%93%A5%E5%93%A5%E4%BB%A3%E8%A8%80%3C/span%3E%3Cspan%3E%E8%81%94%E6%83%B3%E7%94%B5%E8%84%91%EF%BC%81%E4%B9%B0%EF%BC%81%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="Halo Effect 光环效应 某人某一方面很好（通常是长得好看）我们会觉得他在所有方面都很好（一好百好）" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EHalo%20Effect%20%E5%85%89%E7%8E%AF%E6%95%88%E5%BA%94%3C/span%3E%3Cspan%3E%20%E6%9F%90%E4%BA%BA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9F%90%E4%B8%80%E6%96%B9%E9%9D%A2%3C/span%3E%3Cspan%3E%E5%BE%88%E5%A5%BD%EF%BC%88%E9%80%9A%E5%B8%B8%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%95%BF%E5%BE%97%E5%A5%BD%E7%9C%8B%3C/span%3E%3Cspan%3E%EF%BC%89%E6%88%91%E4%BB%AC%E4%BC%9A%E8%A7%89%E5%BE%97%E4%BB%96%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%89%80%E6%9C%89%E6%96%B9%E9%9D%A2%3C/span%3E%3Cspan%3E%E9%83%BD%E5%BE%88%E5%A5%BD%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E4%B8%80%E5%A5%BD%E7%99%BE%E5%A5%BD%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="进门技巧 Compliance Techniques" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%BF%9B%E9%97%A8%E6%8A%80%E5%B7%A7%20Compliance%20Techniques%3C/span%3E" _note="" _mubu_note="">
            <outline text="FITD Foot-in-the-Door 登门槛 对方答应你提出的小要求后，对方更有可能同意一个更大的要求「签个名支持环保？好，那你能不能捐款100元？谢谢！」" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EFITD%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EFoot-in-the-Door%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%99%BB%E9%97%A8%E6%A7%9B%3C/span%3E%3Cspan%3E%20%E5%AF%B9%E6%96%B9%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%AD%94%E5%BA%94%E4%BD%A0%3C/span%3E%3Cspan%3E%E6%8F%90%E5%87%BA%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%B0%8F%E8%A6%81%E6%B1%82%E5%90%8E%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%AF%B9%E6%96%B9%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%9B%B4%E6%9C%89%E5%8F%AF%E8%83%BD%E5%90%8C%E6%84%8F%3C/span%3E%3Cspan%3E%E4%B8%80%E4%B8%AA%E6%9B%B4%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%A4%A7%E7%9A%84%E8%A6%81%E6%B1%82%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%AD%BE%E4%B8%AA%E5%90%8D%3C/span%3E%3Cspan%3E%E6%94%AF%E6%8C%81%E7%8E%AF%E4%BF%9D%EF%BC%9F%E5%A5%BD%EF%BC%8C%E9%82%A3%E4%BD%A0%E8%83%BD%E4%B8%8D%E8%83%BD%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%8D%90%E6%AC%BE100%E5%85%83%3C/span%3E%3Cspan%3E%EF%BC%9F%E8%B0%A2%E8%B0%A2%EF%BC%81%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="DITF Door-in-the-Face 留面子 对方拒绝你的一个大要求后，更有可能同意一个小要求「借我5000买个新Pad？那借我100吃个饭总行了吧？谢谢！」" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EDITF%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EDoor-in-the-Face%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%95%99%E9%9D%A2%E5%AD%90%3C/span%3E%3Cspan%3E%20%E5%AF%B9%E6%96%B9%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8B%92%E7%BB%9D%3C/span%3E%3Cspan%3E%E4%BD%A0%E7%9A%84%E4%B8%80%E4%B8%AA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%A7%E8%A6%81%E6%B1%82%E5%90%8E%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%9B%B4%E6%9C%89%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%8F%AF%E8%83%BD%E5%90%8C%E6%84%8F%3C/span%3E%3Cspan%3E%E4%B8%80%E4%B8%AA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%B0%8F%E8%A6%81%E6%B1%82%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%80%9F%E6%88%915000%3C/span%3E%3Cspan%3E%E4%B9%B0%E4%B8%AA%E6%96%B0Pad%EF%BC%9F%E9%82%A3%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%80%9F%E6%88%91100%3C/span%3E%3Cspan%3E%E5%90%83%E4%B8%AA%E9%A5%AD%E6%80%BB%E8%A1%8C%E4%BA%86%E5%90%A7%EF%BC%9F%E8%B0%A2%E8%B0%A2%EF%BC%81%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Group Dynamics" _mubu_text="%3Cspan%3EGroup%20Dynamics%3C/span%3E" _note="" _mubu_note="">
          <outline text="群体极化 Group Polarization 观点相似的人讨论后，观点更极端「蛐蛐别人」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%BE%A4%E4%BD%93%E6%9E%81%E5%8C%96%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EGroup%20Polarization%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A7%82%E7%82%B9%E7%9B%B8%E4%BC%BC%3C/span%3E%3Cspan%3E%E7%9A%84%E4%BA%BA%E8%AE%A8%E8%AE%BA%E5%90%8E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%A7%82%E7%82%B9%E6%9B%B4%E6%9E%81%E7%AB%AF%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%9B%90%E8%9B%90%E5%88%AB%E4%BA%BA%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="群体思维 Groupthink 为了团体的和谐不敢提出反对意见（导致坏结果）「这个计划… 很好」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%BE%A4%E4%BD%93%E6%80%9D%E7%BB%B4%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EGroupthink%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E4%B8%BA%E4%BA%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%9B%A2%E4%BD%93%E7%9A%84%E5%92%8C%E8%B0%90%3C/span%3E%3Cspan%3E%E4%B8%8D%E6%95%A2%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%8F%90%E5%87%BA%E5%8F%8D%E5%AF%B9%E6%84%8F%E8%A7%81%3C/span%3E%3Cspan%3E%EF%BC%88%E5%AF%BC%E8%87%B4%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%9D%8F%E7%BB%93%E6%9E%9C%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%BF%99%E4%B8%AA%E8%AE%A1%E5%88%92%E2%80%A6%20%E5%BE%88%E5%A5%BD%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="去个性化 Deindividuation 因为在人群中，所以做出疯狂的举动「演唱会我疯狂跟唱」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8E%BB%E4%B8%AA%E6%80%A7%E5%8C%96%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EDeindividuation%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%9B%A0%E4%B8%BA%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BA%BA%E7%BE%A4%E4%B8%AD%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%89%80%E4%BB%A5%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%81%9A%E5%87%BA%E7%96%AF%E7%8B%82%E7%9A%84%E4%B8%BE%E5%8A%A8%3C/span%3E%3Cspan%3E%E3%80%8C%E6%BC%94%E5%94%B1%E4%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%88%91%E7%96%AF%E7%8B%82%E8%B7%9F%E5%94%B1%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="在人群中，因为匿名性 (Anonymity) 和高唤醒 (Arousal)，人失去了自我约束，做出一反常态的（通常是暴力的）行为。" _mubu_text="%3Cspan%3E%E5%9C%A8%E4%BA%BA%E7%BE%A4%E4%B8%AD%EF%BC%8C%E5%9B%A0%E4%B8%BA%E5%8C%BF%E5%90%8D%E6%80%A7%20(Anonymity)%20%E5%92%8C%E9%AB%98%E5%94%A4%E9%86%92%20(Arousal)%EF%BC%8C%E4%BA%BA%E5%A4%B1%E5%8E%BB%E4%BA%86%E8%87%AA%E6%88%91%E7%BA%A6%E6%9D%9F%EF%BC%8C%E5%81%9A%E5%87%BA%E4%B8%80%E5%8F%8D%E5%B8%B8%E6%80%81%E7%9A%84%EF%BC%88%E9%80%9A%E5%B8%B8%E6%98%AF%E6%9A%B4%E5%8A%9B%E7%9A%84%EF%BC%89%E8%A1%8C%E4%B8%BA%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="键盘侠 / 足球流氓" _mubu_text="%3Cspan%3E%E9%94%AE%E7%9B%98%E4%BE%A0%20/%20%E8%B6%B3%E7%90%83%E6%B5%81%E6%B0%93%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="社会懈怠 Social Loafing 个人的贡献无法单独衡量，人就会偷懒「三个和尚没水吃」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A4%BE%E4%BC%9A%E6%87%88%E6%80%A0%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESocial%20Loafing%3C/span%3E%3Cspan%3E%20%E4%B8%AA%E4%BA%BA%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%B4%A1%E7%8C%AE%E6%97%A0%E6%B3%95%E5%8D%95%E7%8B%AC%E8%A1%A1%E9%87%8F%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BA%BA%E5%B0%B1%E4%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%81%B7%E6%87%92%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%89%E4%B8%AA%E5%92%8C%E5%B0%9A%E6%B2%A1%E6%B0%B4%E5%90%83%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="I/O 心理学 Industrial-Organizational Psychology 心理学的分支，心理学+工作场所，提高生产力" _mubu_text="%3Cspan%20class=%22bold%22%3EI/O%20%E5%BF%83%E7%90%86%E5%AD%A6%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EIndustrial-Organizational%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EPsychology%3C/span%3E%3Cspan%3E%20%E5%BF%83%E7%90%86%E5%AD%A6%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%88%86%E6%94%AF%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%83%E7%90%86%E5%AD%A6+%E5%B7%A5%E4%BD%9C%E5%9C%BA%E6%89%80%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%8F%90%E9%AB%98%E7%94%9F%E4%BA%A7%E5%8A%9B%3C/span%3E" _note="" _mubu_note="">
            <outline text="这是心理学的一个分支，专门把心理学原理应用到工作场所 (Workplace)。" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AF%E5%BF%83%E7%90%86%E5%AD%A6%E7%9A%84%E4%B8%80%E4%B8%AA%E5%88%86%E6%94%AF%EF%BC%8C%E4%B8%93%E9%97%A8%E6%8A%8A%E5%BF%83%E7%90%86%E5%AD%A6%E5%8E%9F%E7%90%86%E5%BA%94%E7%94%A8%E5%88%B0%E5%B7%A5%E4%BD%9C%E5%9C%BA%E6%89%80%20(Workplace)%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="目的" _mubu_text="%3Cspan%3E%E7%9B%AE%E7%9A%84%3C/span%3E" _note="" _mubu_note="">
              <outline text="提高生产力 (Productivity)、筛选和晋升员工 (Select and promote)、改善组织文化。" _mubu_text="%3Cspan%3E%E6%8F%90%E9%AB%98%E7%94%9F%E4%BA%A7%E5%8A%9B%20(Productivity)%E3%80%81%E7%AD%9B%E9%80%89%E5%92%8C%E6%99%8B%E5%8D%87%E5%91%98%E5%B7%A5%20(Select%20and%20promote)%E3%80%81%E6%94%B9%E5%96%84%E7%BB%84%E7%BB%87%E6%96%87%E5%8C%96%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="例子" _mubu_text="%3Cspan%3E%E4%BE%8B%E5%AD%90%3C/span%3E" _note="" _mubu_note="">
              <outline text="一家公司请心理学家来设计一套面试题，为了招到性格最适合这个岗位的员工。" _mubu_text="%3Cspan%3E%E4%B8%80%E5%AE%B6%E5%85%AC%E5%8F%B8%E8%AF%B7%E5%BF%83%E7%90%86%E5%AD%A6%E5%AE%B6%E6%9D%A5%E8%AE%BE%E8%AE%A1%E4%B8%80%E5%A5%97%E9%9D%A2%E8%AF%95%E9%A2%98%EF%BC%8C%E4%B8%BA%E4%BA%86%E6%8B%9B%E5%88%B0%E6%80%A7%E6%A0%BC%E6%9C%80%E9%80%82%E5%90%88%E8%BF%99%E4%B8%AA%E5%B2%97%E4%BD%8D%E7%9A%84%E5%91%98%E5%B7%A5%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="或者请专家来优化办公室布局，让员工工作更开心、效率更高。" _mubu_text="%3Cspan%3E%E6%88%96%E8%80%85%E8%AF%B7%E4%B8%93%E5%AE%B6%E6%9D%A5%E4%BC%98%E5%8C%96%E5%8A%9E%E5%85%AC%E5%AE%A4%E5%B8%83%E5%B1%80%EF%BC%8C%E8%AE%A9%E5%91%98%E5%B7%A5%E5%B7%A5%E4%BD%9C%E6%9B%B4%E5%BC%80%E5%BF%83%E3%80%81%E6%95%88%E7%8E%87%E6%9B%B4%E9%AB%98%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="关键词: Workplace (职场), Productivity (生产力), HR (人力资源)。" _mubu_text="%3Cspan%3E%E5%85%B3%E9%94%AE%E8%AF%8D:%20Workplace%20(%E8%81%8C%E5%9C%BA),%20Productivity%20(%E7%94%9F%E4%BA%A7%E5%8A%9B),%20HR%20(%E4%BA%BA%E5%8A%9B%E8%B5%84%E6%BA%90)%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="社会助长和社会抑制 Social Facilitation vs. Social Inhibition " _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A4%BE%E4%BC%9A%E5%8A%A9%E9%95%BF%E5%92%8C%E7%A4%BE%E4%BC%9A%E6%8A%91%E5%88%B6%20Social%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EFacilitation%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3Evs.%20Social%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EInhibition%3C/span%3E%3Cspan%3E%20%3C/span%3E" _note="" _mubu_note="">
            <outline text="当观众在场时，你的表现会变化" _mubu_text="%3Cspan%3E%E5%BD%93%E8%A7%82%E4%BC%97%E5%9C%A8%E5%9C%BA%E6%97%B6%EF%BC%8C%E4%BD%A0%E7%9A%84%E8%A1%A8%E7%8E%B0%E4%BC%9A%E5%8F%98%E5%8C%96%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Facilitation 助长 任务简单或熟练会表现更好「台球高手，打得更顺」" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EFacilitation%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%8A%A9%E9%95%BF%3C/span%3E%3Cspan%3E%20%E4%BB%BB%E5%8A%A1%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%AE%80%E5%8D%95%E6%88%96%E7%86%9F%E7%BB%83%3C/span%3E%3Cspan%3E%E4%BC%9A%E8%A1%A8%E7%8E%B0%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%9B%B4%E5%A5%BD%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%8F%B0%E7%90%83%E9%AB%98%E6%89%8B%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%89%93%E5%BE%97%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%9B%B4%E9%A1%BA%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Inhibition 抑制 任务困难或生疏 表现更差「第一次演讲，紧张得忘词了」" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EInhibition%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%8A%91%E5%88%B6%3C/span%3E%3Cspan%3E%20%E4%BB%BB%E5%8A%A1%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%9B%B0%E9%9A%BE%E6%88%96%E7%94%9F%E7%96%8F%20%3C/span%3E%3Cspan%3E%E8%A1%A8%E7%8E%B0%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%9B%B4%E5%B7%AE%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%AC%AC%E4%B8%80%E6%AC%A1%E6%BC%94%E8%AE%B2%3C/span%3E%3Cspan%3E%EF%BC%8C%E7%B4%A7%E5%BC%A0%E5%BE%97%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BF%98%E8%AF%8D%E4%BA%86%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="虚假共识 False Consensus Effect 高估别人同意我们观点的程度「香菜奶茶好喝，我请你们喝」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%99%9A%E5%81%87%E5%85%B1%E8%AF%86%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EFalse%20Consensus%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EEffect%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%AB%98%E4%BC%B0%3C/span%3E%3Cspan%3E%E5%88%AB%E4%BA%BA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%90%8C%E6%84%8F%E6%88%91%E4%BB%AC%E8%A7%82%E7%82%B9%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%A8%8B%E5%BA%A6%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%A6%99%E8%8F%9C%E5%A5%B6%E8%8C%B6%3C/span%3E%3Cspan%3E%E5%A5%BD%E5%96%9D%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%88%91%E8%AF%B7%E4%BD%A0%E4%BB%AC%E5%96%9D%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="我们倾向于高估 别人对我们观点的同意程度。" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E5%80%BE%E5%90%91%E4%BA%8E%E9%AB%98%E4%BC%B0%20%E5%88%AB%E4%BA%BA%E5%AF%B9%E6%88%91%E4%BB%AC%E8%A7%82%E7%82%B9%E7%9A%84%E5%90%8C%E6%84%8F%E7%A8%8B%E5%BA%A6%E3%80%82%3C/span%3E" _note="" _mubu_note="">
              <outline text="我们觉得自己的想法是“正常的”，所以大多数人应该都跟我想的一样。" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E8%A7%89%E5%BE%97%E8%87%AA%E5%B7%B1%E7%9A%84%E6%83%B3%E6%B3%95%E6%98%AF%E2%80%9C%E6%AD%A3%E5%B8%B8%E7%9A%84%E2%80%9D%EF%BC%8C%E6%89%80%E4%BB%A5%E5%A4%A7%E5%A4%9A%E6%95%B0%E4%BA%BA%E5%BA%94%E8%AF%A5%E9%83%BD%E8%B7%9F%E6%88%91%E6%83%B3%E7%9A%84%E4%B8%80%E6%A0%B7%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="例子" _mubu_text="%3Cspan%3E%E4%BE%8B%E5%AD%90%3C/span%3E" _note="" _mubu_note="">
              <outline text="你特别爱喝香菜奶茶，你觉得“这东西这么好喝，大家应该都喜欢吧？”结果买了一堆请全班喝，发现没人喝。" _mubu_text="%3Cspan%3E%E4%BD%A0%E7%89%B9%E5%88%AB%E7%88%B1%E5%96%9D%E9%A6%99%E8%8F%9C%E5%A5%B6%E8%8C%B6%EF%BC%8C%E4%BD%A0%E8%A7%89%E5%BE%97%E2%80%9C%E8%BF%99%E4%B8%9C%E8%A5%BF%E8%BF%99%E4%B9%88%E5%A5%BD%E5%96%9D%EF%BC%8C%E5%A4%A7%E5%AE%B6%E5%BA%94%E8%AF%A5%E9%83%BD%E5%96%9C%E6%AC%A2%E5%90%A7%EF%BC%9F%E2%80%9D%E7%BB%93%E6%9E%9C%E4%B9%B0%E4%BA%86%E4%B8%80%E5%A0%86%E8%AF%B7%E5%85%A8%E7%8F%AD%E5%96%9D%EF%BC%8C%E5%8F%91%E7%8E%B0%E6%B2%A1%E4%BA%BA%E5%96%9D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="Conflict &amp; Altruism 冲突与利他主义" _mubu_text="%3Cspan%3EConflict%20&amp;amp;%20Altruism%20%E5%86%B2%E7%AA%81%E4%B8%8E%E5%88%A9%E4%BB%96%E4%B8%BB%E4%B9%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="超级目标 Superordinate Goals 化解群体冲突需要给双方一个必须合作完成的目标 「一起推车」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%B6%85%E7%BA%A7%E7%9B%AE%E6%A0%87%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESuperordinate%20Goals%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%8C%96%E8%A7%A3%E7%BE%A4%E4%BD%93%E5%86%B2%E7%AA%81%3C/span%3E%3Cspan%3E%E9%9C%80%E8%A6%81%E7%BB%99%E5%8F%8C%E6%96%B9%E4%B8%80%E4%B8%AA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%85%E9%A1%BB%E5%90%88%E4%BD%9C%E5%AE%8C%E6%88%90%3C/span%3E%3Cspan%3E%E7%9A%84%E7%9B%AE%E6%A0%87%20%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%80%E8%B5%B7%E6%8E%A8%E8%BD%A6%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="如何化解群体冲突？给敌对的双方一个必须合作才能完成的目标。" _mubu_text="%3Cspan%3E%E5%A6%82%E4%BD%95%E5%8C%96%E8%A7%A3%E7%BE%A4%E4%BD%93%E5%86%B2%E7%AA%81%EF%BC%9F%E7%BB%99%E6%95%8C%E5%AF%B9%E7%9A%84%E5%8F%8C%E6%96%B9%E4%B8%80%E4%B8%AA%E5%BF%85%E9%A1%BB%E5%90%88%E4%BD%9C%E6%89%8D%E8%83%BD%E5%AE%8C%E6%88%90%E7%9A%84%E7%9B%AE%E6%A0%87%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="两个互相仇视的小队，如果遇到卡车陷进泥里，必须全员一起推车才能出来，推完车他们关系就好了。" _mubu_text="%3Cspan%3E%E4%B8%A4%E4%B8%AA%E4%BA%92%E7%9B%B8%E4%BB%87%E8%A7%86%E7%9A%84%E5%B0%8F%E9%98%9F%EF%BC%8C%E5%A6%82%E6%9E%9C%E9%81%87%E5%88%B0%E5%8D%A1%E8%BD%A6%E9%99%B7%E8%BF%9B%E6%B3%A5%E9%87%8C%EF%BC%8C%E5%BF%85%E9%A1%BB%E5%85%A8%E5%91%98%E4%B8%80%E8%B5%B7%E6%8E%A8%E8%BD%A6%E6%89%8D%E8%83%BD%E5%87%BA%E6%9D%A5%EF%BC%8C%E6%8E%A8%E5%AE%8C%E8%BD%A6%E4%BB%96%E4%BB%AC%E5%85%B3%E7%B3%BB%E5%B0%B1%E5%A5%BD%E4%BA%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="社会陷阱 Social Trap 个人追求短期利益，导致集体长期毁灭「开私家车导致拥堵」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A4%BE%E4%BC%9A%E9%99%B7%E9%98%B1%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESocial%20Trap%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E4%B8%AA%E4%BA%BA%E8%BF%BD%E6%B1%82%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E7%9F%AD%E6%9C%9F%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%88%A9%E7%9B%8A%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%AF%BC%E8%87%B4%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%9B%86%E4%BD%93%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E9%95%BF%E6%9C%9F%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%AF%81%E7%81%AD%3C/span%3E%3Cspan%3E%E3%80%8C%E5%BC%80%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%A7%81%E5%AE%B6%E8%BD%A6%3C/span%3E%3Cspan%3E%E5%AF%BC%E8%87%B4%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%8B%A5%E5%A0%B5%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="个人追求短期利益，导致集体的长期毁灭。" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BA%BA%E8%BF%BD%E6%B1%82%E7%9F%AD%E6%9C%9F%E5%88%A9%E7%9B%8A%EF%BC%8C%E5%AF%BC%E8%87%B4%E9%9B%86%E4%BD%93%E7%9A%84%E9%95%BF%E6%9C%9F%E6%AF%81%E7%81%AD%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="大家都为了方便开私家车（个人利益），结果导致严重的雾霾和交通拥堵，最后大家都受害（集体损失）。" _mubu_text="%3Cspan%3E%E5%A4%A7%E5%AE%B6%E9%83%BD%E4%B8%BA%E4%BA%86%E6%96%B9%E4%BE%BF%E5%BC%80%E7%A7%81%E5%AE%B6%E8%BD%A6%EF%BC%88%E4%B8%AA%E4%BA%BA%E5%88%A9%E7%9B%8A%EF%BC%89%EF%BC%8C%E7%BB%93%E6%9E%9C%E5%AF%BC%E8%87%B4%E4%B8%A5%E9%87%8D%E7%9A%84%E9%9B%BE%E9%9C%BE%E5%92%8C%E4%BA%A4%E9%80%9A%E6%8B%A5%E5%A0%B5%EF%BC%8C%E6%9C%80%E5%90%8E%E5%A4%A7%E5%AE%B6%E9%83%BD%E5%8F%97%E5%AE%B3%EF%BC%88%E9%9B%86%E4%BD%93%E6%8D%9F%E5%A4%B1%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="旁观者效应&amp;责任分散 Bystander Effect&amp; Diffusion of Responsibility" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%97%81%E8%A7%82%E8%80%85%E6%95%88%E5%BA%94&amp;amp;%E8%B4%A3%E4%BB%BB%E5%88%86%E6%95%A3%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EBystander%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EEffect&amp;amp;%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EDiffusion%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3Eof%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EResponsibility%3C/span%3E" _note="" _mubu_note="">
            <outline text="在场的人越多，你去帮忙的可能性越小（个人贡献不可量化）" _mubu_text="%3Cspan%3E%E5%9C%A8%E5%9C%BA%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BA%BA%E8%B6%8A%E5%A4%9A%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BD%A0%E5%8E%BB%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%B8%AE%E5%BF%99%E7%9A%84%E5%8F%AF%E8%83%BD%E6%80%A7%E8%B6%8A%E5%B0%8F%3C/span%3E%3Cspan%3E%EF%BC%88%E4%B8%AA%E4%BA%BA%E8%B4%A1%E7%8C%AE%E4%B8%8D%E5%8F%AF%E9%87%8F%E5%8C%96%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="利他规范 Altruism Norms" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%88%A9%E4%BB%96%E8%A7%84%E8%8C%83%20Altruism%20Norms%3C/span%3E" _note="" _mubu_note="">
            <outline text="互惠规范 Reciprocity Norm 别人帮了我，我以后也要帮他" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BA%92%E6%83%A0%E8%A7%84%E8%8C%83%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EReciprocity%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3ENorm%3C/span%3E%3Cspan%3E%20%E5%88%AB%E4%BA%BA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%B8%AE%E4%BA%86%E6%88%91%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%88%91%E4%BB%A5%E5%90%8E%E4%B9%9F%E8%A6%81%E5%B8%AE%E4%BB%96%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="社会责任 Social Responsibility Norm 帮助那些弱势群体，即使他们无法回报我们。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A4%BE%E4%BC%9A%E8%B4%A3%E4%BB%BB%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESocial%20Responsibility%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3ENorm%3C/span%3E%3Cspan%3E%20%E5%B8%AE%E5%8A%A9%E9%82%A3%E4%BA%9B%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%BC%B1%E5%8A%BF%E7%BE%A4%E4%BD%93%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%8D%B3%E4%BD%BF%E4%BB%96%E4%BB%AC%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%97%A0%E6%B3%95%E5%9B%9E%E6%8A%A5%E6%88%91%E4%BB%AC%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
      </outline>
      <outline text="4.4 Psychodynamic and Humanistic Theories of Personalities" _mubu_text="%3Cspan%3E4.4%20Psychodynamic%20and%20Humanistic%20Theories%20of%20Personalities%3C/span%3E" _note="" _mubu_note="">
        <outline text="人格 Personality 个体独特的、相对稳定的思想、情感和行为模式「你为什么是你」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BA%BA%E6%A0%BC%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EPersonality%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E4%B8%AA%E4%BD%93%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%8B%AC%E7%89%B9%E7%9A%84%3C/span%3E%3Cspan%3E%E3%80%81%E7%9B%B8%E5%AF%B9%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%A8%B3%E5%AE%9A%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%80%9D%E6%83%B3%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%83%85%E6%84%9F%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%A1%8C%E4%B8%BA%E6%A8%A1%E5%BC%8F%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E4%BD%A0%E4%B8%BA%E4%BB%80%E4%B9%88%E6%98%AF%E4%BD%A0%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="精神分析流派 Psychoanalysis 西格蒙德•弗洛伊德" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B2%BE%E7%A5%9E%E5%88%86%E6%9E%90%E6%B5%81%E6%B4%BE%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EPsychoanalysis%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E8%A5%BF%E6%A0%BC%E8%92%99%E5%BE%B7%E2%80%A2%E5%BC%97%E6%B4%9B%E4%BC%8A%E5%BE%B7%3C/span%3E" _note="" _mubu_note="">
          <outline text="从Sigmund Freud开始「潜意识、童年经历和内部冲突」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BB%8ESigmund%20Freud%E5%BC%80%E5%A7%8B%E3%80%8C%E6%BD%9C%E6%84%8F%E8%AF%86%E3%80%81%E7%AB%A5%E5%B9%B4%E7%BB%8F%E5%8E%86%E5%92%8C%E5%86%85%E9%83%A8%E5%86%B2%E7%AA%81%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="意识的三个层面 Iceberg model 意识、前意识、潜意识" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%84%8F%E8%AF%86%E7%9A%84%E4%B8%89%E4%B8%AA%E5%B1%82%E9%9D%A2%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EIceberg%20model%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E6%84%8F%E8%AF%86%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E5%89%8D%E6%84%8F%E8%AF%86%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E6%BD%9C%E6%84%8F%E8%AF%86%3C/span%3E" _note="" _mubu_note="">
            <outline text="意识层 Conscious 当前能感知到的思想和知觉" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%84%8F%E8%AF%86%E5%B1%82%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EConscious%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%BD%93%E5%89%8D%E8%83%BD%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%84%9F%E7%9F%A5%E5%88%B0%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%80%9D%E6%83%B3%E5%92%8C%E7%9F%A5%E8%A7%89%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="前意识层 Preconscious 当前未意识到，但可以随时提取的记忆和知识" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%89%8D%E6%84%8F%E8%AF%86%E5%B1%82%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EPreconscious%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%BD%93%E5%89%8D%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9C%AA%E6%84%8F%E8%AF%86%3C/span%3E%3Cspan%3E%E5%88%B0%EF%BC%8C%E4%BD%86%E5%8F%AF%E4%BB%A5%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%9A%8F%E6%97%B6%E6%8F%90%E5%8F%96%3C/span%3E%3Cspan%3E%E7%9A%84%E8%AE%B0%E5%BF%86%E5%92%8C%E7%9F%A5%E8%AF%86%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="潜意识层 Unconscious 主要是被压抑的、不可接受的思想、愿望、情感和记忆" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%BD%9C%E6%84%8F%E8%AF%86%E5%B1%82%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EUnconscious%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E4%B8%BB%E8%A6%81%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A2%AB%E5%8E%8B%E6%8A%91%3C/span%3E%3Cspan%3E%E7%9A%84%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%8D%E5%8F%AF%E6%8E%A5%E5%8F%97%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%80%9D%E6%83%B3%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%84%BF%E6%9C%9B%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%83%85%E6%84%9F%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%AE%B0%E5%BF%86%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="人格结构 Id, Superego, Ego 自我、本我、超我" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BA%BA%E6%A0%BC%E7%BB%93%E6%9E%84%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EId,%20Superego,%20Ego%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E8%87%AA%E6%88%91%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E6%9C%AC%E6%88%91%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E8%B6%85%E6%88%91%3C/span%3E" _note="" _mubu_note="">
            <outline text="本我 Id 遵循快乐原则，追求即时满足，吃喝利比多「饿了就哭、困了就睡，想要立即满足」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%9C%AC%E6%88%91%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EId%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E9%81%B5%E5%BE%AA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%AB%E4%B9%90%E5%8E%9F%E5%88%99%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%BF%BD%E6%B1%82%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%8D%B3%E6%97%B6%E6%BB%A1%E8%B6%B3%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%90%83%E5%96%9D%E5%88%A9%E6%AF%94%E5%A4%9A%3C/span%3E%3Cspan%3E%E3%80%8C%E9%A5%BF%E4%BA%86%E5%B0%B1%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%93%AD%3C/span%3E%3Cspan%3E%E3%80%81%E5%9B%B0%E4%BA%86%E5%B0%B1%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%9D%A1%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%83%B3%E8%A6%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%AB%8B%E5%8D%B3%E6%BB%A1%E8%B6%B3%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="超我 Superego 遵循道德原则，代表内化的理想和标准，提供良知和判断「即使没人监督也不作弊，因为&quot;良心过不去&quot;」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%B6%85%E6%88%91%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESuperego%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E9%81%B5%E5%BE%AA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%81%93%E5%BE%B7%E5%8E%9F%E5%88%99%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BB%A3%E8%A1%A8%E5%86%85%E5%8C%96%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%90%86%E6%83%B3%E5%92%8C%E6%A0%87%E5%87%86%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%8F%90%E4%BE%9B%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%89%AF%E7%9F%A5%E5%92%8C%E5%88%A4%E6%96%AD%3C/span%3E%3Cspan%3E%E3%80%8C%E5%8D%B3%E4%BD%BF%E6%B2%A1%E4%BA%BA%E7%9B%91%E7%9D%A3%E4%B9%9F%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%8D%E4%BD%9C%E5%BC%8A%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%9B%A0%E4%B8%BA%22%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E8%89%AF%E5%BF%83%E8%BF%87%E4%B8%8D%E5%8E%BB%3C/span%3E%3Cspan%3E%22%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="自我 Ego 遵循现实原则，作为&quot;执行者&quot;在本我、超我与现实之间进行协调「想要马上玩手机（本我），但知道应该先写作业（超我），于是决定写完再玩（自我调节）」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E6%88%91%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EEgo%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E9%81%B5%E5%BE%AA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%8E%B0%E5%AE%9E%E5%8E%9F%E5%88%99%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BD%9C%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%22%E6%89%A7%E8%A1%8C%E8%80%85%22%3C/span%3E%3Cspan%3E%E5%9C%A8%3C/span%3E%3Cspan%20class=%22underline%22%3E%E6%9C%AC%E6%88%91%E3%80%81%E8%B6%85%E6%88%91%E4%B8%8E%E7%8E%B0%E5%AE%9E%3C/span%3E%3Cspan%3E%E4%B9%8B%E9%97%B4%E8%BF%9B%E8%A1%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%8D%8F%E8%B0%83%3C/span%3E%3Cspan%3E%E3%80%8C%E6%83%B3%E8%A6%81%E9%A9%AC%E4%B8%8A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%8E%A9%E6%89%8B%E6%9C%BA%3C/span%3E%3Cspan%3E%EF%BC%88%E6%9C%AC%E6%88%91%EF%BC%89%EF%BC%8C%E4%BD%86%E7%9F%A5%E9%81%93%E5%BA%94%E8%AF%A5%E5%85%88%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%86%99%E4%BD%9C%E4%B8%9A%3C/span%3E%3Cspan%3E%EF%BC%88%E8%B6%85%E6%88%91%EF%BC%89%EF%BC%8C%E4%BA%8E%E6%98%AF%E5%86%B3%E5%AE%9A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%86%99%E5%AE%8C%E5%86%8D%E7%8E%A9%EF%BC%88%E8%87%AA%E6%88%91%E8%B0%83%E8%8A%82%EF%BC%89%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="自我防御机制 Defense Mechanisms 平衡冲突的方式，减轻焦虑（改变认知评价）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E6%88%91%E9%98%B2%E5%BE%A1%E6%9C%BA%E5%88%B6%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EDefense%20Mechanisms%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E5%B9%B3%E8%A1%A1%E5%86%B2%E7%AA%81%E7%9A%84%E6%96%B9%E5%BC%8F%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%87%8F%E8%BD%BB%E7%84%A6%E8%99%91%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22bold%20text-color-purple%22%3E%E6%94%B9%E5%8F%98%E8%AE%A4%E7%9F%A5%E8%AF%84%E4%BB%B7%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="否认 Denial 无意识地拒绝接受令人痛苦的现实「这不可能，一定是搞错了！」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%90%A6%E8%AE%A4%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EDenial%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%97%A0%E6%84%8F%E8%AF%86%3C/span%3E%3Cspan%3E%E5%9C%B0%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8B%92%E7%BB%9D%E6%8E%A5%E5%8F%97%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%BB%A4%E4%BA%BA%E7%97%9B%E8%8B%A6%E7%9A%84%E7%8E%B0%E5%AE%9E%3C/span%3E%3Cspan%3E%E3%80%8C%E8%BF%99%E4%B8%8D%E5%8F%AF%E8%83%BD%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%80%E5%AE%9A%E6%98%AF%E6%90%9E%E9%94%99%E4%BA%86%3C/span%3E%3Cspan%3E%EF%BC%81%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="位移 Displacement 将情绪转移到更安全或更弱小的对象上「被老板骂后对家人撒气」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BD%8D%E7%A7%BB%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EDisplacement%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%B0%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E7%BB%AA%E8%BD%AC%E7%A7%BB%3C/span%3E%3Cspan%3E%E5%88%B0%E6%9B%B4%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%AE%89%E5%85%A8%3C/span%3E%3Cspan%3E%E6%88%96%E6%9B%B4%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%BC%B1%E5%B0%8F%3C/span%3E%3Cspan%3E%E7%9A%84%E5%AF%B9%E8%B1%A1%E4%B8%8A%E3%80%8C%E8%A2%AB%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%80%81%E6%9D%BF%3C/span%3E%3Cspan%3E%E9%AA%82%E5%90%8E%E5%AF%B9%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%AE%B6%E4%BA%BA%3C/span%3E%3Cspan%3E%E6%92%92%E6%B0%94%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="投射 Projection 将自己难以接受的欲望、动机、情绪或性格特点，“转移”到他人身上，认为别人也有这些行为或想法「以小人之心度君子之腹，“他这么做肯定是为了自己！”」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%8A%95%E5%B0%84%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EProjection%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%B0%86%E8%87%AA%E5%B7%B1%E9%9A%BE%E4%BB%A5%E6%8E%A5%E5%8F%97%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%AC%B2%E6%9C%9B%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%8A%A8%E6%9C%BA%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%83%85%E7%BB%AA%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%80%A7%E6%A0%BC%E7%89%B9%E7%82%B9%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E2%80%9C%E8%BD%AC%E7%A7%BB%E2%80%9D%E5%88%B0%E4%BB%96%E4%BA%BA%E8%BA%AB%E4%B8%8A%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%AE%A4%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%88%AB%E4%BA%BA%3C/span%3E%3Cspan%3E%E4%B9%9F%E6%9C%89%E8%BF%99%E4%BA%9B%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A1%8C%E4%B8%BA%E6%88%96%E6%83%B3%E6%B3%95%3C/span%3E%3Cspan%3E%E3%80%8C%E4%BB%A5%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%B0%8F%E4%BA%BA%E4%B9%8B%E5%BF%83%E5%BA%A6%E5%90%9B%E5%AD%90%E4%B9%8B%E8%85%B9%3C/span%3E%3Cspan%3E%EF%BC%8C%E2%80%9C%E4%BB%96%E8%BF%99%E4%B9%88%E5%81%9A%E8%82%AF%E5%AE%9A%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%BA%E4%BA%86%E8%87%AA%E5%B7%B1%3C/span%3E%3Cspan%3E%EF%BC%81%E2%80%9D%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="合理化 Rationalization 用看似合理的解释掩盖真实的动机（难以接受的）「不是没努力，是考试太难了」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%90%88%E7%90%86%E5%8C%96%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ERationalization%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E7%94%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%9C%8B%E4%BC%BC%E5%90%88%E7%90%86%3C/span%3E%3Cspan%3E%E7%9A%84%E8%A7%A3%E9%87%8A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8E%A9%E7%9B%96%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%9C%9F%E5%AE%9E%E7%9A%84%E5%8A%A8%E6%9C%BA%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E9%9A%BE%E4%BB%A5%E6%8E%A5%E5%8F%97%E7%9A%84%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%8C%E4%B8%8D%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B2%A1%E5%8A%AA%E5%8A%9B%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%80%83%E8%AF%95%E5%A4%AA%E9%9A%BE%E4%BA%86%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="反应形成 Reaction-Formation 表现出与真实冲动完全相反的行为「喜欢某人却故意表现冷淡」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8F%8D%E5%BA%94%E5%BD%A2%E6%88%90%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EReaction-Formation%3C/span%3E%3Cspan%3E%20%E8%A1%A8%E7%8E%B0%E5%87%BA%E4%B8%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%9C%9F%E5%AE%9E%E5%86%B2%E5%8A%A8%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%AE%8C%E5%85%A8%E7%9B%B8%E5%8F%8D%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%96%9C%E6%AC%A2%E6%9F%90%E4%BA%BA%3C/span%3E%3Cspan%3E%E5%8D%B4%E6%95%85%E6%84%8F%E8%A1%A8%E7%8E%B0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%86%B7%E6%B7%A1%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="退行 Regression 面对压力时表现出幼稚或不成熟的行为「成年人哭闹着要回家找妈妈」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%80%80%E8%A1%8C%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ERegression%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E9%9D%A2%E5%AF%B9%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%8E%8B%E5%8A%9B%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%97%B6%3C/span%3E%3Cspan%3E%E8%A1%A8%E7%8E%B0%E5%87%BA%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E5%B9%BC%E7%A8%9A%E6%88%96%E4%B8%8D%E6%88%90%E7%86%9F%3C/span%3E%3Cspan%3E%E7%9A%84%E8%A1%8C%E4%B8%BA%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%88%90%E5%B9%B4%E4%BA%BA%3C/span%3E%3Cspan%3E%E5%93%AD%E9%97%B9%E7%9D%80%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%A6%81%E5%9B%9E%E5%AE%B6%E6%89%BE%E5%A6%88%E5%A6%88%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="升华 Sublimation 将负面能量转化为积极、有益的活动「化悲愤为力量，我要自我提升」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8D%87%E5%8D%8E%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESublimation%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%B0%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%B4%9F%E9%9D%A2%E8%83%BD%E9%87%8F%3C/span%3E%3Cspan%3E%E8%BD%AC%E5%8C%96%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%A7%AF%E6%9E%81%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%9C%89%E7%9B%8A%3C/span%3E%3Cspan%3E%E7%9A%84%E6%B4%BB%E5%8A%A8%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%8C%96%E6%82%B2%E6%84%A4%E4%B8%BA%E5%8A%9B%E9%87%8F%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%88%91%E8%A6%81%E8%87%AA%E6%88%91%E6%8F%90%E5%8D%87%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="压抑 Repression 将痛苦的记忆或欲望无意识地从意识中阻断「想不起小时候被伤害的经历」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8E%8B%E6%8A%91%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ERepression%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%B0%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%97%9B%E8%8B%A6%E7%9A%84%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%AC%B2%E6%9C%9B%3C/span%3E%3Cspan%3E%E6%97%A0%E6%84%8F%E8%AF%86%E5%9C%B0%E4%BB%8E%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%84%8F%E8%AF%86%E4%B8%AD%E9%98%BB%E6%96%AD%3C/span%3E%3Cspan%3E%E3%80%8C%E6%83%B3%E4%B8%8D%E8%B5%B7%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%B0%8F%E6%97%B6%E5%80%99%E8%A2%AB%E4%BC%A4%E5%AE%B3%3C/span%3E%3Cspan%3E%E7%9A%84%E7%BB%8F%E5%8E%86%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="新精神分析学派 Neo-Freudians 荣格、阿德勒、霍妮、埃里克森" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%96%B0%E7%B2%BE%E7%A5%9E%E5%88%86%E6%9E%90%E5%AD%A6%E6%B4%BE%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ENeo-Freudians%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E8%8D%A3%E6%A0%BC%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E9%98%BF%E5%BE%B7%E5%8B%92%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E9%9C%8D%E5%A6%AE%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E5%9F%83%E9%87%8C%E5%85%8B%E6%A3%AE%3C/span%3E" _note="" _mubu_note="">
          <outline text="荣格 Carl Jung、阿德勒 Alfred Adler、霍妮 Karen Horney、埃里克森 Erik Erikson" _mubu_text="%3Cspan%3E%E8%8D%A3%E6%A0%BC%20Carl%20Jung%E3%80%81%E9%98%BF%E5%BE%B7%E5%8B%92%20Alfred%20Adler%E3%80%81%E9%9C%8D%E5%A6%AE%20Karen%20Horney%E3%80%81%E5%9F%83%E9%87%8C%E5%85%8B%E6%A3%AE%20Erik%20Erikson%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="调整方向：增加了意识的作用，减少了性与暴力的绝对化比重 。" _mubu_text="%3Cspan%3E%E8%B0%83%E6%95%B4%E6%96%B9%E5%90%91%EF%BC%9A%E5%A2%9E%E5%8A%A0%E4%BA%86%E6%84%8F%E8%AF%86%E7%9A%84%E4%BD%9C%E7%94%A8%EF%BC%8C%E5%87%8F%E5%B0%91%E4%BA%86%E6%80%A7%E4%B8%8E%E6%9A%B4%E5%8A%9B%E7%9A%84%E7%BB%9D%E5%AF%B9%E5%8C%96%E6%AF%94%E9%87%8D%20%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="人本主义 Humanistic Theories 卡尔·罗杰斯 人人有积极向上的潜能" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BA%BA%E6%9C%AC%E4%B8%BB%E4%B9%89%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EHumanistic%20Theories%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%20%E5%8D%A1%E5%B0%94%C2%B7%E7%BD%97%E6%9D%B0%E6%96%AF%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BA%BA%E4%BA%BA%E6%9C%89%E7%A7%AF%E6%9E%81%E5%90%91%E4%B8%8A%E7%9A%84%E6%BD%9C%E8%83%BD%3C/span%3E" _note="" _mubu_note="">
          <outline text="强调人的整体性和自由意志，认为所有人都有积极向上的潜能" _mubu_text="%3Cspan%3E%E5%BC%BA%E8%B0%83%E4%BA%BA%E7%9A%84%E6%95%B4%E4%BD%93%E6%80%A7%E5%92%8C%E8%87%AA%E7%94%B1%E6%84%8F%E5%BF%97%EF%BC%8C%E8%AE%A4%E4%B8%BA%E6%89%80%E6%9C%89%E4%BA%BA%E9%83%BD%E6%9C%89%E7%A7%AF%E6%9E%81%E5%90%91%E4%B8%8A%E7%9A%84%E6%BD%9C%E8%83%BD%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="自我实现倾向 Self-Actualizing Tendency 个体天生具有成长、发展并实现最大潜能的驱动力「人不断追求成为更好的自己」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E6%88%91%E5%AE%9E%E7%8E%B0%E5%80%BE%E5%90%91%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESelf-Actualizing%20Tendency%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E4%B8%AA%E4%BD%93%E5%A4%A9%E7%94%9F%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%85%B7%E6%9C%89%E6%88%90%E9%95%BF%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%8F%91%E5%B1%95%3C/span%3E%3Cspan%3E%E5%B9%B6%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%AE%9E%E7%8E%B0%3C/span%3E%3Cspan%3E%E6%9C%80%E5%A4%A7%E6%BD%9C%E8%83%BD%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%A9%B1%E5%8A%A8%E5%8A%9B%3C/span%3E%3Cspan%3E%E3%80%8C%E4%BA%BA%E4%B8%8D%E6%96%AD%E8%BF%BD%E6%B1%82%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%88%90%E4%B8%BA%E6%9B%B4%E5%A5%BD%E7%9A%84%E8%87%AA%E5%B7%B1%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="自我概念 Self-Concept 对自己信念和知觉的集合，如果与现实经验不符会产生焦虑「觉得自己是个失败者，即使实际上没那么糟」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E6%88%91%E6%A6%82%E5%BF%B5%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESelf-Concept%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%AF%B9%E8%87%AA%E5%B7%B1%E4%BF%A1%E5%BF%B5%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%9F%A5%E8%A7%89%3C/span%3E%3Cspan%3E%E7%9A%84%E9%9B%86%E5%90%88%EF%BC%8C%E5%A6%82%E6%9E%9C%E4%B8%8E%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%8E%B0%E5%AE%9E%E7%BB%8F%E9%AA%8C%E4%B8%8D%E7%AC%A6%E4%BC%9A%E4%BA%A7%E7%94%9F%E7%84%A6%E8%99%91%3C/span%3E%3Cspan%3E%E3%80%8C%E8%A7%89%E5%BE%97%E8%87%AA%E5%B7%B1%E6%98%AF%E4%B8%AA%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A4%B1%E8%B4%A5%E8%80%85%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%8D%B3%E4%BD%BF%E5%AE%9E%E9%99%85%E4%B8%8A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B2%A1%E9%82%A3%E4%B9%88%E7%B3%9F%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="无条件积极关注 Unconditional Positive Regard 被完全接受和爱、不加判断的状态「无论孩子做了什么，父母都表达接纳和爱」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%97%A0%E6%9D%A1%E4%BB%B6%E7%A7%AF%E6%9E%81%E5%85%B3%E6%B3%A8%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EUnconditional%20Positive%20Regard%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E8%A2%AB%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%AE%8C%E5%85%A8%E6%8E%A5%E5%8F%97%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%88%B1%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%B8%8D%E5%8A%A0%E5%88%A4%E6%96%AD%E7%9A%84%E7%8A%B6%E6%80%81%3C/span%3E%3Cspan%3E%E3%80%8C%E6%97%A0%E8%AE%BA%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%AD%A9%E5%AD%90%3C/span%3E%3Cspan%3E%E5%81%9A%E4%BA%86%E4%BB%80%E4%B9%88%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%88%B6%E6%AF%8D%3C/span%3E%3Cspan%3E%E9%83%BD%E8%A1%A8%E8%BE%BE%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%8E%A5%E7%BA%B3%E5%92%8C%E7%88%B1%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="成长环境 需要具备同理心 Empathy 和接纳 Acceptance 的社会环境「咨询师对来访者完全共情、不评判」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%88%90%E9%95%BF%E7%8E%AF%E5%A2%83%3C/span%3E%3Cspan%3E%20%E9%9C%80%E8%A6%81%E5%85%B7%E5%A4%87%E5%90%8C%E7%90%86%E5%BF%83%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EEmpathy%20%3C/span%3E%3Cspan%3E%E5%92%8C%E6%8E%A5%E7%BA%B3%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EAcceptance%20%3C/span%3E%3Cspan%3E%E7%9A%84%E7%A4%BE%E4%BC%9A%E7%8E%AF%E5%A2%83%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%92%A8%E8%AF%A2%E5%B8%88%E5%AF%B9%E6%9D%A5%E8%AE%BF%E8%80%85%3C/span%3E%3Cspan%3E%E5%AE%8C%E5%85%A8%E5%85%B1%E6%83%85%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%8D%E8%AF%84%E5%88%A4%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="测评方法" _mubu_text="%3Cspan%3E%E6%B5%8B%E8%AF%84%E6%96%B9%E6%B3%95%3C/span%3E" _note="" _mubu_note="">
          <outline text="投射测验 Projective Test 提供模糊刺激（如墨迹图、抽象画），让受试者讲述故事，以此推断潜意识；局限性：信度和效度较差，缺乏科学证据 。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%8A%95%E5%B0%84%E6%B5%8B%E9%AA%8C%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EProjective%20Test%3C/span%3E%3Cspan%3E%20%E6%8F%90%E4%BE%9B%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%A8%A1%E7%B3%8A%E5%88%BA%E6%BF%80%3C/span%3E%3Cspan%3E%EF%BC%88%E5%A6%82%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A2%A8%E8%BF%B9%E5%9B%BE%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%8A%BD%E8%B1%A1%E7%94%BB%3C/span%3E%3Cspan%3E%EF%BC%89%EF%BC%8C%E8%AE%A9%E5%8F%97%E8%AF%95%E8%80%85%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%AE%B2%E8%BF%B0%E6%95%85%E4%BA%8B%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BB%A5%E6%AD%A4%E6%8E%A8%E6%96%AD%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%BD%9C%E6%84%8F%E8%AF%86%3C/span%3E%3Cspan%3E%EF%BC%9B%E5%B1%80%E9%99%90%E6%80%A7%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%BF%A1%E5%BA%A6%E5%92%8C%E6%95%88%E5%BA%A6%E8%BE%83%E5%B7%AE%3C/span%3E%3Cspan%3E%EF%BC%8C%E7%BC%BA%E4%B9%8F%E7%A7%91%E5%AD%A6%E8%AF%81%E6%8D%AE%20%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
      <outline text="4.5 Social-Cognitive and Trait Theories of Personality" _mubu_text="%3Cspan%3E4.5%20Social-Cognitive%20and%20Trait%20Theories%20of%20Personality%3C/span%3E" _note="" _mubu_note="">
        <outline text="社会认知理论 Social Cognitive Theory " _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A4%BE%E4%BC%9A%E8%AE%A4%E7%9F%A5%E7%90%86%E8%AE%BA%20Social%20Cognitive%20Theory%3C/span%3E%3Cspan%3E%20%3C/span%3E" _note="" _mubu_note="">
          <outline text="个人认知过程（Personal Factors）、行为（Behaviors）和环境（Environment）之间相互影响" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BA%BA%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%AE%A4%E7%9F%A5%E8%BF%87%E7%A8%8B%EF%BC%88%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EPersonal%20Factors%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%89%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%A1%8C%E4%B8%BA%EF%BC%88%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EBehaviors%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%89%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%8E%AF%E5%A2%83%EF%BC%88%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EEnvironment%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%89%3C/span%3E%3Cspan%3E%E4%B9%8B%E9%97%B4%E7%9B%B8%E4%BA%92%E5%BD%B1%E5%93%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="心理模型" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BF%83%E7%90%86%E6%A8%A1%E5%9E%8B%3C/span%3E" _note="" _mubu_note="">
            <outline text="行为主义模型 Behaviourist Model 研究可被观察的行为，心理是黑箱，强调刺激和反应的关系" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A1%8C%E4%B8%BA%E4%B8%BB%E4%B9%89%E6%A8%A1%E5%9E%8B%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EBehaviourist%20Model%3C/span%3E%3Cspan%3E%20%E7%A0%94%E7%A9%B6%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%8F%AF%E8%A2%AB%E8%A7%82%E5%AF%9F%3C/span%3E%3Cspan%3E%E7%9A%84%E8%A1%8C%E4%B8%BA%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%BF%83%E7%90%86%E6%98%AF%E9%BB%91%E7%AE%B1%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%BC%BA%E8%B0%83%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%88%BA%E6%BF%80%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%3E%E7%9A%84%E5%85%B3%E7%B3%BB%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="认知模型 Cognitive Model 科学地研究内部行为，关注输入到输出之间的中间过程" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AE%A4%E7%9F%A5%E6%A8%A1%E5%9E%8B%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ECognitive%20Model%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E7%A7%91%E5%AD%A6%E5%9C%B0%E7%A0%94%E7%A9%B6%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%86%85%E9%83%A8%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%85%B3%E6%B3%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%BE%93%E5%85%A5%E5%88%B0%E8%BE%93%E5%87%BA%3C/span%3E%3Cspan%3E%E4%B9%8B%E9%97%B4%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%B8%AD%E9%97%B4%E8%BF%87%E7%A8%8B%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="核心概念" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A0%B8%E5%BF%83%E6%A6%82%E5%BF%B5%3C/span%3E" _note="" _mubu_note="">
            <outline text="互惠决定论 Reciprocal Determinism Bandura 提出了三者之间相互影响「坏学生越来越差」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BA%92%E6%83%A0%E5%86%B3%E5%AE%9A%E8%AE%BA%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EReciprocal%20Determinism%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EBandura%20%3C/span%3E%3Cspan%3E%E6%8F%90%E5%87%BA%E4%BA%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%89%E8%80%85%E4%B9%8B%E9%97%B4%E7%9B%B8%E4%BA%92%E5%BD%B1%E5%93%8D%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%9D%8F%E5%AD%A6%E7%94%9F%E8%B6%8A%E6%9D%A5%E8%B6%8A%E5%B7%AE%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="自我效能感 Self-Efficacy 个体对自己应对各种情况能力的信念（任务）「我能Pass明天的考试」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E6%88%91%E6%95%88%E8%83%BD%E6%84%9F%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESelf-Efficacy%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%20%E4%B8%AA%E4%BD%93%3C/span%3E%3Cspan%3E%E5%AF%B9%E8%87%AA%E5%B7%B1%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BA%94%E5%AF%B9%3C/span%3E%3Cspan%3E%E5%90%84%E7%A7%8D%E6%83%85%E5%86%B5%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%83%BD%E5%8A%9B%3C/span%3E%3Cspan%3E%E7%9A%84%E4%BF%A1%E5%BF%B5%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%BB%BB%E5%8A%A1%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%88%91%E8%83%BDPass%E6%98%8E%E5%A4%A9%E7%9A%84%E8%80%83%E8%AF%95%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="自尊 Self-Esteem 个体对自己价值整体的主观情绪评价（价值）「无论考好考差，我都有价值」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E5%B0%8A%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESelf-Esteem%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%AA%E4%BD%93%3C/span%3E%3Cspan%3E%E5%AF%B9%E8%87%AA%E5%B7%B1%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BB%B7%E5%80%BC%3C/span%3E%3Cspan%3E%E6%95%B4%E4%BD%93%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%BB%E8%A7%82%E6%83%85%E7%BB%AA%E8%AF%84%E4%BB%B7%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%BB%B7%E5%80%BC%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%97%A0%E8%AE%BA%E8%80%83%E5%A5%BD%E8%80%83%E5%B7%AE%EF%BC%8C%E6%88%91%E9%83%BD%E6%9C%89%E4%BB%B7%E5%80%BC%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="自我概念 Self-Concept 没在PPT上，回答我是谁这个问题「Who Am I」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E6%88%91%E6%A6%82%E5%BF%B5%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESelf-Concept%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E6%B2%A1%E5%9C%A8PPT%E4%B8%8A%EF%BC%8C%E5%9B%9E%E7%AD%94%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%88%91%E6%98%AF%E8%B0%81%3C/span%3E%3Cspan%3E%E8%BF%99%E4%B8%AA%E9%97%AE%E9%A2%98%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EWho%20Am%20I%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
