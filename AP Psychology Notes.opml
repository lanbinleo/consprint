          <outline text="行为主义-经典条件 Behavioral: Classical Conditioning 不健康的刺激-反应联结形成「暴露疗法重建条件联结」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A1%8C%E4%B8%BA%E4%B8%BB%E4%B9%89-%E7%BB%8F%E5%85%B8%E6%9D%A1%E4%BB%B6%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EBehavioral%3C/span%3E%3Cspan%20class=%22bold%22%3E:%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EClassical%20Conditioning%3C/span%3E%3Cspan%3E%20%E4%B8%8D%E5%81%A5%E5%BA%B7%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%88%BA%E6%BF%80-%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%3E%E8%81%94%E7%BB%93%E5%BD%A2%E6%88%90%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9A%B4%E9%9C%B2%E7%96%97%E6%B3%95%3C/span%3E%3Cspan%3E%E9%87%8D%E5%BB%BA%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%9D%A1%E4%BB%B6%E8%81%94%E7%BB%93%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="行为主义-操作条件 Behavioral: Operant Conditioning 错误的奖惩强化系统维持问题行为「建立新的行为强化机制」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A1%8C%E4%B8%BA%E4%B8%BB%E4%B9%89-%E6%93%8D%E4%BD%9C%E6%9D%A1%E4%BB%B6%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EBehavioral%3C/span%3E%3Cspan%20class=%22bold%22%3E:%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EOperant%20Conditioning%3C/span%3E%3Cspan%3E%20%E9%94%99%E8%AF%AF%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A5%96%E6%83%A9%E5%BC%BA%E5%8C%96%E7%B3%BB%E7%BB%9F%3C/span%3E%3Cspan%3E%E7%BB%B4%E6%8C%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%97%AE%E9%A2%98%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%E3%80%8C%E5%BB%BA%E7%AB%8B%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%96%B0%E7%9A%84%3C/span%3E%3Cspan%3E%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%BC%BA%E5%8C%96%E6%9C%BA%E5%88%B6%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="认知学派 Cognitive 适应不良的思维模式与认知扭曲「识别并纠正自动化Negative思维」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AE%A4%E7%9F%A5%E5%AD%A6%E6%B4%BE%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ECognitive%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E9%80%82%E5%BA%94%E4%B8%8D%E8%89%AF%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%80%9D%E7%BB%B4%E6%A8%A1%E5%BC%8F%3C/span%3E%3Cspan%3E%E4%B8%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%AE%A4%E7%9F%A5%E6%89%AD%E6%9B%B2%3C/span%3E%3Cspan%3E%E3%80%8C%E8%AF%86%E5%88%AB%E5%B9%B6%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%BA%A0%E6%AD%A3%E8%87%AA%E5%8A%A8%E5%8C%96Negative%3C/span%3E%3Cspan%3E%E6%80%9D%E7%BB%B4%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="生物取向 Biological 神经化学失衡、基因遗传与脑结构异常「药物干预、电刺激、手术」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%94%9F%E7%89%A9%E5%8F%96%E5%90%91%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EBiological%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E7%A5%9E%E7%BB%8F%E5%8C%96%E5%AD%A6%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%B1%E8%A1%A1%3C/span%3E%3Cspan%3E%E3%80%81%E5%9F%BA%E5%9B%A0%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%81%97%E4%BC%A0%3C/span%3E%3Cspan%3E%E4%B8%8E%E8%84%91%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%BB%93%E6%9E%84%E5%BC%82%E5%B8%B8%3C/span%3E%3Cspan%3E%E3%80%8C%E8%8D%AF%E7%89%A9%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%B9%B2%E9%A2%84%3C/span%3E%3Cspan%3E%E3%80%81%E7%94%B5%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%88%BA%E6%BF%80%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%89%8B%E6%9C%AF%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="人本主义 Humanistic 自我实现潜能受阻或成长环境缺陷「移除成长障碍，强调无条件积极关注」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BA%BA%E6%9C%AC%E4%B8%BB%E4%B9%89%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EHumanistic%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E8%87%AA%E6%88%91%E5%AE%9E%E7%8E%B0%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%BD%9C%E8%83%BD%E5%8F%97%E9%98%BB%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%88%90%E9%95%BF%E7%8E%AF%E5%A2%83%3C/span%3E%3Cspan%3E%E7%BC%BA%E9%99%B7%E3%80%8C%E7%A7%BB%E9%99%A4%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%88%90%E9%95%BF%E9%9A%9C%E7%A2%8D%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%BC%BA%E8%B0%83%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%97%A0%E6%9D%A1%E4%BB%B6%E7%A7%AF%E6%9E%81%E5%85%B3%E6%B3%A8%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="社会文化 Sociocultural 个体与社会文化规范的冲突「重新适应社会或改变社会环境」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A4%BE%E4%BC%9A%E6%96%87%E5%8C%96%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESociocultural%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E4%B8%AA%E4%BD%93%E4%B8%8E%E7%A4%BE%E4%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%96%87%E5%8C%96%E8%A7%84%E8%8C%83%3C/span%3E%3Cspan%3E%E7%9A%84%E5%86%B2%E7%AA%81%E3%80%8C%E9%87%8D%E6%96%B0%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%80%82%E5%BA%94%E7%A4%BE%E4%BC%9A%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%94%B9%E5%8F%98%E7%A4%BE%E4%BC%9A%E7%8E%AF%E5%A2%83%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="整合性诊断模型 Integrative Models 当代心理健康专业人员的主流方法" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%95%B4%E5%90%88%E6%80%A7%E8%AF%8A%E6%96%AD%E6%A8%A1%E5%9E%8B%20Integrative%20Models%3C/span%3E%3Cspan%3E%20%E5%BD%93%E4%BB%A3%E5%BF%83%E7%90%86%E5%81%A5%E5%BA%B7%E4%B8%93%E4%B8%9A%E4%BA%BA%E5%91%98%E7%9A%84%E4%B8%BB%E6%B5%81%E6%96%B9%E6%B3%95%3C/span%3E" _note="" _mubu_note="">
          <outline text="生物心理社会模型 Biopsychosocial Model 生物 Biology × 心理 Psychological × 社会 Social" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%94%9F%E7%89%A9%E5%BF%83%E7%90%86%E7%A4%BE%E4%BC%9A%E6%A8%A1%E5%9E%8B%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EBiopsychosocial%20%3C/span%3E%3Cspan%20class=%22bold%22%3EModel%3C/span%3E%3Cspan%3E%20%E7%94%9F%E7%89%A9%20Biology%20%C3%97%20%E5%BF%83%E7%90%86%20Psychological%20%C3%97%20%E7%A4%BE%E4%BC%9A%20Social%3C/span%3E" _note="" _mubu_note="">
            <outline text="三因素交互作用" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%89%E5%9B%A0%E7%B4%A0%3C/span%3E%3Cspan%3E%E4%BA%A4%E4%BA%92%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BD%9C%E7%94%A8%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="折中主义方法 Eclectic Approach：拒绝单因素决定论，综合考虑多维度" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E6%8A%98%E4%B8%AD%E4%B8%BB%E4%B9%89%3C/span%3E%3Cspan%3E%E6%96%B9%E6%B3%95%20Eclectic%20Approach%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%8B%92%E7%BB%9D%E5%8D%95%E5%9B%A0%E7%B4%A0%E5%86%B3%E5%AE%9A%E8%AE%BA%3C/span%3E%3Cspan%3E%EF%BC%8C%E7%BB%BC%E5%90%88%E8%80%83%E8%99%91%E5%A4%9A%E7%BB%B4%E5%BA%A6%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="素质-压力模型 Diathesis-Stress Model" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B4%A0%E8%B4%A8-%E5%8E%8B%E5%8A%9B%E6%A8%A1%E5%9E%8B%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%20Diathesis-Stress%3C/span%3E%3Cspan%20class=%22bold%22%3E%20Model%3C/span%3E" _note="" _mubu_note="">
            <outline text="先天遗传易感性 Diathesis/Nature 与后天压力事件Stress/Nurture" _mubu_text="%3Cspan%3E%E5%85%88%E5%A4%A9%E9%81%97%E4%BC%A0%E6%98%93%E6%84%9F%E6%80%A7%20Diathesis/Nature%20%E4%B8%8E%E5%90%8E%E5%A4%A9%E5%8E%8B%E5%8A%9B%E4%BA%8B%E4%BB%B6Stress/Nurture%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="共同触发障碍 有家族史≠必然发病；" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%85%B1%E5%90%8C%E8%A7%A6%E5%8F%91%3C/span%3E%3Cspan%3E%E9%9A%9C%E7%A2%8D%20%E6%9C%89%E5%AE%B6%E6%97%8F%E5%8F%B2%E2%89%A0%E5%BF%85%E7%84%B6%E5%8F%91%E7%97%85%EF%BC%9B%3C/span%3E" _note="" _mubu_note="">
              <outline text="解释Nature vs. Nurture互动框架，强调遗传脆弱性需环境压力触发" _mubu_text="%3Cspan%3E%E8%A7%A3%E9%87%8ANature%20vs.%20Nurture%E4%BA%92%E5%8A%A8%E6%A1%86%E6%9E%B6%EF%BC%8C%E5%BC%BA%E8%B0%83%E9%81%97%E4%BC%A0%E8%84%86%E5%BC%B1%E6%80%A7%E9%9C%80%E7%8E%AF%E5%A2%83%E5%8E%8B%E5%8A%9B%E8%A7%A6%E5%8F%91%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
      </outline>
      <outline text="5.4 Selection of Categories of Psychological Disorders" _mubu_text="%3Cspan%3E5.4%20Selection%20of%20Categories%20of%20Psychological%20Disorders%3C/span%3E" _note="" _mubu_note="">
        <outline text="精神分裂症 Schizophrenia" _mubu_text="%3Cspan%3E%E7%B2%BE%E7%A5%9E%E5%88%86%E8%A3%82%E7%97%87%20Schizophrenia%3C/span%3E" _note="" _mubu_note="">
          <outline text="精神分裂症 Schizophrenia 功能恶化因异常感知、奇怪思维、情绪紊乱和运动异常「不是人格分裂」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B2%BE%E7%A5%9E%E5%88%86%E8%A3%82%E7%97%87%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESchizophrenia%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%8A%9F%E8%83%BD%E6%81%B6%E5%8C%96%3C/span%3E%3Cspan%3E%E5%9B%A0%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BC%82%E5%B8%B8%E6%84%9F%E7%9F%A5%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A5%87%E6%80%AA%E6%80%9D%E7%BB%B4%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E7%BB%AA%E7%B4%8A%E4%B9%B1%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%BF%90%E5%8A%A8%E5%BC%82%E5%B8%B8%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E4%B8%8D%E6%98%AF%E4%BA%BA%E6%A0%BC%E5%88%86%E8%A3%82%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="分裂的心智 &quot;Split Mind&quot;" _mubu_text="%3Cspan%3E%E5%88%86%E8%A3%82%E7%9A%84%E5%BF%83%E6%99%BA%20%22Split%20Mind%22%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="精神病性障碍 Psychotic Disorder 个人、社会和职业功能因异常感知、奇怪思维、情绪紊乱和运动异常而恶化，而非人格分裂" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B2%BE%E7%A5%9E%E7%97%85%E6%80%A7%E9%9A%9C%E7%A2%8D%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EPsychotic%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EDisorder%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E4%B8%AA%E4%BA%BA%E3%80%81%E7%A4%BE%E4%BC%9A%E5%92%8C%E8%81%8C%E4%B8%9A%E5%8A%9F%E8%83%BD%E5%9B%A0%E5%BC%82%E5%B8%B8%E6%84%9F%E7%9F%A5%E3%80%81%E5%A5%87%E6%80%AA%E6%80%9D%E7%BB%B4%E3%80%81%E6%83%85%E7%BB%AA%E7%B4%8A%E4%B9%B1%E5%92%8C%E8%BF%90%E5%8A%A8%E5%BC%82%E5%B8%B8%E8%80%8C%E6%81%B6%E5%8C%96%EF%BC%8C%E8%80%8C%E9%9D%9E%E4%BA%BA%E6%A0%BC%E5%88%86%E8%A3%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="诊断方法 Diagnostic Criteria 妄想 幻觉 言语紊乱 异常运动 其他阴性症状" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%96%B9%E6%B3%95%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EDiagnostic%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ECriteria%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E5%A6%84%E6%83%B3%20%E5%B9%BB%E8%A7%89%20%E8%A8%80%E8%AF%AD%E7%B4%8A%E4%B9%B1%20%E5%BC%82%E5%B8%B8%E8%BF%90%E5%8A%A8%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%85%B6%E4%BB%96%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E9%98%B4%E6%80%A7%E7%97%87%E7%8A%B6%3C/span%3E" _note="" _mubu_note="">
            <outline text="至少1个月内，个体大部分时间表现出以下2种或更多症状：" _mubu_text="%3Cspan%3E%E8%87%B3%E5%B0%911%E4%B8%AA%E6%9C%88%E5%86%85%EF%BC%8C%E4%B8%AA%E4%BD%93%E5%A4%A7%E9%83%A8%E5%88%86%E6%97%B6%E9%97%B4%E8%A1%A8%E7%8E%B0%E5%87%BA%E4%BB%A5%E4%B8%8B2%E7%A7%8D%E6%88%96%E6%9B%B4%E5%A4%9A%E7%97%87%E7%8A%B6%EF%BC%9A%3C/span%3E" _note="" _mubu_note="">
              <outline text="妄想 Delusions" _mubu_text="%3Cspan%3E%E5%A6%84%E6%83%B3%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EDelusions%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="幻觉 Hallucinations" _mubu_text="%3Cspan%3E%E5%B9%BB%E8%A7%89%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EHallucinations%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="言语紊乱 Disorganized Speech" _mubu_text="%3Cspan%3E%E8%A8%80%E8%AF%AD%E7%B4%8A%E4%B9%B1%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EDisorganized%20Speech%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="异常运动行为 Abnormal Motor Activity(包括紧张症 Catatonia)" _mubu_text="%3Cspan%3E%E5%BC%82%E5%B8%B8%E8%BF%90%E5%8A%A8%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20Abnormal%20Motor%20Activity%3C/span%3E%3Cspan%3E(%E5%8C%85%E6%8B%AC%E7%B4%A7%E5%BC%A0%E7%97%87%20Catatonia)%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="阴性症状 Negative Symptoms" _mubu_text="%3Cspan%3E%E9%98%B4%E6%80%A7%E7%97%87%E7%8A%B6%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20Negative%20Symptoms%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="至少一种症状必须是妄想、幻觉或言语紊乱" _mubu_text="%3Cspan%3E%E8%87%B3%E5%B0%91%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E4%B8%80%E7%A7%8D%E7%97%87%E7%8A%B6%3C/span%3E%3Cspan%3E%E5%BF%85%E9%A1%BB%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A6%84%E6%83%B3%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%B9%BB%E8%A7%89%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A8%80%E8%AF%AD%E7%B4%8A%E4%B9%B1%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="个体在各生活领域的功能明显低于症状出现前" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E5%9C%A8%E5%90%84%E7%94%9F%E6%B4%BB%E9%A2%86%E5%9F%9F%E7%9A%84%E5%8A%9F%E8%83%BD%E6%98%8E%E6%98%BE%E4%BD%8E%E4%BA%8E%E7%97%87%E7%8A%B6%E5%87%BA%E7%8E%B0%E5%89%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="除1个月的强烈症状期外，个体在至少5个月内持续表现出某种程度的功能受损" _mubu_text="%3Cspan%3E%E9%99%A41%E4%B8%AA%E6%9C%88%E7%9A%84%E5%BC%BA%E7%83%88%E7%97%87%E7%8A%B6%E6%9C%9F%E5%A4%96%EF%BC%8C%E4%B8%AA%E4%BD%93%E5%9C%A8%E8%87%B3%E5%B0%915%E4%B8%AA%E6%9C%88%E5%86%85%E6%8C%81%E7%BB%AD%E8%A1%A8%E7%8E%B0%E5%87%BA%E6%9F%90%E7%A7%8D%E7%A8%8B%E5%BA%A6%E7%9A%84%E5%8A%9F%E8%83%BD%E5%8F%97%E6%8D%9F%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="类型分类 Chronic 慢性（青春期开始，随年龄增长）Acute 急性（任何年龄开始，创伤反应）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B1%BB%E5%9E%8B%E5%88%86%E7%B1%BB%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EChronic%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E6%85%A2%E6%80%A7%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%9D%92%E6%98%A5%E6%9C%9F%3C/span%3E%3Cspan%3E%E5%BC%80%E5%A7%8B%EF%BC%8C%E9%9A%8F%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%B9%B4%E9%BE%84%E5%A2%9E%E9%95%BF%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EAcute%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%E6%80%A5%E6%80%A7%3C/span%3E%3Cspan%3E%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BB%BB%E4%BD%95%E5%B9%B4%E9%BE%84%3C/span%3E%3Cspan%3E%E5%BC%80%E5%A7%8B%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%88%9B%E4%BC%A4%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="慢性精神分裂症 Chronic Schizophrenia 症状通常在青春期晚期或成年早期出现,随年龄增长 精神病发作持续时间更长 恢复期缩短" _mubu_text="%3Cspan%3E%E6%85%A2%E6%80%A7%E7%B2%BE%E7%A5%9E%E5%88%86%E8%A3%82%E7%97%87%20Chronic%20Schizophrenia%20%E7%97%87%E7%8A%B6%E9%80%9A%E5%B8%B8%E5%9C%A8%E9%9D%92%E6%98%A5%E6%9C%9F%E6%99%9A%E6%9C%9F%E6%88%96%E6%88%90%E5%B9%B4%E6%97%A9%E6%9C%9F%E5%87%BA%E7%8E%B0,%E9%9A%8F%E5%B9%B4%E9%BE%84%E5%A2%9E%E9%95%BF%20%E7%B2%BE%E7%A5%9E%E7%97%85%E5%8F%91%E4%BD%9C%E6%8C%81%E7%BB%AD%E6%97%B6%E9%97%B4%E6%9B%B4%E9%95%BF%20%E6%81%A2%E5%A4%8D%E6%9C%9F%E7%BC%A9%E7%9F%AD%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="急性精神分裂症 Acute Schizophrenia 可在任何年龄开始 常作为对创伤事件的反应而发生" _mubu_text="%3Cspan%3E%E6%80%A5%E6%80%A7%E7%B2%BE%E7%A5%9E%E5%88%86%E8%A3%82%E7%97%87%20Acute%20Schizophrenia%20%E5%8F%AF%E5%9C%A8%E4%BB%BB%E4%BD%95%E5%B9%B4%E9%BE%84%E5%BC%80%E5%A7%8B%20%E5%B8%B8%E4%BD%9C%E4%B8%BA%E5%AF%B9%E5%88%9B%E4%BC%A4%E4%BA%8B%E4%BB%B6%E7%9A%84%E5%8F%8D%E5%BA%94%E8%80%8C%E5%8F%91%E7%94%9F%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="阳性症状 Positive Symptoms「妄想、幻觉、思维混乱、紧张症」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%98%B3%E6%80%A7%E7%97%87%E7%8A%B6%20Positive%20Symptoms%3C/span%3E%3Cspan%3E%E3%80%8C%E5%A6%84%E6%83%B3%E3%80%81%E5%B9%BB%E8%A7%89%E3%80%81%E6%80%9D%E7%BB%B4%E6%B7%B7%E4%B9%B1%E3%80%81%E7%B4%A7%E5%BC%A0%E7%97%87%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="阳性 = 比别人多做的" _mubu_text="%3Cspan%3E%E9%98%B3%E6%80%A7%20=%20%E6%AF%94%E5%88%AB%E4%BA%BA%E5%A4%9A%E5%81%9A%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="妄想 Delusions 虚假信念，即使被证明不正确也不改变；关系妄想、夸大妄想和被害妄想" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%A6%84%E6%83%B3%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EDelusions%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E8%99%9A%E5%81%87%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BF%A1%E5%BF%B5%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%8D%B3%E4%BD%BF%E8%A2%AB%E8%AF%81%E6%98%8E%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%B8%8D%E6%AD%A3%E7%A1%AE%E4%B9%9F%E4%B8%8D%E6%94%B9%E5%8F%98%3C/span%3E%3Cspan%3E%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%85%B3%E7%B3%BB%E5%A6%84%E6%83%B3%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A4%B8%E5%A4%A7%E5%A6%84%E6%83%B3%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%A2%AB%E5%AE%B3%E5%A6%84%E6%83%B3%3C/span%3E" _note="" _mubu_note="">
              <outline text="关系妄想 Delusions of Reference 相信报纸、电视、广播或杂志通过隐藏信息向自己传递消息 「演员的台词是传递给我的秘密信息」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%85%B3%E7%B3%BB%E5%A6%84%E6%83%B3%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EDelusions%20of%20Reference%3C/span%3E%3Cspan%3E%20%E7%9B%B8%E4%BF%A1%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8A%A5%E7%BA%B8%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%94%B5%E8%A7%86%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%B9%BF%E6%92%AD%3C/span%3E%3Cspan%3E%E6%88%96%E6%9D%82%E5%BF%97%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%80%9A%E8%BF%87%E9%9A%90%E8%97%8F%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%E5%90%91%E8%87%AA%E5%B7%B1%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%BC%A0%E9%80%92%E6%B6%88%E6%81%AF%20%3C/span%3E%3Cspan%3E%E3%80%8C%E6%BC%94%E5%91%98%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%8F%B0%E8%AF%8D%3C/span%3E%3Cspan%3E%E6%98%AF%E4%BC%A0%E9%80%92%E7%BB%99%E6%88%91%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%A7%98%E5%AF%86%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="夸大妄想 Delusions of Grandeur 相信自己是非常强大或重要的人物，拥有特殊能力、财产或权力 「我是某个巨大世家的嫡长子，父母只是在考验我」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%A4%B8%E5%A4%A7%E5%A6%84%E6%83%B3%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EDelusions%20of%20Grandeur%3C/span%3E%3Cspan%3E%20%E7%9B%B8%E4%BF%A1%E8%87%AA%E5%B7%B1%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%9D%9E%E5%B8%B8%E5%BC%BA%E5%A4%A7%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%87%8D%E8%A6%81%E7%9A%84%E4%BA%BA%E7%89%A9%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%8B%A5%E6%9C%89%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%89%B9%E6%AE%8A%E8%83%BD%E5%8A%9B%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%B4%A2%E4%BA%A7%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9D%83%E5%8A%9B%3C/span%3E%3Cspan%3E%20%E3%80%8C%E6%88%91%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%9F%90%E4%B8%AA%E5%B7%A8%E5%A4%A7%E4%B8%96%E5%AE%B6%E7%9A%84%E5%AB%A1%E9%95%BF%E5%AD%90%3C/span%3E%3Cspan%3E%EF%BC%8C%E7%88%B6%E6%AF%8D%E5%8F%AA%E6%98%AF%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%80%83%E9%AA%8C%E6%88%91%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="被害妄想 Delusions of Persecution 相信自己被他人迫害、监视或密谋陷害 「是你给我下毒了，最常见」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A2%AB%E5%AE%B3%E5%A6%84%E6%83%B3%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EDelusions%20of%20Persecution%3C/span%3E%3Cspan%3E%20%E7%9B%B8%E4%BF%A1%E8%87%AA%E5%B7%B1%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A2%AB%E4%BB%96%E4%BA%BA%E8%BF%AB%E5%AE%B3%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%9B%91%E8%A7%86%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%AF%86%E8%B0%8B%E9%99%B7%E5%AE%B3%3C/span%3E%3Cspan%3E%20%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%98%AF%E4%BD%A0%E7%BB%99%E6%88%91%E4%B8%8B%E6%AF%92%E4%BA%86%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E6%9C%80%E5%B8%B8%E8%A7%81%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="幻觉 Hallucinations - 感知虚假的感官刺激，对体验者来说生动真实，内容通常是负面的" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B9%BB%E8%A7%89%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EHallucinations%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E-%20%E6%84%9F%E7%9F%A5%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%99%9A%E5%81%87%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%84%9F%E5%AE%98%E5%88%BA%E6%BF%80%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%AF%B9%E4%BD%93%E9%AA%8C%E8%80%85%E6%9D%A5%E8%AF%B4%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%94%9F%E5%8A%A8%E7%9C%9F%E5%AE%9E%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E5%86%85%E5%AE%B9%E9%80%9A%E5%B8%B8%E6%98%AF%E8%B4%9F%E9%9D%A2%E7%9A%84%3C/span%3E" _note="" _mubu_note="">
              <outline text="看到、感觉到、尝到或闻到不存在的东西(听觉幻觉 Auditory Hallucinations 最常见)" _mubu_text="%3Cspan%3E%E7%9C%8B%E5%88%B0%E3%80%81%E6%84%9F%E8%A7%89%E5%88%B0%E3%80%81%E5%B0%9D%E5%88%B0%E6%88%96%E9%97%BB%E5%88%B0%E4%B8%8D%E5%AD%98%E5%9C%A8%E7%9A%84%E4%B8%9C%E8%A5%BF(%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%90%AC%E8%A7%89%E5%B9%BB%E8%A7%89%20Auditory%20Hallucinations%3C/span%3E%3Cspan%3E%20%E6%9C%80%E5%B8%B8%E8%A7%81)%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="研究表明,有听觉幻觉的人实际上在大脑中产生声音的神经信号,&quot;听到&quot;它们,然后相信外部来源是负责的" _mubu_text="%3Cspan%3E%E7%A0%94%E7%A9%B6%E8%A1%A8%E6%98%8E,%E6%9C%89%E5%90%AC%E8%A7%89%E5%B9%BB%E8%A7%89%E7%9A%84%E4%BA%BA%E5%AE%9E%E9%99%85%E4%B8%8A%E5%9C%A8%E5%A4%A7%E8%84%91%E4%B8%AD%E4%BA%A7%E7%94%9F%E5%A3%B0%E9%9F%B3%E7%9A%84%E7%A5%9E%E7%BB%8F%E4%BF%A1%E5%8F%B7,%22%E5%90%AC%E5%88%B0%22%E5%AE%83%E4%BB%AC,%E7%84%B6%E5%90%8E%E7%9B%B8%E4%BF%A1%E5%A4%96%E9%83%A8%E6%9D%A5%E6%BA%90%E6%98%AF%E8%B4%9F%E8%B4%A3%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="言语/思维紊乱 Disorganized Speech/Thinking 不连贯或无意义的言语模式「Word Salad」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A8%80%E8%AF%AD/%E6%80%9D%E7%BB%B4%E7%B4%8A%E4%B9%B1%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EDisorganized%20Speech/Thinking%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%8D%E8%BF%9E%E8%B4%AF%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%97%A0%E6%84%8F%E4%B9%89%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%A8%80%E8%AF%AD%E6%A8%A1%E5%BC%8F%3C/span%3E%3Cspan%3E%E3%80%8CWord%20Salad%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="不连贯或无意义的言语模式，如在不相关的话题之间跳跃或不恰当地使用词语，反映思维过程紊乱" _mubu_text="%3Cspan%3E%E4%B8%8D%E8%BF%9E%E8%B4%AF%E6%88%96%E6%97%A0%E6%84%8F%E4%B9%89%E7%9A%84%E8%A8%80%E8%AF%AD%E6%A8%A1%E5%BC%8F%EF%BC%8C%E5%A6%82%E5%9C%A8%E4%B8%8D%E7%9B%B8%E5%85%B3%E7%9A%84%E8%AF%9D%E9%A2%98%E4%B9%8B%E9%97%B4%E8%B7%B3%E8%B7%83%E6%88%96%E4%B8%8D%E6%81%B0%E5%BD%93%E5%9C%B0%E4%BD%BF%E7%94%A8%E8%AF%8D%E8%AF%AD%EF%BC%8C%E5%8F%8D%E6%98%A0%E6%80%9D%E7%BB%B4%E8%BF%87%E7%A8%8B%E7%B4%8A%E4%B9%B1%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="词语沙拉 Word Salad: 完全混乱的言语" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8D%E8%AF%AD%E6%B2%99%E6%8B%89%20Word%20Salad%3C/span%3E%3Cspan%3E:%20%E5%AE%8C%E5%85%A8%E6%B7%B7%E4%B9%B1%E7%9A%84%E8%A8%80%E8%AF%AD%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="紧张症 Catatonia / 运动行为紊乱 过度的、无目的的运动活动「过度激动、奇怪姿势、踱步……」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B4%A7%E5%BC%A0%E7%97%87%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ECatatonia%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E/%20%E8%BF%90%E5%8A%A8%E8%A1%8C%E4%B8%BA%E7%B4%8A%E4%B9%B1%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%BF%87%E5%BA%A6%E7%9A%84%E3%80%81%E6%97%A0%E7%9B%AE%E7%9A%84%E7%9A%84%E8%BF%90%E5%8A%A8%E6%B4%BB%E5%8A%A8%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%BF%87%E5%BA%A6%E6%BF%80%E5%8A%A8%E3%80%81%E5%A5%87%E6%80%AA%E5%A7%BF%E5%8A%BF%E3%80%81%E8%B8%B1%E6%AD%A5%E2%80%A6%E2%80%A6%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="作为阳性症状:过度的、无目的的运动活动,如过度激动、奇怪姿势、踱步、重复动作、攻击和暴力行为;也可能包括奇怪的行为或言语、模仿附近人的动作或谈话,甚至自我伤害行为" _mubu_text="%3Cspan%3E%E4%BD%9C%E4%B8%BA%E9%98%B3%E6%80%A7%E7%97%87%E7%8A%B6:%E8%BF%87%E5%BA%A6%E7%9A%84%E3%80%81%E6%97%A0%E7%9B%AE%E7%9A%84%E7%9A%84%E8%BF%90%E5%8A%A8%E6%B4%BB%E5%8A%A8,%E5%A6%82%E8%BF%87%E5%BA%A6%E6%BF%80%E5%8A%A8%E3%80%81%E5%A5%87%E6%80%AA%E5%A7%BF%E5%8A%BF%E3%80%81%E8%B8%B1%E6%AD%A5%E3%80%81%E9%87%8D%E5%A4%8D%E5%8A%A8%E4%BD%9C%E3%80%81%E6%94%BB%E5%87%BB%E5%92%8C%E6%9A%B4%E5%8A%9B%E8%A1%8C%E4%B8%BA;%E4%B9%9F%E5%8F%AF%E8%83%BD%E5%8C%85%E6%8B%AC%E5%A5%87%E6%80%AA%E7%9A%84%E8%A1%8C%E4%B8%BA%E6%88%96%E8%A8%80%E8%AF%AD%E3%80%81%E6%A8%A1%E4%BB%BF%E9%99%84%E8%BF%91%E4%BA%BA%E7%9A%84%E5%8A%A8%E4%BD%9C%E6%88%96%E8%B0%88%E8%AF%9D,%E7%94%9A%E8%87%B3%E8%87%AA%E6%88%91%E4%BC%A4%E5%AE%B3%E8%A1%8C%E4%B8%BA%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="阴性症状 Negative Symptoms「紧张性木僵、情感平淡」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%98%B4%E6%80%A7%E7%97%87%E7%8A%B6%20Negative%20Symptoms%3C/span%3E%3Cspan%3E%E3%80%8C%E7%B4%A7%E5%BC%A0%E6%80%A7%E6%9C%A8%E5%83%B5%E3%80%81%E6%83%85%E6%84%9F%E5%B9%B3%E6%B7%A1%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="阴性 = 比别人少的，可能被误解为抑郁或懒惰" _mubu_text="%3Cspan%3E%E9%98%B4%E6%80%A7%20=%20%E6%AF%94%E5%88%AB%E4%BA%BA%E5%B0%91%E7%9A%84%EF%BC%8C%E5%8F%AF%E8%83%BD%E8%A2%AB%E8%AF%AF%E8%A7%A3%E4%B8%BA%E6%8A%91%E9%83%81%E6%88%96%E6%87%92%E6%83%B0%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="紧张性木僵 Catatonia Stupor - 缺乏运动或反应，身体抗拒移动「诡异的姿势」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B4%A7%E5%BC%A0%E6%80%A7%E6%9C%A8%E5%83%B5%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ECatatonia%20Stupor%3C/span%3E%3Cspan%3E%20-%20%E7%BC%BA%E4%B9%8F%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%BF%90%E5%8A%A8%E6%88%96%E5%8F%8D%E5%BA%94%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%BA%AB%E4%BD%93%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8A%97%E6%8B%92%E7%A7%BB%E5%8A%A8%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%AF%A1%E5%BC%82%E7%9A%84%E5%A7%BF%E5%8A%BF%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="包括对环境无反应和不动" _mubu_text="%3Cspan%3E%E5%8C%85%E6%8B%AC%E5%AF%B9%E7%8E%AF%E5%A2%83%E6%97%A0%E5%8F%8D%E5%BA%94%E5%92%8C%E4%B8%8D%E5%8A%A8%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="可能以不寻常的姿势保持自己,甚至可能抵抗移动他们的尝试" _mubu_text="%3Cspan%3E%E5%8F%AF%E8%83%BD%E4%BB%A5%E4%B8%8D%E5%AF%BB%E5%B8%B8%E7%9A%84%E5%A7%BF%E5%8A%BF%E4%BF%9D%E6%8C%81%E8%87%AA%E5%B7%B1,%E7%94%9A%E8%87%B3%E5%8F%AF%E8%83%BD%E6%8A%B5%E6%8A%97%E7%A7%BB%E5%8A%A8%E4%BB%96%E4%BB%AC%E7%9A%84%E5%B0%9D%E8%AF%95%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="情感平淡 Flat Affect - 情绪表达严重减少「面瘫」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%83%85%E6%84%9F%E5%B9%B3%E6%B7%A1%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EFlat%20Affect%3C/span%3E%3Cspan%3E%20-%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E7%BB%AA%E8%A1%A8%E8%BE%BE%3C/span%3E%3Cspan%3E%E4%B8%A5%E9%87%8D%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%87%8F%E5%B0%91%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E9%9D%A2%E7%98%AB%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="面部静止,眼神接触差,声音单调" _mubu_text="%3Cspan%3E%E9%9D%A2%E9%83%A8%E9%9D%99%E6%AD%A2,%E7%9C%BC%E7%A5%9E%E6%8E%A5%E8%A7%A6%E5%B7%AE,%E5%A3%B0%E9%9F%B3%E5%8D%95%E8%B0%83%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="面部表情不变,自发动作减少,缺乏表达性手势,眼神接触差,声音缺乏抑扬顿挫,言语缓慢" _mubu_text="%3Cspan%3E%E9%9D%A2%E9%83%A8%E8%A1%A8%E6%83%85%E4%B8%8D%E5%8F%98,%E8%87%AA%E5%8F%91%E5%8A%A8%E4%BD%9C%E5%87%8F%E5%B0%91,%E7%BC%BA%E4%B9%8F%E8%A1%A8%E8%BE%BE%E6%80%A7%E6%89%8B%E5%8A%BF,%E7%9C%BC%E7%A5%9E%E6%8E%A5%E8%A7%A6%E5%B7%AE,%E5%A3%B0%E9%9F%B3%E7%BC%BA%E4%B9%8F%E6%8A%91%E6%89%AC%E9%A1%BF%E6%8C%AB,%E8%A8%80%E8%AF%AD%E7%BC%93%E6%85%A2%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="病因学 Etiology" _mubu_text="%3Cspan%3E%E7%97%85%E5%9B%A0%E5%AD%A6%20Etiology%3C/span%3E" _note="" _mubu_note="">
          <outline text="精神分裂症的病因 Schizophrenia Etiology 原因未知，因素众多" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B2%BE%E7%A5%9E%E5%88%86%E8%A3%82%E7%97%87%E7%9A%84%E7%97%85%E5%9B%A0%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESchizophrenia%20Etiology%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%8E%9F%E5%9B%A0%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9C%AA%E7%9F%A5%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%9B%A0%E7%B4%A0%E4%BC%97%E5%A4%9A%3C/span%3E" _note="" _mubu_note="">
            <outline text="疾病的确切原因未知，遗传、环境、神经生物学和心理社会压力均做出贡献" _mubu_text="%3Cspan%3E%E7%96%BE%E7%97%85%E7%9A%84%E7%A1%AE%E5%88%87%E5%8E%9F%E5%9B%A0%E6%9C%AA%E7%9F%A5%EF%BC%8C%E9%81%97%E4%BC%A0%E3%80%81%E7%8E%AF%E5%A2%83%E3%80%81%E7%A5%9E%E7%BB%8F%E7%94%9F%E7%89%A9%E5%AD%A6%E5%92%8C%E5%BF%83%E7%90%86%E7%A4%BE%E4%BC%9A%E5%8E%8B%E5%8A%9B%E5%9D%87%E5%81%9A%E5%87%BA%E8%B4%A1%E7%8C%AE%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="素质-应激模型 Diathesis-Stress Model 可以尝试解释病因" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B4%A0%E8%B4%A8-%E5%BA%94%E6%BF%80%E6%A8%A1%E5%9E%8B%20Diathesis-Stress%20Model%3C/span%3E%3Cspan%3E%20%E5%8F%AF%E4%BB%A5%E5%B0%9D%E8%AF%95%E8%A7%A3%E9%87%8A%E7%97%85%E5%9B%A0%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="遗传联系 Genetic Link 遗传因素在精神分裂症中起重要作用" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%81%97%E4%BC%A0%E8%81%94%E7%B3%BB%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EGenetic%20Link%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%81%97%E4%BC%A0%E5%9B%A0%E7%B4%A0%3C/span%3E%3Cspan%3E%E5%9C%A8%E7%B2%BE%E7%A5%9E%E5%88%86%E8%A3%82%E7%97%87%E4%B8%AD%E8%B5%B7%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%87%8D%E8%A6%81%E4%BD%9C%E7%94%A8%3C/span%3E" _note="" _mubu_note="">
            <outline text="遗传因素在精神分裂症中起重要作用,家族研究显示风险随亲缘关系增加" _mubu_text="%3Cspan%3E%E9%81%97%E4%BC%A0%E5%9B%A0%E7%B4%A0%E5%9C%A8%E7%B2%BE%E7%A5%9E%E5%88%86%E8%A3%82%E7%97%87%E4%B8%AD%E8%B5%B7%E9%87%8D%E8%A6%81%E4%BD%9C%E7%94%A8,%E5%AE%B6%E6%97%8F%E7%A0%94%E7%A9%B6%E6%98%BE%E7%A4%BA%E9%A3%8E%E9%99%A9%E9%9A%8F%E4%BA%B2%E7%BC%98%E5%85%B3%E7%B3%BB%E5%A2%9E%E5%8A%A0%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="产前病毒暴露 Prenatal Virus Exposure 流感、弓形虫抗体升高、风疹、生殖感染" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BA%A7%E5%89%8D%E7%97%85%E6%AF%92%E6%9A%B4%E9%9C%B2%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EPrenatal%20Virus%20Exposure%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%20%E6%B5%81%E6%84%9F%3C/span%3E%3Cspan%3E%E3%80%81%E5%BC%93%E5%BD%A2%E8%99%AB%E6%8A%97%E4%BD%93%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%8D%87%E9%AB%98%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%A3%8E%E7%96%B9%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%94%9F%E6%AE%96%E6%84%9F%E6%9F%93%3C/span%3E" _note="" _mubu_note="">
            <outline text="产前暴露于流感、弓形虫抗体升高、风疹、生殖感染等与后代精神分裂症风险增加相关" _mubu_text="%3Cspan%3E%E4%BA%A7%E5%89%8D%E6%9A%B4%E9%9C%B2%E4%BA%8E%E6%B5%81%E6%84%9F%E3%80%81%E5%BC%93%E5%BD%A2%E8%99%AB%E6%8A%97%E4%BD%93%E5%8D%87%E9%AB%98%E3%80%81%E9%A3%8E%E7%96%B9%E3%80%81%E7%94%9F%E6%AE%96%E6%84%9F%E6%9F%93%E7%AD%89%E4%B8%8E%E5%90%8E%E4%BB%A3%E7%B2%BE%E7%A5%9E%E5%88%86%E8%A3%82%E7%97%87%E9%A3%8E%E9%99%A9%E5%A2%9E%E5%8A%A0%E7%9B%B8%E5%85%B3%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="多巴胺假说 Dopamine Hypothesis 多巴胺水平的高度波动可能导致精神分裂症症状" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%A4%9A%E5%B7%B4%E8%83%BA%3C/span%3E%3Cspan%20class=%22bold%20text-color-purple%22%3E%E5%81%87%E8%AF%B4%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EDopamine%20Hypothesis%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%9A%E5%B7%B4%E8%83%BA%E6%B0%B4%E5%B9%B3%3C/span%3E%3Cspan%3E%E7%9A%84%E9%AB%98%E5%BA%A6%E6%B3%A2%E5%8A%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%8F%AF%E8%83%BD%E5%AF%BC%E8%87%B4%3C/span%3E%3Cspan%3E%E7%B2%BE%E7%A5%9E%E5%88%86%E8%A3%82%E7%97%87%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%97%87%E7%8A%B6%3C/span%3E" _note="" _mubu_note="">
            <outline text="与精神分裂症相关的神经递质" _mubu_text="%3Cspan%3E%E4%B8%8E%E7%B2%BE%E7%A5%9E%E5%88%86%E8%A3%82%E7%97%87%E7%9B%B8%E5%85%B3%E7%9A%84%E7%A5%9E%E7%BB%8F%E9%80%92%E8%B4%A8%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="多巴胺水平的高度波动可能导致精神分裂症症状" _mubu_text="%3Cspan%3E%E5%A4%9A%E5%B7%B4%E8%83%BA%E6%B0%B4%E5%B9%B3%E7%9A%84%E9%AB%98%E5%BA%A6%E6%B3%A2%E5%8A%A8%E5%8F%AF%E8%83%BD%E5%AF%BC%E8%87%B4%E7%B2%BE%E7%A5%9E%E5%88%86%E8%A3%82%E7%97%87%E7%97%87%E7%8A%B6%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="神经发育障碍 Neurodevelopmental Disorders" _mubu_text="%3Cspan%3E%E7%A5%9E%E7%BB%8F%E5%8F%91%E8%82%B2%E9%9A%9C%E7%A2%8D%20Neurodevelopmental%20Disorders%3C/span%3E" _note="" _mubu_note="">
          <outline text="神经发育障碍 Neurodevelopmental Disorders 幼儿期出现的神经发育障碍「ADHD，ASD」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A5%9E%E7%BB%8F%E5%8F%91%E8%82%B2%E9%9A%9C%E7%A2%8D%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ENeurodevelopmental%20Disorders%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%B9%BC%E5%84%BF%E6%9C%9F%3C/span%3E%3Cspan%3E%E5%87%BA%E7%8E%B0%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%A5%9E%E7%BB%8F%E5%8F%91%E8%82%B2%E9%9A%9C%E7%A2%8D%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EADHD%EF%BC%8CASD%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="在出生时或幼儿早期出现的大脑功能障碍群体" _mubu_text="%3Cspan%3E%E5%9C%A8%E5%87%BA%E7%94%9F%E6%97%B6%E6%88%96%E5%B9%BC%E5%84%BF%E6%97%A9%E6%9C%9F%E5%87%BA%E7%8E%B0%E7%9A%84%E5%A4%A7%E8%84%91%E5%8A%9F%E8%83%BD%E9%9A%9C%E7%A2%8D%E7%BE%A4%E4%BD%93%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="这些障碍的可能原因包括遗传、生理和环境因素" _mubu_text="%3Cspan%3E%E8%BF%99%E4%BA%9B%E9%9A%9C%E7%A2%8D%E7%9A%84%E5%8F%AF%E8%83%BD%E5%8E%9F%E5%9B%A0%E5%8C%85%E6%8B%AC%E9%81%97%E4%BC%A0%E3%80%81%E7%94%9F%E7%90%86%E5%92%8C%E7%8E%AF%E5%A2%83%E5%9B%A0%E7%B4%A0%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="影响个体的行为、记忆、注意力和/或学习能力" _mubu_text="%3Cspan%3E%E5%BD%B1%E5%93%8D%E4%B8%AA%E4%BD%93%E7%9A%84%E8%A1%8C%E4%B8%BA%E3%80%81%E8%AE%B0%E5%BF%86%E3%80%81%E6%B3%A8%E6%84%8F%E5%8A%9B%E5%92%8C/%E6%88%96%E5%AD%A6%E4%B9%A0%E8%83%BD%E5%8A%9B%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="注意缺陷/多动障碍 Attention-Deficit/Hyperactivity Disorder (ADHD) 持续注意力不集中或多动冲动" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%B3%A8%E6%84%8F%E7%BC%BA%E9%99%B7/%E5%A4%9A%E5%8A%A8%E9%9A%9C%E7%A2%8D%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EAttention-Deficit/Hyperactivity%20Disorder%20(ADHD)%3C/span%3E%3Cspan%3E%20%E6%8C%81%E7%BB%AD%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%B3%A8%E6%84%8F%E5%8A%9B%E4%B8%8D%E9%9B%86%E4%B8%AD%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%A4%9A%E5%8A%A8%E5%86%B2%E5%8A%A8%3C/span%3E" _note="" _mubu_note="">
            <outline text="以持续的注意力不集中 Inattention 和/或 多动-冲动 Hyperactivity-Impulsivity 模式为特征，干扰功能或发展，导致难以保持专注、控制行为和保持组织性" _mubu_text="%3Cspan%3E%E4%BB%A5%E6%8C%81%E7%BB%AD%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%B3%A8%E6%84%8F%E5%8A%9B%E4%B8%8D%E9%9B%86%E4%B8%AD%20Inattention%3C/span%3E%3Cspan%3E%20%E5%92%8C/%E6%88%96%3C/span%3E%3Cspan%20class=%22bold%22%3E%20%E5%A4%9A%E5%8A%A8-%E5%86%B2%E5%8A%A8%20Hyperactivity-Impulsivity%3C/span%3E%3Cspan%3E%20%E6%A8%A1%E5%BC%8F%E4%B8%BA%E7%89%B9%E5%BE%81%EF%BC%8C%E5%B9%B2%E6%89%B0%E5%8A%9F%E8%83%BD%E6%88%96%E5%8F%91%E5%B1%95%EF%BC%8C%E5%AF%BC%E8%87%B4%E9%9A%BE%E4%BB%A5%E4%BF%9D%E6%8C%81%E4%B8%93%E6%B3%A8%E3%80%81%E6%8E%A7%E5%88%B6%E8%A1%8C%E4%B8%BA%E5%92%8C%E4%BF%9D%E6%8C%81%E7%BB%84%E7%BB%87%E6%80%A7%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="诊断标准 表现出注意力不集中、多动或冲动症状" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%A0%87%E5%87%86%3C/span%3E%3Cspan%3E%20%E8%A1%A8%E7%8E%B0%E5%87%BA%E6%B3%A8%E6%84%8F%E5%8A%9B%E4%B8%8D%E9%9B%86%E4%B8%AD%E3%80%81%E5%A4%9A%E5%8A%A8%E6%88%96%E5%86%B2%E5%8A%A8%E7%97%87%E7%8A%B6%3C/span%3E" _note="" _mubu_note="">
              <outline text="个体表现出以下一种或两种模式:" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E8%A1%A8%E7%8E%B0%E5%87%BA%E4%BB%A5%E4%B8%8B%E4%B8%80%E7%A7%8D%E6%88%96%E4%B8%A4%E7%A7%8D%E6%A8%A1%E5%BC%8F:%3C/span%3E" _note="" _mubu_note="">
                <outline text="6个月或更长时间，个体频繁表现出至少6种注意力不集中症状" _mubu_text="%3Cspan%3E6%E4%B8%AA%E6%9C%88%E6%88%96%E6%9B%B4%E9%95%BF%E6%97%B6%E9%97%B4%EF%BC%8C%E4%B8%AA%E4%BD%93%E9%A2%91%E7%B9%81%E8%A1%A8%E7%8E%B0%E5%87%BA%E8%87%B3%E5%B0%916%E7%A7%8D%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%B3%A8%E6%84%8F%E5%8A%9B%E4%B8%8D%E9%9B%86%E4%B8%AD%E7%97%87%E7%8A%B6%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="6个月或更长时间，个体频繁表现出至少6种多动和冲动症状" _mubu_text="%3Cspan%3E6%E4%B8%AA%E6%9C%88%E6%88%96%E6%9B%B4%E9%95%BF%E6%97%B6%E9%97%B4%EF%BC%8C%E4%B8%AA%E4%BD%93%E9%A2%91%E7%B9%81%E8%A1%A8%E7%8E%B0%E5%87%BA%E8%87%B3%E5%B0%916%E7%A7%8D%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%A4%9A%E5%8A%A8%E5%92%8C%E5%86%B2%E5%8A%A8%E7%97%87%E7%8A%B6%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="个体在12岁之前表现出一些症状" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E5%9C%A812%E5%B2%81%E4%B9%8B%E5%89%8D%E8%A1%A8%E7%8E%B0%E5%87%BA%E4%B8%80%E4%BA%9B%E7%97%87%E7%8A%B6%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="个体在多个环境中表现出症状" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E5%9C%A8%E5%A4%9A%E4%B8%AA%E7%8E%AF%E5%A2%83%E4%B8%AD%E8%A1%A8%E7%8E%B0%E5%87%BA%E7%97%87%E7%8A%B6%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="个体经历功能受损" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E7%BB%8F%E5%8E%86%E5%8A%9F%E8%83%BD%E5%8F%97%E6%8D%9F%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="自闭症谱系障碍 Autism Spectrum Disorder (ASD) 社交、沟通及行为障碍「来自星星的孩子」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E9%97%AD%E7%97%87%E8%B0%B1%E7%B3%BB%E9%9A%9C%E7%A2%8D%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EAutism%20Spectrum%20Disorder%20(ASD)%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E7%A4%BE%E4%BA%A4%E3%80%81%E6%B2%9F%E9%80%9A%E5%8F%8A%E8%A1%8C%E4%B8%BA%E9%9A%9C%E7%A2%8D%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%9D%A5%E8%87%AA%E6%98%9F%E6%98%9F%E7%9A%84%E5%AD%A9%E5%AD%90%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="以对他人极度无反应、严重的沟通缺陷以及高度重复和刻板的行为、兴趣和活动为特征的障碍" _mubu_text="%3Cspan%3E%E4%BB%A5%E5%AF%B9%E4%BB%96%E4%BA%BA%E6%9E%81%E5%BA%A6%E6%97%A0%E5%8F%8D%E5%BA%94%E3%80%81%E4%B8%A5%E9%87%8D%E7%9A%84%E6%B2%9F%E9%80%9A%E7%BC%BA%E9%99%B7%E4%BB%A5%E5%8F%8A%E9%AB%98%E5%BA%A6%E9%87%8D%E5%A4%8D%E5%92%8C%E5%88%BB%E6%9D%BF%E7%9A%84%E8%A1%8C%E4%B8%BA%E3%80%81%E5%85%B4%E8%B6%A3%E5%92%8C%E6%B4%BB%E5%8A%A8%E4%B8%BA%E7%89%B9%E5%BE%81%E7%9A%84%E9%9A%9C%E7%A2%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="诊断标准 社交领域能力缺陷，行为表现出限制和重复，幼儿期发展出症状" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%A0%87%E5%87%86%20%3C/span%3E%3Cspan%3E%E7%A4%BE%E4%BA%A4%E9%A2%86%E5%9F%9F%E8%83%BD%E5%8A%9B%E7%BC%BA%E9%99%B7%EF%BC%8C%E8%A1%8C%E4%B8%BA%E8%A1%A8%E7%8E%B0%E5%87%BA%E9%99%90%E5%88%B6%E5%92%8C%E9%87%8D%E5%A4%8D%EF%BC%8C%E5%B9%BC%E5%84%BF%E6%9C%9F%E5%8F%91%E5%B1%95%E5%87%BA%E7%97%87%E7%8A%B6%3C/span%3E" _note="" _mubu_note="">
              <outline text="个体在各种沟通和社交互动领域表现出持续缺陷,包括社交-情感互惠 Social-Emotional Reciprocity、非言语沟通 Nonverbal Communication、关系发展和维持 Development and Maintenance of Relationships" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E5%9C%A8%E5%90%84%E7%A7%8D%E6%B2%9F%E9%80%9A%E5%92%8C%E7%A4%BE%E4%BA%A4%E4%BA%92%E5%8A%A8%E9%A2%86%E5%9F%9F%E8%A1%A8%E7%8E%B0%E5%87%BA%E6%8C%81%E7%BB%AD%E7%BC%BA%E9%99%B7,%E5%8C%85%E6%8B%AC%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%A4%BE%E4%BA%A4-%E6%83%85%E6%84%9F%E4%BA%92%E6%83%A0%20Social-Emotional%20Reciprocity%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E9%9D%9E%E8%A8%80%E8%AF%AD%E6%B2%9F%E9%80%9A%20Nonverbal%20Communication%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%85%B3%E7%B3%BB%E5%8F%91%E5%B1%95%E5%92%8C%E7%BB%B4%E6%8C%81%20Development%20and%20Maintenance%20of%20Relationships%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="个体在行为、兴趣或活动中表现出显著的限制和重复,包括以下两种或更多:夸张和重复的言语模式、动作或物体使用、对相同例行程序的不灵活要求、高度受限、固定和过度强烈的兴趣、对环境感官输入的过度或不足反应" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E5%9C%A8%E8%A1%8C%E4%B8%BA%E3%80%81%E5%85%B4%E8%B6%A3%E6%88%96%E6%B4%BB%E5%8A%A8%E4%B8%AD%E8%A1%A8%E7%8E%B0%E5%87%BA%E6%98%BE%E8%91%97%E7%9A%84%E9%99%90%E5%88%B6%E5%92%8C%E9%87%8D%E5%A4%8D,%E5%8C%85%E6%8B%AC%E4%BB%A5%E4%B8%8B%E4%B8%A4%E7%A7%8D%E6%88%96%E6%9B%B4%E5%A4%9A:%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%A4%B8%E5%BC%A0%E5%92%8C%E9%87%8D%E5%A4%8D%E7%9A%84%E8%A8%80%E8%AF%AD%E6%A8%A1%E5%BC%8F%E3%80%81%E5%8A%A8%E4%BD%9C%E6%88%96%E7%89%A9%E4%BD%93%E4%BD%BF%E7%94%A8%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%AF%B9%E7%9B%B8%E5%90%8C%E4%BE%8B%E8%A1%8C%E7%A8%8B%E5%BA%8F%E7%9A%84%E4%B8%8D%E7%81%B5%E6%B4%BB%E8%A6%81%E6%B1%82%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E9%AB%98%E5%BA%A6%E5%8F%97%E9%99%90%E3%80%81%E5%9B%BA%E5%AE%9A%E5%92%8C%E8%BF%87%E5%BA%A6%E5%BC%BA%E7%83%88%E7%9A%84%E5%85%B4%E8%B6%A3%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%AF%B9%E7%8E%AF%E5%A2%83%E6%84%9F%E5%AE%98%E8%BE%93%E5%85%A5%E7%9A%84%E8%BF%87%E5%BA%A6%E6%88%96%E4%B8%8D%E8%B6%B3%E5%8F%8D%E5%BA%94%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="个体在幼儿期发展出症状" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E5%9C%A8%E5%B9%BC%E5%84%BF%E6%9C%9F%E5%8F%91%E5%B1%95%E5%87%BA%E7%97%87%E7%8A%B6%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="个体经历显著损害" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E7%BB%8F%E5%8E%86%E6%98%BE%E8%91%97%E6%8D%9F%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="焦虑障碍 Anxiety Disorders" _mubu_text="%3Cspan%3E%E7%84%A6%E8%99%91%E9%9A%9C%E7%A2%8D%20Anxiety%20Disorders%3C/span%3E" _note="" _mubu_note="">
          <outline text="病理性焦虑是破坏性的、非理性的和不可控的；美国最常见的心理障碍（1900万成年人）" _mubu_text="%3Cspan%3E%E7%97%85%E7%90%86%E6%80%A7%E7%84%A6%E8%99%91%E6%98%AF%E7%A0%B4%E5%9D%8F%E6%80%A7%E7%9A%84%E3%80%81%E9%9D%9E%E7%90%86%E6%80%A7%E7%9A%84%E5%92%8C%E4%B8%8D%E5%8F%AF%E6%8E%A7%E7%9A%84%EF%BC%9B%E7%BE%8E%E5%9B%BD%E6%9C%80%E5%B8%B8%E8%A7%81%E7%9A%84%E5%BF%83%E7%90%86%E9%9A%9C%E7%A2%8D%EF%BC%881900%E4%B8%87%E6%88%90%E5%B9%B4%E4%BA%BA%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="广泛性焦虑障碍 Generalized Anxiety Disorder (GAD) 几乎对任何事情都担心「自由浮动焦虑」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B9%BF%E6%B3%9B%E6%80%A7%E7%84%A6%E8%99%91%E9%9A%9C%E7%A2%8D%20Generalized%20Anxiety%20Disorder%20(GAD)%3C/span%3E%3Cspan%3E%20%E5%87%A0%E4%B9%8E%E5%AF%B9%E4%BB%BB%E4%BD%95%E4%BA%8B%E6%83%85%E9%83%BD%E6%8B%85%E5%BF%83%E3%80%8C%E8%87%AA%E7%94%B1%E6%B5%AE%E5%8A%A8%E7%84%A6%E8%99%91%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="在大多数情况下经历过度焦虑，几乎对任何事情都担心" _mubu_text="%3Cspan%3E%E5%9C%A8%E5%A4%A7%E5%A4%9A%E6%95%B0%E6%83%85%E5%86%B5%E4%B8%8B%E7%BB%8F%E5%8E%86%E8%BF%87%E5%BA%A6%E7%84%A6%E8%99%91%EF%BC%8C%E5%87%A0%E4%B9%8E%E5%AF%B9%E4%BB%BB%E4%BD%95%E4%BA%8B%E6%83%85%E9%83%BD%E6%8B%85%E5%BF%83%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="自由浮动焦虑 Free-Floating Anxiety：焦虑没有明确的触发因素或起点" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E7%94%B1%E6%B5%AE%E5%8A%A8%E7%84%A6%E8%99%91%20Free-Floating%20Anxiety%3C/span%3E%3Cspan%3E%EF%BC%9A%E7%84%A6%E8%99%91%E6%B2%A1%E6%9C%89%E6%98%8E%E7%A1%AE%E7%9A%84%E8%A7%A6%E5%8F%91%E5%9B%A0%E7%B4%A0%E6%88%96%E8%B5%B7%E7%82%B9%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="诊断标准 长期对各种事情持续地的焦虑和担忧，紧张、疲劳、注意力、易怒、肌肉紧张、睡眠" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%A0%87%E5%87%86%3C/span%3E%3Cspan%3E%20%E9%95%BF%E6%9C%9F%E5%AF%B9%E5%90%84%E7%A7%8D%E4%BA%8B%E6%83%85%E6%8C%81%E7%BB%AD%E5%9C%B0%E7%9A%84%E7%84%A6%E8%99%91%E5%92%8C%E6%8B%85%E5%BF%A7%EF%BC%8C%E7%B4%A7%E5%BC%A0%E3%80%81%E7%96%B2%E5%8A%B3%E3%80%81%E6%B3%A8%E6%84%8F%E5%8A%9B%E3%80%81%E6%98%93%E6%80%92%E3%80%81%E8%82%8C%E8%82%89%E7%B4%A7%E5%BC%A0%E3%80%81%E7%9D%A1%E7%9C%A0%3C/span%3E" _note="" _mubu_note="">
              <outline text="6个月或更长时间,个体对多种事项经历不成比例、不可控和持续的焦虑和担忧" _mubu_text="%3Cspan%3E6%E4%B8%AA%E6%9C%88%E6%88%96%E6%9B%B4%E9%95%BF%E6%97%B6%E9%97%B4,%E4%B8%AA%E4%BD%93%E5%AF%B9%E5%A4%9A%E7%A7%8D%E4%BA%8B%E9%A1%B9%E7%BB%8F%E5%8E%86%E4%B8%8D%E6%88%90%E6%AF%94%E4%BE%8B%E3%80%81%E4%B8%8D%E5%8F%AF%E6%8E%A7%E5%92%8C%E6%8C%81%E7%BB%AD%E7%9A%84%E7%84%A6%E8%99%91%E5%92%8C%E6%8B%85%E5%BF%A7%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="症状包括以下至少三种:紧张 Edginess、疲劳 Fatigue、注意力差 Poor Concentration、易怒 Irritability、肌肉紧张 Muscle Tension、睡眠问题 Sleep Problems" _mubu_text="%3Cspan%3E%E7%97%87%E7%8A%B6%E5%8C%85%E6%8B%AC%E4%BB%A5%E4%B8%8B%E8%87%B3%E5%B0%91%E4%B8%89%E7%A7%8D:%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%B4%A7%E5%BC%A0%20Edginess%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%96%B2%E5%8A%B3%20Fatigue%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%B3%A8%E6%84%8F%E5%8A%9B%E5%B7%AE%20Poor%20Concentration%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%98%93%E6%80%92%20Irritability%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%82%8C%E8%82%89%E7%B4%A7%E5%BC%A0%20Muscle%20Tension%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%9D%A1%E7%9C%A0%E9%97%AE%E9%A2%98%20Sleep%20Problems%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="显著痛苦或损害" _mubu_text="%3Cspan%3E%E6%98%BE%E8%91%97%E7%97%9B%E8%8B%A6%E6%88%96%E6%8D%9F%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="惊恐障碍 Panic Disorder 以惊恐发作为特征的焦虑障碍 「Ataque de nervios」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%83%8A%E6%81%90%E9%9A%9C%E7%A2%8D%20Panic%20Disorder%20%3C/span%3E%3Cspan%3E%E4%BB%A5%E6%83%8A%E6%81%90%E5%8F%91%E4%BD%9C%E4%B8%BA%E7%89%B9%E5%BE%81%E7%9A%84%E7%84%A6%E8%99%91%E9%9A%9C%E7%A2%8D%20%E3%80%8CAtaque%20de%20nervios%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="以反复和不可预测的惊恐发作 Panic Attacks 为特征的焦虑障碍" _mubu_text="%3Cspan%3E%E4%BB%A5%E5%8F%8D%E5%A4%8D%E5%92%8C%E4%B8%8D%E5%8F%AF%E9%A2%84%E6%B5%8B%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%83%8A%E6%81%90%E5%8F%91%E4%BD%9C%20Panic%20Attacks%3C/span%3E%3Cspan%3E%20%E4%B8%BA%E7%89%B9%E5%BE%81%E7%9A%84%E7%84%A6%E8%99%91%E9%9A%9C%E7%A2%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="强烈焦虑发作,伴有严重胸痛、肌肉紧绷、窒息、出汗等急性症状" _mubu_text="%3Cspan%3E%E5%BC%BA%E7%83%88%E7%84%A6%E8%99%91%E5%8F%91%E4%BD%9C,%E4%BC%B4%E6%9C%89%E4%B8%A5%E9%87%8D%E8%83%B8%E7%97%9B%E3%80%81%E8%82%8C%E8%82%89%E7%B4%A7%E7%BB%B7%E3%80%81%E7%AA%92%E6%81%AF%E3%80%81%E5%87%BA%E6%B1%97%E7%AD%89%E6%80%A5%E6%80%A7%E7%97%87%E7%8A%B6%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="症状可持续几分钟到几小时（无触发因素）" _mubu_text="%3Cspan%3E%E7%97%87%E7%8A%B6%E5%8F%AF%E6%8C%81%E7%BB%AD%E5%87%A0%E5%88%86%E9%92%9F%E5%88%B0%E5%87%A0%E5%B0%8F%E6%97%B6%EF%BC%88%E6%97%A0%E8%A7%A6%E5%8F%91%E5%9B%A0%E7%B4%A0%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="诊断标准 反复发生的惊恐，或伴随功能失调行为变化" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%A0%87%E5%87%86%3C/span%3E%3Cspan%3E%20%E5%8F%8D%E5%A4%8D%E5%8F%91%E7%94%9F%E7%9A%84%E6%83%8A%E6%81%90%EF%BC%8C%E6%88%96%E4%BC%B4%E9%9A%8F%E5%8A%9F%E8%83%BD%E5%A4%B1%E8%B0%83%E8%A1%8C%E4%B8%BA%E5%8F%98%E5%8C%96%3C/span%3E" _note="" _mubu_note="">
              <outline text="反复发生不可预见的惊恐发作" _mubu_text="%3Cspan%3E%E5%8F%8D%E5%A4%8D%E5%8F%91%E7%94%9F%E4%B8%8D%E5%8F%AF%E9%A2%84%E8%A7%81%E7%9A%84%E6%83%8A%E6%81%90%E5%8F%91%E4%BD%9C%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="一次或多次发作之前出现以下症状之一:" _mubu_text="%3Cspan%3E%E4%B8%80%E6%AC%A1%E6%88%96%E5%A4%9A%E6%AC%A1%E5%8F%91%E4%BD%9C%E4%B9%8B%E5%89%8D%E5%87%BA%E7%8E%B0%E4%BB%A5%E4%B8%8B%E7%97%87%E7%8A%B6%E4%B9%8B%E4%B8%80:%3C/span%3E" _note="" _mubu_note="">
                <outline text="至少一个月持续担心再次发作" _mubu_text="%3Cspan%3E%E8%87%B3%E5%B0%91%E4%B8%80%E4%B8%AA%E6%9C%88%E6%8C%81%E7%BB%AD%E6%8B%85%E5%BF%83%E5%86%8D%E6%AC%A1%E5%8F%91%E4%BD%9C%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="至少一个月与发作相关的功能失调行为变化(例如,避免新体验)" _mubu_text="%3Cspan%3E%E8%87%B3%E5%B0%91%E4%B8%80%E4%B8%AA%E6%9C%88%E4%B8%8E%E5%8F%91%E4%BD%9C%E7%9B%B8%E5%85%B3%E7%9A%84%E5%8A%9F%E8%83%BD%E5%A4%B1%E8%B0%83%E8%A1%8C%E4%B8%BA%E5%8F%98%E5%8C%96(%E4%BE%8B%E5%A6%82,%E9%81%BF%E5%85%8D%E6%96%B0%E4%BD%93%E9%AA%8C)%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="Ataque de nervios - 文化束缚综合征，常见于拉丁美洲和地中海文化" _mubu_text="%3Cspan%20class=%22bold%22%3EAtaque%20de%20nervios%3C/span%3E%3Cspan%3E%20-%20%E6%96%87%E5%8C%96%E6%9D%9F%E7%BC%9A%E7%BB%BC%E5%90%88%E5%BE%81%EF%BC%8C%E5%B8%B8%E8%A7%81%E4%BA%8E%E6%8B%89%E4%B8%81%E7%BE%8E%E6%B4%B2%E5%92%8C%E5%9C%B0%E4%B8%AD%E6%B5%B7%E6%96%87%E5%8C%96%3C/span%3E" _note="" _mubu_note="">
              <outline text="以情绪爆发或情绪控制丧失状态为特征,通常伴有尖叫、哭泣、颤抖或昏厥等症状" _mubu_text="%3Cspan%3E%E4%BB%A5%E6%83%85%E7%BB%AA%E7%88%86%E5%8F%91%E6%88%96%E6%83%85%E7%BB%AA%E6%8E%A7%E5%88%B6%E4%B8%A7%E5%A4%B1%E7%8A%B6%E6%80%81%E4%B8%BA%E7%89%B9%E5%BE%81,%E9%80%9A%E5%B8%B8%E4%BC%B4%E6%9C%89%E5%B0%96%E5%8F%AB%E3%80%81%E5%93%AD%E6%B3%A3%E3%80%81%E9%A2%A4%E6%8A%96%E6%88%96%E6%98%8F%E5%8E%A5%E7%AD%89%E7%97%87%E7%8A%B6%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="这种情况通常被认为是对强烈情绪事件或压力源的反应" _mubu_text="%3Cspan%3E%E8%BF%99%E7%A7%8D%E6%83%85%E5%86%B5%E9%80%9A%E5%B8%B8%E8%A2%AB%E8%AE%A4%E4%B8%BA%E6%98%AF%E5%AF%B9%E5%BC%BA%E7%83%88%E6%83%85%E7%BB%AA%E4%BA%8B%E4%BB%B6%E6%88%96%E5%8E%8B%E5%8A%9B%E6%BA%90%E7%9A%84%E5%8F%8D%E5%BA%94%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="特定恐惧症 Specific Phobia 特定刺激的强烈、非理性恐惧「恐高、幽闭、学业、蜘蛛」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%89%B9%E5%AE%9A%E6%81%90%E6%83%A7%E7%97%87%20Specific%20Phobia%20%3C/span%3E%3Cspan%3E%E7%89%B9%E5%AE%9A%E5%88%BA%E6%BF%80%E7%9A%84%E5%BC%BA%E7%83%88%E3%80%81%E9%9D%9E%E7%90%86%E6%80%A7%E6%81%90%E6%83%A7%E3%80%8C%E6%81%90%E9%AB%98%E3%80%81%E5%B9%BD%E9%97%AD%E3%80%81%E5%AD%A6%E4%B8%9A%E3%80%81%E8%9C%98%E8%9B%9B%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="对特定刺激的强烈、非理性恐惧反应" _mubu_text="%3Cspan%3E%E5%AF%B9%E7%89%B9%E5%AE%9A%E5%88%BA%E6%BF%80%E7%9A%84%E5%BC%BA%E7%83%88%E3%80%81%E9%9D%9E%E7%90%86%E6%80%A7%E6%81%90%E6%83%A7%E5%8F%8D%E5%BA%94%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="常见恐惧症包括：恐高症 Acrophobia(高度)、幽闭恐惧症 Claustrophobia(小空间)、恐血症 Hemophobia(血液)、恐蛛症 Arachnophobia(蜘蛛)" _mubu_text="%3Cspan%3E%E5%B8%B8%E8%A7%81%E6%81%90%E6%83%A7%E7%97%87%E5%8C%85%E6%8B%AC%EF%BC%9A%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%81%90%E9%AB%98%E7%97%87%20Acrophobia%3C/span%3E%3Cspan%3E(%E9%AB%98%E5%BA%A6)%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%B9%BD%E9%97%AD%E6%81%90%E6%83%A7%E7%97%87%20Claustrophobia%3C/span%3E%3Cspan%3E(%E5%B0%8F%E7%A9%BA%E9%97%B4)%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%81%90%E8%A1%80%E7%97%87%20Hemophobia%3C/span%3E%3Cspan%3E(%E8%A1%80%E6%B6%B2)%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%81%90%E8%9B%9B%E7%97%87%20Arachnophobia%3C/span%3E%3Cspan%3E(%E8%9C%98%E8%9B%9B)%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="诊断标准 对特定物体或情景明显且持续的恐惧（至少6个月）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%A0%87%E5%87%86%3C/span%3E%3Cspan%3E%20%E5%AF%B9%E7%89%B9%E5%AE%9A%E7%89%A9%E4%BD%93%E6%88%96%E6%83%85%E6%99%AF%E6%98%8E%E6%98%BE%E4%B8%94%E6%8C%81%E7%BB%AD%E7%9A%84%E6%81%90%E6%83%A7%EF%BC%88%E8%87%B3%E5%B0%916%E4%B8%AA%E6%9C%88%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
              <outline text="对特定物体或情境的明显、持续和不成比例的恐惧,通常持续至少6个月" _mubu_text="%3Cspan%3E%E5%AF%B9%E7%89%B9%E5%AE%9A%E7%89%A9%E4%BD%93%E6%88%96%E6%83%85%E5%A2%83%E7%9A%84%E6%98%8E%E6%98%BE%E3%80%81%E6%8C%81%E7%BB%AD%E5%92%8C%E4%B8%8D%E6%88%90%E6%AF%94%E4%BE%8B%E7%9A%84%E6%81%90%E6%83%A7,%E9%80%9A%E5%B8%B8%E6%8C%81%E7%BB%AD%E8%87%B3%E5%B0%916%E4%B8%AA%E6%9C%88%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="暴露于该物体会产生即时恐惧" _mubu_text="%3Cspan%3E%E6%9A%B4%E9%9C%B2%E4%BA%8E%E8%AF%A5%E7%89%A9%E4%BD%93%E4%BC%9A%E4%BA%A7%E7%94%9F%E5%8D%B3%E6%97%B6%E6%81%90%E6%83%A7%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="避免恐惧情境" _mubu_text="%3Cspan%3E%E9%81%BF%E5%85%8D%E6%81%90%E6%83%A7%E6%83%85%E5%A2%83%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="显著痛苦或损害" _mubu_text="%3Cspan%3E%E6%98%BE%E8%91%97%E7%97%9B%E8%8B%A6%E6%88%96%E6%8D%9F%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="社交焦虑障碍 Social Anxiety Disorder 在社交场合中的强烈恐惧和焦虑「Taijin Kyofusho」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A4%BE%E4%BA%A4%E7%84%A6%E8%99%91%E9%9A%9C%E7%A2%8D%20Social%20Anxiety%20Disorder%3C/span%3E%3Cspan%3E%20%E5%9C%A8%E7%A4%BE%E4%BA%A4%E5%9C%BA%E5%90%88%E4%B8%AD%E7%9A%84%E5%BC%BA%E7%83%88%E6%81%90%E6%83%A7%E5%92%8C%E7%84%A6%E8%99%91%E3%80%8CTaijin%20Kyofusho%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="在社交场合中的强烈恐惧和焦虑" _mubu_text="%3Cspan%3E%E5%9C%A8%E7%A4%BE%E4%BA%A4%E5%9C%BA%E5%90%88%E4%B8%AD%E7%9A%84%E5%BC%BA%E7%83%88%E6%81%90%E6%83%A7%E5%92%8C%E7%84%A6%E8%99%91%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="对人恐惧症 Taijin Kyofusho 源自日本的文化束缚综合征，以强烈害怕用自己的外表或行为冒犯或使他人尴尬为特征" _mubu_text="%3Cspan%3E%E5%AF%B9%E4%BA%BA%E6%81%90%E6%83%A7%E7%97%87%20Taijin%20Kyofusho%20%E6%BA%90%E8%87%AA%E6%97%A5%E6%9C%AC%E7%9A%84%E6%96%87%E5%8C%96%E6%9D%9F%E7%BC%9A%E7%BB%BC%E5%90%88%E5%BE%81%EF%BC%8C%E4%BB%A5%E5%BC%BA%E7%83%88%E5%AE%B3%E6%80%95%E7%94%A8%E8%87%AA%E5%B7%B1%E7%9A%84%E5%A4%96%E8%A1%A8%E6%88%96%E8%A1%8C%E4%B8%BA%E5%86%92%E7%8A%AF%E6%88%96%E4%BD%BF%E4%BB%96%E4%BA%BA%E5%B0%B4%E5%B0%AC%E4%B8%BA%E7%89%B9%E5%BE%81%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="诊断标准 因为焦虑、恐惧（某种后果）决定不进行社交" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%A0%87%E5%87%86%20%3C/span%3E%3Cspan%3E%E5%9B%A0%E4%B8%BA%E7%84%A6%E8%99%91%E3%80%81%E6%81%90%E6%83%A7%EF%BC%88%E6%9F%90%E7%A7%8D%E5%90%8E%E6%9E%9C%EF%BC%89%E5%86%B3%E5%AE%9A%E4%B8%8D%E8%BF%9B%E8%A1%8C%E7%A4%BE%E4%BA%A4%3C/span%3E" _note="" _mubu_note="">
              <outline text="对一个或多个社交场合的明显恐惧或焦虑,个体暴露于他人可能的审视之下(例如社交互动、被观察或在他人面前表演)" _mubu_text="%3Cspan%3E%E5%AF%B9%E4%B8%80%E4%B8%AA%E6%88%96%E5%A4%9A%E4%B8%AA%E7%A4%BE%E4%BA%A4%E5%9C%BA%E5%90%88%E7%9A%84%E6%98%8E%E6%98%BE%E6%81%90%E6%83%A7%E6%88%96%E7%84%A6%E8%99%91,%E4%B8%AA%E4%BD%93%E6%9A%B4%E9%9C%B2%E4%BA%8E%E4%BB%96%E4%BA%BA%E5%8F%AF%E8%83%BD%E7%9A%84%E5%AE%A1%E8%A7%86%E4%B9%8B%E4%B8%8B(%E4%BE%8B%E5%A6%82%E7%A4%BE%E4%BA%A4%E4%BA%92%E5%8A%A8%E3%80%81%E8%A2%AB%E8%A7%82%E5%AF%9F%E6%88%96%E5%9C%A8%E4%BB%96%E4%BA%BA%E9%9D%A2%E5%89%8D%E8%A1%A8%E6%BC%94)%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="个体害怕自己会以某种方式行事或表现出焦虑症状,会被负面评价" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E5%AE%B3%E6%80%95%E8%87%AA%E5%B7%B1%E4%BC%9A%E4%BB%A5%E6%9F%90%E7%A7%8D%E6%96%B9%E5%BC%8F%E8%A1%8C%E4%BA%8B%E6%88%96%E8%A1%A8%E7%8E%B0%E5%87%BA%E7%84%A6%E8%99%91%E7%97%87%E7%8A%B6,%E4%BC%9A%E8%A2%AB%E8%B4%9F%E9%9D%A2%E8%AF%84%E4%BB%B7%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="社交场合几乎总是引发恐惧或焦虑" _mubu_text="%3Cspan%3E%E7%A4%BE%E4%BA%A4%E5%9C%BA%E5%90%88%E5%87%A0%E4%B9%8E%E6%80%BB%E6%98%AF%E5%BC%95%E5%8F%91%E6%81%90%E6%83%A7%E6%88%96%E7%84%A6%E8%99%91%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="社交场合被避免或以强烈恐惧或焦虑忍受" _mubu_text="%3Cspan%3E%E7%A4%BE%E4%BA%A4%E5%9C%BA%E5%90%88%E8%A2%AB%E9%81%BF%E5%85%8D%E6%88%96%E4%BB%A5%E5%BC%BA%E7%83%88%E6%81%90%E6%83%A7%E6%88%96%E7%84%A6%E8%99%91%E5%BF%8D%E5%8F%97%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="恐惧或焦虑是持续的,通常持续6个月或更长时间" _mubu_text="%3Cspan%3E%E6%81%90%E6%83%A7%E6%88%96%E7%84%A6%E8%99%91%E6%98%AF%E6%8C%81%E7%BB%AD%E7%9A%84,%E9%80%9A%E5%B8%B8%E6%8C%81%E7%BB%AD6%E4%B8%AA%E6%9C%88%E6%88%96%E6%9B%B4%E9%95%BF%E6%97%B6%E9%97%B4%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="恐惧或焦虑与社交场合构成的实际威胁不成比例" _mubu_text="%3Cspan%3E%E6%81%90%E6%83%A7%E6%88%96%E7%84%A6%E8%99%91%E4%B8%8E%E7%A4%BE%E4%BA%A4%E5%9C%BA%E5%90%88%E6%9E%84%E6%88%90%E7%9A%84%E5%AE%9E%E9%99%85%E5%A8%81%E8%83%81%E4%B8%8D%E6%88%90%E6%AF%94%E4%BE%8B%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="恐惧、焦虑或回避导致临床上显著的痛苦或社交、职业或其他重要功能领域的损害" _mubu_text="%3Cspan%3E%E6%81%90%E6%83%A7%E3%80%81%E7%84%A6%E8%99%91%E6%88%96%E5%9B%9E%E9%81%BF%E5%AF%BC%E8%87%B4%E4%B8%B4%E5%BA%8A%E4%B8%8A%E6%98%BE%E8%91%97%E7%9A%84%E7%97%9B%E8%8B%A6%E6%88%96%E7%A4%BE%E4%BA%A4%E3%80%81%E8%81%8C%E4%B8%9A%E6%88%96%E5%85%B6%E4%BB%96%E9%87%8D%E8%A6%81%E5%8A%9F%E8%83%BD%E9%A2%86%E5%9F%9F%E7%9A%84%E6%8D%9F%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="恐惧、焦虑或回避不能归因于物质的生理效应" _mubu_text="%3Cspan%3E%E6%81%90%E6%83%A7%E3%80%81%E7%84%A6%E8%99%91%E6%88%96%E5%9B%9E%E9%81%BF%E4%B8%8D%E8%83%BD%E5%BD%92%E5%9B%A0%E4%BA%8E%E7%89%A9%E8%B4%A8%E7%9A%84%E7%94%9F%E7%90%86%E6%95%88%E5%BA%94%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="强迫症 Obsessive-Compulsive Disorder (OCD) 思想和行为的复合障碍「观念和行为」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BC%BA%E8%BF%AB%E7%97%87%20Obsessive-Compulsive%20Disorder%20(OCD)%20%3C/span%3E%3Cspan%3E%E6%80%9D%E6%83%B3%E5%92%8C%E8%A1%8C%E4%B8%BA%E7%9A%84%E5%A4%8D%E5%90%88%E9%9A%9C%E7%A2%8D%E3%80%8C%E8%A7%82%E5%BF%B5%E5%92%8C%E8%A1%8C%E4%B8%BA%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="强迫观念 Obsessions 是持续的、侵入性的、不想要的思想，个体无法摆脱" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BC%BA%E8%BF%AB%E8%A7%82%E5%BF%B5%20Obsessions%3C/span%3E%3Cspan%3E%20%E6%98%AF%E6%8C%81%E7%BB%AD%E7%9A%84%E3%80%81%E4%BE%B5%E5%85%A5%E6%80%A7%E7%9A%84%E3%80%81%E4%B8%8D%E6%83%B3%E8%A6%81%E7%9A%84%E6%80%9D%E6%83%B3%EF%BC%8C%E4%B8%AA%E4%BD%93%E6%97%A0%E6%B3%95%E6%91%86%E8%84%B1%3C/span%3E" _note="" _mubu_note="">
              <outline text="污染恐惧、害怕伤害自己或他人、需要对称或精确、侵入性性或暴力思想、过度关注宗教或道德正确性、害怕失去重要物品" _mubu_text="%3Cspan%3E%E6%B1%A1%E6%9F%93%E6%81%90%E6%83%A7%E3%80%81%E5%AE%B3%E6%80%95%E4%BC%A4%E5%AE%B3%E8%87%AA%E5%B7%B1%E6%88%96%E4%BB%96%E4%BA%BA%E3%80%81%E9%9C%80%E8%A6%81%E5%AF%B9%E7%A7%B0%E6%88%96%E7%B2%BE%E7%A1%AE%E3%80%81%E4%BE%B5%E5%85%A5%E6%80%A7%E6%80%A7%E6%88%96%E6%9A%B4%E5%8A%9B%E6%80%9D%E6%83%B3%E3%80%81%E8%BF%87%E5%BA%A6%E5%85%B3%E6%B3%A8%E5%AE%97%E6%95%99%E6%88%96%E9%81%93%E5%BE%B7%E6%AD%A3%E7%A1%AE%E6%80%A7%E3%80%81%E5%AE%B3%E6%80%95%E5%A4%B1%E5%8E%BB%E9%87%8D%E8%A6%81%E7%89%A9%E5%93%81%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="强迫行为 Compulsions 是反复执行的仪式性行为" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BC%BA%E8%BF%AB%E8%A1%8C%E4%B8%BA%20Compulsions%3C/span%3E%3Cspan%3E%20%E6%98%AF%E5%8F%8D%E5%A4%8D%E6%89%A7%E8%A1%8C%E7%9A%84%E4%BB%AA%E5%BC%8F%E6%80%A7%E8%A1%8C%E4%B8%BA%3C/span%3E" _note="" _mubu_note="">
              <outline text="过度洗涤和清洁、反复检查锁、电器等、以特定方式排列物品或精确排序、默默重复单词、强迫性祈祷或重复仪式、不必要地收集或囤积物品" _mubu_text="%3Cspan%3E%E8%BF%87%E5%BA%A6%E6%B4%97%E6%B6%A4%E5%92%8C%E6%B8%85%E6%B4%81%E3%80%81%E5%8F%8D%E5%A4%8D%E6%A3%80%E6%9F%A5%E9%94%81%E3%80%81%E7%94%B5%E5%99%A8%E7%AD%89%E3%80%81%E4%BB%A5%E7%89%B9%E5%AE%9A%E6%96%B9%E5%BC%8F%E6%8E%92%E5%88%97%E7%89%A9%E5%93%81%E6%88%96%E7%B2%BE%E7%A1%AE%E6%8E%92%E5%BA%8F%E3%80%81%E9%BB%98%E9%BB%98%E9%87%8D%E5%A4%8D%E5%8D%95%E8%AF%8D%E3%80%81%E5%BC%BA%E8%BF%AB%E6%80%A7%E7%A5%88%E7%A5%B7%E6%88%96%E9%87%8D%E5%A4%8D%E4%BB%AA%E5%BC%8F%E3%80%81%E4%B8%8D%E5%BF%85%E8%A6%81%E5%9C%B0%E6%94%B6%E9%9B%86%E6%88%96%E5%9B%A4%E7%A7%AF%E7%89%A9%E5%93%81%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="思想和行为的复合障碍" _mubu_text="%3Cspan%3E%E6%80%9D%E6%83%B3%E5%92%8C%E8%A1%8C%E4%B8%BA%E7%9A%84%E5%A4%8D%E5%90%88%E9%9A%9C%E7%A2%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="诊断标准 反复出现强迫观念、强迫行为，占用大量时间，显著痛苦" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%A0%87%E5%87%86%20%3C/span%3E%3Cspan%3E%E5%8F%8D%E5%A4%8D%E5%87%BA%E7%8E%B0%E5%BC%BA%E8%BF%AB%E8%A7%82%E5%BF%B5%E3%80%81%E5%BC%BA%E8%BF%AB%E8%A1%8C%E4%B8%BA%EF%BC%8C%E5%8D%A0%E7%94%A8%E5%A4%A7%E9%87%8F%E6%97%B6%E9%97%B4%EF%BC%8C%E6%98%BE%E8%91%97%E7%97%9B%E8%8B%A6%3C/span%3E" _note="" _mubu_note="">
              <outline text="反复出现强迫观念、强迫行为或两者兼有" _mubu_text="%3Cspan%3E%E5%8F%8D%E5%A4%8D%E5%87%BA%E7%8E%B0%E5%BC%BA%E8%BF%AB%E8%A7%82%E5%BF%B5%E3%80%81%E5%BC%BA%E8%BF%AB%E8%A1%8C%E4%B8%BA%E6%88%96%E4%B8%A4%E8%80%85%E5%85%BC%E6%9C%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="强迫观念或强迫行为占用大量时间" _mubu_text="%3Cspan%3E%E5%BC%BA%E8%BF%AB%E8%A7%82%E5%BF%B5%E6%88%96%E5%BC%BA%E8%BF%AB%E8%A1%8C%E4%B8%BA%E5%8D%A0%E7%94%A8%E5%A4%A7%E9%87%8F%E6%97%B6%E9%97%B4%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="显著痛苦或损害" _mubu_text="%3Cspan%3E%E6%98%BE%E8%91%97%E7%97%9B%E8%8B%A6%E6%88%96%E6%8D%9F%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="囤积障碍 Hoarding Disorder 难以丢弃财务，因为感觉需要保存物品「囤囤鼠」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%9B%A4%E7%A7%AF%E9%9A%9C%E7%A2%8D%20Hoarding%20Disorder%3C/span%3E%3Cspan%3E%20%E9%9A%BE%E4%BB%A5%E4%B8%A2%E5%BC%83%E8%B4%A2%E5%8A%A1%EF%BC%8C%E5%9B%A0%E4%B8%BA%E6%84%9F%E8%A7%89%E9%9C%80%E8%A6%81%E4%BF%9D%E5%AD%98%E7%89%A9%E5%93%81%E3%80%8C%E5%9B%A4%E5%9B%A4%E9%BC%A0%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="以持续难以丢弃或放弃财物为特征，因为感觉需要保存物品并对放弃它们感到痛苦" _mubu_text="%3Cspan%3E%E4%BB%A5%E6%8C%81%E7%BB%AD%E9%9A%BE%E4%BB%A5%E4%B8%A2%E5%BC%83%E6%88%96%E6%94%BE%E5%BC%83%E8%B4%A2%E7%89%A9%E4%B8%BA%E7%89%B9%E5%BE%81%EF%BC%8C%E5%9B%A0%E4%B8%BA%E6%84%9F%E8%A7%89%E9%9C%80%E8%A6%81%E4%BF%9D%E5%AD%98%E7%89%A9%E5%93%81%E5%B9%B6%E5%AF%B9%E6%94%BE%E5%BC%83%E5%AE%83%E4%BB%AC%E6%84%9F%E5%88%B0%E7%97%9B%E8%8B%A6%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="诊断标准" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%A0%87%E5%87%86%3C/span%3E" _note="" _mubu_note="">
              <outline text="个体反复无法放弃或扔掉他们的财物,即使是无价值的,因为他们觉得需要保存它们并想避免处置的不适" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E5%8F%8D%E5%A4%8D%E6%97%A0%E6%B3%95%E6%94%BE%E5%BC%83%E6%88%96%E6%89%94%E6%8E%89%E4%BB%96%E4%BB%AC%E7%9A%84%E8%B4%A2%E7%89%A9,%E5%8D%B3%E4%BD%BF%E6%98%AF%E6%97%A0%E4%BB%B7%E5%80%BC%E7%9A%84,%E5%9B%A0%E4%B8%BA%E4%BB%96%E4%BB%AC%E8%A7%89%E5%BE%97%E9%9C%80%E8%A6%81%E4%BF%9D%E5%AD%98%E5%AE%83%E4%BB%AC%E5%B9%B6%E6%83%B3%E9%81%BF%E5%85%8D%E5%A4%84%E7%BD%AE%E7%9A%84%E4%B8%8D%E9%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="个体积累了大量财物,严重堵塞和拥挤他们的家" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E7%A7%AF%E7%B4%AF%E4%BA%86%E5%A4%A7%E9%87%8F%E8%B4%A2%E7%89%A9,%E4%B8%A5%E9%87%8D%E5%A0%B5%E5%A1%9E%E5%92%8C%E6%8B%A5%E6%8C%A4%E4%BB%96%E4%BB%AC%E7%9A%84%E5%AE%B6%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="显著痛苦或损害" _mubu_text="%3Cspan%3E%E6%98%BE%E8%91%97%E7%97%9B%E8%8B%A6%E6%88%96%E6%8D%9F%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="心境障碍 Mood Disorders" _mubu_text="%3Cspan%3E%E5%BF%83%E5%A2%83%E9%9A%9C%E7%A2%8D%20Mood%20Disorders%3C/span%3E" _note="" _mubu_note="">
          <outline text="抑郁障碍" _mubu_text="%3Cspan%3E%E6%8A%91%E9%83%81%E9%9A%9C%E7%A2%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="重度抑郁障碍 Major Depressive Disorder 持续低落、动力缺失的抑郁状态「单相 Unipolar」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%87%8D%E5%BA%A6%E6%8A%91%E9%83%81%E9%9A%9C%E7%A2%8D%20Major%20Depressive%20Disorder%20%3C/span%3E%3Cspan%3E%E6%8C%81%E7%BB%AD%E4%BD%8E%E8%90%BD%E3%80%81%E5%8A%A8%E5%8A%9B%E7%BC%BA%E5%A4%B1%E7%9A%84%E6%8A%91%E9%83%81%E7%8A%B6%E6%80%81%E3%80%8C%E5%8D%95%E7%9B%B8%20Unipolar%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="涉及强烈的抑郁情绪、对活动的兴趣或愉悦感减少、能量丧失以及决策问题,持续至少2周" _mubu_text="%3Cspan%3E%E6%B6%89%E5%8F%8A%E5%BC%BA%E7%83%88%E7%9A%84%E6%8A%91%E9%83%81%E6%83%85%E7%BB%AA%E3%80%81%E5%AF%B9%E6%B4%BB%E5%8A%A8%E7%9A%84%E5%85%B4%E8%B6%A3%E6%88%96%E6%84%89%E6%82%A6%E6%84%9F%E5%87%8F%E5%B0%91%E3%80%81%E8%83%BD%E9%87%8F%E4%B8%A7%E5%A4%B1%E4%BB%A5%E5%8F%8A%E5%86%B3%E7%AD%96%E9%97%AE%E9%A2%98,%E6%8C%81%E7%BB%AD%E8%87%B3%E5%B0%912%E5%91%A8%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="诊断标准 长期且多症状的抑郁障碍" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%A0%87%E5%87%86%20%3C/span%3E%3Cspan%3E%E9%95%BF%E6%9C%9F%E4%B8%94%E5%A4%9A%E7%97%87%E7%8A%B6%E7%9A%84%E6%8A%91%E9%83%81%E9%9A%9C%E7%A2%8D%3C/span%3E" _note="" _mubu_note="">
                <outline text="在2周期间,个体在每天的大部分时间表现出抑郁情绪增加和/或在大多数活动中享受或兴趣减少" _mubu_text="%3Cspan%3E%E5%9C%A82%E5%91%A8%E6%9C%9F%E9%97%B4,%E4%B8%AA%E4%BD%93%E5%9C%A8%E6%AF%8F%E5%A4%A9%E7%9A%84%E5%A4%A7%E9%83%A8%E5%88%86%E6%97%B6%E9%97%B4%E8%A1%A8%E7%8E%B0%E5%87%BA%E6%8A%91%E9%83%81%E6%83%85%E7%BB%AA%E5%A2%9E%E5%8A%A0%E5%92%8C/%E6%88%96%E5%9C%A8%E5%A4%A7%E5%A4%9A%E6%95%B0%E6%B4%BB%E5%8A%A8%E4%B8%AD%E4%BA%AB%E5%8F%97%E6%88%96%E5%85%B4%E8%B6%A3%E5%87%8F%E5%B0%91%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="在同样的2周内,个体还经历以下至少3或4种症状:显著体重变化或食欲变化、每日失眠或嗜睡、每日激动或运动活动减少、每日疲劳或嗜睡、每日无价值感或过度内疚感、每日注意力或决断力减少、反复关注死亡或自杀、自杀计划或自杀企图" _mubu_text="%3Cspan%3E%E5%9C%A8%E5%90%8C%E6%A0%B7%E7%9A%842%E5%91%A8%E5%86%85,%E4%B8%AA%E4%BD%93%E8%BF%98%E7%BB%8F%E5%8E%86%E4%BB%A5%E4%B8%8B%E8%87%B3%E5%B0%913%E6%88%964%E7%A7%8D%E7%97%87%E7%8A%B6:%E6%98%BE%E8%91%97%E4%BD%93%E9%87%8D%E5%8F%98%E5%8C%96%E6%88%96%E9%A3%9F%E6%AC%B2%E5%8F%98%E5%8C%96%E3%80%81%E6%AF%8F%E6%97%A5%E5%A4%B1%E7%9C%A0%E6%88%96%E5%97%9C%E7%9D%A1%E3%80%81%E6%AF%8F%E6%97%A5%E6%BF%80%E5%8A%A8%E6%88%96%E8%BF%90%E5%8A%A8%E6%B4%BB%E5%8A%A8%E5%87%8F%E5%B0%91%E3%80%81%E6%AF%8F%E6%97%A5%E7%96%B2%E5%8A%B3%E6%88%96%E5%97%9C%E7%9D%A1%E3%80%81%E6%AF%8F%E6%97%A5%E6%97%A0%E4%BB%B7%E5%80%BC%E6%84%9F%E6%88%96%E8%BF%87%E5%BA%A6%E5%86%85%E7%96%9A%E6%84%9F%E3%80%81%E6%AF%8F%E6%97%A5%E6%B3%A8%E6%84%8F%E5%8A%9B%E6%88%96%E5%86%B3%E6%96%AD%E5%8A%9B%E5%87%8F%E5%B0%91%E3%80%81%E5%8F%8D%E5%A4%8D%E5%85%B3%E6%B3%A8%E6%AD%BB%E4%BA%A1%E6%88%96%E8%87%AA%E6%9D%80%E3%80%81%E8%87%AA%E6%9D%80%E8%AE%A1%E5%88%92%E6%88%96%E8%87%AA%E6%9D%80%E4%BC%81%E5%9B%BE%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="显著痛苦或损害" _mubu_text="%3Cspan%3E%E6%98%BE%E8%91%97%E7%97%9B%E8%8B%A6%E6%88%96%E6%8D%9F%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="持续性抑郁障碍 Persistent Depressive Disorder 长期的持续性抑郁，逾两年「更长 Longer」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%8C%81%E7%BB%AD%E6%80%A7%E6%8A%91%E9%83%81%E9%9A%9C%E7%A2%8D%20Persistent%20Depressive%20Disorder%3C/span%3E%3Cspan%3E%20%E9%95%BF%E6%9C%9F%E7%9A%84%E6%8C%81%E7%BB%AD%E6%80%A7%E6%8A%91%E9%83%81%EF%BC%8C%E9%80%BE%E4%B8%A4%E5%B9%B4%E3%80%8C%E6%9B%B4%E9%95%BF%20Longer%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="一种长期的抑郁形式,以持续的悲伤和低落情绪为特征,持续至少两年或更长时间" _mubu_text="%3Cspan%3E%E4%B8%80%E7%A7%8D%E9%95%BF%E6%9C%9F%E7%9A%84%E6%8A%91%E9%83%81%E5%BD%A2%E5%BC%8F,%E4%BB%A5%E6%8C%81%E7%BB%AD%E7%9A%84%E6%82%B2%E4%BC%A4%E5%92%8C%E4%BD%8E%E8%90%BD%E6%83%85%E7%BB%AA%E4%B8%BA%E7%89%B9%E5%BE%81,%E6%8C%81%E7%BB%AD%E8%87%B3%E5%B0%91%E4%B8%A4%E5%B9%B4%E6%88%96%E6%9B%B4%E9%95%BF%E6%97%B6%E9%97%B4%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="患有此障碍的个体可能经历各种抑郁症状,如食欲变化、睡眠障碍、低能量和负面自我感知" _mubu_text="%3Cspan%3E%E6%82%A3%E6%9C%89%E6%AD%A4%E9%9A%9C%E7%A2%8D%E7%9A%84%E4%B8%AA%E4%BD%93%E5%8F%AF%E8%83%BD%E7%BB%8F%E5%8E%86%E5%90%84%E7%A7%8D%E6%8A%91%E9%83%81%E7%97%87%E7%8A%B6,%E5%A6%82%E9%A3%9F%E6%AC%B2%E5%8F%98%E5%8C%96%E3%80%81%E7%9D%A1%E7%9C%A0%E9%9A%9C%E7%A2%8D%E3%80%81%E4%BD%8E%E8%83%BD%E9%87%8F%E5%92%8C%E8%B4%9F%E9%9D%A2%E8%87%AA%E6%88%91%E6%84%9F%E7%9F%A5%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="诊断标准 两年以上持续抑郁" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%A0%87%E5%87%86%20%3C/span%3E%3Cspan%3E%E4%B8%A4%E5%B9%B4%E4%BB%A5%E4%B8%8A%E6%8C%81%E7%BB%AD%E6%8A%91%E9%83%81%3C/span%3E" _note="" _mubu_note="">
                <outline text="在大多数日子里,大部分时间处于抑郁情绪,至少两年" _mubu_text="%3Cspan%3E%E5%9C%A8%E5%A4%A7%E5%A4%9A%E6%95%B0%E6%97%A5%E5%AD%90%E9%87%8C,%E5%A4%A7%E9%83%A8%E5%88%86%E6%97%B6%E9%97%B4%E5%A4%84%E4%BA%8E%E6%8A%91%E9%83%81%E6%83%85%E7%BB%AA,%E8%87%B3%E5%B0%91%E4%B8%A4%E5%B9%B4%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="在抑郁时,存在以下两种(或更多)症状:食欲不振或暴食、失眠或嗜睡、低能量或疲劳、低自尊、注意力差或决策困难、绝望感" _mubu_text="%3Cspan%3E%E5%9C%A8%E6%8A%91%E9%83%81%E6%97%B6,%E5%AD%98%E5%9C%A8%E4%BB%A5%E4%B8%8B%E4%B8%A4%E7%A7%8D(%E6%88%96%E6%9B%B4%E5%A4%9A)%E7%97%87%E7%8A%B6:%3C/span%3E%3Cspan%20class=%22bold%22%3E%E9%A3%9F%E6%AC%B2%E4%B8%8D%E6%8C%AF%E6%88%96%E6%9A%B4%E9%A3%9F%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%A4%B1%E7%9C%A0%E6%88%96%E5%97%9C%E7%9D%A1%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BD%8E%E8%83%BD%E9%87%8F%E6%88%96%E7%96%B2%E5%8A%B3%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BD%8E%E8%87%AA%E5%B0%8A%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%B3%A8%E6%84%8F%E5%8A%9B%E5%B7%AE%E6%88%96%E5%86%B3%E7%AD%96%E5%9B%B0%E9%9A%BE%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%BB%9D%E6%9C%9B%E6%84%9F%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="在两年期间(儿童或青少年为一年),个体从未连续超过两个月没有标准A和B中的症状" _mubu_text="%3Cspan%3E%E5%9C%A8%E4%B8%A4%E5%B9%B4%E6%9C%9F%E9%97%B4(%E5%84%BF%E7%AB%A5%E6%88%96%E9%9D%92%E5%B0%91%E5%B9%B4%E4%B8%BA%E4%B8%80%E5%B9%B4),%E4%B8%AA%E4%BD%93%E4%BB%8E%E6%9C%AA%E8%BF%9E%E7%BB%AD%E8%B6%85%E8%BF%87%E4%B8%A4%E4%B8%AA%E6%9C%88%E6%B2%A1%E6%9C%89%E6%A0%87%E5%87%86A%E5%92%8CB%E4%B8%AD%E7%9A%84%E7%97%87%E7%8A%B6%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
          </outline>
          <outline text="双相障碍" _mubu_text="%3Cspan%3E%E5%8F%8C%E7%9B%B8%E9%9A%9C%E7%A2%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="双相障碍 Bipolar Disorders 躁狂与重度抑郁交替的情绪波动「双相循环」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8F%8C%E7%9B%B8%E9%9A%9C%E7%A2%8D%20Bipolar%20Disorders%20%3C/span%3E%3Cspan%3E%E8%BA%81%E7%8B%82%E4%B8%8E%E9%87%8D%E5%BA%A6%E6%8A%91%E9%83%81%E4%BA%A4%E6%9B%BF%E7%9A%84%E6%83%85%E7%BB%AA%E6%B3%A2%E5%8A%A8%E3%80%8C%E5%8F%8C%E7%9B%B8%E5%BE%AA%E7%8E%AF%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="在重度抑郁和躁狂之间交替的情绪波动" _mubu_text="%3Cspan%3E%E5%9C%A8%E9%87%8D%E5%BA%A6%E6%8A%91%E9%83%81%E5%92%8C%E8%BA%81%E7%8B%82%E4%B9%8B%E9%97%B4%E4%BA%A4%E6%9B%BF%E7%9A%84%E6%83%85%E7%BB%AA%E6%B3%A2%E5%8A%A8%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="双相循环涉及这些情绪状态之间的转换,持续时间和强度可能有所不同" _mubu_text="%3Cspan%3E%E5%8F%8C%E7%9B%B8%E5%BE%AA%E7%8E%AF%E6%B6%89%E5%8F%8A%E8%BF%99%E4%BA%9B%E6%83%85%E7%BB%AA%E7%8A%B6%E6%80%81%E4%B9%8B%E9%97%B4%E7%9A%84%E8%BD%AC%E6%8D%A2,%E6%8C%81%E7%BB%AD%E6%97%B6%E9%97%B4%E5%92%8C%E5%BC%BA%E5%BA%A6%E5%8F%AF%E8%83%BD%E6%9C%89%E6%89%80%E4%B8%8D%E5%90%8C%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="双相I型障碍 Bipolar I Disorder 特征为完全躁狂发作「更严重」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8F%8C%E7%9B%B8I%E5%9E%8B%E9%9A%9C%E7%A2%8D%20Bipolar%20I%20Disorder%20%3C/span%3E%3Cspan%3E%E7%89%B9%E5%BE%81%E4%B8%BA%E5%AE%8C%E5%85%A8%E8%BA%81%E7%8B%82%E5%8F%91%E4%BD%9C%E3%80%8C%E6%9B%B4%E4%B8%A5%E9%87%8D%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="以至少一次躁狂发作 Manic Episode 为特征,可能在之前或之后有轻躁狂 Hypomanic 或重度抑郁发作" _mubu_text="%3Cspan%3E%E4%BB%A5%E8%87%B3%E5%B0%91%E4%B8%80%E6%AC%A1%E8%BA%81%E7%8B%82%E5%8F%91%E4%BD%9C%20Manic%20Episode%20%E4%B8%BA%E7%89%B9%E5%BE%81,%E5%8F%AF%E8%83%BD%E5%9C%A8%E4%B9%8B%E5%89%8D%E6%88%96%E4%B9%8B%E5%90%8E%E6%9C%89%E8%BD%BB%E8%BA%81%E7%8B%82%20Hypomanic%20%E6%88%96%E9%87%8D%E5%BA%A6%E6%8A%91%E9%83%81%E5%8F%91%E4%BD%9C%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="由于双相I型存在完全的躁狂发作,比双相II型更严重" _mubu_text="%3Cspan%3E%E7%94%B1%E4%BA%8E%E5%8F%8C%E7%9B%B8I%E5%9E%8B%E5%AD%98%E5%9C%A8%E5%AE%8C%E5%85%A8%E7%9A%84%E8%BA%81%E7%8B%82%E5%8F%91%E4%BD%9C,%E6%AF%94%E5%8F%8C%E7%9B%B8II%E5%9E%8B%E6%9B%B4%E4%B8%A5%E9%87%8D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="双相II型障碍 Bipolar II Disorder 轻躁狂伴重度抑郁「程度较轻」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8F%8C%E7%9B%B8II%E5%9E%8B%E9%9A%9C%E7%A2%8D%20Bipolar%20II%20Disorder%20%3C/span%3E%3Cspan%3E%E8%BD%BB%E8%BA%81%E7%8B%82%E4%BC%B4%E9%87%8D%E5%BA%A6%E6%8A%91%E9%83%81%E3%80%8C%E7%A8%8B%E5%BA%A6%E8%BE%83%E8%BD%BB%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="以至少一次轻躁狂发作和一次重度抑郁发作为特征,从未有过完全的躁狂发作" _mubu_text="%3Cspan%3E%E4%BB%A5%E8%87%B3%E5%B0%91%E4%B8%80%E6%AC%A1%E8%BD%BB%E8%BA%81%E7%8B%82%E5%8F%91%E4%BD%9C%E5%92%8C%E4%B8%80%E6%AC%A1%E9%87%8D%E5%BA%A6%E6%8A%91%E9%83%81%E5%8F%91%E4%BD%9C%E4%B8%BA%E7%89%B9%E5%BE%81,%E4%BB%8E%E6%9C%AA%E6%9C%89%E8%BF%87%E5%AE%8C%E5%85%A8%E7%9A%84%E8%BA%81%E7%8B%82%E5%8F%91%E4%BD%9C%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="轻躁狂发作是持续至少四天的持续性情绪高涨或易怒以及活动或能量增加的时期,比躁狂发作严重程度较轻,不会导致社交或职业功能的显著损害或需要住院治疗" _mubu_text="%3Cspan%3E%E8%BD%BB%E8%BA%81%E7%8B%82%E5%8F%91%E4%BD%9C%E6%98%AF%E6%8C%81%E7%BB%AD%E8%87%B3%E5%B0%91%E5%9B%9B%E5%A4%A9%E7%9A%84%E6%8C%81%E7%BB%AD%E6%80%A7%E6%83%85%E7%BB%AA%E9%AB%98%E6%B6%A8%E6%88%96%E6%98%93%E6%80%92%E4%BB%A5%E5%8F%8A%E6%B4%BB%E5%8A%A8%E6%88%96%E8%83%BD%E9%87%8F%E5%A2%9E%E5%8A%A0%E7%9A%84%E6%97%B6%E6%9C%9F,%E6%AF%94%E8%BA%81%E7%8B%82%E5%8F%91%E4%BD%9C%E4%B8%A5%E9%87%8D%E7%A8%8B%E5%BA%A6%E8%BE%83%E8%BD%BB,%E4%B8%8D%E4%BC%9A%E5%AF%BC%E8%87%B4%E7%A4%BE%E4%BA%A4%E6%88%96%E8%81%8C%E4%B8%9A%E5%8A%9F%E8%83%BD%E7%9A%84%E6%98%BE%E8%91%97%E6%8D%9F%E5%AE%B3%E6%88%96%E9%9C%80%E8%A6%81%E4%BD%8F%E9%99%A2%E6%B2%BB%E7%96%97%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="躁狂与抑郁症状对比 躁狂：高能亢奋、思维奔逸与冲动外向；抑郁：低能虚脱、思维迟滞与自我封闭" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%BA%81%E7%8B%82%E4%B8%8E%E6%8A%91%E9%83%81%E7%97%87%E7%8A%B6%E5%AF%B9%E6%AF%94%3C/span%3E%3Cspan%3E%20%E8%BA%81%E7%8B%82%EF%BC%9A%E9%AB%98%E8%83%BD%E4%BA%A2%E5%A5%8B%E3%80%81%E6%80%9D%E7%BB%B4%E5%A5%94%E9%80%B8%E4%B8%8E%E5%86%B2%E5%8A%A8%E5%A4%96%E5%90%91%EF%BC%9B%E6%8A%91%E9%83%81%EF%BC%9A%E4%BD%8E%E8%83%BD%E8%99%9A%E8%84%B1%E3%80%81%E6%80%9D%E7%BB%B4%E8%BF%9F%E6%BB%9E%E4%B8%8E%E8%87%AA%E6%88%91%E5%B0%81%E9%97%AD%3C/span%3E" _note="" _mubu_note="">
            <outline text="躁狂症状:情绪高涨、扩张或易怒;能量和活动水平增加;睡眠需求减少;比平时更健谈或有说话压力;思维奔逸或意念飞跃;目标导向活动增加或身体不安;过度参与危险活动;自尊心膨胀或夸大;更外向、社交性增加或性放纵" _mubu_text="%3Cspan%3E%E8%BA%81%E7%8B%82%E7%97%87%E7%8A%B6:%E6%83%85%E7%BB%AA%E9%AB%98%E6%B6%A8%E3%80%81%E6%89%A9%E5%BC%A0%E6%88%96%E6%98%93%E6%80%92;%E8%83%BD%E9%87%8F%E5%92%8C%E6%B4%BB%E5%8A%A8%E6%B0%B4%E5%B9%B3%E5%A2%9E%E5%8A%A0;%E7%9D%A1%E7%9C%A0%E9%9C%80%E6%B1%82%E5%87%8F%E5%B0%91;%E6%AF%94%E5%B9%B3%E6%97%B6%E6%9B%B4%E5%81%A5%E8%B0%88%E6%88%96%E6%9C%89%E8%AF%B4%E8%AF%9D%E5%8E%8B%E5%8A%9B;%E6%80%9D%E7%BB%B4%E5%A5%94%E9%80%B8%E6%88%96%E6%84%8F%E5%BF%B5%E9%A3%9E%E8%B7%83;%E7%9B%AE%E6%A0%87%E5%AF%BC%E5%90%91%E6%B4%BB%E5%8A%A8%E5%A2%9E%E5%8A%A0%E6%88%96%E8%BA%AB%E4%BD%93%E4%B8%8D%E5%AE%89;%E8%BF%87%E5%BA%A6%E5%8F%82%E4%B8%8E%E5%8D%B1%E9%99%A9%E6%B4%BB%E5%8A%A8;%E8%87%AA%E5%B0%8A%E5%BF%83%E8%86%A8%E8%83%80%E6%88%96%E5%A4%B8%E5%A4%A7;%E6%9B%B4%E5%A4%96%E5%90%91%E3%80%81%E7%A4%BE%E4%BA%A4%E6%80%A7%E5%A2%9E%E5%8A%A0%E6%88%96%E6%80%A7%E6%94%BE%E7%BA%B5%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="抑郁症状:持续悲伤或空虚情绪;疲劳或能量丧失;失眠或过度睡眠;注意力集中或决策困难;无价值感或过度内疚感;对几乎所有活动的兴趣或愉悦感减少;自杀想法或行为;绝望感;从朋友和活动中退缩" _mubu_text="%3Cspan%3E%E6%8A%91%E9%83%81%E7%97%87%E7%8A%B6:%E6%8C%81%E7%BB%AD%E6%82%B2%E4%BC%A4%E6%88%96%E7%A9%BA%E8%99%9A%E6%83%85%E7%BB%AA;%E7%96%B2%E5%8A%B3%E6%88%96%E8%83%BD%E9%87%8F%E4%B8%A7%E5%A4%B1;%E5%A4%B1%E7%9C%A0%E6%88%96%E8%BF%87%E5%BA%A6%E7%9D%A1%E7%9C%A0;%E6%B3%A8%E6%84%8F%E5%8A%9B%E9%9B%86%E4%B8%AD%E6%88%96%E5%86%B3%E7%AD%96%E5%9B%B0%E9%9A%BE;%E6%97%A0%E4%BB%B7%E5%80%BC%E6%84%9F%E6%88%96%E8%BF%87%E5%BA%A6%E5%86%85%E7%96%9A%E6%84%9F;%E5%AF%B9%E5%87%A0%E4%B9%8E%E6%89%80%E6%9C%89%E6%B4%BB%E5%8A%A8%E7%9A%84%E5%85%B4%E8%B6%A3%E6%88%96%E6%84%89%E6%82%A6%E6%84%9F%E5%87%8F%E5%B0%91;%E8%87%AA%E6%9D%80%E6%83%B3%E6%B3%95%E6%88%96%E8%A1%8C%E4%B8%BA;%E7%BB%9D%E6%9C%9B%E6%84%9F;%E4%BB%8E%E6%9C%8B%E5%8F%8B%E5%92%8C%E6%B4%BB%E5%8A%A8%E4%B8%AD%E9%80%80%E7%BC%A9%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="解离性障碍 Dissociative Disorders " _mubu_text="%3Cspan%3E%E8%A7%A3%E7%A6%BB%E6%80%A7%E9%9A%9C%E7%A2%8D%20Dissociative%20Disorders%20%3C/span%3E" _note="" _mubu_note="">
          <outline text="分离性障碍 Dissociative Disorders 意识中断，导致功能受损「开车时做白日梦」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%88%86%E7%A6%BB%E6%80%A7%E9%9A%9C%E7%A2%8D%20Dissociative%20Disorders%3C/span%3E%3Cspan%3E%20%E6%84%8F%E8%AF%86%E4%B8%AD%E6%96%AD%EF%BC%8C%E5%AF%BC%E8%87%B4%E5%8A%9F%E8%83%BD%E5%8F%97%E6%8D%9F%E3%80%8C%E5%BC%80%E8%BD%A6%E6%97%B6%E5%81%9A%E7%99%BD%E6%97%A5%E6%A2%A6%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="以意识、记忆、身份或感知的中断或不连续为特征,导致日常功能的显著损害" _mubu_text="%3Cspan%3E%E4%BB%A5%E6%84%8F%E8%AF%86%E3%80%81%E8%AE%B0%E5%BF%86%E3%80%81%E8%BA%AB%E4%BB%BD%E6%88%96%E6%84%9F%E7%9F%A5%E7%9A%84%E4%B8%AD%E6%96%AD%E6%88%96%E4%B8%8D%E8%BF%9E%E7%BB%AD%E4%B8%BA%E7%89%B9%E5%BE%81,%E5%AF%BC%E8%87%B4%E6%97%A5%E5%B8%B8%E5%8A%9F%E8%83%BD%E7%9A%84%E6%98%BE%E8%91%97%E6%8D%9F%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="如果极度压力,我们可能会经历意识觉知的分离" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E6%9E%81%E5%BA%A6%E5%8E%8B%E5%8A%9B,%E6%88%91%E4%BB%AC%E5%8F%AF%E8%83%BD%E4%BC%9A%E7%BB%8F%E5%8E%86%E6%84%8F%E8%AF%86%E8%A7%89%E7%9F%A5%E7%9A%84%E5%88%86%E7%A6%BB%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="分离描述常见事件,如开车时做白日梦「你是否在开车去熟悉的地方时,意识到自己并没有完全注意,而是处于&quot;自动驾驶&quot;状态」" _mubu_text="%3Cspan%3E%E5%88%86%E7%A6%BB%E6%8F%8F%E8%BF%B0%E5%B8%B8%E8%A7%81%E4%BA%8B%E4%BB%B6,%E5%A6%82%E5%BC%80%E8%BD%A6%E6%97%B6%E5%81%9A%E7%99%BD%E6%97%A5%E6%A2%A6%E3%80%8C%E4%BD%A0%E6%98%AF%E5%90%A6%E5%9C%A8%E5%BC%80%E8%BD%A6%E5%8E%BB%E7%86%9F%E6%82%89%E7%9A%84%E5%9C%B0%E6%96%B9%E6%97%B6,%E6%84%8F%E8%AF%86%E5%88%B0%E8%87%AA%E5%B7%B1%E5%B9%B6%E6%B2%A1%E6%9C%89%E5%AE%8C%E5%85%A8%E6%B3%A8%E6%84%8F,%E8%80%8C%E6%98%AF%E5%A4%84%E4%BA%8E%22%E8%87%AA%E5%8A%A8%E9%A9%BE%E9%A9%B6%22%E7%8A%B6%E6%80%81%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="分离性遗忘 Dissociative Amnesia 创伤致重要记忆缺失「自传记忆缺失」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%88%86%E7%A6%BB%E6%80%A7%E9%81%97%E5%BF%98%20Dissociative%20Amnesia%20%3C/span%3E%3Cspan%3E%E5%88%9B%E4%BC%A4%E8%87%B4%E9%87%8D%E8%A6%81%E8%AE%B0%E5%BF%86%E7%BC%BA%E5%A4%B1%E3%80%8C%E8%87%AA%E4%BC%A0%E8%AE%B0%E5%BF%86%E7%BC%BA%E5%A4%B1%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="涉及无法回忆重要的自传信息,通常是创伤性质的" _mubu_text="%3Cspan%3E%E6%B6%89%E5%8F%8A%E6%97%A0%E6%B3%95%E5%9B%9E%E5%BF%86%E9%87%8D%E8%A6%81%E7%9A%84%E8%87%AA%E4%BC%A0%E4%BF%A1%E6%81%AF,%E9%80%9A%E5%B8%B8%E6%98%AF%E5%88%9B%E4%BC%A4%E6%80%A7%E8%B4%A8%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="诊断标准 创伤导致的重要记忆丧失" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%A0%87%E5%87%86%20%3C/span%3E%3Cspan%3E%E5%88%9B%E4%BC%A4%E5%AF%BC%E8%87%B4%E7%9A%84%E9%87%8D%E8%A6%81%E8%AE%B0%E5%BF%86%E4%B8%A7%E5%A4%B1%3C/span%3E" _note="" _mubu_note="">
              <outline text="个体无法回忆重要的生活相关信息,通常是创伤性或压力性信息,记忆问题不仅仅是简单的遗忘" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E6%97%A0%E6%B3%95%E5%9B%9E%E5%BF%86%E9%87%8D%E8%A6%81%E7%9A%84%E7%94%9F%E6%B4%BB%E7%9B%B8%E5%85%B3%E4%BF%A1%E6%81%AF,%E9%80%9A%E5%B8%B8%E6%98%AF%E5%88%9B%E4%BC%A4%E6%80%A7%E6%88%96%E5%8E%8B%E5%8A%9B%E6%80%A7%E4%BF%A1%E6%81%AF,%E8%AE%B0%E5%BF%86%E9%97%AE%E9%A2%98%E4%B8%8D%E4%BB%85%E4%BB%85%E6%98%AF%E7%AE%80%E5%8D%95%E7%9A%84%E9%81%97%E5%BF%98%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="显著痛苦或损害" _mubu_text="%3Cspan%3E%E6%98%BE%E8%91%97%E7%97%9B%E8%8B%A6%E6%88%96%E6%8D%9F%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="症状不是由物质或医疗状况引起的" _mubu_text="%3Cspan%3E%E7%97%87%E7%8A%B6%E4%B8%8D%E6%98%AF%E7%94%B1%E7%89%A9%E8%B4%A8%E6%88%96%E5%8C%BB%E7%96%97%E7%8A%B6%E5%86%B5%E5%BC%95%E8%B5%B7%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="分离性漫游 Dissociative Fugue 遗忘自我身份并离家出逃「遗忘的极端版本」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%88%86%E7%A6%BB%E6%80%A7%E6%BC%AB%E6%B8%B8%20Dissociative%20Fugue%3C/span%3E%3Cspan%3E%20%E9%81%97%E5%BF%98%E8%87%AA%E6%88%91%E8%BA%AB%E4%BB%BD%E5%B9%B6%E7%A6%BB%E5%AE%B6%E5%87%BA%E9%80%83%E3%80%8C%E9%81%97%E5%BF%98%E7%9A%84%E6%9E%81%E7%AB%AF%E7%89%88%E6%9C%AC%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="忘记个人身份和过去生活的细节,逃到新地点" _mubu_text="%3Cspan%3E%E5%BF%98%E8%AE%B0%E4%B8%AA%E4%BA%BA%E8%BA%AB%E4%BB%BD%E5%92%8C%E8%BF%87%E5%8E%BB%E7%94%9F%E6%B4%BB%E7%9A%84%E7%BB%86%E8%8A%82,%E9%80%83%E5%88%B0%E6%96%B0%E5%9C%B0%E7%82%B9%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="分离性身份障碍 Dissociative Identity Disorder (DID)  多重人格引发身份与记忆解离「性虐待、家暴」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%88%86%E7%A6%BB%E6%80%A7%E8%BA%AB%E4%BB%BD%E9%9A%9C%E7%A2%8D%20Dissociative%20Identity%20Disorder%20(DID)%20%20%3C/span%3E%3Cspan%3E%E5%A4%9A%E9%87%8D%E4%BA%BA%E6%A0%BC%E5%BC%95%E5%8F%91%E8%BA%AB%E4%BB%BD%E4%B8%8E%E8%AE%B0%E5%BF%86%E8%A7%A3%E7%A6%BB%E3%80%8C%E6%80%A7%E8%99%90%E5%BE%85%E3%80%81%E5%AE%B6%E6%9A%B4%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="以至少两个不同的人格身份的存在为特征,每个都有自己感知和与世界互动的模式,导致记忆空白和自我感的破坏" _mubu_text="%3Cspan%3E%E4%BB%A5%E8%87%B3%E5%B0%91%E4%B8%A4%E4%B8%AA%E4%B8%8D%E5%90%8C%E7%9A%84%E4%BA%BA%E6%A0%BC%E8%BA%AB%E4%BB%BD%E7%9A%84%E5%AD%98%E5%9C%A8%E4%B8%BA%E7%89%B9%E5%BE%81,%E6%AF%8F%E4%B8%AA%E9%83%BD%E6%9C%89%E8%87%AA%E5%B7%B1%E6%84%9F%E7%9F%A5%E5%92%8C%E4%B8%8E%E4%B8%96%E7%95%8C%E4%BA%92%E5%8A%A8%E7%9A%84%E6%A8%A1%E5%BC%8F,%E5%AF%BC%E8%87%B4%E8%AE%B0%E5%BF%86%E7%A9%BA%E7%99%BD%E5%92%8C%E8%87%AA%E6%88%91%E6%84%9F%E7%9A%84%E7%A0%B4%E5%9D%8F%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="常见于幼年时遭受身体/性虐待的人" _mubu_text="%3Cspan%3E%E5%B8%B8%E8%A7%81%E4%BA%8E%E5%B9%BC%E5%B9%B4%E6%97%B6%E9%81%AD%E5%8F%97%E8%BA%AB%E4%BD%93/%E6%80%A7%E8%99%90%E5%BE%85%E7%9A%84%E4%BA%BA%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="诊断标准 身份分裂，伴有记忆缺失" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%A0%87%E5%87%86%20%3C/span%3E%3Cspan%3E%E8%BA%AB%E4%BB%BD%E5%88%86%E8%A3%82%EF%BC%8C%E4%BC%B4%E6%9C%89%E8%AE%B0%E5%BF%86%E7%BC%BA%E5%A4%B1%3C/span%3E" _note="" _mubu_note="">
              <outline text="个体经历其身份的破坏,反映为至少两个独立的人格状态或被附身的体验" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E7%BB%8F%E5%8E%86%E5%85%B6%E8%BA%AB%E4%BB%BD%E7%9A%84%E7%A0%B4%E5%9D%8F,%E5%8F%8D%E6%98%A0%E4%B8%BA%E8%87%B3%E5%B0%91%E4%B8%A4%E4%B8%AA%E7%8B%AC%E7%AB%8B%E7%9A%84%E4%BA%BA%E6%A0%BC%E7%8A%B6%E6%80%81%E6%88%96%E8%A2%AB%E9%99%84%E8%BA%AB%E7%9A%84%E4%BD%93%E9%AA%8C%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="个体反复经历关于日常事件、关键个人信息或创伤事件的记忆空白,超出普通遗忘" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E5%8F%8D%E5%A4%8D%E7%BB%8F%E5%8E%86%E5%85%B3%E4%BA%8E%E6%97%A5%E5%B8%B8%E4%BA%8B%E4%BB%B6%E3%80%81%E5%85%B3%E9%94%AE%E4%B8%AA%E4%BA%BA%E4%BF%A1%E6%81%AF%E6%88%96%E5%88%9B%E4%BC%A4%E4%BA%8B%E4%BB%B6%E7%9A%84%E8%AE%B0%E5%BF%86%E7%A9%BA%E7%99%BD,%E8%B6%85%E5%87%BA%E6%99%AE%E9%80%9A%E9%81%97%E5%BF%98%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="显著痛苦或损害" _mubu_text="%3Cspan%3E%E6%98%BE%E8%91%97%E7%97%9B%E8%8B%A6%E6%88%96%E6%8D%9F%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="症状不是由物质或医疗状况引起的" _mubu_text="%3Cspan%3E%E7%97%87%E7%8A%B6%E4%B8%8D%E6%98%AF%E7%94%B1%E7%89%A9%E8%B4%A8%E6%88%96%E5%8C%BB%E7%96%97%E7%8A%B6%E5%86%B5%E5%BC%95%E8%B5%B7%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="创伤和应激相关障碍 Trauma and Stressor-Related Disorders" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%88%9B%E4%BC%A4%E5%92%8C%E5%BA%94%E6%BF%80%E7%9B%B8%E5%85%B3%E9%9A%9C%E7%A2%8D%20Trauma%20and%20Stressor-Related%20Disorders%3C/span%3E" _note="" _mubu_note="">
          <outline text="创伤后的压力，包括警觉焦虑、闪回失眠及情感疏离" _mubu_text="%3Cspan%3E%E5%88%9B%E4%BC%A4%E5%90%8E%E7%9A%84%E5%8E%8B%E5%8A%9B%EF%BC%8C%E5%8C%85%E6%8B%AC%E8%AD%A6%E8%A7%89%E7%84%A6%E8%99%91%E3%80%81%E9%97%AA%E5%9B%9E%E5%A4%B1%E7%9C%A0%E5%8F%8A%E6%83%85%E6%84%9F%E7%96%8F%E7%A6%BB%3C/span%3E" _note="" _mubu_note="">
            <outline text="涉及暴露于创伤或压力事件后的心理困扰,以过度警觉 Hypervigilance、严重焦虑 Severe Anxiety、闪回 Flashbacks、失眠 Insomnia、情感疏离 Emotional Detachment 和敌意 Hostility 等症状为特征,损害日常功能" _mubu_text="%3Cspan%3E%E6%B6%89%E5%8F%8A%E6%9A%B4%E9%9C%B2%E4%BA%8E%E5%88%9B%E4%BC%A4%E6%88%96%E5%8E%8B%E5%8A%9B%E4%BA%8B%E4%BB%B6%E5%90%8E%E7%9A%84%E5%BF%83%E7%90%86%E5%9B%B0%E6%89%B0,%E4%BB%A5%E8%BF%87%E5%BA%A6%E8%AD%A6%E8%A7%89%20Hypervigilance%E3%80%81%E4%B8%A5%E9%87%8D%E7%84%A6%E8%99%91%20Severe%20Anxiety%E3%80%81%E9%97%AA%E5%9B%9E%20Flashbacks%E3%80%81%E5%A4%B1%E7%9C%A0%20Insomnia%E3%80%81%E6%83%85%E6%84%9F%E7%96%8F%E7%A6%BB%20Emotional%20Detachment%20%E5%92%8C%E6%95%8C%E6%84%8F%20Hostility%20%E7%AD%89%E7%97%87%E7%8A%B6%E4%B8%BA%E7%89%B9%E5%BE%81,%E6%8D%9F%E5%AE%B3%E6%97%A5%E5%B8%B8%E5%8A%9F%E8%83%BD%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="创伤后应激障碍 Posttraumatic Stress Disorder (PTSD) 创伤致闪回、回避及反应增强「严重受损」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%88%9B%E4%BC%A4%E5%90%8E%E5%BA%94%E6%BF%80%E9%9A%9C%E7%A2%8D%20Posttraumatic%20Stress%20Disorder%20(PTSD)%3C/span%3E%3Cspan%3E%20%E5%88%9B%E4%BC%A4%E8%87%B4%E9%97%AA%E5%9B%9E%E3%80%81%E5%9B%9E%E9%81%BF%E5%8F%8A%E5%8F%8D%E5%BA%94%E5%A2%9E%E5%BC%BA%E3%80%8C%E4%B8%A5%E9%87%8D%E5%8F%97%E6%8D%9F%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="暴露于创伤事件后持续的心理和情绪压力,以侵入性记忆(闪回) Intrusive Memories (Flashbacks)、回避创伤提醒 Avoidance of Reminders、反应性增强(如夸大的惊吓反应) Heightened Reactivity、情感麻木 Emotional Numbness 为特征" _mubu_text="%3Cspan%3E%E6%9A%B4%E9%9C%B2%E4%BA%8E%E5%88%9B%E4%BC%A4%E4%BA%8B%E4%BB%B6%E5%90%8E%E6%8C%81%E7%BB%AD%E7%9A%84%E5%BF%83%E7%90%86%E5%92%8C%E6%83%85%E7%BB%AA%E5%8E%8B%E5%8A%9B,%E4%BB%A5%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BE%B5%E5%85%A5%E6%80%A7%E8%AE%B0%E5%BF%86(%E9%97%AA%E5%9B%9E)%20Intrusive%20Memories%20(Flashbacks)%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%9B%9E%E9%81%BF%E5%88%9B%E4%BC%A4%E6%8F%90%E9%86%92%20Avoidance%20of%20Reminders%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%8F%8D%E5%BA%94%E6%80%A7%E5%A2%9E%E5%BC%BA(%E5%A6%82%E5%A4%B8%E5%A4%A7%E7%9A%84%E6%83%8A%E5%90%93%E5%8F%8D%E5%BA%94)%20Heightened%20Reactivity%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%83%85%E6%84%9F%E9%BA%BB%E6%9C%A8%20Emotional%20Numbness%3C/span%3E%3Cspan%3E%20%E4%B8%BA%E7%89%B9%E5%BE%81%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="诊断标准 创伤暴露后，出现回避、认知情绪负面改变、过度唤醒等症状，持续超一月且严重损及功能" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%A0%87%E5%87%86%3C/span%3E%3Cspan%3E%20%E5%88%9B%E4%BC%A4%E6%9A%B4%E9%9C%B2%E5%90%8E%EF%BC%8C%E5%87%BA%E7%8E%B0%E5%9B%9E%E9%81%BF%E3%80%81%E8%AE%A4%E7%9F%A5%E6%83%85%E7%BB%AA%E8%B4%9F%E9%9D%A2%E6%94%B9%E5%8F%98%E3%80%81%E8%BF%87%E5%BA%A6%E5%94%A4%E9%86%92%E7%AD%89%E7%97%87%E7%8A%B6%EF%BC%8C%E6%8C%81%E7%BB%AD%E8%B6%85%E4%B8%80%E6%9C%88%E4%B8%94%E4%B8%A5%E9%87%8D%E6%8D%9F%E5%8F%8A%E5%8A%9F%E8%83%BD%3C/span%3E" _note="" _mubu_note="">
              <outline text="个体暴露于创伤事件——死亡或威胁死亡、严重伤害或性侵犯" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E6%9A%B4%E9%9C%B2%E4%BA%8E%E5%88%9B%E4%BC%A4%E4%BA%8B%E4%BB%B6%E2%80%94%E2%80%94%E6%AD%BB%E4%BA%A1%E6%88%96%E5%A8%81%E8%83%81%E6%AD%BB%E4%BA%A1%E3%80%81%E4%B8%A5%E9%87%8D%E4%BC%A4%E5%AE%B3%E6%88%96%E6%80%A7%E4%BE%B5%E7%8A%AF%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="个体持续回避与创伤相关的刺激" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E6%8C%81%E7%BB%AD%E5%9B%9E%E9%81%BF%E4%B8%8E%E5%88%9B%E4%BC%A4%E7%9B%B8%E5%85%B3%E7%9A%84%E5%88%BA%E6%BF%80%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="个体在与创伤相关的认知和情绪方面经历负面变化,如无法记住事件的关键特征或经历反复的负面情绪" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E5%9C%A8%E4%B8%8E%E5%88%9B%E4%BC%A4%E7%9B%B8%E5%85%B3%E7%9A%84%E8%AE%A4%E7%9F%A5%E5%92%8C%E6%83%85%E7%BB%AA%E6%96%B9%E9%9D%A2%E7%BB%8F%E5%8E%86%E8%B4%9F%E9%9D%A2%E5%8F%98%E5%8C%96,%E5%A6%82%E6%97%A0%E6%B3%95%E8%AE%B0%E4%BD%8F%E4%BA%8B%E4%BB%B6%E7%9A%84%E5%85%B3%E9%94%AE%E7%89%B9%E5%BE%81%E6%88%96%E7%BB%8F%E5%8E%86%E5%8F%8D%E5%A4%8D%E7%9A%84%E8%B4%9F%E9%9D%A2%E6%83%85%E7%BB%AA%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="个体表现出明显的唤醒和反应性变化,如过度警觉、极端惊吓反应或睡眠障碍" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E8%A1%A8%E7%8E%B0%E5%87%BA%E6%98%8E%E6%98%BE%E7%9A%84%E5%94%A4%E9%86%92%E5%92%8C%E5%8F%8D%E5%BA%94%E6%80%A7%E5%8F%98%E5%8C%96,%E5%A6%82%E8%BF%87%E5%BA%A6%E8%AD%A6%E8%A7%89%E3%80%81%E6%9E%81%E7%AB%AF%E6%83%8A%E5%90%93%E5%8F%8D%E5%BA%94%E6%88%96%E7%9D%A1%E7%9C%A0%E9%9A%9C%E7%A2%8D%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="个体经历显著痛苦或损害,症状持续超过一个月" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E7%BB%8F%E5%8E%86%E6%98%BE%E8%91%97%E7%97%9B%E8%8B%A6%E6%88%96%E6%8D%9F%E5%AE%B3,%E7%97%87%E7%8A%B6%E6%8C%81%E7%BB%AD%E8%B6%85%E8%BF%87%E4%B8%80%E4%B8%AA%E6%9C%88%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="PTSD的症状可能在创伤事件后不久开始,也可能在数月或数年后开始" _mubu_text="%3Cspan%3EPTSD%E7%9A%84%E7%97%87%E7%8A%B6%E5%8F%AF%E8%83%BD%E5%9C%A8%E5%88%9B%E4%BC%A4%E4%BA%8B%E4%BB%B6%E5%90%8E%E4%B8%8D%E4%B9%85%E5%BC%80%E5%A7%8B,%E4%B9%9F%E5%8F%AF%E8%83%BD%E5%9C%A8%E6%95%B0%E6%9C%88%E6%88%96%E6%95%B0%E5%B9%B4%E5%90%8E%E5%BC%80%E5%A7%8B%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="进食障碍 Eating &amp; Feeding Disorders" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%BF%9B%E9%A3%9F%E9%9A%9C%E7%A2%8D%20Eating%20&amp;amp;%20Feeding%20Disorders%3C/span%3E" _note="" _mubu_note="">
          <outline text="进食障碍 Eating &amp; Feeding Disorders 过量或不足摄入，损害健康和心理功能「厌食、暴食」" _mubu_text="%3Cspan%3E%E8%BF%9B%E9%A3%9F%E9%9A%9C%E7%A2%8D%20Eating%20&amp;amp;%20Feeding%20Disorders%20%E8%BF%87%E9%87%8F%E6%88%96%E4%B8%8D%E8%B6%B3%E6%91%84%E5%85%A5%EF%BC%8C%E6%8D%9F%E5%AE%B3%E5%81%A5%E5%BA%B7%E5%92%8C%E5%BF%83%E7%90%86%E5%8A%9F%E8%83%BD%E3%80%8C%E5%8E%8C%E9%A3%9F%E3%80%81%E6%9A%B4%E9%A3%9F%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="以食物消费或吸收改变为定义的心理障碍,可能涉及食物摄入不足或过量,损害健康和心理功能" _mubu_text="%3Cspan%3E%E4%BB%A5%E9%A3%9F%E7%89%A9%E6%B6%88%E8%B4%B9%E6%88%96%E5%90%B8%E6%94%B6%E6%94%B9%E5%8F%98%E4%B8%BA%E5%AE%9A%E4%B9%89%E7%9A%84%E5%BF%83%E7%90%86%E9%9A%9C%E7%A2%8D,%E5%8F%AF%E8%83%BD%E6%B6%89%E5%8F%8A%E9%A3%9F%E7%89%A9%E6%91%84%E5%85%A5%E4%B8%8D%E8%B6%B3%E6%88%96%E8%BF%87%E9%87%8F,%E6%8D%9F%E5%AE%B3%E5%81%A5%E5%BA%B7%E5%92%8C%E5%BF%83%E7%90%86%E5%8A%9F%E8%83%BD%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="神经性厌食症 Anorexia Nervosa 过度节食与病态自我形象致体重锐减「厌食症」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A5%9E%E7%BB%8F%E6%80%A7%E5%8E%8C%E9%A3%9F%E7%97%87%20Anorexia%20Nervosa%20%3C/span%3E%3Cspan%3E%E8%BF%87%E5%BA%A6%E8%8A%82%E9%A3%9F%E4%B8%8E%E7%97%85%E6%80%81%E8%87%AA%E6%88%91%E5%BD%A2%E8%B1%A1%E8%87%B4%E4%BD%93%E9%87%8D%E9%94%90%E5%87%8F%E3%80%8C%E5%8E%8C%E9%A3%9F%E7%97%87%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="以限制食物摄入、强烈害怕体重增加和扭曲的身体形象为特征,导致显著体重减轻和健康并发症" _mubu_text="%3Cspan%3E%E4%BB%A5%E9%99%90%E5%88%B6%E9%A3%9F%E7%89%A9%E6%91%84%E5%85%A5%E3%80%81%E5%BC%BA%E7%83%88%E5%AE%B3%E6%80%95%E4%BD%93%E9%87%8D%E5%A2%9E%E5%8A%A0%E5%92%8C%E6%89%AD%E6%9B%B2%E7%9A%84%E8%BA%AB%E4%BD%93%E5%BD%A2%E8%B1%A1%E4%B8%BA%E7%89%B9%E5%BE%81,%E5%AF%BC%E8%87%B4%E6%98%BE%E8%91%97%E4%BD%93%E9%87%8D%E5%87%8F%E8%BD%BB%E5%92%8C%E5%81%A5%E5%BA%B7%E5%B9%B6%E5%8F%91%E7%97%87%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="神经性贪食症 Bulimia Nervosa 暴食后采取极端补偿行为防止体重增加「暴食症」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A5%9E%E7%BB%8F%E6%80%A7%E8%B4%AA%E9%A3%9F%E7%97%87%20Bulimia%20Nervosa%20%3C/span%3E%3Cspan%3E%E6%9A%B4%E9%A3%9F%E5%90%8E%E9%87%87%E5%8F%96%E6%9E%81%E7%AB%AF%E8%A1%A5%E5%81%BF%E8%A1%8C%E4%B8%BA%E9%98%B2%E6%AD%A2%E4%BD%93%E9%87%8D%E5%A2%9E%E5%8A%A0%E3%80%8C%E6%9A%B4%E9%A3%9F%E7%97%87%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="以反复的暴食发作为特征,随后采取不当的补偿行为,如自我诱导呕吐、禁食或过度运动,以防止体重增加,造成显著痛苦" _mubu_text="%3Cspan%3E%E4%BB%A5%E5%8F%8D%E5%A4%8D%E7%9A%84%E6%9A%B4%E9%A3%9F%E5%8F%91%E4%BD%9C%E4%B8%BA%E7%89%B9%E5%BE%81,%E9%9A%8F%E5%90%8E%E9%87%87%E5%8F%96%E4%B8%8D%E5%BD%93%E7%9A%84%E8%A1%A5%E5%81%BF%E8%A1%8C%E4%B8%BA,%E5%A6%82%E8%87%AA%E6%88%91%E8%AF%B1%E5%AF%BC%E5%91%95%E5%90%90%E3%80%81%E7%A6%81%E9%A3%9F%E6%88%96%E8%BF%87%E5%BA%A6%E8%BF%90%E5%8A%A8,%E4%BB%A5%E9%98%B2%E6%AD%A2%E4%BD%93%E9%87%8D%E5%A2%9E%E5%8A%A0,%E9%80%A0%E6%88%90%E6%98%BE%E8%91%97%E7%97%9B%E8%8B%A6%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="人格障碍 Personality Disorders" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Personality%20Disorders%3C/span%3E" _note="" _mubu_note="">
          <outline text="人格障碍 Personality Disorders 行为失调且无自知，模式僵化、功能受损，成年方可诊断" _mubu_text="%3Cspan%3E%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Personality%20Disorders%20%E8%A1%8C%E4%B8%BA%E5%A4%B1%E8%B0%83%E4%B8%94%E6%97%A0%E8%87%AA%E7%9F%A5%EF%BC%8C%E6%A8%A1%E5%BC%8F%E5%83%B5%E5%8C%96%E3%80%81%E5%8A%9F%E8%83%BD%E5%8F%97%E6%8D%9F%EF%BC%8C%E6%88%90%E5%B9%B4%E6%96%B9%E5%8F%AF%E8%AF%8A%E6%96%AD%3C/span%3E" _note="" _mubu_note="">
            <outline text="长期的、适应不良的思想和行为模式,对他人造成困扰、有害或非法" _mubu_text="%3Cspan%3E%E9%95%BF%E6%9C%9F%E7%9A%84%E3%80%81%E9%80%82%E5%BA%94%E4%B8%8D%E8%89%AF%E7%9A%84%E6%80%9D%E6%83%B3%E5%92%8C%E8%A1%8C%E4%B8%BA%E6%A8%A1%E5%BC%8F,%E5%AF%B9%E4%BB%96%E4%BA%BA%E9%80%A0%E6%88%90%E5%9B%B0%E6%89%B0%E3%80%81%E6%9C%89%E5%AE%B3%E6%88%96%E9%9D%9E%E6%B3%95%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="损害人们的社会功能,个体不会经历焦虑、抑郁或妄想" _mubu_text="%3Cspan%3E%E6%8D%9F%E5%AE%B3%E4%BA%BA%E4%BB%AC%E7%9A%84%E7%A4%BE%E4%BC%9A%E5%8A%9F%E8%83%BD,%E4%B8%AA%E4%BD%93%E4%B8%8D%E4%BC%9A%E7%BB%8F%E5%8E%86%E7%84%A6%E8%99%91%E3%80%81%E6%8A%91%E9%83%81%E6%88%96%E5%A6%84%E6%83%B3%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="诊断标准 模式僵化、功能受损，成年方可诊断" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%8A%E6%96%AD%E6%A0%87%E5%87%86%20%3C/span%3E%3Cspan%3E%E6%A8%A1%E5%BC%8F%E5%83%B5%E5%8C%96%E3%80%81%E5%8A%9F%E8%83%BD%E5%8F%97%E6%8D%9F%EF%BC%8C%E6%88%90%E5%B9%B4%E6%96%B9%E5%8F%AF%E8%AF%8A%E6%96%AD%3C/span%3E" _note="" _mubu_note="">
              <outline text="个体表现出长期的、僵化的、广泛的内在体验和行为模式,导致至少两个以下领域的功能障碍:认知 Cognitive、情绪 Emotion、社交互动 Social Interactions、冲动性 Impulsivity" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E8%A1%A8%E7%8E%B0%E5%87%BA%E9%95%BF%E6%9C%9F%E7%9A%84%E3%80%81%E5%83%B5%E5%8C%96%E7%9A%84%E3%80%81%E5%B9%BF%E6%B3%9B%E7%9A%84%E5%86%85%E5%9C%A8%E4%BD%93%E9%AA%8C%E5%92%8C%E8%A1%8C%E4%B8%BA%E6%A8%A1%E5%BC%8F,%E5%AF%BC%E8%87%B4%E8%87%B3%E5%B0%91%E4%B8%A4%E4%B8%AA%E4%BB%A5%E4%B8%8B%E9%A2%86%E5%9F%9F%E7%9A%84%E5%8A%9F%E8%83%BD%E9%9A%9C%E7%A2%8D:%E8%AE%A4%E7%9F%A5%20Cognitive%E3%80%81%E6%83%85%E7%BB%AA%20Emotion%E3%80%81%E7%A4%BE%E4%BA%A4%E4%BA%92%E5%8A%A8%20Social%20Interactions%E3%80%81%E5%86%B2%E5%8A%A8%E6%80%A7%20Impulsivity%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="个体的模式与其文化中通常发现的模式明显不同" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E7%9A%84%E6%A8%A1%E5%BC%8F%E4%B8%8E%E5%85%B6%E6%96%87%E5%8C%96%E4%B8%AD%E9%80%9A%E5%B8%B8%E5%8F%91%E7%8E%B0%E7%9A%84%E6%A8%A1%E5%BC%8F%E6%98%8E%E6%98%BE%E4%B8%8D%E5%90%8C%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="个体经历显著痛苦或损害" _mubu_text="%3Cspan%3E%E4%B8%AA%E4%BD%93%E7%BB%8F%E5%8E%86%E6%98%BE%E8%91%97%E7%97%9B%E8%8B%A6%E6%88%96%E6%8D%9F%E5%AE%B3%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="人格障碍在18岁之前不被诊断,因为我们的人格在该年龄之前处于不断发展中" _mubu_text="%3Cspan%3E%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%E5%9C%A818%E5%B2%81%E4%B9%8B%E5%89%8D%E4%B8%8D%E8%A2%AB%E8%AF%8A%E6%96%AD,%E5%9B%A0%E4%B8%BA%E6%88%91%E4%BB%AC%E7%9A%84%E4%BA%BA%E6%A0%BC%E5%9C%A8%E8%AF%A5%E5%B9%B4%E9%BE%84%E4%B9%8B%E5%89%8D%E5%A4%84%E4%BA%8E%E4%B8%8D%E6%96%AD%E5%8F%91%E5%B1%95%E4%B8%AD%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="A组人格障碍 Cluster A 「怪异 Weird」" _mubu_text="%3Cspan%3EA%E7%BB%84%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Cluster%20A%20%E3%80%8C%E6%80%AA%E5%BC%82%20Weird%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="偏执型人格障碍 Paranoid Personality Disorder 多疑不安 「指责性 Accusatory」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%81%8F%E6%89%A7%E5%9E%8B%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Paranoid%20Personality%20Disorder%3C/span%3E%3Cspan%3E%20%E5%A4%9A%E7%96%91%E4%B8%8D%E5%AE%89%20%E3%80%8C%E6%8C%87%E8%B4%A3%E6%80%A7%20Accusatory%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="对他人动机的不信任和怀疑模式,个体认为他人会威胁、背叛、剥削或伤害自己" _mubu_text="%3Cspan%3E%E5%AF%B9%E4%BB%96%E4%BA%BA%E5%8A%A8%E6%9C%BA%E7%9A%84%E4%B8%8D%E4%BF%A1%E4%BB%BB%E5%92%8C%E6%80%80%E7%96%91%E6%A8%A1%E5%BC%8F,%E4%B8%AA%E4%BD%93%E8%AE%A4%E4%B8%BA%E4%BB%96%E4%BA%BA%E4%BC%9A%E5%A8%81%E8%83%81%E3%80%81%E8%83%8C%E5%8F%9B%E3%80%81%E5%89%A5%E5%89%8A%E6%88%96%E4%BC%A4%E5%AE%B3%E8%87%AA%E5%B7%B1%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="通常不向他人倾诉,经常误读他人" _mubu_text="%3Cspan%3E%E9%80%9A%E5%B8%B8%E4%B8%8D%E5%90%91%E4%BB%96%E4%BA%BA%E5%80%BE%E8%AF%89,%E7%BB%8F%E5%B8%B8%E8%AF%AF%E8%AF%BB%E4%BB%96%E4%BA%BA%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="分裂样人格障碍 Schizoid Personality Disorder 孤僻冷漠「冷漠 Aloof，Cold🤣」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%88%86%E8%A3%82%E6%A0%B7%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Schizoid%20Personality%20Disorder%3C/span%3E%3Cspan%3E%20%E5%AD%A4%E5%83%BB%E5%86%B7%E6%BC%A0%E3%80%8C%E5%86%B7%E6%BC%A0%20Aloof%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3ECold%3C/span%3E%3Cspan%3E%F0%9F%A4%A3%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="以持续回避社交关系和情绪表达很少为特征" _mubu_text="%3Cspan%3E%E4%BB%A5%E6%8C%81%E7%BB%AD%E5%9B%9E%E9%81%BF%E7%A4%BE%E4%BA%A4%E5%85%B3%E7%B3%BB%E5%92%8C%E6%83%85%E7%BB%AA%E8%A1%A8%E8%BE%BE%E5%BE%88%E5%B0%91%E4%B8%BA%E7%89%B9%E5%BE%81%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="真正喜欢独处,不努力开始或保持关系" _mubu_text="%3Cspan%3E%E7%9C%9F%E6%AD%A3%E5%96%9C%E6%AC%A2%E7%8B%AC%E5%A4%84,%E4%B8%8D%E5%8A%AA%E5%8A%9B%E5%BC%80%E5%A7%8B%E6%88%96%E4%BF%9D%E6%8C%81%E5%85%B3%E7%B3%BB%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="退缩行为,被认为&quot;冷漠&quot;(在男性中更常见)" _mubu_text="%3Cspan%3E%E9%80%80%E7%BC%A9%E8%A1%8C%E4%B8%BA,%E8%A2%AB%E8%AE%A4%E4%B8%BA%22%E5%86%B7%E6%BC%A0%22(%E5%9C%A8%E7%94%B7%E6%80%A7%E4%B8%AD%E6%9B%B4%E5%B8%B8%E8%A7%81)%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="分裂型人格障碍 Schizotypal Personality Disorder 怪异疏离「尴尬 Awkward」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%88%86%E8%A3%82%E5%9E%8B%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Schizotypal%20Personality%20Disorder%3C/span%3E%3Cspan%3E%20%E6%80%AA%E5%BC%82%E7%96%8F%E7%A6%BB%E3%80%8C%E5%B0%B4%E5%B0%AC%20Awkward%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="以非常奇怪的思维和感知模式以及行为古怪为特征" _mubu_text="%3Cspan%3E%E4%BB%A5%E9%9D%9E%E5%B8%B8%E5%A5%87%E6%80%AA%E7%9A%84%E6%80%9D%E7%BB%B4%E5%92%8C%E6%84%9F%E7%9F%A5%E6%A8%A1%E5%BC%8F%E4%BB%A5%E5%8F%8A%E8%A1%8C%E4%B8%BA%E5%8F%A4%E6%80%AA%E4%B8%BA%E7%89%B9%E5%BE%81%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="患者通常经历扭曲的思维并避免亲密关系" _mubu_text="%3Cspan%3E%E6%82%A3%E8%80%85%E9%80%9A%E5%B8%B8%E7%BB%8F%E5%8E%86%E6%89%AD%E6%9B%B2%E7%9A%84%E6%80%9D%E7%BB%B4%E5%B9%B6%E9%81%BF%E5%85%8D%E4%BA%B2%E5%AF%86%E5%85%B3%E7%B3%BB%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="B组人格障碍 Cluster B 「狂野 Wild」" _mubu_text="%3Cspan%3EB%E7%BB%84%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Cluster%20B%20%E3%80%8C%E7%8B%82%E9%87%8E%20Wild%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="反社会型人格障碍 Antisocial Personality Disorder (APD) 无视权力，冷酷虚伪" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8F%8D%E7%A4%BE%E4%BC%9A%E5%9E%8B%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Antisocial%20Personality%20Disorder%20(APD)%3C/span%3E%3Cspan%3E%20%E6%97%A0%E8%A7%86%E6%9D%83%E5%8A%9B%EF%BC%8C%E5%86%B7%E9%85%B7%E8%99%9A%E4%BC%AA%3C/span%3E" _note="" _mubu_note="">
              <outline text="以普遍无视和侵犯他人权利的模式为特征(与犯罪行为密切相关)" _mubu_text="%3Cspan%3E%E4%BB%A5%E6%99%AE%E9%81%8D%E6%97%A0%E8%A7%86%E5%92%8C%E4%BE%B5%E7%8A%AF%E4%BB%96%E4%BA%BA%E6%9D%83%E5%88%A9%E7%9A%84%E6%A8%A1%E5%BC%8F%E4%B8%BA%E7%89%B9%E5%BE%81(%E4%B8%8E%E7%8A%AF%E7%BD%AA%E8%A1%8C%E4%B8%BA%E5%AF%86%E5%88%87%E7%9B%B8%E5%85%B3)%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="曾被称为反社会者或精神病患者" _mubu_text="%3Cspan%3E%E6%9B%BE%E8%A2%AB%E7%A7%B0%E4%B8%BA%E5%8F%8D%E7%A4%BE%E4%BC%9A%E8%80%85%E6%88%96%E7%B2%BE%E7%A5%9E%E7%97%85%E6%82%A3%E8%80%85%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="无内疚地侵犯他人权利" _mubu_text="%3Cspan%3E%E6%97%A0%E5%86%85%E7%96%9A%E5%9C%B0%E4%BE%B5%E7%8A%AF%E4%BB%96%E4%BA%BA%E6%9D%83%E5%88%A9%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="操纵性、剥削性、自我放纵、不负责任(在男性中更常见)" _mubu_text="%3Cspan%3E%E6%93%8D%E7%BA%B5%E6%80%A7%E3%80%81%E5%89%A5%E5%89%8A%E6%80%A7%E3%80%81%E8%87%AA%E6%88%91%E6%94%BE%E7%BA%B5%E3%80%81%E4%B8%8D%E8%B4%9F%E8%B4%A3%E4%BB%BB(%E5%9C%A8%E7%94%B7%E6%80%A7%E4%B8%AD%E6%9B%B4%E5%B8%B8%E8%A7%81)%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="边缘型人格障碍 Borderline Personality Disorder 情绪不稳，冲动自毁" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%BE%B9%E7%BC%98%E5%9E%8B%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Borderline%20Personality%20Disorder%20%3C/span%3E%3Cspan%3E%E6%83%85%E7%BB%AA%E4%B8%8D%E7%A8%B3%EF%BC%8C%E5%86%B2%E5%8A%A8%E8%87%AA%E6%AF%81%3C/span%3E" _note="" _mubu_note="">
              <outline text="以人际关系、自我形象和情绪的反复不稳定以及冲动行为为特征" _mubu_text="%3Cspan%3E%E4%BB%A5%E4%BA%BA%E9%99%85%E5%85%B3%E7%B3%BB%E3%80%81%E8%87%AA%E6%88%91%E5%BD%A2%E8%B1%A1%E5%92%8C%E6%83%85%E7%BB%AA%E7%9A%84%E5%8F%8D%E5%A4%8D%E4%B8%8D%E7%A8%B3%E5%AE%9A%E4%BB%A5%E5%8F%8A%E5%86%B2%E5%8A%A8%E8%A1%8C%E4%B8%BA%E4%B8%BA%E7%89%B9%E5%BE%81%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="不可预测且容易感到无聊(在女性中更常见)" _mubu_text="%3Cspan%3E%E4%B8%8D%E5%8F%AF%E9%A2%84%E6%B5%8B%E4%B8%94%E5%AE%B9%E6%98%93%E6%84%9F%E5%88%B0%E6%97%A0%E8%81%8A(%E5%9C%A8%E5%A5%B3%E6%80%A7%E4%B8%AD%E6%9B%B4%E5%B8%B8%E8%A7%81)%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="总是与周围世界发生冲突,自杀威胁和行为也很常见" _mubu_text="%3Cspan%3E%E6%80%BB%E6%98%AF%E4%B8%8E%E5%91%A8%E5%9B%B4%E4%B8%96%E7%95%8C%E5%8F%91%E7%94%9F%E5%86%B2%E7%AA%81,%E8%87%AA%E6%9D%80%E5%A8%81%E8%83%81%E5%92%8C%E8%A1%8C%E4%B8%BA%E4%B9%9F%E5%BE%88%E5%B8%B8%E8%A7%81%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="表演型人格障碍 Histrionic Personality Disorder 情绪戏剧，博取关注" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A1%A8%E6%BC%94%E5%9E%8B%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Histrionic%20Personality%20Disorder%20%3C/span%3E%3Cspan%3E%E6%83%85%E7%BB%AA%E6%88%8F%E5%89%A7%EF%BC%8C%E5%8D%9A%E5%8F%96%E5%85%B3%E6%B3%A8%3C/span%3E" _note="" _mubu_note="">
              <outline text="以过度情绪化(戏剧性)和寻求注意的模式为特征" _mubu_text="%3Cspan%3E%E4%BB%A5%E8%BF%87%E5%BA%A6%E6%83%85%E7%BB%AA%E5%8C%96(%E6%88%8F%E5%89%A7%E6%80%A7)%E5%92%8C%E5%AF%BB%E6%B1%82%E6%B3%A8%E6%84%8F%E7%9A%84%E6%A8%A1%E5%BC%8F%E4%B8%BA%E7%89%B9%E5%BE%81%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="倾向于反应过度和以自我为中心(在女性中更常见)" _mubu_text="%3Cspan%3E%E5%80%BE%E5%90%91%E4%BA%8E%E5%8F%8D%E5%BA%94%E8%BF%87%E5%BA%A6%E5%92%8C%E4%BB%A5%E8%87%AA%E6%88%91%E4%B8%BA%E4%B8%AD%E5%BF%83(%E5%9C%A8%E5%A5%B3%E6%80%A7%E4%B8%AD%E6%9B%B4%E5%B8%B8%E8%A7%81)%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="夸大身体疾病、关系的深度" _mubu_text="%3Cspan%3E%E5%A4%B8%E5%A4%A7%E8%BA%AB%E4%BD%93%E7%96%BE%E7%97%85%E3%80%81%E5%85%B3%E7%B3%BB%E7%9A%84%E6%B7%B1%E5%BA%A6%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="自恋型人格障碍 Narcissistic Personality Disorder 自负傲慢，缺乏共情" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E6%81%8B%E5%9E%8B%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Narcissistic%20Personality%20Disorder%20%3C/span%3E%3Cspan%3E%E8%87%AA%E8%B4%9F%E5%82%B2%E6%85%A2%EF%BC%8C%E7%BC%BA%E4%B9%8F%E5%85%B1%E6%83%85%3C/span%3E" _note="" _mubu_note="">
              <outline text="以夸大、需要赞美和缺乏同理心的模式为特征" _mubu_text="%3Cspan%3E%E4%BB%A5%E5%A4%B8%E5%A4%A7%E3%80%81%E9%9C%80%E8%A6%81%E8%B5%9E%E7%BE%8E%E5%92%8C%E7%BC%BA%E4%B9%8F%E5%90%8C%E7%90%86%E5%BF%83%E7%9A%84%E6%A8%A1%E5%BC%8F%E4%B8%BA%E7%89%B9%E5%BE%81%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="不切实际地自我重要,操纵性,不能接受批评,期望特殊待遇(在男性中更常见)" _mubu_text="%3Cspan%3E%E4%B8%8D%E5%88%87%E5%AE%9E%E9%99%85%E5%9C%B0%E8%87%AA%E6%88%91%E9%87%8D%E8%A6%81,%E6%93%8D%E7%BA%B5%E6%80%A7,%E4%B8%8D%E8%83%BD%E6%8E%A5%E5%8F%97%E6%89%B9%E8%AF%84,%E6%9C%9F%E6%9C%9B%E7%89%B9%E6%AE%8A%E5%BE%85%E9%81%87(%E5%9C%A8%E7%94%B7%E6%80%A7%E4%B8%AD%E6%9B%B4%E5%B8%B8%E8%A7%81)%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="C组人格障碍 Cluster C 「担忧 Worried」" _mubu_text="%3Cspan%3EC%E7%BB%84%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Cluster%20C%20%E3%80%8C%E6%8B%85%E5%BF%A7%20Worried%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="回避型人格障碍 Avoidant Personality Disorder 自卑敏感，畏惧被拒" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%9B%9E%E9%81%BF%E5%9E%8B%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Avoidant%20Personality%20Disorder%20%3C/span%3E%3Cspan%3E%E8%87%AA%E5%8D%91%E6%95%8F%E6%84%9F%EF%BC%8C%E7%95%8F%E6%83%A7%E8%A2%AB%E6%8B%92%3C/span%3E" _note="" _mubu_note="">
              <outline text="以社交场合中持续的不适和克制、压倒性的不足感以及对负面评价/潜在拒绝的极度敏感为特征" _mubu_text="%3Cspan%3E%E4%BB%A5%E7%A4%BE%E4%BA%A4%E5%9C%BA%E5%90%88%E4%B8%AD%E6%8C%81%E7%BB%AD%E7%9A%84%E4%B8%8D%E9%80%82%E5%92%8C%E5%85%8B%E5%88%B6%E3%80%81%E5%8E%8B%E5%80%92%E6%80%A7%E7%9A%84%E4%B8%8D%E8%B6%B3%E6%84%9F%E4%BB%A5%E5%8F%8A%E5%AF%B9%E8%B4%9F%E9%9D%A2%E8%AF%84%E4%BB%B7/%E6%BD%9C%E5%9C%A8%E6%8B%92%E7%BB%9D%E7%9A%84%E6%9E%81%E5%BA%A6%E6%95%8F%E6%84%9F%E4%B8%BA%E7%89%B9%E5%BE%81%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="依赖型人格障碍 Dependent Personality Disorder 顺从依附，过度欠缺自主" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BE%9D%E8%B5%96%E5%9E%8B%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Dependent%20Personality%20Disorder%20%3C/span%3E%3Cspan%3E%E9%A1%BA%E4%BB%8E%E4%BE%9D%E9%99%84%EF%BC%8C%E8%BF%87%E5%BA%A6%E6%AC%A0%E7%BC%BA%E8%87%AA%E4%B8%BB%3C/span%3E" _note="" _mubu_note="">
              <outline text="以依附和服从、害怕分离以及持续需要被照顾的模式为特征" _mubu_text="%3Cspan%3E%E4%BB%A5%E4%BE%9D%E9%99%84%E5%92%8C%E6%9C%8D%E4%BB%8E%E3%80%81%E5%AE%B3%E6%80%95%E5%88%86%E7%A6%BB%E4%BB%A5%E5%8F%8A%E6%8C%81%E7%BB%AD%E9%9C%80%E8%A6%81%E8%A2%AB%E7%85%A7%E9%A1%BE%E7%9A%84%E6%A8%A1%E5%BC%8F%E4%B8%BA%E7%89%B9%E5%BE%81%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="过度缺乏自信,从属自己的需求,允许他人做出所有决定(在女性中更常见)" _mubu_text="%3Cspan%3E%E8%BF%87%E5%BA%A6%E7%BC%BA%E4%B9%8F%E8%87%AA%E4%BF%A1,%E4%BB%8E%E5%B1%9E%E8%87%AA%E5%B7%B1%E7%9A%84%E9%9C%80%E6%B1%82,%E5%85%81%E8%AE%B8%E4%BB%96%E4%BA%BA%E5%81%9A%E5%87%BA%E6%89%80%E6%9C%89%E5%86%B3%E5%AE%9A(%E5%9C%A8%E5%A5%B3%E6%80%A7%E4%B8%AD%E6%9B%B4%E5%B8%B8%E8%A7%81)%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="强迫型人格障碍 Obsessive-Compulsive Personality Disorder 执着完美，缺乏灵活性" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BC%BA%E8%BF%AB%E5%9E%8B%E4%BA%BA%E6%A0%BC%E9%9A%9C%E7%A2%8D%20Obsessive-Compulsive%20Personality%20Disorder%20%3C/span%3E%3Cspan%3E%E6%89%A7%E7%9D%80%E5%AE%8C%E7%BE%8E%EF%BC%8C%E7%BC%BA%E4%B9%8F%E7%81%B5%E6%B4%BB%E6%80%A7%3C/span%3E" _note="" _mubu_note="">
              <outline text="以强烈关注秩序、完美主义和控制为特征,以至于个体失去灵活性、开放性和效率" _mubu_text="%3Cspan%3E%E4%BB%A5%E5%BC%BA%E7%83%88%E5%85%B3%E6%B3%A8%E7%A7%A9%E5%BA%8F%E3%80%81%E5%AE%8C%E7%BE%8E%E4%B8%BB%E4%B9%89%E5%92%8C%E6%8E%A7%E5%88%B6%E4%B8%BA%E7%89%B9%E5%BE%81,%E4%BB%A5%E8%87%B3%E4%BA%8E%E4%B8%AA%E4%BD%93%E5%A4%B1%E5%8E%BB%E7%81%B5%E6%B4%BB%E6%80%A7%E3%80%81%E5%BC%80%E6%94%BE%E6%80%A7%E5%92%8C%E6%95%88%E7%8E%87%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="专注于规则、时间表、细节,极其传统" _mubu_text="%3Cspan%3E%E4%B8%93%E6%B3%A8%E4%BA%8E%E8%A7%84%E5%88%99%E3%80%81%E6%97%B6%E9%97%B4%E8%A1%A8%E3%80%81%E7%BB%86%E8%8A%82,%E6%9E%81%E5%85%B6%E4%BC%A0%E7%BB%9F%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
      </outline>
      <outline text="5.5 Treatment of Psychological Disorders" _mubu_text="%3Cspan%3E5.5%20Treatment%20of%20Psychological%20Disorders%3C/span%3E" _note="" _mubu_note="">
        <outline text="背景 Background" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%83%8C%E6%99%AF%20Background%3C/span%3E" _note="" _mubu_note="">
          <outline text="去机构化 Deinstitutionalization 20世纪后期，精神类药物进步，将非危险性患者从精神病院（asylum）转移至社区心理健康服务" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8E%BB%E6%9C%BA%E6%9E%84%E5%8C%96%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EDeinstitutionalization%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E20%E4%B8%96%E7%BA%AA%E5%90%8E%E6%9C%9F%EF%BC%8C%3C/span%3E%3Cspan%20class=%22bold%20underline%22%3E%E7%B2%BE%E7%A5%9E%E7%B1%BB%E8%8D%AF%E7%89%A9%E8%BF%9B%E6%AD%A5%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%B0%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%9D%9E%E5%8D%B1%E9%99%A9%E6%80%A7%E6%82%A3%E8%80%85%3C/span%3E%3Cspan%3E%E4%BB%8E%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%B2%BE%E7%A5%9E%E7%97%85%E9%99%A2%EF%BC%88asylum%EF%BC%89%3C/span%3E%3Cspan%3E%E8%BD%AC%E7%A7%BB%E8%87%B3%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%A4%BE%E5%8C%BA%E5%BF%83%E7%90%86%E5%81%A5%E5%BA%B7%E6%9C%8D%E5%8A%A1%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="心理治疗 Psychotherapy 心理学家或专业人士与个人/团体识别问题并制定解决方案「谈话与思考」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BF%83%E7%90%86%E6%B2%BB%E7%96%97%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EPsychotherapy%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%83%E7%90%86%E5%AD%A6%E5%AE%B6%E6%88%96%E4%B8%93%E4%B8%9A%E4%BA%BA%E5%A3%AB%3C/span%3E%3Cspan%3E%E4%B8%8E%E4%B8%AA%E4%BA%BA/%E5%9B%A2%E4%BD%93%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%AF%86%E5%88%AB%E9%97%AE%E9%A2%98%E5%B9%B6%E5%88%B6%E5%AE%9A%E8%A7%A3%E5%86%B3%E6%96%B9%E6%A1%88%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%B0%88%E8%AF%9D%E4%B8%8E%E6%80%9D%E8%80%83%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="有效性（无论流派，关注共性，如共情、来访者心态和治疗过程）" _mubu_text="%3Cspan%3E%E6%9C%89%E6%95%88%E6%80%A7%EF%BC%88%E6%97%A0%E8%AE%BA%E6%B5%81%E6%B4%BE%EF%BC%8C%E5%85%B3%E6%B3%A8%E5%85%B1%E6%80%A7%EF%BC%8C%E5%A6%82%E5%85%B1%E6%83%85%E3%80%81%E6%9D%A5%E8%AE%BF%E8%80%85%E5%BF%83%E6%80%81%E5%92%8C%E6%B2%BB%E7%96%97%E8%BF%87%E7%A8%8B%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="沟通（建好治疗联盟；保持文化谦逊）" _mubu_text="%3Cspan%3E%E6%B2%9F%E9%80%9A%EF%BC%88%E5%BB%BA%E5%A5%BD%E6%B2%BB%E7%96%97%E8%81%94%E7%9B%9F%EF%BC%9B%E4%BF%9D%E6%8C%81%E6%96%87%E5%8C%96%E8%B0%A6%E9%80%8A%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="协作（药物辅助+心理干预）" _mubu_text="%3Cspan%3E%E5%8D%8F%E4%BD%9C%EF%BC%88%E8%8D%AF%E7%89%A9%E8%BE%85%E5%8A%A9+%E5%BF%83%E7%90%86%E5%B9%B2%E9%A2%84%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="循证干预 Evidence-Based Interventions 以科学研究和实证支持的治疗方法，确保有效性与可靠性" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BE%AA%E8%AF%81%E5%B9%B2%E9%A2%84%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EEvidence-Based%20Interventions%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E4%BB%A5%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%A7%91%E5%AD%A6%E7%A0%94%E7%A9%B6%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%AE%9E%E8%AF%81%E6%94%AF%E6%8C%81%3C/span%3E%3Cspan%3E%E7%9A%84%E6%B2%BB%E7%96%97%E6%96%B9%E6%B3%95%EF%BC%8C%E7%A1%AE%E4%BF%9D%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%9C%89%E6%95%88%E6%80%A7%E4%B8%8E%E5%8F%AF%E9%9D%A0%E6%80%A7%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="APA 伦理原则 APA Ethical Principles" _mubu_text="%3Cspan%20class=%22bold%22%3EAPA%20%E4%BC%A6%E7%90%86%E5%8E%9F%E5%88%99%20APA%20Ethical%20Principles%3C/span%3E" _note="" _mubu_note="">
          <outline text="无害原则 Nonmaleficence 避免对来访者造成身体、情感或心理伤害「Do no harm」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%97%A0%E5%AE%B3%E5%8E%9F%E5%88%99%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ENonmaleficence%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E9%81%BF%E5%85%8D%E5%AF%B9%E6%9D%A5%E8%AE%BF%E8%80%85%E9%80%A0%E6%88%90%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%BA%AB%E4%BD%93%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E6%84%9F%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%83%E7%90%86%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%BC%A4%E5%AE%B3%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EDo%20no%20harm%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="忠诚 Fidelity 在治疗关系中保持信任、诚实与承诺「信守咨询契约」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BF%A0%E8%AF%9A%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EFidelity%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%B2%BB%E7%96%97%E5%85%B3%E7%B3%BB%3C/span%3E%3Cspan%3E%E4%B8%AD%E4%BF%9D%E6%8C%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%BF%A1%E4%BB%BB%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%AF%9A%E5%AE%9E%3C/span%3E%3Cspan%3E%E4%B8%8E%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%89%BF%E8%AF%BA%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%BF%A1%E5%AE%88%E5%92%A8%E8%AF%A2%E5%A5%91%E7%BA%A6%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="诚信 Integrity 在专业行为中保持诚实、透明、一致「坦诚对待咨询」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%9A%E4%BF%A1%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EIntegrity%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%93%E4%B8%9A%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%E4%B8%AD%E4%BF%9D%E6%8C%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%AF%9A%E5%AE%9E%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%80%8F%E6%98%8E%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%B8%80%E8%87%B4%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%9D%A6%E8%AF%9A%E5%AF%B9%E5%BE%85%E5%92%A8%E8%AF%A2%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="尊重权利与尊严 Respect for Rights &amp; Dignity 保护隐私、保密性与自我决定权「允许随时暂停」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B0%8A%E9%87%8D%E6%9D%83%E5%88%A9%E4%B8%8E%E5%B0%8A%E4%B8%A5%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ERespect%20for%20Rights%20&amp;amp;%20Dignity%3C/span%3E%3Cspan%3E%20%E4%BF%9D%E6%8A%A4%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%9A%90%E7%A7%81%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BF%9D%E5%AF%86%E6%80%A7%3C/span%3E%3Cspan%3E%E4%B8%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%87%AA%E6%88%91%E5%86%B3%E5%AE%9A%E6%9D%83%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%85%81%E8%AE%B8%E9%9A%8F%E6%97%B6%E6%9A%82%E5%81%9C%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="文化谦逊 Cultural Humility 持续自我反思，学习来访者的文化背景「尊重文化差异」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%96%87%E5%8C%96%E8%B0%A6%E9%80%8A%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ECultural%20Humility%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E6%8C%81%E7%BB%AD%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%87%AA%E6%88%91%E5%8F%8D%E6%80%9D%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%AD%A6%E4%B9%A0%E6%9D%A5%E8%AE%BF%E8%80%85%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%96%87%E5%8C%96%E8%83%8C%E6%99%AF%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%B0%8A%E9%87%8D%E6%96%87%E5%8C%96%E5%B7%AE%E5%BC%82%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
