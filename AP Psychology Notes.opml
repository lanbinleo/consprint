          <outline text="研究方法" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A0%94%E7%A9%B6%E6%96%B9%E6%B3%95%3C/span%3E" _note="" _mubu_note="">
            <outline text="人格量表 Personality Inventory 通过Self-Report Qs 来评估和测量人格特质「MBTI」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BA%BA%E6%A0%BC%E9%87%8F%E8%A1%A8%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EPersonality%20Inventory%3C/span%3E%3Cspan%3E%20%E9%80%9A%E8%BF%87%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3ESelf-Report%3C/span%3E%3Cspan%3E%20Qs%20%E6%9D%A5%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%AF%84%E4%BC%B0%E5%92%8C%E6%B5%8B%E9%87%8F%3C/span%3E%3Cspan%3E%E4%BA%BA%E6%A0%BC%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%89%B9%E8%B4%A8%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EMBTI%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="因素分析 Factor Analysis 用于识别数据集中相关项目的因素「大五人格来源」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%9B%A0%E7%B4%A0%E5%88%86%E6%9E%90%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EFactor%20Analysis%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E7%94%A8%E4%BA%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%AF%86%E5%88%AB%E6%95%B0%E6%8D%AE%E9%9B%86%3C/span%3E%3Cspan%3E%E4%B8%AD%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%9B%B8%E5%85%B3%3C/span%3E%3Cspan%3E%E9%A1%B9%E7%9B%AE%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%9B%A0%E7%B4%A0%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A4%A7%E4%BA%94%3C/span%3E%3Cspan%3E%E4%BA%BA%E6%A0%BC%E6%9D%A5%E6%BA%90%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="大五人格因素 Big Five Personality Factors / OCEAN" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%A4%A7%E4%BA%94%E4%BA%BA%E6%A0%BC%E5%9B%A0%E7%B4%A0%20Big%20Five%20Personality%20Factors%20/%20OCEAN%3C/span%3E" _note="" _mubu_note="">
            <outline text="开放性 Openness 强调想象力和洞察力。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BC%80%E6%94%BE%E6%80%A7%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EOpenness%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%BC%BA%E8%B0%83%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%B3%E8%B1%A1%E5%8A%9B%E5%92%8C%E6%B4%9E%E5%AF%9F%E5%8A%9B%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note="">
              <outline text="高分者好奇心强、富有创造力；低分者倾向于传统，难以进行抽象思维" _mubu_text="%3Cspan%3E%E9%AB%98%E5%88%86%E8%80%85%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%A5%BD%E5%A5%87%E5%BF%83%E5%BC%BA%3C/span%3E%3Cspan%3E%E3%80%81%E5%AF%8C%E6%9C%89%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%88%9B%E9%80%A0%E5%8A%9B%3C/span%3E%3Cspan%3E%EF%BC%9B%E4%BD%8E%E5%88%86%E8%80%85%E5%80%BE%E5%90%91%E4%BA%8E%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%BC%A0%E7%BB%9F%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%9A%BE%E4%BB%A5%E8%BF%9B%E8%A1%8C%3C/span%3E%3Cspan%3E%E6%8A%BD%E8%B1%A1%E6%80%9D%E7%BB%B4%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="「喜欢艺术和哲学 vs. 喜欢按部就班的工作」" _mubu_text="%3Cspan%3E%E3%80%8C%E5%96%9C%E6%AC%A2%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%89%BA%E6%9C%AF%E5%92%8C%E5%93%B2%E5%AD%A6%3C/span%3E%3Cspan%3E%20vs.%20%E5%96%9C%E6%AC%A2%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%8C%89%E9%83%A8%E5%B0%B1%E7%8F%AD%3C/span%3E%3Cspan%3E%E7%9A%84%E5%B7%A5%E4%BD%9C%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="尽责性 Conscientiousness 深思熟虑、良好的冲动控制和组织能力。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B0%BD%E8%B4%A3%E6%80%A7%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EConscientiousness%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%B7%B1%E6%80%9D%E7%86%9F%E8%99%91%3C/span%3E%3Cspan%3E%E3%80%81%E8%89%AF%E5%A5%BD%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%86%B2%E5%8A%A8%E6%8E%A7%E5%88%B6%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%BB%84%E7%BB%87%3C/span%3E%3Cspan%3E%E8%83%BD%E5%8A%9B%E3%80%82%3C/span%3E" _note="" _mubu_note="">
              <outline text="高分者有计划、可靠；低分者散漫、容易拖延" _mubu_text="%3Cspan%3E%E9%AB%98%E5%88%86%E8%80%85%E6%9C%89%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%AE%A1%E5%88%92%E3%80%81%E5%8F%AF%E9%9D%A0%3C/span%3E%3Cspan%3E%EF%BC%9B%E4%BD%8E%E5%88%86%E8%80%85%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%95%A3%E6%BC%AB%E3%80%81%E5%AE%B9%E6%98%93%E6%8B%96%E5%BB%B6%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="「每天列待办清单 vs. 经常忘记截止日期」" _mubu_text="%3Cspan%3E%E3%80%8C%E6%AF%8F%E5%A4%A9%E5%88%97%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BE%85%E5%8A%9E%E6%B8%85%E5%8D%95%3C/span%3E%3Cspan%3E%20vs.%20%E7%BB%8F%E5%B8%B8%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BF%98%E8%AE%B0%E6%88%AA%E6%AD%A2%E6%97%A5%E6%9C%9F%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="外向性 Extraversion 社交性、健谈和丰富的情绪表达。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%A4%96%E5%90%91%E6%80%A7%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EExtraversion%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%A4%BE%E4%BA%A4%E6%80%A7%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%81%A5%E8%B0%88%3C/span%3E%3Cspan%3E%E5%92%8C%E4%B8%B0%E5%AF%8C%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E7%BB%AA%E8%A1%A8%E8%BE%BE%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note="">
              <outline text="外向者在社交中获得能量；内向者 Introverted 较含蓄，需要独处恢复精力" _mubu_text="%3Cspan%3E%E5%A4%96%E5%90%91%E8%80%85%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%A4%BE%E4%BA%A4%E4%B8%AD%E8%8E%B7%E5%BE%97%E8%83%BD%E9%87%8F%3C/span%3E%3Cspan%3E%EF%BC%9B%E5%86%85%E5%90%91%E8%80%85%20Introverted%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%BE%83%E5%90%AB%E8%93%84%3C/span%3E%3Cspan%3E%EF%BC%8C%E9%9C%80%E8%A6%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%8B%AC%E5%A4%84%3C/span%3E%3Cspan%3E%E6%81%A2%E5%A4%8D%E7%B2%BE%E5%8A%9B%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="「参加派对感到兴奋 vs. 独处才能充电」" _mubu_text="%3Cspan%3E%E3%80%8C%E5%8F%82%E5%8A%A0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B4%BE%E5%AF%B9%3C/span%3E%3Cspan%3E%E6%84%9F%E5%88%B0%E5%85%B4%E5%A5%8B%20vs.%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%20%E7%8B%AC%E5%A4%84%E6%89%8D%E8%83%BD%E5%85%85%E7%94%B5%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="宜人性 Agreeableness 信任、利他、友善和合作等亲社会行为。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%AE%9C%E4%BA%BA%E6%80%A7%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EAgreeableness%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BF%A1%E4%BB%BB%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%88%A9%E4%BB%96%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%8F%8B%E5%96%84%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%90%88%E4%BD%9C%3C/span%3E%3Cspan%3E%E7%AD%89%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BA%B2%E7%A4%BE%E4%BC%9A%3C/span%3E%3Cspan%3E%E8%A1%8C%E4%B8%BA%E3%80%82%3C/span%3E" _note="" _mubu_note="">
              <outline text="高分者具合作精神；低分者更具竞争性或操纵性" _mubu_text="%3Cspan%3E%E9%AB%98%E5%88%86%E8%80%85%E5%85%B7%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%90%88%E4%BD%9C%E7%B2%BE%E7%A5%9E%3C/span%3E%3Cspan%3E%EF%BC%9B%E4%BD%8E%E5%88%86%E8%80%85%E6%9B%B4%E5%85%B7%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%AB%9E%E4%BA%89%E6%80%A7%E6%88%96%E6%93%8D%E7%BA%B5%E6%80%A7%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="「主动帮助同事 vs. 为达目的不择手段」" _mubu_text="%3Cspan%3E%E3%80%8C%E4%B8%BB%E5%8A%A8%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%B8%AE%E5%8A%A9%E5%90%8C%E4%BA%8B%3C/span%3E%3Cspan%3E%20vs.%20%E4%B8%BA%E8%BE%BE%E7%9B%AE%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%8D%E6%8B%A9%E6%89%8B%E6%AE%B5%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="神经质 Neuroticism 忧郁、情绪化和情绪不稳定。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%A5%9E%E7%BB%8F%E8%B4%A8%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ENeuroticism%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%A7%E9%83%81%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E7%BB%AA%E5%8C%96%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E7%BB%AA%E4%B8%8D%E7%A8%B3%E5%AE%9A%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note="">
              <outline text="高分者易焦虑和情绪波动；低分者情绪稳定且有韧性" _mubu_text="%3Cspan%3E%E9%AB%98%E5%88%86%E8%80%85%E6%98%93%E7%84%A6%E8%99%91%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%83%85%E7%BB%AA%E6%B3%A2%E5%8A%A8%3C/span%3E%3Cspan%3E%EF%BC%9B%E4%BD%8E%E5%88%86%E8%80%85%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%83%85%E7%BB%AA%E7%A8%B3%E5%AE%9A%3C/span%3E%3Cspan%3E%E4%B8%94%E6%9C%89%E9%9F%A7%E6%80%A7%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="「遇到小事就焦虑 vs. 泰山崩于前而色不变」" _mubu_text="%3Cspan%3E%E3%80%8C%E9%81%87%E5%88%B0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%B0%8F%E4%BA%8B%E5%B0%B1%E7%84%A6%E8%99%91%3C/span%3E%3Cspan%3E%20vs.%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B3%B0%E5%B1%B1%E5%B4%A9%3C/span%3E%3Cspan%3E%E4%BA%8E%E5%89%8D%E8%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%89%B2%E4%B8%8D%E5%8F%98%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
