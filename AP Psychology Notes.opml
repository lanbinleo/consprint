          </outline>
          <outline text="REM Sleep Behavior Disorder (RBD)" _mubu_text="%3Cspan%3EREM%20Sleep%20Behavior%20Disorder%20(%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3ERBD%3C/span%3E%3Cspan%3E)%3C/span%3E" _note="" _mubu_note="">
            <outline text="50岁以上的中老年男性，神经退行性疾病" _mubu_text="%3Cspan%3E50%E5%B2%81%E4%BB%A5%E4%B8%8A%E7%9A%84%E4%B8%AD%E8%80%81%E5%B9%B4%E7%94%B7%E6%80%A7%EF%BC%8C%E7%A5%9E%E7%BB%8F%E9%80%80%E8%A1%8C%E6%80%A7%E7%96%BE%E7%97%85%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="REM期真的动起来 / 梦和动作同步" _mubu_text="%3Cspan%3EREM%E6%9C%9F%E7%9C%9F%E7%9A%84%E5%8A%A8%E8%B5%B7%E6%9D%A5%20/%20%E6%A2%A6%E5%92%8C%E5%8A%A8%E4%BD%9C%E5%90%8C%E6%AD%A5%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="REM期间，常见后半夜；拳打脚踢，根据梦境内容做出反应" _mubu_text="%3Cspan%3EREM%E6%9C%9F%E9%97%B4%EF%BC%8C%E5%B8%B8%E8%A7%81%E5%90%8E%E5%8D%8A%E5%A4%9C%EF%BC%9B%E6%8B%B3%E6%89%93%E8%84%9A%E8%B8%A2%EF%BC%8C%E6%A0%B9%E6%8D%AE%E6%A2%A6%E5%A2%83%E5%86%85%E5%AE%B9%E5%81%9A%E5%87%BA%E5%8F%8D%E5%BA%94%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="正常来说，肌肉应该是麻痹的 muscles paralyzed 肌肉麻痹（防止你在梦里的动作带进现实）" _mubu_text="%3Cspan%3E%E6%AD%A3%E5%B8%B8%E6%9D%A5%E8%AF%B4%EF%BC%8C%E8%82%8C%E8%82%89%E5%BA%94%E8%AF%A5%E6%98%AF%E9%BA%BB%E7%97%B9%E7%9A%84%20%3C/span%3E%3Cspan%20class=%22node-mention%22%20id=%22nLQJQAWisM%22%20spellcheck=%22false%22%20contenteditable=%22false%22%20data-doc=%221qN74cOm072%22%20data-node=%22FEURRQKDXc%22%20data-text=%22%255B%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522muscles%2520paralyzed%2520%25E8%2582%258C%25E8%2582%2589%25E9%25BA%25BB%25E7%2597%25B9%25EF%25BC%2588%25E9%2598%25B2%25E6%25AD%25A2%25E4%25BD%25A0%25E5%259C%25A8%25E6%25A2%25A6%25E9%2587%258C%25E7%259A%2584%25E5%258A%25A8%25E4%25BD%259C%25E5%25B8%25A6%25E8%25BF%259B%25E7%258E%25B0%25E5%25AE%259E%25EF%25BC%2589%2522%252C%2522style%2522%253A%257B%257D%257D%255D%22%3E%3Cspan%3Emuscles%20paralyzed%20%E8%82%8C%E8%82%89%E9%BA%BB%E7%97%B9%EF%BC%88%E9%98%B2%E6%AD%A2%E4%BD%A0%E5%9C%A8%E6%A2%A6%E9%87%8C%E7%9A%84%E5%8A%A8%E4%BD%9C%E5%B8%A6%E8%BF%9B%E7%8E%B0%E5%AE%9E%EF%BC%89%3C/span%3E%3C/span%3E%3Cspan%3E%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="容易被唤醒，醒来后，患者迅速恢复意识，并且能清楚描述那个梦境" _mubu_text="%3Cspan%3E%E5%AE%B9%E6%98%93%E8%A2%AB%E5%94%A4%E9%86%92%EF%BC%8C%E9%86%92%E6%9D%A5%E5%90%8E%EF%BC%8C%E6%82%A3%E8%80%85%E8%BF%85%E9%80%9F%E6%81%A2%E5%A4%8D%E6%84%8F%E8%AF%86%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%B9%B6%E4%B8%94%E8%83%BD%E6%B8%85%E6%A5%9A%E6%8F%8F%E8%BF%B0%E9%82%A3%E4%B8%AA%E6%A2%A6%E5%A2%83%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Somnambulism 梦游" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ESomnambulism%20%3C/span%3E%3Cspan%3E%E6%A2%A6%E6%B8%B8%3C/span%3E" _note="" _mubu_note="">
            <outline text="青少年和儿童，大脑尚未发育完全（压力过大，睡眠不足，遗传。良性）" _mubu_text="%3Cspan%3E%E9%9D%92%E5%B0%91%E5%B9%B4%E5%92%8C%E5%84%BF%E7%AB%A5%EF%BC%8C%E5%A4%A7%E8%84%91%E5%B0%9A%E6%9C%AA%E5%8F%91%E8%82%B2%E5%AE%8C%E5%85%A8%EF%BC%88%E5%8E%8B%E5%8A%9B%E8%BF%87%E5%A4%A7%EF%BC%8C%E7%9D%A1%E7%9C%A0%E4%B8%8D%E8%B6%B3%EF%BC%8C%E9%81%97%E4%BC%A0%E3%80%82%E8%89%AF%E6%80%A7%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="场景相对简单重复，比如起床行走、穿衣服、甚至去厨房找吃的" _mubu_text="%3Cspan%3E%E5%9C%BA%E6%99%AF%E7%9B%B8%E5%AF%B9%E7%AE%80%E5%8D%95%E9%87%8D%E5%A4%8D%EF%BC%8C%E6%AF%94%E5%A6%82%E8%B5%B7%E5%BA%8A%E8%A1%8C%E8%B5%B0%E3%80%81%E7%A9%BF%E8%A1%A3%E6%9C%8D%E3%80%81%E7%94%9A%E8%87%B3%E5%8E%BB%E5%8E%A8%E6%88%BF%E6%89%BE%E5%90%83%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="双眼睁着，但是眼神空洞" _mubu_text="%3Cspan%3E%E5%8F%8C%E7%9C%BC%E7%9D%81%E7%9D%80%EF%BC%8C%E4%BD%86%E6%98%AF%E7%9C%BC%E7%A5%9E%E7%A9%BA%E6%B4%9E%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="可能根本没做梦 / 很难被叫醒，不知道自己刚刚干了什么" _mubu_text="%3Cspan%3E%E5%8F%AF%E8%83%BD%E6%A0%B9%E6%9C%AC%E6%B2%A1%E5%81%9A%E6%A2%A6%20/%20%E5%BE%88%E9%9A%BE%E8%A2%AB%E5%8F%AB%E9%86%92%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%8D%E7%9F%A5%E9%81%93%E8%87%AA%E5%B7%B1%E5%88%9A%E5%88%9A%E5%B9%B2%E4%BA%86%E4%BB%80%E4%B9%88%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
      </outline>
      <outline text="1.6 感知 Sensation（视、听、触、化学、体感，1200字）" _mubu_text="%3Cspan%3E1.6%20%E6%84%9F%E7%9F%A5%20Sensation%EF%BC%88%E8%A7%86%E3%80%81%E5%90%AC%E3%80%81%E8%A7%A6%E3%80%81%E5%8C%96%E5%AD%A6%E3%80%81%E4%BD%93%E6%84%9F%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E1200%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="Sensation vs. Perception" _mubu_text="%3Cspan%3ESensation%20vs.%20Perception%3C/span%3E" _note="" _mubu_note="">
          <outline text="Sensation 感觉" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ESensation%20%3C/span%3E%3Cspan%3E%E6%84%9F%E8%A7%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="detection / encoding / physical energy" _mubu_text="%3Cspan%3Edetection%20/%20encoding%20/%20physical%20energy%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="没有理解，就是感受" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E6%B2%A1%E6%9C%89%E7%90%86%E8%A7%A3%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%B0%B1%E6%98%AF%E6%84%9F%E5%8F%97%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Perception 直觉" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EPerception%20%3C/span%3E%3Cspan%3E%E7%9B%B4%E8%A7%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="Meaning-making" _mubu_text="%3Cspan%3EMeaning-making%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="对感觉到的信息进行 解释和组织" _mubu_text="%3Cspan%3E%E5%AF%B9%E6%84%9F%E8%A7%89%E5%88%B0%E7%9A%84%E4%BF%A1%E6%81%AF%E8%BF%9B%E8%A1%8C%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A7%A3%E9%87%8A%E5%92%8C%E7%BB%84%E7%BB%87%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Transduction 换能" _mubu_text="%3Cspan%20class=%22underline%22%3ETransduction%3C/span%3E%3Cspan%3E%20%E6%8D%A2%E8%83%BD%3C/span%3E" _note="" _mubu_note="">
            <outline text="从 physical or chemical energy 到 electrochemical 的 neural impulses 的过程，换而言之，从物理信号到生理信号" _mubu_text="%3Cspan%3E%E4%BB%8E%20physical%20or%20chemical%20energy%20%E5%88%B0%20electrochemical%20%E7%9A%84%20neural%20impulses%20%E7%9A%84%E8%BF%87%E7%A8%8B%EF%BC%8C%E6%8D%A2%E8%80%8C%E8%A8%80%E4%B9%8B%EF%BC%8C%E4%BB%8E%E7%89%A9%E7%90%86%E4%BF%A1%E5%8F%B7%E5%88%B0%E7%94%9F%E7%90%86%E4%BF%A1%E5%8F%B7%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="光波 / 声波 / 化学气味分子 -&gt; 感受器 -&gt; nervous impulses -&gt; brain" _mubu_text="%3Cspan%3E%E5%85%89%E6%B3%A2%20/%20%E5%A3%B0%E6%B3%A2%20/%20%E5%8C%96%E5%AD%A6%E6%B0%94%E5%91%B3%E5%88%86%E5%AD%90%20-&amp;gt;%20%E6%84%9F%E5%8F%97%E5%99%A8%20-&amp;gt;%20nervous%20impulses%20-&amp;gt;%20brain%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Sensory Interaction &amp; Adaptation 感官交互和适应" _mubu_text="%3Cspan%3ESensory%20Interaction%20&amp;amp;%20Adaptation%20%E6%84%9F%E5%AE%98%E4%BA%A4%E4%BA%92%E5%92%8C%E9%80%82%E5%BA%94%3C/span%3E" _note="" _mubu_note="">
            <outline text="1. Sensory Interaction 感官互动" _mubu_text="%3Cspan%3E1.%20Sensory%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EInteraction%20%3C/span%3E%3Cspan%3E%E6%84%9F%E5%AE%98%E4%BA%92%E5%8A%A8%3C/span%3E" _note="" _mubu_note="">
              <outline text="感觉不是独立工作的，一个会影响另一个" _mubu_text="%3Cspan%3E%E6%84%9F%E8%A7%89%E4%B8%8D%E6%98%AF%E7%8B%AC%E7%AB%8B%E5%B7%A5%E4%BD%9C%E7%9A%84%EF%BC%8C%E4%B8%80%E4%B8%AA%E4%BC%9A%E5%BD%B1%E5%93%8D%E5%8F%A6%E4%B8%80%E4%B8%AA%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="味觉+嗅觉 - 鼻子堵了会导致食物变淡" _mubu_text="%3Cspan%3E%E5%91%B3%E8%A7%89+%E5%97%85%E8%A7%89%20-%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%BC%BB%E5%AD%90%E5%A0%B5%E4%BA%86%E4%BC%9A%E5%AF%BC%E8%87%B4%E9%A3%9F%E7%89%A9%E5%8F%98%E6%B7%A1%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="2. Synesthesia 联觉" _mubu_text="%3Cspan%3E2.%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3ESynesthesia%20%3C/span%3E%3Cspan%3E%E8%81%94%E8%A7%89%3C/span%3E" _note="" _mubu_note="">
              <outline text="一种刺激，同时引发多种感觉" _mubu_text="%3Cspan%3E%E4%B8%80%E7%A7%8D%E5%88%BA%E6%BF%80%EF%BC%8C%E5%90%8C%E6%97%B6%E5%BC%95%E5%8F%91%E5%A4%9A%E7%A7%8D%E6%84%9F%E8%A7%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="听到声音看到颜色" _mubu_text="%3Cspan%3E%E5%90%AC%E5%88%B0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A3%B0%E9%9F%B3%E7%9C%8B%E5%88%B0%E9%A2%9C%E8%89%B2%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="不是错觉，也不是想象" _mubu_text="%3Cspan%3E%E4%B8%8D%E6%98%AF%E9%94%99%E8%A7%89%EF%BC%8C%E4%B9%9F%E4%B8%8D%E6%98%AF%E6%83%B3%E8%B1%A1%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="3. Sensory Adaptation 感官适应" _mubu_text="%3Cspan%3E3.%20Sensory%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EAdaptation%20%3C/span%3E%3Cspan%3E%E6%84%9F%E5%AE%98%E9%80%82%E5%BA%94%3C/span%3E" _note="" _mubu_note="">
              <outline text="在多次刺激之后，忽略恒定刺激" _mubu_text="%3Cspan%3E%E5%9C%A8%E5%A4%9A%E6%AC%A1%E5%88%BA%E6%BF%80%E4%B9%8B%E5%90%8E%EF%BC%8C%E5%BF%BD%E7%95%A5%E6%81%92%E5%AE%9A%E5%88%BA%E6%BF%80%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Habituation 习惯化，对于重复出现的无关紧要的刺激逐渐降低反应；不是Sensory Adaptation！SA是生理层面的，HB是CNS层面的「学会忽略」Habituation 习惯化，对于重复出现的无关紧要的刺激逐渐降低反应；不是Sensory Adaptation！SA是生理层面的，HB是CNS层面的「学会忽略」" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EHabituation%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%B9%A0%E6%83%AF%E5%8C%96%EF%BC%8C%E5%AF%B9%E4%BA%8E%E9%87%8D%E5%A4%8D%E5%87%BA%E7%8E%B0%E7%9A%84%E6%97%A0%E5%85%B3%E7%B4%A7%E8%A6%81%E7%9A%84%E5%88%BA%E6%BF%80%E9%80%90%E6%B8%90%E9%99%8D%E4%BD%8E%E5%8F%8D%E5%BA%94%EF%BC%9B%E4%B8%8D%E6%98%AF%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ESensory%20Adaptation%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%81SA%E6%98%AF%E7%94%9F%E7%90%86%E5%B1%82%E9%9D%A2%E7%9A%84%EF%BC%8CHB%E6%98%AFCNS%E5%B1%82%E9%9D%A2%E7%9A%84%E3%80%8C%E5%AD%A6%E4%BC%9A%E5%BF%BD%E7%95%A5%E3%80%8D%3C/span%3E%3Cspan%20class=%22bold%20node-mention%22%20id=%22LCXQ3t0WtI%22%20spellcheck=%22false%22%20contenteditable=%22false%22%20data-doc=%221qN74cOm072%22%20data-node=%22FXWnIjueNF%22%20data-text=%22%255B%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Habituation%2520%25E4%25B9%25A0%25E6%2583%25AF%25E5%258C%2596%25EF%25BC%258C%25E5%25AF%25B9%25E4%25BA%258E%25E9%2587%258D%25E5%25A4%258D%25E5%2587%25BA%25E7%258E%25B0%25E7%259A%2584%25E6%2597%25A0%25E5%2585%25B3%25E7%25B4%25A7%25E8%25A6%2581%25E7%259A%2584%25E5%2588%25BA%25E6%25BF%2580%25E9%2580%2590%25E6%25B8%2590%25E9%2599%258D%25E4%25BD%258E%25E5%258F%258D%25E5%25BA%2594%25EF%25BC%259B%2522%252C%2522style%2522%253A%257B%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522%25E4%25B8%258D%25E6%2598%25AFSensory%2520Adaptation%25EF%25BC%2581%2522%252C%2522style%2522%253A%257B%2522bold%2522%253Atrue%252C%2522color%2522%253A%2522%2523dc2d1e%2522%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522SA%25E6%2598%25AF%25E7%2594%259F%25E7%2590%2586%25E5%25B1%2582%25E9%259D%25A2%25E7%259A%2584%25EF%25BC%258CHB%25E6%2598%25AFCNS%25E5%25B1%2582%25E9%259D%25A2%25E7%259A%2584%25E3%2580%258C%25E5%25AD%25A6%25E4%25BC%259A%25E5%25BF%25BD%25E7%2595%25A5%25E3%2580%258D%2522%252C%2522style%2522%253A%257B%257D%257D%255D%22%3E%3Cspan%3EHabituation%20%E4%B9%A0%E6%83%AF%E5%8C%96%EF%BC%8C%E5%AF%B9%E4%BA%8E%E9%87%8D%E5%A4%8D%E5%87%BA%E7%8E%B0%E7%9A%84%E6%97%A0%E5%85%B3%E7%B4%A7%E8%A6%81%E7%9A%84%E5%88%BA%E6%BF%80%E9%80%90%E6%B8%90%E9%99%8D%E4%BD%8E%E5%8F%8D%E5%BA%94%EF%BC%9B%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E4%B8%8D%E6%98%AFSensory%20Adaptation%EF%BC%81%3C/span%3E%3Cspan%3ESA%E6%98%AF%E7%94%9F%E7%90%86%E5%B1%82%E9%9D%A2%E7%9A%84%EF%BC%8CHB%E6%98%AFCNS%E5%B1%82%E9%9D%A2%E7%9A%84%E3%80%8C%E5%AD%A6%E4%BC%9A%E5%BF%BD%E7%95%A5%E3%80%8D%3C/span%3E%3C/span%3E%3Cspan%3E%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="香水店闻久了没味 / 衣服穿久了没感觉" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E9%A6%99%E6%B0%B4%E5%BA%97%3C/span%3E%3Cspan%3E%E9%97%BB%E4%B9%85%E4%BA%86%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B2%A1%E5%91%B3%3C/span%3E%3Cspan%3E%20/%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%A1%A3%E6%9C%8D%E7%A9%BF%E4%B9%85%E4%BA%86%E6%B2%A1%E6%84%9F%E8%A7%89%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="Threshold" _mubu_text="%3Cspan%3EThreshold%3C/span%3E" _note="" _mubu_note="">
          <outline text="Absolute Threshold（绝对阈限）" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EAbsolute%20%3C/span%3E%3Cspan%3EThreshold%EF%BC%88%E7%BB%9D%E5%AF%B9%E9%98%88%E9%99%90%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="在50%的时间内可以感受到的最小刺激" _mubu_text="%3Cspan%3E%E5%9C%A850%25%E7%9A%84%E6%97%B6%E9%97%B4%E5%86%85%E5%8F%AF%E4%BB%A5%E6%84%9F%E5%8F%97%E5%88%B0%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9C%80%E5%B0%8F%E5%88%BA%E6%BF%80%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="能不能感觉到" _mubu_text="%3Cspan%3E%E8%83%BD%E4%B8%8D%E8%83%BD%E6%84%9F%E8%A7%89%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E5%88%B0%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Just Noticeable Difference (JND / Difference Threshold）" _mubu_text="%3Cspan%3EJust%20Noticeable%20Difference%20(%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EJND%3C/span%3E%3Cspan%3E%20/%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EDifference%20%3C/span%3E%3Cspan%3EThreshold%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="在50%的时间内可以区分的最小的2个不同的刺激" _mubu_text="%3Cspan%3E%E5%9C%A850%25%E7%9A%84%E6%97%B6%E9%97%B4%E5%86%85%E5%8F%AF%E4%BB%A5%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%8C%BA%E5%88%86%E7%9A%84%E6%9C%80%E5%B0%8F%E7%9A%842%E4%B8%AA%E4%B8%8D%E5%90%8C%3C/span%3E%3Cspan%3E%E7%9A%84%E5%88%BA%E6%BF%80%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="“这两个哪个更重呀”" _mubu_text="%3Cspan%3E%E2%80%9C%E8%BF%99%E4%B8%A4%E4%B8%AA%E5%93%AA%E4%B8%AA%E6%9B%B4%E9%87%8D%E5%91%80%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="能不能感觉到变化" _mubu_text="%3Cspan%3E%E8%83%BD%E4%B8%8D%E8%83%BD%E6%84%9F%E8%A7%89%E5%88%B0%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E5%8F%98%E5%8C%96%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Weber&apos;s Law" _mubu_text="%3Cspan%3EWeber&apos;s%20Law%3C/span%3E" _note="" _mubu_note="">
            <outline text="刺激越大，需要的变化也越大" _mubu_text="%3Cspan%3E%E5%88%BA%E6%BF%80%E8%B6%8A%E5%A4%A7%EF%BC%8C%E9%9C%80%E8%A6%81%E7%9A%84%E5%8F%98%E5%8C%96%E4%B9%9F%E8%B6%8A%E5%A4%A7%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="如果你手里拿着一块 100 克的巧克力，再给你加 2 克，你可能就能感觉到变重了。但如果你手里拿的是 1000 克的哑铃，再加 2 克，你完全感觉不到变化；你可能需要增加 20 克才能察觉到差异。" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E4%BD%A0%E6%89%8B%E9%87%8C%E6%8B%BF%E7%9D%80%E4%B8%80%E5%9D%97%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E100%20%E5%85%8B%E7%9A%84%E5%B7%A7%E5%85%8B%E5%8A%9B%EF%BC%8C%E5%86%8D%E7%BB%99%E4%BD%A0%E5%8A%A0%202%20%E5%85%8B%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BD%A0%E5%8F%AF%E8%83%BD%E5%B0%B1%E8%83%BD%E6%84%9F%E8%A7%89%E5%88%B0%E5%8F%98%E9%87%8D%E4%BA%86%E3%80%82%E4%BD%86%E5%A6%82%E6%9E%9C%E4%BD%A0%E6%89%8B%E9%87%8C%E6%8B%BF%E7%9A%84%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%201000%20%E5%85%8B%E7%9A%84%E5%93%91%E9%93%83%EF%BC%8C%E5%86%8D%E5%8A%A0%202%20%E5%85%8B%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BD%A0%E5%AE%8C%E5%85%A8%E6%84%9F%E8%A7%89%E4%B8%8D%E5%88%B0%E5%8F%98%E5%8C%96%EF%BC%9B%E4%BD%A0%E5%8F%AF%E8%83%BD%E9%9C%80%E8%A6%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A2%9E%E5%8A%A0%2020%20%E5%85%8B%3C/span%3E%3Cspan%3E%E6%89%8D%E8%83%BD%E5%AF%9F%E8%A7%89%E5%88%B0%E5%B7%AE%E5%BC%82%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Vision 视觉" _mubu_text="%3Cspan%3EVision%20%E8%A7%86%E8%A7%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="dominant sense 主要的sense，大量脑区负责视觉处理" _mubu_text="%3Cspan%3Edominant%20sense%20%E4%B8%BB%E8%A6%81%E7%9A%84sense%EF%BC%8C%E5%A4%A7%E9%87%8F%E8%84%91%E5%8C%BA%E8%B4%9F%E8%B4%A3%E8%A7%86%E8%A7%89%E5%A4%84%E7%90%86%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Two Dimension" _mubu_text="%3Cspan%3ETwo%20Dimension%3C/span%3E" _note="" _mubu_note="">
            <outline text="Wavelength: Hue 波长决定颜色" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EWavelength%3C/span%3E%3Cspan%3E:%20Hue%20%E6%B3%A2%E9%95%BF%E5%86%B3%E5%AE%9A%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%A2%9C%E8%89%B2%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Amplitude: Brightness 振幅决定亮度" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EAmplitude%3C/span%3E%3Cspan%3E:%20Brightness%20%E6%8C%AF%E5%B9%85%E5%86%B3%E5%AE%9A%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%BA%AE%E5%BA%A6%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Eye Anatomy 眼球结构 &amp; " _mubu_text="%3Cspan%3EEye%20Anatomy%20%E7%9C%BC%E7%90%83%E7%BB%93%E6%9E%84%20&amp;amp;%20%3C/span%3E" _note="" _mubu_note="">
            <outline text="图" _mubu_text="%3Cspan%3E%E5%9B%BE%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22aAThKWcch6%22%2C%22oh%22%3A689%2C%22ow%22%3A1360%2C%22uri%22%3A%22document_image%2F33585682_f20789af-149c-41e7-ae1f-330d4e4de503.png%22%2C%22w%22%3A400%7D%5D"/>
            <outline text="1. Lens 晶状体" _mubu_text="%3Cspan%3E1.%20Lens%20%E6%99%B6%E7%8A%B6%E4%BD%93%3C/span%3E" _note="" _mubu_note="">
              <outline text="调节焦距" _mubu_text="%3Cspan%3E%E8%B0%83%E8%8A%82%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%84%A6%E8%B7%9D%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Nearsightedness 近视：成像在视网膜前" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ENearsightedness%20%3C/span%3E%3Cspan%3E%E8%BF%91%E8%A7%86%EF%BC%9A%E6%88%90%E5%83%8F%E5%9C%A8%E8%A7%86%E7%BD%91%E8%86%9C%E5%89%8D%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Farsightedness 远视：成像在视网膜后" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EFarsightedness%20%3C/span%3E%3Cspan%3E%E8%BF%9C%E8%A7%86%EF%BC%9A%E6%88%90%E5%83%8F%E5%9C%A8%E8%A7%86%E7%BD%91%E8%86%9C%E5%90%8E%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="2. Retina 视网膜" _mubu_text="%3Cspan%3E2.%20Retina%20%E8%A7%86%E7%BD%91%E8%86%9C%3C/span%3E" _note="" _mubu_note="">
              <outline text="Transduction 发生的地方 Transduction 换能" _mubu_text="%3Cspan%3ETransduction%20%E5%8F%91%E7%94%9F%E7%9A%84%E5%9C%B0%E6%96%B9%20%3C/span%3E%3Cspan%20class=%22node-mention%22%20id=%225Rhr8zLwXc%22%20spellcheck=%22false%22%20contenteditable=%22false%22%20data-doc=%221qN74cOm072%22%20data-node=%22tcneQmFyrz%22%20data-text=%22%255B%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Transduction%2522%252C%2522style%2522%253A%257B%2522underline%2522%253Atrue%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522%2520%25E6%258D%25A2%25E8%2583%25BD%2522%252C%2522style%2522%253A%257B%257D%257D%255D%22%3E%3Cspan%20class=%22underline%22%3ETransduction%3C/span%3E%3Cspan%3E%20%E6%8D%A2%E8%83%BD%3C/span%3E%3C/span%3E%3Cspan%3E%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="把光能变成神经信号" _mubu_text="%3Cspan%3E%E6%8A%8A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%85%89%E8%83%BD%E5%8F%98%E6%88%90%E7%A5%9E%E7%BB%8F%E4%BF%A1%E5%8F%B7%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="图像是倒立的" _mubu_text="%3Cspan%3E%E5%9B%BE%E5%83%8F%E6%98%AF%E5%80%92%E7%AB%8B%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="3. Photoreceptors" _mubu_text="%3Cspan%3E3.%20Photoreceptors%3C/span%3E" _note="" _mubu_note="">
              <outline text="图" _mubu_text="%3Cspan%3E%E5%9B%BE%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%222n2sLub81w%22%2C%22oh%22%3A480%2C%22ow%22%3A579%2C%22uri%22%3A%22document_image%2F33585682_6c83cf0e-46cb-4df7-9834-f7124f270b14.png%22%2C%22w%22%3A299%7D%5D"/>
              <outline text="Rods 杆体细胞" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ERods%20%3C/span%3E%3Cspan%3E%E6%9D%86%E4%BD%93%E7%BB%86%E8%83%9E%3C/span%3E" _note="" _mubu_note="">
                <outline text="低光环境，黑白，周边视觉，数量多" _mubu_text="%3Cspan%3E%E4%BD%8E%E5%85%89%E7%8E%AF%E5%A2%83%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%BB%91%E7%99%BD%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%91%A8%E8%BE%B9%E8%A7%86%E8%A7%89%EF%BC%8C%E6%95%B0%E9%87%8F%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%9A%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="Fovea 没有 rods" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EFovea%20%E6%B2%A1%E6%9C%89%20rods%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="Cones 锥体细胞" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ECones%3C/span%3E%3Cspan%3E%20%E9%94%A5%E4%BD%93%E7%BB%86%E8%83%9E%3C/span%3E" _note="" _mubu_note="">
                <outline text="颜色，细节，强光下，数量少" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E9%A2%9C%E8%89%B2%EF%BC%8C%E7%BB%86%E8%8A%82%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%BC%BA%E5%85%89%E4%B8%8B%EF%BC%8C%E6%95%B0%E9%87%8F%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%B0%91%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="集中在Fovea" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E9%9B%86%E4%B8%AD%E5%9C%A8Fovea%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="4. Fovea 中央凹" _mubu_text="%3Cspan%3E4.%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3EFovea%20%3C/span%3E%3Cspan%3E%E4%B8%AD%E5%A4%AE%E5%87%B9%3C/span%3E" _note="" _mubu_note="">
              <outline text="最清晰的中央视觉，高密度cones，没有rods" _mubu_text="%3Cspan%3E%E6%9C%80%E6%B8%85%E6%99%B0%E7%9A%84%E4%B8%AD%E5%A4%AE%E8%A7%86%E8%A7%89%EF%BC%8C%E9%AB%98%E5%AF%86%E5%BA%A6%3C/span%3E%3Cspan%20class=%22text-color-red%22%3Econes%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%B2%A1%E6%9C%89%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3Erods%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="图" _mubu_text="%3Cspan%3E%E5%9B%BE%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22Z6xCVk1jrB%22%2C%22oh%22%3A633%2C%22ow%22%3A618%2C%22uri%22%3A%22document_image%2F33585682_0f7b5421-3ad8-4dec-931e-c13bb2f6dc36.png%22%2C%22w%22%3A214%7D%5D"/>
            </outline>
            <outline text="5. Blind Spot" _mubu_text="%3Cspan%3E5.%20Blind%20Spot%3C/span%3E" _note="" _mubu_note="">
              <outline text="optic nerve 离开眼球的位置" _mubu_text="%3Cspan%3Eoptic%20nerve%20%E7%A6%BB%E5%BC%80%E7%9C%BC%E7%90%83%E7%9A%84%E4%BD%8D%E7%BD%AE%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="没有感光细胞，大脑会自动补全" _mubu_text="%3Cspan%3E%E6%B2%A1%E6%9C%89%E6%84%9F%E5%85%89%E7%BB%86%E8%83%9E%EF%BC%8C%E5%A4%A7%E8%84%91%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BC%9A%E8%87%AA%E5%8A%A8%E8%A1%A5%E5%85%A8%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="Color Vision Theories（视觉理论，为什么我们看见颜色）" _mubu_text="%3Cspan%3EColor%20Vision%20Theories%EF%BC%88%E8%A7%86%E8%A7%89%E7%90%86%E8%AE%BA%EF%BC%8C%E4%B8%BA%E4%BB%80%E4%B9%88%E6%88%91%E4%BB%AC%E7%9C%8B%E8%A7%81%E9%A2%9C%E8%89%B2%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="1. Trichromatic 三原色理论" _mubu_text="%3Cspan%3E1.%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3ETrichromatic%20%3C/span%3E%3Cspan%3E%E4%B8%89%E5%8E%9F%E8%89%B2%E7%90%86%E8%AE%BA%3C/span%3E" _note="" _mubu_note="">
              <outline text="红绿蓝（光学三原色），有三种视锥细胞" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E7%BA%A2%E7%BB%BF%E8%93%9D%3C/span%3E%3Cspan%3E%EF%BC%88%E5%85%89%E5%AD%A6%E4%B8%89%E5%8E%9F%E8%89%B2%EF%BC%89%EF%BC%8C%E6%9C%89%E4%B8%89%E7%A7%8D%E8%A7%86%E9%94%A5%E7%BB%86%E8%83%9E%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="2. Opponent-Process Theory" _mubu_text="%3Cspan%3E2.%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3EOpponent-Process%3C/span%3E%3Cspan%3E%20Theory%3C/span%3E" _note="" _mubu_note="">
              <outline text="有三组补色系统，blue-yellow, red-green, black-white" _mubu_text="%3Cspan%3E%E6%9C%89%E4%B8%89%E7%BB%84%E8%A1%A5%E8%89%B2%E7%B3%BB%E7%BB%9F%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Eblue-yellow,%20red-green,%20black-white%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="解释了 afterimage 产生的原因" _mubu_text="%3Cspan%3E%E8%A7%A3%E9%87%8A%E4%BA%86%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3Eafterimage%20%3C/span%3E%3Cspan%3E%E4%BA%A7%E7%94%9F%E7%9A%84%E5%8E%9F%E5%9B%A0%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="特殊情况" _mubu_text="%3Cspan%3E%E7%89%B9%E6%AE%8A%E6%83%85%E5%86%B5%3C/span%3E" _note="" _mubu_note="">
            <outline text="Color-Deficient Vision 色觉缺失" _mubu_text="%3Cspan%3EColor-%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EDeficient%20%3C/span%3E%3Cspan%3EVision%20%E8%89%B2%E8%A7%89%E7%BC%BA%E5%A4%B1%3C/span%3E" _note="" _mubu_note="">
              <outline text="Monochromatism 完全色盲，只有rods" _mubu_text="%3Cspan%3EMonochromatism%20%E5%AE%8C%E5%85%A8%E8%89%B2%E7%9B%B2%EF%BC%8C%E5%8F%AA%E6%9C%89rods%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Dichromatism 缺失一种cone" _mubu_text="%3Cspan%3EDichromatism%20%E7%BC%BA%E5%A4%B1%E4%B8%80%E7%A7%8Dcone%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Prosopagnosia 脸盲" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EProsopagnosia%20%3C/span%3E%3Cspan%3E%E8%84%B8%E7%9B%B2%3C/span%3E" _note="" _mubu_note="">
              <outline text="无法识别人脸" _mubu_text="%3Cspan%3E%E6%97%A0%E6%B3%95%E8%AF%86%E5%88%AB%E4%BA%BA%E8%84%B8%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="与 fusiform gyrus（花状回，一个脑部结构）有关" _mubu_text="%3Cspan%3E%E4%B8%8E%20fusiform%20gyrus%EF%BC%88%E8%8A%B1%E7%8A%B6%E5%9B%9E%EF%BC%8C%E4%B8%80%E4%B8%AA%E8%84%91%E9%83%A8%E7%BB%93%E6%9E%84%EF%BC%89%E6%9C%89%E5%85%B3%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Blindsight 盲视" _mubu_text="%3Cspan%3EBlindsight%20%E7%9B%B2%E8%A7%86%3C/span%3E" _note="" _mubu_note="">
              <outline text="occipital cortex 受损 Occipital Lobe 枕叶（后，Optic Nerve直接连到后面）" _mubu_text="%3Cspan%3Eoccipital%20cortex%20%E5%8F%97%E6%8D%9F%20%3C/span%3E%3Cspan%20class=%22node-mention%22%20id=%225OOMaVQq4e%22%20spellcheck=%22false%22%20contenteditable=%22false%22%20data-doc=%221qN74cOm072%22%20data-node=%228hmmBhiMLi%22%20data-text=%22%255B%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Occipital%2520%2522%252C%2522style%2522%253A%257B%2522color%2522%253A%2522%2523ffaf38%2522%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Lobe%2520%25E6%259E%2595%25E5%258F%25B6%2522%252C%2522style%2522%253A%257B%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522%25EF%25BC%2588%25E5%2590%258E%25EF%25BC%258COptic%2520Nerve%25E7%259B%25B4%25E6%258E%25A5%25E8%25BF%259E%25E5%2588%25B0%25E5%2590%258E%25E9%259D%25A2%25EF%25BC%2589%2522%252C%2522style%2522%253A%257B%2522color%2522%253A%2522%2523797ec9%2522%257D%257D%255D%22%3E%3Cspan%20class=%22text-color-yellow%22%3EOccipital%20%3C/span%3E%3Cspan%3ELobe%20%E6%9E%95%E5%8F%B6%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%EF%BC%88%E5%90%8E%EF%BC%8COptic%20Nerve%E7%9B%B4%E6%8E%A5%E8%BF%9E%E5%88%B0%E5%90%8E%E9%9D%A2%EF%BC%89%3C/span%3E%3C/span%3E%3Cspan%3E%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="没有意识视觉 但是能感知运动或者位置" _mubu_text="%3Cspan%3E%E6%B2%A1%E6%9C%89%E6%84%8F%E8%AF%86%E8%A7%86%E8%A7%89%20%E4%BD%86%E6%98%AF%E8%83%BD%E6%84%9F%E7%9F%A5%E8%BF%90%E5%8A%A8%E6%88%96%E8%80%85%E4%BD%8D%E7%BD%AE%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="Audition 听觉" _mubu_text="%3Cspan%3EAudition%20%E5%90%AC%E8%A7%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="耳朵处理sound waves的过程" _mubu_text="%3Cspan%3E%E8%80%B3%E6%9C%B5%E5%A4%84%E7%90%86sound%20waves%E7%9A%84%E8%BF%87%E7%A8%8B%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Two Dimensions" _mubu_text="%3Cspan%3ETwo%20Dimensions%3C/span%3E" _note="" _mubu_note="">
            <outline text="Amplitude 振幅 - Loudness 响度" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EAmplitude%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%8C%AF%E5%B9%85%20-%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-yellow%22%3ELoudness%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%93%8D%E5%BA%A6%3C/span%3E" _note="" _mubu_note="">
              <outline text="decibels，≥120dB 听力损伤；150dB 鼓膜破裂" _mubu_text="%3Cspan%3Edecibels%EF%BC%8C%E2%89%A5120dB%20%E5%90%AC%E5%8A%9B%E6%8D%9F%E4%BC%A4%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E150dB%20%E9%BC%93%E8%86%9C%E7%A0%B4%E8%A3%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Frequency 频率 - Pitch 音高" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EFrequency%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E9%A2%91%E7%8E%87%20-%20%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-yellow%22%3EPitch%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E9%9F%B3%E9%AB%98%3C/span%3E" _note="" _mubu_note="">
              <outline text="hertz，人类听觉范围：20-20000Hz；shorter wavelength - higher frequency - higher pitch" _mubu_text="%3Cspan%3Ehertz%EF%BC%8C%E4%BA%BA%E7%B1%BB%E5%90%AC%E8%A7%89%E8%8C%83%E5%9B%B4%EF%BC%9A20-20000Hz%EF%BC%9Bshorter%20wavelength%20-%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Ehigher%20frequency%20-%20higher%20pitch%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="Auditory Transduction 听觉换能" _mubu_text="%3Cspan%3EAuditory%20Transduction%20%E5%90%AC%E8%A7%89%E6%8D%A2%E8%83%BD%3C/span%3E" _note="" _mubu_note="">
            <outline text="不需要背，有印象就好" _mubu_text="%3Cspan%3E%E4%B8%8D%E9%9C%80%E8%A6%81%E8%83%8C%EF%BC%8C%E6%9C%89%E5%8D%B0%E8%B1%A1%E5%B0%B1%E5%A5%BD%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Pinna（耳廓） → Auditory canal（耳道） → Eardrum（耳鼓） → Ossicles（听小骨） → Cochlea（耳蜗） → Neural signals → Thalamus 丘脑 看起来就有感觉，对吧 → Auditory cortex (temporal lobe Temporal Lobe 颞叶（下，离耳朵近）)" _mubu_text="%3Cspan%3EPinna%EF%BC%88%E8%80%B3%E5%BB%93%EF%BC%89%20%E2%86%92%20Auditory%20canal%EF%BC%88%E8%80%B3%E9%81%93%EF%BC%89%20%E2%86%92%20Eardrum%EF%BC%88%E8%80%B3%E9%BC%93%EF%BC%89%20%E2%86%92%20Ossicles%EF%BC%88%E5%90%AC%E5%B0%8F%E9%AA%A8%EF%BC%89%20%E2%86%92%20Cochlea%EF%BC%88%E8%80%B3%E8%9C%97%EF%BC%89%20%E2%86%92%20Neural%20signals%20%E2%86%92%20%3C/span%3E%3Cspan%20class=%22node-mention%22%20id=%22oh5vHjzHvr%22%20spellcheck=%22false%22%20contenteditable=%22false%22%20data-doc=%221qN74cOm072%22%20data-node=%22HEaQlepCoA%22%20data-text=%22%255B%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Thalamus%2522%252C%2522style%2522%253A%257B%2522bold%2522%253Atrue%252C%2522color%2522%253A%2522%2523dc2d1e%2522%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522%2520%2522%252C%2522style%2522%253A%257B%2522color%2522%253A%2522%2523dc2d1e%2522%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522%25E4%25B8%2598%25E8%2584%2591%2520%2522%252C%2522style%2522%253A%257B%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522%25E7%259C%258B%25E8%25B5%25B7%25E6%259D%25A5%25E5%25B0%25B1%25E6%259C%2589%25E6%2584%259F%25E8%25A7%2589%25EF%25BC%258C%25E5%25AF%25B9%25E5%2590%25A7%2522%252C%2522style%2522%253A%257B%2522color%2522%253A%2522%2523797ec9%2522%257D%257D%255D%22%3E%3Cspan%20class=%22bold%20text-color-red%22%3EThalamus%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E4%B8%98%E8%84%91%20%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E7%9C%8B%E8%B5%B7%E6%9D%A5%E5%B0%B1%E6%9C%89%E6%84%9F%E8%A7%89%EF%BC%8C%E5%AF%B9%E5%90%A7%3C/span%3E%3C/span%3E%3Cspan%3E%3C/span%3E%3Cspan%3E%20%E2%86%92%20Auditory%20cortex%20(%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Etemporal%20%3C/span%3E%3Cspan%3Elobe%20%3C/span%3E%3Cspan%20class=%22node-mention%22%20id=%22SdnFolF18O%22%20spellcheck=%22false%22%20contenteditable=%22false%22%20data-doc=%221qN74cOm072%22%20data-node=%22OaBokt6lKm%22%20data-text=%22%255B%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Temporal%2520%2522%252C%2522style%2522%253A%257B%2522color%2522%253A%2522%2523ffaf38%2522%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Lobe%2520%25E9%25A2%259E%25E5%258F%25B6%2522%252C%2522style%2522%253A%257B%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522%25EF%25BC%2588%25E4%25B8%258B%25EF%25BC%258C%25E7%25A6%25BB%25E8%2580%25B3%25E6%259C%25B5%25E8%25BF%2591%25EF%25BC%2589%2522%252C%2522style%2522%253A%257B%2522color%2522%253A%2522%2523797ec9%2522%257D%257D%255D%22%3E%3Cspan%20class=%22text-color-yellow%22%3ETemporal%20%3C/span%3E%3Cspan%3ELobe%20%E9%A2%9E%E5%8F%B6%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%EF%BC%88%E4%B8%8B%EF%BC%8C%E7%A6%BB%E8%80%B3%E6%9C%B5%E8%BF%91%EF%BC%89%3C/span%3E%3C/span%3E%3Cspan%3E%3C/span%3E%3Cspan%3E)%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Pitch Perception 音高知觉，人耳是怎么区分音高？" _mubu_text="%3Cspan%3EPitch%20Perception%20%E9%9F%B3%E9%AB%98%E7%9F%A5%E8%A7%89%EF%BC%8C%E4%BA%BA%E8%80%B3%E6%98%AF%E6%80%8E%E4%B9%88%E5%8C%BA%E5%88%86%E9%9F%B3%E9%AB%98%EF%BC%9F%3C/span%3E" _note="" _mubu_note="">
            <outline text="1. Place Theory 位置理论" _mubu_text="%3Cspan%3E1.%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EPlace%20%3C/span%3E%3Cspan%3ETheory%20%E4%BD%8D%E7%BD%AE%E7%90%86%E8%AE%BA%3C/span%3E" _note="" _mubu_note="">
              <outline text="能感受高音的receptors在 cochlea（耳蜗）的外面，低音的在里面，通过判断是哪里被刺激了，判断音高" _mubu_text="%3Cspan%3E%E8%83%BD%E6%84%9F%E5%8F%97%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%AB%98%E9%9F%B3%E7%9A%84receptors%E5%9C%A8%20cochlea%EF%BC%88%E8%80%B3%E8%9C%97%EF%BC%89%E7%9A%84%E5%A4%96%E9%9D%A2%EF%BC%8C%E4%BD%8E%E9%9F%B3%E7%9A%84%E5%9C%A8%E9%87%8C%E9%9D%A2%3C/span%3E%3Cspan%3E%EF%BC%8C%E9%80%9A%E8%BF%87%E5%88%A4%E6%96%AD%E6%98%AF%E5%93%AA%E9%87%8C%E8%A2%AB%E5%88%BA%E6%BF%80%E4%BA%86%EF%BC%8C%E5%88%A4%E6%96%AD%E9%9F%B3%E9%AB%98%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="2. Frequency Theory 频率理论" _mubu_text="%3Cspan%3E2.%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EFrequency%20%3C/span%3E%3Cspan%3ETheory%20%E9%A2%91%E7%8E%87%E7%90%86%E8%AE%BA%3C/span%3E" _note="" _mubu_note="">
              <outline text="越高频率，firing rate越高，表明pitch越高" _mubu_text="%3Cspan%3E%E8%B6%8A%E9%AB%98%E9%A2%91%E7%8E%87%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Efiring%20rate%3C/span%3E%3Cspan%3E%E8%B6%8A%E9%AB%98%EF%BC%8C%E8%A1%A8%E6%98%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Epitch%3C/span%3E%3Cspan%3E%E8%B6%8A%E9%AB%98%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="3. Volley Principle 齐射原理" _mubu_text="%3Cspan%3E3.%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EVolley%20%3C/span%3E%3Cspan%3EPrinciple%20%E9%BD%90%E5%B0%84%E5%8E%9F%E7%90%86%3C/span%3E" _note="" _mubu_note="">
              <outline text="高频的声音 &gt;1000Hz，单个神经元跟不上" _mubu_text="%3Cspan%3E%E9%AB%98%E9%A2%91%E7%9A%84%E5%A3%B0%E9%9F%B3%20&amp;gt;1000Hz%EF%BC%8C%E5%8D%95%E4%B8%AA%E7%A5%9E%E7%BB%8F%E5%85%83%E8%B7%9F%E4%B8%8D%E4%B8%8A%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="一组神经元轮流firing" _mubu_text="%3Cspan%3E%E4%B8%80%E7%BB%84%E7%A5%9E%E7%BB%8F%E5%85%83%E8%BD%AE%E6%B5%81firing%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="Sound Localization 声音定位" _mubu_text="%3Cspan%3ESound%20Localization%20%E5%A3%B0%E9%9F%B3%E5%AE%9A%E4%BD%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="arrival time difference" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3Earrival%20time%3C/span%3E%3Cspan%3E%20difference%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="intensity difference" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3Eintensity%20%3C/span%3E%3Cspan%3Edifference%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Hearing Loss" _mubu_text="%3Cspan%3EHearing%20Loss%3C/span%3E" _note="" _mubu_note="">
            <outline text="1. Conduction Deafness 结构性损伤" _mubu_text="%3Cspan%3E1.%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3EConduction%20%3C/span%3E%3Cspan%3EDeafness%20%E7%BB%93%E6%9E%84%E6%80%A7%E6%8D%9F%E4%BC%A4%3C/span%3E" _note="" _mubu_note="">
              <outline text="声波无法有效到达cochlea（耳蜗）" _mubu_text="%3Cspan%3E%E5%A3%B0%E6%B3%A2%E6%97%A0%E6%B3%95%E6%9C%89%E6%95%88%E5%88%B0%E8%BE%BEcochlea%EF%BC%88%E8%80%B3%E8%9C%97%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="hearing aids 助听器可以补偿" _mubu_text="%3Cspan%3Ehearing%20aids%20%E5%8A%A9%E5%90%AC%E5%99%A8%E5%8F%AF%E4%BB%A5%E8%A1%A5%E5%81%BF%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="2. Sensorineural Deafness" _mubu_text="%3Cspan%3E2.%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3ESensorineural%20%3C/span%3E%3Cspan%3EDeafness%3C/span%3E" _note="" _mubu_note="">
              <outline text="内耳 / cochlea / auditory nerve损伤" _mubu_text="%3Cspan%3E%E5%86%85%E8%80%B3%20/%20cochlea%20/%20auditory%20nerve%E6%8D%9F%E4%BC%A4%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="原因：aging / loud noise / genetics" _mubu_text="%3Cspan%3E%E5%8E%9F%E5%9B%A0%EF%BC%9Aaging%20/%20loud%20noise%20/%20genetics%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="Touch / Somesthetic Sense 触觉" _mubu_text="%3Cspan%3ETouch%20/%20Somesthetic%20Sense%20%E8%A7%A6%E8%A7%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="包含 pressure / pain / cold / warmth" _mubu_text="%3Cspan%3E%E5%8C%85%E5%90%AB%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Epressure%20%3C/span%3E%3Cspan%3E/%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Epain%20%3C/span%3E%3Cspan%3E/%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Ecold%20%3C/span%3E%3Cspan%3E/%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Ewarmth%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Receptors → Thalamus → Somatosensory cortex (parietal lobe) Parietal Lobe 顶叶（顶，最上面，居高临下俯视，才能感受全身）" _mubu_text="%3Cspan%3EReceptors%20%E2%86%92%20Thalamus%20%E2%86%92%20%3C/span%3E%3Cspan%20class=%22bold%22%3ESomatosensory%20cortex%20(parietal%20lobe)%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20node-mention%22%20id=%22o9bodDUFrg%22%20spellcheck=%22false%22%20contenteditable=%22false%22%20data-doc=%221qN74cOm072%22%20data-node=%222splYL65sc%22%20data-text=%22%255B%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Parietal%2520%2522%252C%2522style%2522%253A%257B%2522color%2522%253A%2522%2523ffaf38%2522%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Lobe%2520%25E9%25A1%25B6%25E5%258F%25B6%2522%252C%2522style%2522%253A%257B%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522%25EF%25BC%2588%25E9%25A1%25B6%25EF%25BC%258C%25E6%259C%2580%25E4%25B8%258A%25E9%259D%25A2%25EF%25BC%258C%25E5%25B1%2585%25E9%25AB%2598%25E4%25B8%25B4%25E4%25B8%258B%25E4%25BF%25AF%25E8%25A7%2586%25EF%25BC%258C%25E6%2589%258D%25E8%2583%25BD%25E6%2584%259F%25E5%258F%2597%25E5%2585%25A8%25E8%25BA%25AB%25EF%25BC%2589%2522%252C%2522style%2522%253A%257B%2522color%2522%253A%2522%2523797ec9%2522%257D%257D%255D%22%3E%3Cspan%20class=%22text-color-yellow%22%3EParietal%20%3C/span%3E%3Cspan%3ELobe%20%E9%A1%B6%E5%8F%B6%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%EF%BC%88%E9%A1%B6%EF%BC%8C%E6%9C%80%E4%B8%8A%E9%9D%A2%EF%BC%8C%E5%B1%85%E9%AB%98%E4%B8%B4%E4%B8%8B%E4%BF%AF%E8%A7%86%EF%BC%8C%E6%89%8D%E8%83%BD%E6%84%9F%E5%8F%97%E5%85%A8%E8%BA%AB%EF%BC%89%3C/span%3E%3C/span%3E%3Cspan%3E%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Gate-Control Theory 门控理论" _mubu_text="%3Cspan%3EGate-Control%20Theory%20%E9%97%A8%E6%8E%A7%E7%90%86%E8%AE%BA%3C/span%3E" _note="" _mubu_note="">
            <outline text="gate可以 block pain 和 allow pain" _mubu_text="%3Cspan%3Egate%E5%8F%AF%E4%BB%A5%20block%20pain%20%E5%92%8C%20allow%20pain%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="减少疼痛：1. 皮肤刺激，揉、按摩；2. endorphins或者其他止痛药；3. distraction 转移注意力" _mubu_text="%3Cspan%3E%E5%87%8F%E5%B0%91%E7%96%BC%E7%97%9B%EF%BC%9A1.%20%E7%9A%AE%E8%82%A4%E5%88%BA%E6%BF%80%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%8F%89%E3%80%81%E6%8C%89%E6%91%A9%3C/span%3E%3Cspan%3E%EF%BC%9B2.%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3Eendorphins%3C/span%3E%3Cspan%3E%E6%88%96%E8%80%85%E5%85%B6%E4%BB%96%E6%AD%A2%E7%97%9B%E8%8D%AF%EF%BC%9B3.%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3Edistraction%20%3C/span%3E%3Cspan%3E%E8%BD%AC%E7%A7%BB%E6%B3%A8%E6%84%8F%E5%8A%9B%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Phantom Limb Sensation 幻肢感" _mubu_text="%3Cspan%3EPhantom%20Limb%20Sensation%20%E5%B9%BB%E8%82%A2%E6%84%9F%3C/span%3E" _note="" _mubu_note="">
            <outline text="截肢后还感觉到肢体的存在" _mubu_text="%3Cspan%3E%E6%88%AA%E8%82%A2%E5%90%8E%E8%BF%98%E6%84%9F%E8%A7%89%E5%88%B0%E8%82%A2%E4%BD%93%E7%9A%84%E5%AD%98%E5%9C%A8%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="somatosensory cortex 仍然保留了 mapping" _mubu_text="%3Cspan%3Esomatosensory%20cortex%20%E4%BB%8D%E7%84%B6%E4%BF%9D%E7%95%99%E4%BA%86%20mapping%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="不是幻觉，是实在的神经现象" _mubu_text="%3Cspan%3E%E4%B8%8D%E6%98%AF%E5%B9%BB%E8%A7%89%EF%BC%8C%E6%98%AF%E5%AE%9E%E5%9C%A8%E7%9A%84%E7%A5%9E%E7%BB%8F%E7%8E%B0%E8%B1%A1%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Chemical Senses 化学感觉" _mubu_text="%3Cspan%3EChemical%20Senses%20%E5%8C%96%E5%AD%A6%E6%84%9F%E8%A7%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="Gustation 味觉" _mubu_text="%3Cspan%3EGustation%20%E5%91%B3%E8%A7%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="sweet / salty / sour / bitter / umami 鲜 / oleogustus 腻" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3Esweet%20%3C/span%3E%3Cspan%3E/%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Esalty%20%3C/span%3E%3Cspan%3E/%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Esour%20%3C/span%3E%3Cspan%3E/%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Ebitter%20%3C/span%3E%3Cspan%3E/%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Eumami%20%3C/span%3E%3Cspan%3E%E9%B2%9C%20/%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Eoleogustus%20%3C/span%3E%3Cspan%3E%E8%85%BB%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Spicy 不是 Taste！是Pain！" _mubu_text="%3Cspan%20class=%22bold%20underline%20text-color-red%22%3ESpicy%20%E4%B8%8D%E6%98%AF%20Taste%EF%BC%81%E6%98%AFPain%EF%BC%81%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Supertaster 味蕾多，敏感；还有Medium Taster和Nontatser" _mubu_text="%3Cspan%3ESupertaster%20%E5%91%B3%E8%95%BE%E5%A4%9A%EF%BC%8C%E6%95%8F%E6%84%9F%EF%BC%9B%E8%BF%98%E6%9C%89Medium%20Taster%E5%92%8CNontatser%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Olfaction 嗅觉" _mubu_text="%3Cspan%3EOlfaction%20%E5%97%85%E8%A7%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="80%的味觉来自嗅觉" _mubu_text="%3Cspan%3E80%25%E7%9A%84%E5%91%B3%E8%A7%89%E6%9D%A5%E8%87%AA%E5%97%85%E8%A7%89%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="不经过thalamus" _mubu_text="%3Cspan%3E%E4%B8%8D%E7%BB%8F%E8%BF%87%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-red%22%3Ethalamus%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="直接到 cortex，amygdala，hippocampus" _mubu_text="%3Cspan%20class=%22bold%20underline%22%3E%E7%9B%B4%E6%8E%A5%E5%88%B0%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-blue%22%3E%20cortex%EF%BC%8Camygdala%EF%BC%8Chippocampus%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="气味 = 记忆触发器" _mubu_text="%3Cspan%3E%E6%B0%94%E5%91%B3%20=%20%E8%AE%B0%E5%BF%86%E8%A7%A6%E5%8F%91%E5%99%A8%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Pheromones 信息素" _mubu_text="%3Cspan%3EPheromones%20%E4%BF%A1%E6%81%AF%E7%B4%A0%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Body Position Senses" _mubu_text="%3Cspan%3EBody%20Position%20Senses%3C/span%3E" _note="" _mubu_note="">
          <outline text="Vestibular Sense 前庭觉" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EVestibular%20%3C/span%3E%3Cspan%3ESense%20%E5%89%8D%E5%BA%AD%E8%A7%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="平衡感" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E5%B9%B3%E8%A1%A1%3C/span%3E%3Cspan%3E%E6%84%9F%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="头部位置 &amp; 运动" _mubu_text="%3Cspan%3E%E5%A4%B4%E9%83%A8%E4%BD%8D%E7%BD%AE%20&amp;amp;%20%E8%BF%90%E5%8A%A8%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="半规管 Semicircular Canals" _mubu_text="%3Cspan%3E%E5%8D%8A%E8%A7%84%E7%AE%A1%20Semicircular%20Canals%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="半规管内液体移动出发hair cells弯曲，产生神经信号" _mubu_text="%3Cspan%3E%E5%8D%8A%E8%A7%84%E7%AE%A1%E5%86%85%E6%B6%B2%E4%BD%93%E7%A7%BB%E5%8A%A8%E5%87%BA%E5%8F%91hair%20cells%E5%BC%AF%E6%9B%B2%EF%BC%8C%E4%BA%A7%E7%94%9F%E7%A5%9E%E7%BB%8F%E4%BF%A1%E5%8F%B7%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Kinesthetic Sense 动觉" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EKinesthetic%20%3C/span%3E%3Cspan%3ESense%20%E5%8A%A8%E8%A7%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="肌肉 / 关节" _mubu_text="%3Cspan%3E%E8%82%8C%E8%82%89%20/%20%E5%85%B3%E8%8A%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="不看也知道手脚在哪里" _mubu_text="%3Cspan%3E%E4%B8%8D%E7%9C%8B%E4%B9%9F%E7%9F%A5%E9%81%93%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%89%8B%E8%84%9A%E5%9C%A8%E5%93%AA%E9%87%8C%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
      </outline>
    </outline>
    <outline text="Unit 2（15000字）" _mubu_text="%3Cspan%3EUnit%202%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E15000%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
      <outline text="这个单元的结构和其他有点不一样（啰里八唆），所以看起来字数多 😢" _mubu_text="%3Cspan%3E%E8%BF%99%E4%B8%AA%E5%8D%95%E5%85%83%E7%9A%84%E7%BB%93%E6%9E%84%E5%92%8C%E5%85%B6%E4%BB%96%E6%9C%89%E7%82%B9%E4%B8%8D%E4%B8%80%E6%A0%B7%EF%BC%88%E5%95%B0%E9%87%8C%E5%85%AB%E5%94%86%EF%BC%89%EF%BC%8C%E6%89%80%E4%BB%A5%E7%9C%8B%E8%B5%B7%E6%9D%A5%E5%AD%97%E6%95%B0%E5%A4%9A%20%F0%9F%98%A2%3C/span%3E" _note="" _mubu_note="">
        <outline text="我后面抽象了一下，把大段解释都变成了一条一条的概念，希望可以帮到你！😁" _mubu_text="%3Cspan%3E%E6%88%91%E5%90%8E%E9%9D%A2%E6%8A%BD%E8%B1%A1%E4%BA%86%E4%B8%80%E4%B8%8B%EF%BC%8C%E6%8A%8A%E5%A4%A7%E6%AE%B5%E8%A7%A3%E9%87%8A%E9%83%BD%E5%8F%98%E6%88%90%E4%BA%86%E4%B8%80%E6%9D%A1%E4%B8%80%E6%9D%A1%E7%9A%84%E6%A6%82%E5%BF%B5%EF%BC%8C%E5%B8%8C%E6%9C%9B%E5%8F%AF%E4%BB%A5%E5%B8%AE%E5%88%B0%E4%BD%A0%EF%BC%81%F0%9F%98%81%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="当你展开一个chapter后，默认已经是完全展开的啦，有一些看起来没展开，但是里面是重复的内容，但是更详细；" _mubu_text="%3Cspan%3E%E5%BD%93%E4%BD%A0%E5%B1%95%E5%BC%80%E4%B8%80%E4%B8%AAchapter%E5%90%8E%EF%BC%8C%E9%BB%98%E8%AE%A4%E5%B7%B2%E7%BB%8F%E6%98%AF%E5%AE%8C%E5%85%A8%E5%B1%95%E5%BC%80%E7%9A%84%E5%95%A6%EF%BC%8C%E6%9C%89%E4%B8%80%E4%BA%9B%E7%9C%8B%E8%B5%B7%E6%9D%A5%E6%B2%A1%E5%B1%95%E5%BC%80%EF%BC%8C%E4%BD%86%E6%98%AF%E9%87%8C%E9%9D%A2%E6%98%AF%E9%87%8D%E5%A4%8D%E7%9A%84%E5%86%85%E5%AE%B9%EF%BC%8C%E4%BD%86%E6%98%AF%E6%9B%B4%E8%AF%A6%E7%BB%86%EF%BC%9B%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="如果对哪个知识点不太熟悉，可以展开看详情 💖" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E5%AF%B9%E5%93%AA%E4%B8%AA%E7%9F%A5%E8%AF%86%E7%82%B9%E4%B8%8D%E5%A4%AA%E7%86%9F%E6%82%89%EF%BC%8C%E5%8F%AF%E4%BB%A5%E5%B1%95%E5%BC%80%E7%9C%8B%E8%AF%A6%E6%83%85%20%F0%9F%92%96%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="看到3000字别害怕，其实没有那么多的" _mubu_text="%3Cspan%3E%E7%9C%8B%E5%88%B03000%E5%AD%97%E5%88%AB%E5%AE%B3%E6%80%95%EF%BC%8C%E5%85%B6%E5%AE%9E%E6%B2%A1%E6%9C%89%E9%82%A3%E4%B9%88%E5%A4%9A%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
      </outline>
      <outline text="2.1 认知 Perception（1600字）" _mubu_text="%3Cspan%3E2.1%20%E8%AE%A4%E7%9F%A5%20Perception%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E1600%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="Perception is &quot;interpretation&quot;（这章需要手动展开一下）" _mubu_text="%3Cspan%3EPerception%20is%20%22interpretation%22%EF%BC%88%E8%BF%99%E7%AB%A0%E9%9C%80%E8%A6%81%E6%89%8B%E5%8A%A8%E5%B1%95%E5%BC%80%E4%B8%80%E4%B8%8B%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="1. Sensation vs. Perception" _mubu_text="%3Cspan%3E1.%20Sensation%20vs.%20Perception%3C/span%3E" _note="" _mubu_note="">
          <outline text="可以看这里：Sensation vs. Perception" _mubu_text="%3Cspan%3E%E5%8F%AF%E4%BB%A5%E7%9C%8B%E8%BF%99%E9%87%8C%EF%BC%9A%3C/span%3E%3Cspan%20class=%22node-mention%22%20id=%22o962xedR29%22%20spellcheck=%22false%22%20contenteditable=%22false%22%20data-doc=%221qN74cOm072%22%20data-node=%22tXUCW1bgKI%22%20data-text=%22%255B%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Sensation%2520vs.%2520Perception%2522%252C%2522style%2522%253A%257B%257D%257D%255D%22%3E%3Cspan%3ESensation%20vs.%20Perception%3C/span%3E%3C/span%3E%3Cspan%3E%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Sensation" _mubu_text="%3Cspan%3ESensation%3C/span%3E" _note="" _mubu_note="">
            <outline text="physical process" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3Ephysical%3C/span%3E%3Cspan%3E%20process%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="眼睛、耳朵等把外接接收到的物理刺激转换成为电信号的过程（transduction）" _mubu_text="%3Cspan%3E%E7%9C%BC%E7%9D%9B%E3%80%81%E8%80%B3%E6%9C%B5%E7%AD%89%E6%8A%8A%E5%A4%96%E6%8E%A5%E6%8E%A5%E6%94%B6%E5%88%B0%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%89%A9%E7%90%86%E5%88%BA%E6%BF%80%E8%BD%AC%E6%8D%A2%E6%88%90%E4%B8%BA%E7%94%B5%E4%BF%A1%E5%8F%B7%3C/span%3E%3Cspan%3E%E7%9A%84%E8%BF%87%E7%A8%8B%EF%BC%88transduction%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Perception" _mubu_text="%3Cspan%3EPerception%3C/span%3E" _note="" _mubu_note="">
            <outline text="psychological process" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3Epsychological%3C/span%3E%3Cspan%3E%20process%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="在sensation的基础上，大脑对神经信号进行组织识别和解释" _mubu_text="%3Cspan%3E%E5%9C%A8sensation%E7%9A%84%E5%9F%BA%E7%A1%80%E4%B8%8A%EF%BC%8C%E5%A4%A7%E8%84%91%E5%AF%B9%E7%A5%9E%E7%BB%8F%E4%BF%A1%E5%8F%B7%E8%BF%9B%E8%A1%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%BB%84%E7%BB%87%E8%AF%86%E5%88%AB%E5%92%8C%E8%A7%A3%E9%87%8A%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Prosopagnosia（面容失认症）：sensation是完好的，可以清楚看到每一个部分，但是大脑无法将其整合成一张“脸”" _mubu_text="%3Cspan%20class=%22bold%22%3EProsopagnosia%EF%BC%88%E9%9D%A2%E5%AE%B9%E5%A4%B1%E8%AE%A4%E7%97%87%EF%BC%89%3C/span%3E%3Cspan%3E%EF%BC%9Asensation%E6%98%AF%E5%AE%8C%E5%A5%BD%E7%9A%84%EF%BC%8C%E5%8F%AF%E4%BB%A5%E6%B8%85%E6%A5%9A%E7%9C%8B%E5%88%B0%E6%AF%8F%E4%B8%80%E4%B8%AA%E9%83%A8%E5%88%86%EF%BC%8C%E4%BD%86%E6%98%AF%E5%A4%A7%E8%84%91%E6%97%A0%E6%B3%95%E5%B0%86%E5%85%B6%E6%95%B4%E5%90%88%E6%88%90%E4%B8%80%E5%BC%A0%E2%80%9C%E8%84%B8%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="2. Bottom-up &amp; Top-down" _mubu_text="%3Cspan%3E2.%20Bottom-up%20&amp;amp;%20Top-down%3C/span%3E" _note="" _mubu_note="">
          <outline text="Bottom-Up Processing" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EBottom-Up%3C/span%3E%3Cspan%3E%20Processing%3C/span%3E" _note="自下而上的过程" _mubu_note="%3Cspan%3E%E8%87%AA%E4%B8%8B%E8%80%8C%E4%B8%8A%E7%9A%84%E8%BF%87%E7%A8%8B%3C/span%3E">
            <outline text="BU: Build Up from the details" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3EBU:%20Build%20Up%20from%20the%20details%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="它不依赖你已有的知识或期望，纯粹是基于你当前接收到的感觉信息。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%AE%83%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E4%B8%8D%E4%BE%9D%E8%B5%96%E4%BD%A0%E5%B7%B2%E6%9C%89%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%9F%A5%E8%AF%86%E6%88%96%E6%9C%9F%E6%9C%9B%EF%BC%8C%E7%BA%AF%E7%B2%B9%E6%98%AF%E5%9F%BA%E4%BA%8E%E4%BD%A0%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E5%BD%93%E5%89%8D%E6%8E%A5%E6%94%B6%E5%88%B0%E7%9A%84%E6%84%9F%E8%A7%89%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="老外第一次看到汉字，可能会一个笔画一个笔画地拆解" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E8%80%81%E5%A4%96%E7%AC%AC%E4%B8%80%E6%AC%A1%E7%9C%8B%E5%88%B0%E6%B1%89%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%8F%AF%E8%83%BD%E4%BC%9A%E4%B8%80%E4%B8%AA%E7%AC%94%E7%94%BB%E4%B8%80%E4%B8%AA%E7%AC%94%E7%94%BB%E5%9C%B0%E6%8B%86%E8%A7%A3%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Top-Down Processing" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ETop-Down%3C/span%3E%3Cspan%3E%20Processing%3C/span%3E" _note="自上而下的处理" _mubu_note="%3Cspan%3E%E8%87%AA%E4%B8%8A%E8%80%8C%E4%B8%8B%E7%9A%84%E5%A4%84%E7%90%86%3C/span%3E">
            <outline text="TD: Think Down from the big picture" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3ETD:%20Think%20Down%20from%20the%20big%20picture%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="这是我们日常生活中更常用的一种方式，因为它更高效。" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AF%E6%88%91%E4%BB%AC%E6%97%A5%E5%B8%B8%E7%94%9F%E6%B4%BB%E4%B8%AD%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%9B%B4%E5%B8%B8%E7%94%A8%E7%9A%84%E4%B8%80%E7%A7%8D%E6%96%B9%E5%BC%8F%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%9B%A0%E4%B8%BA%E5%AE%83%E6%9B%B4%E9%AB%98%E6%95%88%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="我们即使看到乱序的汉字，也明白这是什么" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E5%8D%B3%E4%BD%BF%E7%9C%8B%E5%88%B0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B9%B1%E5%BA%8F%E7%9A%84%E6%B1%89%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%B9%9F%E6%98%8E%E7%99%BD%E8%BF%99%E6%98%AF%E4%BB%80%E4%B9%88%3C/span%3E" _note="" _mubu_note="">
              <outline text="AOCCCDRNIG TO RSCCHEARCH AT CMABRIGDE UINERVTISY, IT DEOSN&apos;T MTTAER IN WHAT OREDR THE LTTEERS IN A WORD ARE, THE OLNY IPRMOETNT TIHNG IS THAT THE FRIST AND ISAT LTTEER BE AT THE RGHT PCLAE. THE RSET CAN BE A TOATL MSES AND YOU CAN STILL RAED IT WOUTHIT A PORBELM. THIS IS BCUSEAE THE HUAMN MNID DEOS NOT RAED ERVEY LTETER BY ISTLEF, BUT THE WORD AS A WLOHE." _mubu_text="%3Cspan%20class=%22text-color-green%22%3EAOCCCDRNIG%20TO%20RSCCHEARCH%20AT%20CMABRIGDE%20UINERVTISY%3C/span%3E%3Cspan%3E,%20IT%20DEOSN&apos;T%20MTTAER%20IN%20WHAT%20OREDR%20THE%20LTTEERS%20IN%20A%20WORD%20ARE,%20THE%20OLNY%20IPRMOETNT%20TIHNG%20IS%20THAT%20THE%20FRIST%20AND%20ISAT%20LTTEER%20BE%20AT%20THE%20RGHT%20PCLAE.%20THE%20RSET%20CAN%20BE%20A%20TOATL%20MSES%20AND%20YOU%20CAN%20STILL%20RAED%20IT%20WOUTHIT%20A%20PORBELM.%20THIS%20IS%20BCUSEAE%20THE%20HUAMN%20MNID%20DEOS%20NOT%20RAED%20ERVEY%20LTETER%20BY%20ISTLEF,%20BUT%20THE%20WORD%20AS%20A%20WLOHE.%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="研表究明：汉字的序顺并不定一影阅响读！事证实明了当您看这完句话之后才发现都字乱是的……" _mubu_text="%3Cspan%3E%E7%A0%94%E8%A1%A8%E7%A9%B6%E6%98%8E%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B1%89%E5%AD%97%E7%9A%84%E5%BA%8F%E9%A1%BA%3C/span%3E%3Cspan%3E%E5%B9%B6%E4%B8%8D%E5%AE%9A%E4%B8%80%E5%BD%B1%E9%98%85%E5%93%8D%E8%AF%BB%EF%BC%81%E4%BA%8B%E8%AF%81%E5%AE%9E%E6%98%8E%E4%BA%86%E5%BD%93%E6%82%A8%E7%9C%8B%E8%BF%99%E5%AE%8C%E5%8F%A5%E8%AF%9D%E4%B9%8B%E5%90%8E%E6%89%8D%E5%8F%91%E7%8E%B0%E9%83%BD%E5%AD%97%E4%B9%B1%E6%98%AF%E7%9A%84%E2%80%A6%E2%80%A6%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="3. Perceptual set 思维定势" _mubu_text="%3Cspan%3E3.%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3EPerceptual%20set%3C/span%3E%3Cspan%3E%20%E6%80%9D%E7%BB%B4%E5%AE%9A%E5%8A%BF%3C/span%3E" _note="" _mubu_note="">
          <outline text="TD的绝佳体现，没有所谓的Positive和Negative之分！Mental Set才是不好的！" _mubu_text="%3Cspan%3ETD%E7%9A%84%E7%BB%9D%E4%BD%B3%E4%BD%93%E7%8E%B0%EF%BC%8C%E6%B2%A1%E6%9C%89%E6%89%80%E8%B0%93%E7%9A%84Positive%E5%92%8CNegative%E4%B9%8B%E5%88%86%EF%BC%81%3C/span%3E%3Cspan%20class=%22bold%20underline%22%3EMental%20Set%E6%89%8D%E6%98%AF%E4%B8%8D%E5%A5%BD%E7%9A%84%EF%BC%81%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="一种心理倾向，基于经验、文化、情绪和动机，以某种特定的方式去理解事务而忽略其他可能性" _mubu_text="%3Cspan%3E%E4%B8%80%E7%A7%8D%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%83%E7%90%86%E5%80%BE%E5%90%91%EF%BC%8C%E5%9F%BA%E4%BA%8E%E7%BB%8F%E9%AA%8C%E3%80%81%E6%96%87%E5%8C%96%E3%80%81%E6%83%85%E7%BB%AA%E5%92%8C%E5%8A%A8%E6%9C%BA%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BB%A5%E6%9F%90%E7%A7%8D%E7%89%B9%E5%AE%9A%E7%9A%84%E6%96%B9%E5%BC%8F%E5%8E%BB%E7%90%86%E8%A7%A3%E4%BA%8B%E5%8A%A1%E8%80%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%BD%E7%95%A5%3C/span%3E%3Cspan%3E%E5%85%B6%E4%BB%96%E5%8F%AF%E8%83%BD%E6%80%A7%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="“先入为主”，你看到的是你希望看到的" _mubu_text="%3Cspan%3E%E2%80%9C%E5%85%88%E5%85%A5%E4%B8%BA%E4%B8%BB%E2%80%9D%EF%BC%8C%E4%BD%A0%E7%9C%8B%E5%88%B0%E7%9A%84%E6%98%AF%E4%BD%A0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%B8%8C%E6%9C%9B%E7%9C%8B%E5%88%B0%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="可能原因（没事，不用看）" _mubu_text="%3Cspan%3E%E5%8F%AF%E8%83%BD%E5%8E%9F%E5%9B%A0%EF%BC%88%E6%B2%A1%E4%BA%8B%EF%BC%8C%E4%B8%8D%E7%94%A8%E7%9C%8B%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="CONTEXT" _mubu_text="%3Cspan%3ECONTEXT%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="CULTURE" _mubu_text="%3Cspan%3ECULTURE%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="ATTITUDE" _mubu_text="%3Cspan%3EATTITUDE%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="EMOTIONS" _mubu_text="%3Cspan%3EEMOTIONS%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="MOTIVATION" _mubu_text="%3Cspan%3EMOTIVATION%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="EXPECTATIONS" _mubu_text="%3Cspan%3EEXPECTATIONS%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="4. Selective Attention" _mubu_text="%3Cspan%3E4.%20Selective%20Attention%3C/span%3E" _note="" _mubu_note="">
          <outline text="过滤器，我们会将意识集中于某个特定刺激，同时忽略其他刺激的过程" _mubu_text="%3Cspan%3E%E8%BF%87%E6%BB%A4%E5%99%A8%EF%BC%8C%E6%88%91%E4%BB%AC%E4%BC%9A%E5%B0%86%E6%84%8F%E8%AF%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%9B%86%E4%B8%AD%E4%BA%8E%E6%9F%90%E4%B8%AA%E7%89%B9%E5%AE%9A%E5%88%BA%E6%BF%80%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%90%8C%E6%97%B6%E5%BF%BD%E7%95%A5%E5%85%B6%E4%BB%96%E5%88%BA%E6%BF%80%E7%9A%84%E8%BF%87%E7%A8%8B%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Cocktail Party Effect" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ECocktail%20Party%20Effect%3C/span%3E" _note="" _mubu_note="">
            <outline text="在一个嘈杂的排队上，你可能不会在意别人聊了什么，但是远处有人叫你名字时，你的注意力会立刻被吸引过去" _mubu_text="%3Cspan%3E%E5%9C%A8%E4%B8%80%E4%B8%AA%E5%98%88%E6%9D%82%E7%9A%84%E6%8E%92%E9%98%9F%E4%B8%8A%EF%BC%8C%E4%BD%A0%E5%8F%AF%E8%83%BD%E4%B8%8D%E4%BC%9A%E5%9C%A8%E6%84%8F%E5%88%AB%E4%BA%BA%E8%81%8A%E4%BA%86%E4%BB%80%E4%B9%88%EF%BC%8C%E4%BD%86%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%BF%9C%E5%A4%84%E6%9C%89%E4%BA%BA%E5%8F%AB%E4%BD%A0%E5%90%8D%E5%AD%97%E6%97%B6%EF%BC%8C%E4%BD%A0%E7%9A%84%E6%B3%A8%E6%84%8F%E5%8A%9B%E4%BC%9A%E7%AB%8B%E5%88%BB%E8%A2%AB%E5%90%B8%E5%BC%95%E8%BF%87%E5%8E%BB%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="意味着并未完全“屏蔽”信息，而是在后台默默监控" _mubu_text="%3Cspan%3E%E6%84%8F%E5%91%B3%E7%9D%80%E5%B9%B6%E6%9C%AA%E5%AE%8C%E5%85%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E2%80%9C%E5%B1%8F%E8%94%BD%E2%80%9D%E4%BF%A1%E6%81%AF%EF%BC%8C%E8%80%8C%E6%98%AF%E5%9C%A8%E5%90%8E%E5%8F%B0%E9%BB%98%E9%BB%98%E7%9B%91%E6%8E%A7%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Related Effects 大猩猩和问路" _mubu_text="%3Cspan%3ERelated%20Effects%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A4%A7%E7%8C%A9%E7%8C%A9%E5%92%8C%E9%97%AE%E8%B7%AF%3C/span%3E" _note="" _mubu_note="">
            <outline text="Inattentional Blindness (非注意盲视) 看不见很明显的东西" _mubu_text="%3Cspan%20class=%22bold%22%3EInattentional%20Blindness%20(%E9%9D%9E%E6%B3%A8%E6%84%8F%E7%9B%B2%E8%A7%86)%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%9C%8B%E4%B8%8D%E8%A7%81%E5%BE%88%E6%98%8E%E6%98%BE%E7%9A%84%E4%B8%9C%E8%A5%BF%3C/span%3E" _note="" _mubu_note="">
              <outline text="当你把注意力高度集中在一件事情上时，你可能会完全“看不见”视野中出现的其他东西，即使那个东西非常明显。" _mubu_text="%3Cspan%3E%E5%BD%93%E4%BD%A0%E6%8A%8A%E6%B3%A8%E6%84%8F%E5%8A%9B%E9%AB%98%E5%BA%A6%E9%9B%86%E4%B8%AD%E5%9C%A8%E4%B8%80%E4%BB%B6%E4%BA%8B%E6%83%85%E4%B8%8A%E6%97%B6%EF%BC%8C%E4%BD%A0%E5%8F%AF%E8%83%BD%E4%BC%9A%E5%AE%8C%E5%85%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E2%80%9C%E7%9C%8B%E4%B8%8D%E8%A7%81%E2%80%9D%E8%A7%86%E9%87%8E%E4%B8%AD%E5%87%BA%E7%8E%B0%E7%9A%84%E5%85%B6%E4%BB%96%E4%B8%9C%E8%A5%BF%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%8D%B3%E4%BD%BF%E9%82%A3%E4%B8%AA%E4%B8%9C%E8%A5%BF%E9%9D%9E%E5%B8%B8%E6%98%8E%E6%98%BE%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="大猩猩 🦍" _mubu_text="%3Cspan%20class=%22bold%20text-color-green%22%3E%E5%A4%A7%E7%8C%A9%E7%8C%A9%20%F0%9F%A6%8D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Change Blindness (变化盲视) 发现不到场景的变化" _mubu_text="%3Cspan%20class=%22bold%22%3EChange%20Blindness%20(%E5%8F%98%E5%8C%96%E7%9B%B2%E8%A7%86)%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%8F%91%E7%8E%B0%E4%B8%8D%E5%88%B0%E5%9C%BA%E6%99%AF%E7%9A%84%E5%8F%98%E5%8C%96%3C/span%3E" _note="" _mubu_note="">
              <outline text="当场景发生明显变化时，如果没有特别留意，人们往往发现不了。" _mubu_text="%3Cspan%3E%E5%BD%93%E5%9C%BA%E6%99%AF%E5%8F%91%E7%94%9F%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%98%8E%E6%98%BE%E5%8F%98%E5%8C%96%E6%97%B6%EF%BC%8C%E5%A6%82%E6%9E%9C%E6%B2%A1%E6%9C%89%E7%89%B9%E5%88%AB%E7%95%99%E6%84%8F%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BA%BA%E4%BB%AC%E5%BE%80%E5%BE%80%E5%8F%91%E7%8E%B0%E4%B8%8D%E4%BA%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="问路被换掉" _mubu_text="%3Cspan%20class=%22bold%20text-color-green%22%3E%E9%97%AE%E8%B7%AF%E8%A2%AB%E6%8D%A2%E6%8E%89%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="5. Gestalt Psychology" _mubu_text="%3Cspan%3E5.%20Gestalt%20Psychology%3C/span%3E" _note="" _mubu_note="">
          <outline text="格式塔心理学" _mubu_text="%3Cspan%3E%E6%A0%BC%E5%BC%8F%E5%A1%94%E5%BF%83%E7%90%86%E5%AD%A6%3C/span%3E" _note="" _mubu_note="">
            <outline text="&quot;The whole is greater than the sum of its parts&quot; (整体大于部分之和)" _mubu_text="%3Cspan%3E%22The%20whole%20is%20greater%20than%20the%20sum%20of%20its%20parts%22%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E6%95%B4%E4%BD%93%E5%A4%A7%E4%BA%8E%E9%83%A8%E5%88%86%E4%B9%8B%E5%92%8C)%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="我们的大脑天生就擅长将零散的信息整合成一个有意义的，完整的整体来感知。我们看到的不是一些孤立无援的点和线" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E7%9A%84%E5%A4%A7%E8%84%91%E5%A4%A9%E7%94%9F%E5%B0%B1%E6%93%85%E9%95%BF%E5%B0%86%E9%9B%B6%E6%95%A3%E7%9A%84%E4%BF%A1%E6%81%AF%E6%95%B4%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E5%90%88%E6%88%90%E4%B8%80%E4%B8%AA%E6%9C%89%E6%84%8F%E4%B9%89%E7%9A%84%EF%BC%8C%E5%AE%8C%E6%95%B4%E7%9A%84%E6%95%B4%E4%BD%93%E6%9D%A5%E6%84%9F%E7%9F%A5%3C/span%3E%3Cspan%3E%E3%80%82%E6%88%91%E4%BB%AC%E7%9C%8B%E5%88%B0%E7%9A%84%E4%B8%8D%E6%98%AF%E4%B8%80%E4%BA%9B%E5%AD%A4%E7%AB%8B%E6%97%A0%E6%8F%B4%E7%9A%84%E7%82%B9%E5%92%8C%E7%BA%BF%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Gestalt Laws" _mubu_text="%3Cspan%3EGestalt%20Laws%3C/span%3E" _note="" _mubu_note="">
            <outline text="Figure-Ground Pattern 主体-背景" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EFigure-Ground%3C/span%3E%3Cspan%3E%20Pattern%20%E4%B8%BB%E4%BD%93-%E8%83%8C%E6%99%AF%3C/span%3E" _note="" _mubu_note="">
              <outline text="大脑会自行将图片分为主体和背景" _mubu_text="%3Cspan%3E%E5%A4%A7%E8%84%91%E4%BC%9A%E8%87%AA%E8%A1%8C%E5%B0%86%E5%9B%BE%E7%89%87%E5%88%86%E4%B8%BA%E4%B8%BB%E4%BD%93%E5%92%8C%E8%83%8C%E6%99%AF%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22N6KEwbJjgW%22%2C%22oh%22%3A287%2C%22ow%22%3A270%2C%22uri%22%3A%22document_image%2F33585682_a3fe2aca-b018-458c-a8ab-d1eee7b11fa5.png%22%7D%5D"/>
              <outline text="Figure: Object-like regions that are distinguished from background" _mubu_text="%3Cspan%3EFigure:%20Object-like%20regions%20that%20are%20distinguished%20from%20background%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Ground: Background areas that are against which figures stand out" _mubu_text="%3Cspan%3EGround:%20Background%20areas%20that%20are%20against%20which%20figures%20stand%20out%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Also used in other senses（提琴曲中其他都是伴奏，歌曲中和弦是背景）" _mubu_text="%3Cspan%3EAlso%20used%20in%20other%20senses%EF%BC%88%E6%8F%90%E7%90%B4%E6%9B%B2%E4%B8%AD%E5%85%B6%E4%BB%96%E9%83%BD%E6%98%AF%E4%BC%B4%E5%A5%8F%EF%BC%8C%E6%AD%8C%E6%9B%B2%E4%B8%AD%E5%92%8C%E5%BC%A6%E6%98%AF%E8%83%8C%E6%99%AF%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Grouping 分组" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EGrouping%20%3C/span%3E%3Cspan%3E%E5%88%86%E7%BB%84%3C/span%3E" _note="" _mubu_note="">
              <outline text="Law of Similarity 相似律（颜色、形状、大小等）归为一组" _mubu_text="%3Cspan%3ELaw%20of%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3ESimilarity%20%3C/span%3E%3Cspan%3E%E7%9B%B8%E4%BC%BC%E5%BE%8B%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%EF%BC%88%E9%A2%9C%E8%89%B2%E3%80%81%E5%BD%A2%E7%8A%B6%E3%80%81%E5%A4%A7%E5%B0%8F%E7%AD%89%EF%BC%89%E5%BD%92%E4%B8%BA%E4%B8%80%E7%BB%84%3C/span%3E" _note="" _mubu_note="">
                <outline text="我们倾向于把外观相似（颜色、形状、大小等）的东西归为一组" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E5%80%BE%E5%90%91%E4%BA%8E%E6%8A%8A%E5%A4%96%E8%A7%82%E7%9B%B8%E4%BC%BC%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%A2%9C%E8%89%B2%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%BD%A2%E7%8A%B6%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22underline%22%3E%E5%A4%A7%E5%B0%8F%3C/span%3E%3Cspan%3E%E7%AD%89%EF%BC%89%E7%9A%84%E4%B8%9C%E8%A5%BF%E5%BD%92%E4%B8%BA%E4%B8%80%E7%BB%84%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="Example" _mubu_text="%3Cspan%3EExample%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22C796PQ8Liq%22%2C%22oh%22%3A214%2C%22ow%22%3A1050%2C%22uri%22%3A%22document_image%2F33585682_aecf22c5-3101-40d1-fb1b-54cf6bcfdae2.png%22%2C%22w%22%3A400%7D%5D"/>
              </outline>
              <outline text="Law of Proximity 临近律（空间上靠得近）归为一组" _mubu_text="%3Cspan%3ELaw%20of%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EProximity%20%3C/span%3E%3Cspan%3E%E4%B8%B4%E8%BF%91%E5%BE%8B%EF%BC%88%E7%A9%BA%E9%97%B4%E4%B8%8A%E9%9D%A0%E5%BE%97%E8%BF%91%EF%BC%89%E5%BD%92%E4%B8%BA%E4%B8%80%E7%BB%84%3C/span%3E" _note="" _mubu_note="">
                <outline text="我们倾向于把空间上靠得近的东西归为一组" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E5%80%BE%E5%90%91%E4%BA%8E%E6%8A%8A%3C/span%3E%3Cspan%20class=%22underline%22%3E%E7%A9%BA%E9%97%B4%E4%B8%8A%E9%9D%A0%E5%BE%97%E8%BF%91%3C/span%3E%3Cspan%3E%E7%9A%84%E4%B8%9C%E8%A5%BF%E5%BD%92%E4%B8%BA%E4%B8%80%E7%BB%84%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="Example" _mubu_text="%3Cspan%3EExample%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22wGsF0lPP2K%22%2C%22oh%22%3A208%2C%22ow%22%3A875%2C%22uri%22%3A%22document_image%2F33585682_5d035b21-adc3-45ab-8a95-abf88c593adc.png%22%2C%22w%22%3A400%7D%5D"/>
              </outline>
              <outline text="Law of Closure 闭合律（把缺失一块的圆补充成完整的）" _mubu_text="%3Cspan%3ELaw%20of%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EClosure%20%3C/span%3E%3Cspan%3E%E9%97%AD%E5%90%88%E5%BE%8B%EF%BC%88%E6%8A%8A%E7%BC%BA%E5%A4%B1%E4%B8%80%E5%9D%97%E7%9A%84%E5%9C%86%E8%A1%A5%E5%85%85%E6%88%90%E5%AE%8C%E6%95%B4%E7%9A%84%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
                <outline text="我们的大脑倾向于自动“脑补”缺失的部分" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E7%9A%84%E5%A4%A7%E8%84%91%E5%80%BE%E5%90%91%E4%BA%8E%E8%87%AA%E5%8A%A8%E2%80%9C%E8%84%91%E8%A1%A5%E2%80%9D%E7%BC%BA%E5%A4%B1%E7%9A%84%E9%83%A8%E5%88%86%3C/span%3E" _note="" _mubu_note="">
                  <outline text="将不完整的图形看作一个完整的图形。" _mubu_text="%3Cspan%3E%E5%B0%86%E4%B8%8D%E5%AE%8C%E6%95%B4%E7%9A%84%E5%9B%BE%E5%BD%A2%E7%9C%8B%E4%BD%9C%E4%B8%80%E4%B8%AA%E5%AE%8C%E6%95%B4%E7%9A%84%E5%9B%BE%E5%BD%A2%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                </outline>
                <outline text="Example" _mubu_text="%3Cspan%3EExample%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22BpVTQPuGkq%22%2C%22oh%22%3A227%2C%22ow%22%3A673%2C%22uri%22%3A%22document_image%2F33585682_7b794e9b-75c8-4562-f99e-27c1935af114.png%22%2C%22w%22%3A400%7D%5D"/>
              </outline>
            </outline>
          </outline>
        </outline>
        <outline text="6. Apparent Movement 似动" _mubu_text="%3Cspan%3E6.%20Apparent%20Movement%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BC%BC%E5%8A%A8%3C/span%3E" _note="" _mubu_note="">
          <outline text="当一系列静止的图像快速连续呈现时，我们会感知到运动的幻觉。" _mubu_text="%3Cspan%3E%E5%BD%93%E4%B8%80%E7%B3%BB%E5%88%97%E9%9D%99%E6%AD%A2%E7%9A%84%E5%9B%BE%E5%83%8F%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%AB%E9%80%9F%E8%BF%9E%E7%BB%AD%E5%91%88%E7%8E%B0%E6%97%B6%EF%BC%8C%E6%88%91%E4%BB%AC%E4%BC%9A%E6%84%9F%E7%9F%A5%E5%88%B0%E8%BF%90%E5%8A%A8%E7%9A%84%E5%B9%BB%E8%A7%89%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note="">
            <outline text="这其实就是电影和动画的基本原理。" _mubu_text="%3Cspan%3E%E8%BF%99%E5%85%B6%E5%AE%9E%E5%B0%B1%E6%98%AF%E7%94%B5%E5%BD%B1%E5%92%8C%E5%8A%A8%E7%94%BB%E7%9A%84%E5%9F%BA%E6%9C%AC%E5%8E%9F%E7%90%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Phi Phenomenon（飞现象） 是一个相关的概念 但是不考" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EPhi%20Phenomenon%3C/span%3E%3Cspan%3E%EF%BC%88%E9%A3%9E%E7%8E%B0%E8%B1%A1%EF%BC%89%20%E6%98%AF%E4%B8%80%E4%B8%AA%E7%9B%B8%E5%85%B3%E7%9A%84%E6%A6%82%E5%BF%B5%20%3C/span%3E%3Cspan%20class=%22underline%20text-color-red%22%3E%E4%BD%86%E6%98%AF%E4%B8%8D%E8%80%83%3C/span%3E" _note="" _mubu_note="">
            <outline text="指的是相邻的灯光快速依次闪烁，我们会觉得光点在移动。" _mubu_text="%3Cspan%3E%E6%8C%87%E7%9A%84%E6%98%AF%E7%9B%B8%E9%82%BB%E7%9A%84%E7%81%AF%E5%85%89%E5%BF%AB%E9%80%9F%E4%BE%9D%E6%AC%A1%E9%97%AA%E7%83%81%EF%BC%8C%E6%88%91%E4%BB%AC%E4%BC%9A%E8%A7%89%E5%BE%97%E5%85%89%E7%82%B9%E5%9C%A8%E7%A7%BB%E5%8A%A8%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Windows电脑加载Logo" _mubu_text="%3Cspan%3EWindows%E7%94%B5%E8%84%91%E5%8A%A0%E8%BD%BDLogo%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="7. Depth Perception（深度知觉）" _mubu_text="%3Cspan%3E7.%20Depth%20Perception%EF%BC%88%E6%B7%B1%E5%BA%A6%E7%9F%A5%E8%A7%89%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
          <outline text="Binocular Cues 双眼线索" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EBinocular%3C/span%3E%3Cspan%20class=%22bold%22%3E%20Cues%3C/span%3E%3Cspan%3E%20%E5%8F%8C%E7%9C%BC%E7%BA%BF%E7%B4%A2%3C/span%3E" _note="" _mubu_note="">
            <outline text="需要两只眼睛同时工作才能获得的深度信息，主要用于判断近距离物体的远近。" _mubu_text="%3Cspan%3E%E9%9C%80%E8%A6%81%E4%B8%A4%E5%8F%AA%E7%9C%BC%E7%9D%9B%E5%90%8C%E6%97%B6%E5%B7%A5%E4%BD%9C%E6%89%8D%E8%83%BD%E8%8E%B7%E5%BE%97%E7%9A%84%E6%B7%B1%E5%BA%A6%E4%BF%A1%E6%81%AF%EF%BC%8C%E4%B8%BB%E8%A6%81%E7%94%A8%E4%BA%8E%E5%88%A4%E6%96%AD%E8%BF%91%E8%B7%9D%E7%A6%BB%E7%89%A9%E4%BD%93%E7%9A%84%E8%BF%9C%E8%BF%91%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Retinal Disparity (视网膜差异) 左右眼视觉的样子不一样，因为物体的远近不一样。" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3ERetinal%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EDisparity%20(%E8%A7%86%E7%BD%91%E8%86%9C%E5%B7%AE%E5%BC%82)%3C/span%3E%3Cspan%3E%20%E5%B7%A6%E5%8F%B3%E7%9C%BC%E8%A7%86%E8%A7%89%E7%9A%84%E6%A0%B7%E5%AD%90%E4%B8%8D%E4%B8%80%E6%A0%B7%EF%BC%8C%E5%9B%A0%E4%B8%BA%E7%89%A9%E4%BD%93%E7%9A%84%E8%BF%9C%E8%BF%91%E4%B8%8D%E4%B8%80%E6%A0%B7%E3%80%82%3C/span%3E" _note="" _mubu_note="">
              <outline text="物体越近，这种差异就越大。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%89%A9%E4%BD%93%E8%B6%8A%E8%BF%91%EF%BC%8C%E8%BF%99%E7%A7%8D%E5%B7%AE%E5%BC%82%E5%B0%B1%E8%B6%8A%E5%A4%A7%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Convergence (辐合) 当你看近处物体时，你的两只眼睛会向内转动，形成“斗鸡眼”。大脑能感知到眼部肌肉的紧张程度，肌肉越紧张，说明物体越近。" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3EConvergence%3C/span%3E%3Cspan%20class=%22bold%22%3E%20(%E8%BE%90%E5%90%88)%3C/span%3E%3Cspan%3E%20%E5%BD%93%E4%BD%A0%E7%9C%8B%E8%BF%91%E5%A4%84%E7%89%A9%E4%BD%93%E6%97%B6%EF%BC%8C%E4%BD%A0%E7%9A%84%E4%B8%A4%E5%8F%AA%E7%9C%BC%E7%9D%9B%E4%BC%9A%E5%90%91%E5%86%85%E8%BD%AC%E5%8A%A8%EF%BC%8C%E5%BD%A2%E6%88%90%E2%80%9C%E6%96%97%E9%B8%A1%E7%9C%BC%E2%80%9D%E3%80%82%E5%A4%A7%E8%84%91%E8%83%BD%E6%84%9F%E7%9F%A5%E5%88%B0%E7%9C%BC%E9%83%A8%E8%82%8C%E8%82%89%E7%9A%84%E7%B4%A7%E5%BC%A0%E7%A8%8B%E5%BA%A6%EF%BC%8C%E8%82%8C%E8%82%89%E8%B6%8A%E7%B4%A7%E5%BC%A0%EF%BC%8C%E8%AF%B4%E6%98%8E%E7%89%A9%E4%BD%93%E8%B6%8A%E8%BF%91%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Monocular Cues 单眼线索" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EMonocular%3C/span%3E%3Cspan%20class=%22bold%22%3E%20Cues%3C/span%3E%3Cspan%3E%20%E5%8D%95%E7%9C%BC%E7%BA%BF%E7%B4%A2%3C/span%3E" _note="" _mubu_note="">
            <outline text="Linear Perspective (线性透视) ：平行线汇聚于一点，汇聚越厉害，越远" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3ELinear%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EPerspective%20(%E7%BA%BF%E6%80%A7%E9%80%8F%E8%A7%86)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%B9%B3%E8%A1%8C%E7%BA%BF%3C/span%3E%3Cspan%3E%E6%B1%87%E8%81%9A%E4%BA%8E%E4%B8%80%E7%82%B9%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B1%87%E8%81%9A%E8%B6%8A%E5%8E%89%E5%AE%B3%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%B6%8A%E8%BF%9C%3C/span%3E" _note="" _mubu_note="">
              <outline text="平行的线条（如铁轨、公路）在远方看起来会汇聚于一点。汇聚得越厉害，感觉距离越远。" _mubu_text="%3Cspan%3E%E5%B9%B3%E8%A1%8C%E7%9A%84%E7%BA%BF%E6%9D%A1%EF%BC%88%E5%A6%82%E9%93%81%E8%BD%A8%E3%80%81%E5%85%AC%E8%B7%AF%EF%BC%89%E5%9C%A8%E8%BF%9C%E6%96%B9%E7%9C%8B%E8%B5%B7%E6%9D%A5%E4%BC%9A%E6%B1%87%E8%81%9A%E4%BA%8E%E4%B8%80%E7%82%B9%E3%80%82%E6%B1%87%E8%81%9A%E5%BE%97%E8%B6%8A%E5%8E%89%E5%AE%B3%EF%BC%8C%E6%84%9F%E8%A7%89%E8%B7%9D%E7%A6%BB%E8%B6%8A%E8%BF%9C%E3%80%82%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22xBAJYpFELD%22%2C%22oh%22%3A1536%2C%22ow%22%3A2048%2C%22uri%22%3A%22document_image%2F33585682_b978ffe2-9bd0-4ff1-8850-137ecbf4cefe.png%22%2C%22w%22%3A400%7D%5D"/>
            </outline>
            <outline text="Interposition (or Overlap, 遮挡) ：被挡住的物体更远" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3EInterposition%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(or%20Overlap,%20%E9%81%AE%E6%8C%A1)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%A2%AB%E6%8C%A1%E4%BD%8F%3C/span%3E%3Cspan%3E%E7%9A%84%E7%89%A9%E4%BD%93%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%9B%B4%E8%BF%9C%3C/span%3E" _note="" _mubu_note="">
              <outline text="如果一个物体挡住了另一个物体，被挡住的那个物体会被感知为更远。" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E4%B8%80%E4%B8%AA%E7%89%A9%E4%BD%93%E6%8C%A1%E4%BD%8F%E4%BA%86%E5%8F%A6%E4%B8%80%E4%B8%AA%E7%89%A9%E4%BD%93%EF%BC%8C%E8%A2%AB%E6%8C%A1%E4%BD%8F%E7%9A%84%E9%82%A3%E4%B8%AA%E7%89%A9%E4%BD%93%E4%BC%9A%E8%A2%AB%E6%84%9F%E7%9F%A5%E4%B8%BA%E6%9B%B4%E8%BF%9C%E3%80%82%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22WYPJWmzGda%22%2C%22oh%22%3A1536%2C%22ow%22%3A2048%2C%22uri%22%3A%22document_image%2F33585682_b6ed61fc-cffd-49a2-d8c6-d11b77af329a.png%22%2C%22w%22%3A400%7D%5D"/>
            </outline>
            <outline text="Relative Size (相对大小) ：如果两个物体大小相同，小的那个更远" _mubu_text="%3Cspan%20class=%22bold%22%3ERelative%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3ESize%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E7%9B%B8%E5%AF%B9%E5%A4%A7%E5%B0%8F)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%E5%A6%82%E6%9E%9C%E4%B8%A4%E4%B8%AA%E7%89%A9%E4%BD%93%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A4%A7%E5%B0%8F%E7%9B%B8%E5%90%8C%EF%BC%8C%E5%B0%8F%E7%9A%84%E9%82%A3%E4%B8%AA%E6%9B%B4%E8%BF%9C%3C/span%3E" _note="" _mubu_note="">
              <outline text="如果我们知道两个物体实际大小相同，那么在视野中看起来更小的那个会被感知为更远。" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E6%88%91%E4%BB%AC%E7%9F%A5%E9%81%93%E4%B8%A4%E4%B8%AA%E7%89%A9%E4%BD%93%E5%AE%9E%E9%99%85%E5%A4%A7%E5%B0%8F%E7%9B%B8%E5%90%8C%EF%BC%8C%E9%82%A3%E4%B9%88%E5%9C%A8%E8%A7%86%E9%87%8E%E4%B8%AD%E7%9C%8B%E8%B5%B7%E6%9D%A5%E6%9B%B4%E5%B0%8F%E7%9A%84%E9%82%A3%E4%B8%AA%E4%BC%9A%E8%A2%AB%E6%84%9F%E7%9F%A5%E4%B8%BA%E6%9B%B4%E8%BF%9C%E3%80%82%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22PIYPOQxUGC%22%2C%22oh%22%3A1536%2C%22ow%22%3A2048%2C%22uri%22%3A%22document_image%2F33585682_426c9773-9f09-413d-d3b6-0aead725142c.png%22%2C%22w%22%3A400%7D%5D"/>
            </outline>
            <outline text="Relative Clarity (相对清晰度) ：更清晰的更近，更朦胧的更远" _mubu_text="%3Cspan%20class=%22bold%22%3ERelative%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EClarity%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E7%9B%B8%E5%AF%B9%E6%B8%85%E6%99%B0%E5%BA%A6)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%9B%B4%E6%B8%85%E6%99%B0%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%9B%B4%E8%BF%91%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%9B%B4%E6%9C%A6%E8%83%A7%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%9B%B4%E8%BF%9C%3C/span%3E" _note="" _mubu_note="">
              <outline text="远处的物体看起来更模糊、朦胧，而近处的物体更清晰。这是因为空气中的尘埃和水汽会影响光线。" _mubu_text="%3Cspan%3E%E8%BF%9C%E5%A4%84%E7%9A%84%E7%89%A9%E4%BD%93%E7%9C%8B%E8%B5%B7%E6%9D%A5%E6%9B%B4%E6%A8%A1%E7%B3%8A%E3%80%81%E6%9C%A6%E8%83%A7%EF%BC%8C%E8%80%8C%E8%BF%91%E5%A4%84%E7%9A%84%E7%89%A9%E4%BD%93%E6%9B%B4%E6%B8%85%E6%99%B0%E3%80%82%E8%BF%99%E6%98%AF%E5%9B%A0%E4%B8%BA%E7%A9%BA%E6%B0%94%E4%B8%AD%E7%9A%84%E5%B0%98%E5%9F%83%E5%92%8C%E6%B0%B4%E6%B1%BD%E4%BC%9A%E5%BD%B1%E5%93%8D%E5%85%89%E7%BA%BF%E3%80%82%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22qXssJXTJhf%22%2C%22oh%22%3A1536%2C%22ow%22%3A2048%2C%22uri%22%3A%22document_image%2F33585682_5a20af51-3f2c-48b1-baac-c49d95caa946.png%22%2C%22w%22%3A400%7D%5D"/>
            </outline>
            <outline text="Texture Gradient (纹理梯度) ：纹理清晰更近，纹理模糊更远" _mubu_text="%3Cspan%20class=%22bold%22%3ETexture%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EGradient%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E7%BA%B9%E7%90%86%E6%A2%AF%E5%BA%A6)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%E7%BA%B9%E7%90%86%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B8%85%E6%99%B0%E6%9B%B4%E8%BF%91%3C/span%3E%3Cspan%3E%EF%BC%8C%E7%BA%B9%E7%90%86%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%A8%A1%E7%B3%8A%E6%9B%B4%E8%BF%9C%3C/span%3E" _note="" _mubu_note="">
              <outline text="近处的物体纹理细节清晰可见，远处的物体纹理则变得密集而模糊。" _mubu_text="%3Cspan%3E%E8%BF%91%E5%A4%84%E7%9A%84%E7%89%A9%E4%BD%93%E7%BA%B9%E7%90%86%E7%BB%86%E8%8A%82%E6%B8%85%E6%99%B0%E5%8F%AF%E8%A7%81%EF%BC%8C%E8%BF%9C%E5%A4%84%E7%9A%84%E7%89%A9%E4%BD%93%E7%BA%B9%E7%90%86%E5%88%99%E5%8F%98%E5%BE%97%E5%AF%86%E9%9B%86%E8%80%8C%E6%A8%A1%E7%B3%8A%E3%80%82%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22eIt5S6loHf%22%2C%22oh%22%3A1537%2C%22ow%22%3A2048%2C%22uri%22%3A%22document_image%2F33585682_6951372f-66cb-4fe1-b26b-ac8ec1af50d6.png%22%2C%22w%22%3A400%7D%5D"/>
            </outline>
          </outline>
        </outline>
        <outline text="8. Perceptual Constancy" _mubu_text="%3Cspan%3E8.%20Perceptual%20Constancy%3C/span%3E" _note="" _mubu_note="">
          <outline text="即使物体在变化，我们仍然认得出物体" _mubu_text="%3Cspan%3E%E5%8D%B3%E4%BD%BF%E7%89%A9%E4%BD%93%E5%9C%A8%E5%8F%98%E5%8C%96%EF%BC%8C%E6%88%91%E4%BB%AC%E4%BB%8D%E7%84%B6%E8%AE%A4%E5%BE%97%E5%87%BA%E7%89%A9%E4%BD%93%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Color Constancy 颜色一致性 - 看起来不同，实际上相同" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EColor%20%3C/span%3E%3Cspan%3EConstancy%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%A2%9C%E8%89%B2%3C/span%3E%3Cspan%3E%E4%B8%80%E8%87%B4%E6%80%A7%20-%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%9C%8B%E8%B5%B7%E6%9D%A5%3C/span%3E%3Cspan%3E%E4%B8%8D%E5%90%8C%EF%BC%8C%E5%AE%9E%E9%99%85%E4%B8%8A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%9B%B8%E5%90%8C%3C/span%3E" _note="" _mubu_note="">
            <outline text="图：深绿色和浅绿色其实会被认为是一个颜色，即使他们不一样。阳光欺骗了你。看起来不同，你感觉相同。" _mubu_text="%3Cspan%3E%E5%9B%BE%EF%BC%9A%E6%B7%B1%E7%BB%BF%E8%89%B2%E5%92%8C%E6%B5%85%E7%BB%BF%E8%89%B2%E5%85%B6%E5%AE%9E%E4%BC%9A%E8%A2%AB%E8%AE%A4%E4%B8%BA%E6%98%AF%E4%B8%80%E4%B8%AA%E9%A2%9C%E8%89%B2%EF%BC%8C%E5%8D%B3%E4%BD%BF%E4%BB%96%E4%BB%AC%E4%B8%8D%E4%B8%80%E6%A0%B7%E3%80%82%E9%98%B3%E5%85%89%E6%AC%BA%E9%AA%97%E4%BA%86%E4%BD%A0%E3%80%82%E7%9C%8B%E8%B5%B7%E6%9D%A5%E4%B8%8D%E5%90%8C%EF%BC%8C%E4%BD%A0%E6%84%9F%E8%A7%89%E7%9B%B8%E5%90%8C%E3%80%82%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22Bw6YiKZq7y%22%2C%22oh%22%3A718%2C%22ow%22%3A960%2C%22uri%22%3A%22document_image%2F33585682_8ac3059a-b209-410b-e6df-e3ce0ba5a863.jpeg%22%2C%22w%22%3A400%7D%5D"/>
          </outline>
          <outline text="Lightness Constancy 光线一致性 - 看起来不同，实际上相同" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ELightness%20%3C/span%3E%3Cspan%3EConstancy%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%85%89%E7%BA%BF%3C/span%3E%3Cspan%3E%E4%B8%80%E8%87%B4%E6%80%A7%20-%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%9C%8B%E8%B5%B7%E6%9D%A5%3C/span%3E%3Cspan%3E%E4%B8%8D%E5%90%8C%EF%BC%8C%E5%AE%9E%E9%99%85%E4%B8%8A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%9B%B8%E5%90%8C%3C/span%3E" _note="" _mubu_note="">
            <outline text="图：你敢信！AB其实是一个颜色。看起来相同，你感觉不同。" _mubu_text="%3Cspan%3E%E5%9B%BE%EF%BC%9A%E4%BD%A0%E6%95%A2%E4%BF%A1%EF%BC%81AB%E5%85%B6%E5%AE%9E%E6%98%AF%E4%B8%80%E4%B8%AA%E9%A2%9C%E8%89%B2%E3%80%82%E7%9C%8B%E8%B5%B7%E6%9D%A5%E7%9B%B8%E5%90%8C%EF%BC%8C%E4%BD%A0%E6%84%9F%E8%A7%89%E4%B8%8D%E5%90%8C%E3%80%82%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22mD9ZJyMPNy%22%2C%22oh%22%3A381%2C%22ow%22%3A500%2C%22uri%22%3A%22document_image%2F33585682_213e3333-4f9a-4982-9659-3863b3019656.png%22%2C%22w%22%3A400%7D%2C%7B%22id%22%3A%22q2Rs9qvZfO%22%2C%22oh%22%3A389%2C%22ow%22%3A500%2C%22uri%22%3A%22document_image%2F33585682_4f7b496f-5ad4-4d73-e924-bd609901e2ec.gif%22%2C%22w%22%3A400%7D%5D"/>
          </outline>
          <outline text="Shape Constancy 形状一致性 - 旋转一下，形状是相同的" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EShape%20%3C/span%3E%3Cspan%3EConstancy%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BD%A2%E7%8A%B6%3C/span%3E%3Cspan%3E%E4%B8%80%E8%87%B4%E6%80%A7%20-%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%97%8B%E8%BD%AC%E4%B8%80%E4%B8%8B%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%BD%A2%E7%8A%B6%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%9B%B8%E5%90%8C%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E" _note="" _mubu_note="">
            <outline text="图：我一直知道这是一个长方形，而不是梯形" _mubu_text="%3Cspan%3E%E5%9B%BE%EF%BC%9A%E6%88%91%E4%B8%80%E7%9B%B4%E7%9F%A5%E9%81%93%E8%BF%99%E6%98%AF%E4%B8%80%E4%B8%AA%E9%95%BF%E6%96%B9%E5%BD%A2%EF%BC%8C%E8%80%8C%E4%B8%8D%E6%98%AF%E6%A2%AF%E5%BD%A2%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22EKfTFJDLiS%22%2C%22oh%22%3A696%2C%22ow%22%3A1400%2C%22uri%22%3A%22document_image%2F33585682_fa956d13-1d92-4140-f2ac-5474b48676fa.gif%22%2C%22w%22%3A400%7D%5D"/>
          </outline>
        </outline>
      </outline>
      <outline text="2.2 思考 Thinking, Problem- Solving, Judgments, and Decision-Making（2200字）" _mubu_text="%3Cspan%3E2.2%20%E6%80%9D%E8%80%83%20Thinking,%20Problem-%20Solving,%20Judgments,%20and%20Decision-Making%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E2200%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="What is Thinking? Sensation - Perception - Thinking" _mubu_text="%3Cspan%3EWhat%20is%20Thinking?%20%3C/span%3E%3Cspan%20class=%22underline%22%3ESensation%20-%20Perception%20-%20Thinking%3C/span%3E" _note="" _mubu_note="">
          <outline text="Cognitive Psychology 认知心理学" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ECognitive%20%3C/span%3E%3Cspan%20class=%22bold%22%3EPsychology%3C/span%3E%3Cspan%3E%20%E8%AE%A4%E7%9F%A5%E5%BF%83%E7%90%86%E5%AD%A6%3C/span%3E" _note="" _mubu_note="">
            <outline text="研究所有内部心理过程的领域，包括思考、记忆、沟通等等" _mubu_text="%3Cspan%3E%E7%A0%94%E7%A9%B6%E6%89%80%E6%9C%89%E5%86%85%E9%83%A8%E5%BF%83%E7%90%86%E8%BF%87%E7%A8%8B%E7%9A%84%E9%A2%86%E5%9F%9F%EF%BC%8C%E5%8C%85%E6%8B%AC%E6%80%9D%E8%80%83%E3%80%81%E8%AE%B0%E5%BF%86%E3%80%81%E6%B2%9F%E9%80%9A%E7%AD%89%E7%AD%89%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="额叶在工作" _mubu_text="%3Cspan%3E%E9%A2%9D%E5%8F%B6%E5%9C%A8%E5%B7%A5%E4%BD%9C%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Metacognition 你发现自己在思考，Thinking you&apos;re thinking" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EMetacognition%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E4%BD%A0%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%8F%91%E7%8E%B0%E8%87%AA%E5%B7%B1%E5%9C%A8%E6%80%9D%E8%80%83%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EThinking%20you&apos;re%20thinking%3C/span%3E" _note="" _mubu_note="">
            <outline text="反思和监控你自己的思考过程。" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%8F%8D%E6%80%9D%E5%92%8C%E7%9B%91%E6%8E%A7%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BD%A0%E8%87%AA%E5%B7%B1%E7%9A%84%E6%80%9D%E8%80%83%E8%BF%87%E7%A8%8B%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="1. Concepts 概念，针对相似的物体、事件、想法或人物的分组" _mubu_text="%3Cspan%3E1.%20Concepts%20%E6%A6%82%E5%BF%B5%EF%BC%8C%E9%92%88%E5%AF%B9%E7%9B%B8%E4%BC%BC%E7%9A%84%E7%89%A9%E4%BD%93%E3%80%81%E4%BA%8B%E4%BB%B6%E3%80%81%E6%83%B3%E6%B3%95%E6%88%96%E4%BA%BA%E7%89%A9%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%88%86%E7%BB%84%3C/span%3E" _note="" _mubu_note="">
          <outline text="大脑处理海量信息的方式是依靠Concepts" _mubu_text="%3Cspan%3E%E5%A4%A7%E8%84%91%E5%A4%84%E7%90%86%E6%B5%B7%E9%87%8F%E4%BF%A1%E6%81%AF%E7%9A%84%E6%96%B9%E5%BC%8F%E6%98%AF%E4%BE%9D%E9%9D%A0Concepts%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Concepts 概念，针对相似的物体、事件、想法或人物的心理分组，&quot;What is it?&quot;，一个概念是什么（老师是教课的人）" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EConcepts%20%3C/span%3E%3Cspan%3E%E6%A6%82%E5%BF%B5%EF%BC%8C%E9%92%88%E5%AF%B9%E7%9B%B8%E4%BC%BC%E7%9A%84%3C/span%3E%3Cspan%20class=%22underline%22%3E%E7%89%A9%E4%BD%93%E3%80%81%E4%BA%8B%E4%BB%B6%E3%80%81%E6%83%B3%E6%B3%95%E6%88%96%E4%BA%BA%E7%89%A9%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%83%E7%90%86%E5%88%86%E7%BB%84%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-red%22%3E%22What%20is%20it?%22%EF%BC%8C%3C/span%3E%3Cspan%20class=%22underline%22%3E%E4%B8%80%E4%B8%AA%E6%A6%82%E5%BF%B5%E6%98%AF%E4%BB%80%E4%B9%88%EF%BC%88%E8%80%81%E5%B8%88%E6%98%AF%E6%95%99%E8%AF%BE%E7%9A%84%E4%BA%BA%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="“狗🐶”就是一个概念" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E2%80%9C%E7%8B%97%F0%9F%90%B6%E2%80%9D%3C/span%3E%3Cspan%3E%E5%B0%B1%E6%98%AF%E4%B8%80%E4%B8%AA%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E6%A6%82%E5%BF%B5%3C/span%3E" _note="" _mubu_note="">
              <outline text="你不需要记住每一只狗的样子" _mubu_text="%3Cspan%3E%E4%BD%A0%E4%B8%8D%E9%9C%80%E8%A6%81%E8%AE%B0%E4%BD%8F%E6%AF%8F%E4%B8%80%E5%8F%AA%E7%8B%97%E7%9A%84%E6%A0%B7%E5%AD%90%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="你只需要知道“狗”这个概念包含了“四条腿、会汪汪叫、有尾巴”等共同特征。" _mubu_text="%3Cspan%3E%E4%BD%A0%E5%8F%AA%E9%9C%80%E8%A6%81%E7%9F%A5%E9%81%93%E2%80%9C%E7%8B%97%E2%80%9D%E8%BF%99%E4%B8%AA%E6%A6%82%E5%BF%B5%E5%8C%85%E5%90%AB%E4%BA%86%E2%80%9C%E5%9B%9B%E6%9D%A1%E8%85%BF%E3%80%81%E4%BC%9A%E6%B1%AA%E6%B1%AA%E5%8F%AB%E3%80%81%E6%9C%89%E5%B0%BE%E5%B7%B4%E2%80%9D%E7%AD%89%E5%85%B1%E5%90%8C%E7%89%B9%E5%BE%81%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="Prototype 原型，概念中最经典的例子" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EPrototype%20%3C/span%3E%3Cspan%3E%E5%8E%9F%E5%9E%8B%EF%BC%8C%E6%A6%82%E5%BF%B5%E4%B8%AD%3C/span%3E%3Cspan%20class=%22underline%22%3E%E6%9C%80%E7%BB%8F%E5%85%B8%E7%9A%84%3C/span%3E%3Cspan%20class=%22underline%20text-color-blue%22%3E%E4%BE%8B%E5%AD%90%3C/span%3E" _note="" _mubu_note="">
            <outline text="这是某个概念中最典型、最具代表性的例子。" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AF%E6%9F%90%E4%B8%AA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%A6%82%E5%BF%B5%3C/span%3E%3Cspan%3E%E4%B8%AD%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%9C%80%E5%85%B8%E5%9E%8B%E3%80%81%E6%9C%80%E5%85%B7%E4%BB%A3%E8%A1%A8%E6%80%A7%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E4%BE%8B%E5%AD%90%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="当提到“鸟🐦”的时候，脑子里出现的可能是麻雀或者鸽子，而不是企鹅🐧或者鸵鸟" _mubu_text="%3Cspan%3E%E5%BD%93%E6%8F%90%E5%88%B0%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E2%80%9C%E9%B8%9F%F0%9F%90%A6%E2%80%9D%3C/span%3E%3Cspan%3E%E7%9A%84%E6%97%B6%E5%80%99%EF%BC%8C%E8%84%91%E5%AD%90%E9%87%8C%E5%87%BA%E7%8E%B0%E7%9A%84%E5%8F%AF%E8%83%BD%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%BA%BB%E9%9B%80%E6%88%96%E8%80%85%E9%B8%BD%E5%AD%90%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%80%8C%E4%B8%8D%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%BC%81%E9%B9%85%F0%9F%90%A7%E6%88%96%E8%80%85%E9%B8%B5%E9%B8%9F%3C/span%3E" _note="" _mubu_note="">
              <outline text="因为麻雀和鸽子更符合“小巧、会飞、有羽毛”的特点" _mubu_text="%3Cspan%3E%E5%9B%A0%E4%B8%BA%E9%BA%BB%E9%9B%80%E5%92%8C%E9%B8%BD%E5%AD%90%E6%9B%B4%E7%AC%A6%E5%90%88%E2%80%9C%E5%B0%8F%E5%B7%A7%E3%80%81%E4%BC%9A%E9%A3%9E%E3%80%81%E6%9C%89%E7%BE%BD%E6%AF%9B%E2%80%9D%E7%9A%84%E7%89%B9%E7%82%B9%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="所以麻雀和鸽子更容易被归类为“鸟”，而企鹅需要花费更多时间" _mubu_text="%3Cspan%3E%E6%89%80%E4%BB%A5%E9%BA%BB%E9%9B%80%E5%92%8C%E9%B8%BD%E5%AD%90%E6%9B%B4%E5%AE%B9%E6%98%93%E8%A2%AB%E5%BD%92%E7%B1%BB%E4%B8%BA%E2%80%9C%E9%B8%9F%E2%80%9D%EF%BC%8C%E8%80%8C%E4%BC%81%E9%B9%85%E9%9C%80%E8%A6%81%E8%8A%B1%E8%B4%B9%E6%9B%B4%E5%A4%9A%E6%97%B6%E9%97%B4%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="e.g. 鲸鱼是哺乳动物🐳" _mubu_text="%3Cspan%3Ee.g.%20%E9%B2%B8%E9%B1%BC%E6%98%AF%E5%93%BA%E4%B9%B3%E5%8A%A8%E7%89%A9%F0%9F%90%B3%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="Schema 图式，是一个组织我们知识的心理框架，&quot;What should I expect?&quot;，我的行为规范（下课铃响了才能离开教室）" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ESchema%20%3C/span%3E%3Cspan%3E%E5%9B%BE%E5%BC%8F%EF%BC%8C%E6%98%AF%E4%B8%80%E4%B8%AA%3C/span%3E%3Cspan%20class=%22underline%22%3E%E7%BB%84%E7%BB%87%E6%88%91%E4%BB%AC%E7%9F%A5%E8%AF%86%E7%9A%84%3C/span%3E%3Cspan%20class=%22underline%20text-color-blue%22%3E%E5%BF%83%E7%90%86%E6%A1%86%E6%9E%B6%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-red%22%3E%22What%20should%20I%20expect?%22%EF%BC%8C%3C/span%3E%3Cspan%20class=%22underline%22%3E%E6%88%91%E7%9A%84%E8%A1%8C%E4%B8%BA%E8%A7%84%E8%8C%83%EF%BC%88%E4%B8%8B%E8%AF%BE%E9%93%83%E5%93%8D%E4%BA%86%E6%89%8D%E8%83%BD%E7%A6%BB%E5%BC%80%E6%95%99%E5%AE%A4%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="Assimilation (同化) 大脑的舒适区，把例子套到模式中" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EAssimilation%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E5%90%8C%E5%8C%96)%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22underline%22%3E%E5%A4%A7%E8%84%91%E7%9A%84%3C/span%3E%3Cspan%20class=%22underline%20text-color-blue%22%3E%E8%88%92%E9%80%82%E5%8C%BA%3C/span%3E%3Cspan%20class=%22underline%22%3E%EF%BC%8C%E6%8A%8A%E4%BE%8B%E5%AD%90%E5%A5%97%E5%88%B0%E6%A8%A1%E5%BC%8F%E4%B8%AD%3C/span%3E" _note="" _mubu_note="">
              <outline text="将新信息融入已有的Schema中。把符合schema的新例子“同化”进去。" _mubu_text="%3Cspan%3E%E5%B0%86%E6%96%B0%E4%BF%A1%E6%81%AF%E8%9E%8D%E5%85%A5%E5%B7%B2%E6%9C%89%E7%9A%84Schema%E4%B8%AD%E3%80%82%E6%8A%8A%E7%AC%A6%E5%90%88schema%E7%9A%84%E6%96%B0%E4%BE%8B%E5%AD%90%E2%80%9C%E5%90%8C%E5%8C%96%E2%80%9D%E8%BF%9B%E5%8E%BB%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Accommodation (顺应/调节) 学习的镇痛区，重构认知以学习" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EAccommodation%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E9%A1%BA%E5%BA%94/%E8%B0%83%E8%8A%82)%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22underline%22%3E%E5%AD%A6%E4%B9%A0%E7%9A%84%3C/span%3E%3Cspan%20class=%22underline%20text-color-blue%22%3E%E9%95%87%E7%97%9B%E5%8C%BA%3C/span%3E%3Cspan%20class=%22underline%22%3E%EF%BC%8C%E9%87%8D%E6%9E%84%E8%AE%A4%E7%9F%A5%E4%BB%A5%E5%AD%A6%E4%B9%A0%3C/span%3E" _note="" _mubu_note="">
              <outline text="当新信息与已有的Schema冲突时，我们需要修改或调整旧的Schema。他必须调节Schema，加入新的信息，比如“猫会喵喵叫，而狗会汪汪叫”，从而区分猫和狗。这就是Accommodation。" _mubu_text="%3Cspan%3E%E5%BD%93%E6%96%B0%E4%BF%A1%E6%81%AF%E4%B8%8E%E5%B7%B2%E6%9C%89%E7%9A%84Schema%E5%86%B2%E7%AA%81%E6%97%B6%EF%BC%8C%E6%88%91%E4%BB%AC%E9%9C%80%E8%A6%81%E4%BF%AE%E6%94%B9%E6%88%96%E8%B0%83%E6%95%B4%E6%97%A7%E7%9A%84Schema%E3%80%82%E4%BB%96%E5%BF%85%E9%A1%BB%E8%B0%83%E8%8A%82Schema%EF%BC%8C%E5%8A%A0%E5%85%A5%E6%96%B0%E7%9A%84%E4%BF%A1%E6%81%AF%EF%BC%8C%E6%AF%94%E5%A6%82%E2%80%9C%E7%8C%AB%E4%BC%9A%E5%96%B5%E5%96%B5%E5%8F%AB%EF%BC%8C%E8%80%8C%E7%8B%97%E4%BC%9A%E6%B1%AA%E6%B1%AA%E5%8F%AB%E2%80%9D%EF%BC%8C%E4%BB%8E%E8%80%8C%E5%8C%BA%E5%88%86%E7%8C%AB%E5%92%8C%E7%8B%97%E3%80%82%E8%BF%99%E5%B0%B1%E6%98%AFAccommodation%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="“猫🐱”的Schema可能包括：有胡须、爪子很锋利、喜欢玩玩具、会喵喵叫等等。" _mubu_text="%3Cspan%3E%E2%80%9C%E7%8C%AB%F0%9F%90%B1%E2%80%9D%E7%9A%84Schema%E5%8F%AF%E8%83%BD%E5%8C%85%E6%8B%AC%EF%BC%9A%E6%9C%89%E8%83%A1%E9%A1%BB%E3%80%81%E7%88%AA%E5%AD%90%E5%BE%88%E9%94%8B%E5%88%A9%E3%80%81%E5%96%9C%E6%AC%A2%E7%8E%A9%E7%8E%A9%E5%85%B7%E3%80%81%E4%BC%9A%E5%96%B5%E5%96%B5%E5%8F%AB%E7%AD%89%E7%AD%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="2. Problem Solving 解决问题" _mubu_text="%3Cspan%3E2.%20Problem%20Solving%20%E8%A7%A3%E5%86%B3%E9%97%AE%E9%A2%98%3C/span%3E" _note="" _mubu_note="">
          <outline text="思维方式 Thinking Way" _mubu_text="%3Cspan%3E%E6%80%9D%E7%BB%B4%E6%96%B9%E5%BC%8F%20Thinking%20Way%3C/span%3E" _note="" _mubu_note="">
            <outline text="Convergent Thinking (聚合思维) 缩小可能性，找到正确答案；选择题四选一" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EConvergent%20%3C/span%3E%3Cspan%20class=%22bold%22%3EThinking%20(%E8%81%9A%E5%90%88%E6%80%9D%E7%BB%B4)%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%BC%A9%E5%B0%8F%E5%8F%AF%E8%83%BD%E6%80%A7%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%89%BE%E5%88%B0%E6%AD%A3%E7%A1%AE%E7%AD%94%E6%A1%88%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%80%89%E6%8B%A9%E9%A2%98%E5%9B%9B%E9%80%89%E4%B8%80%3C/span%3E" _note="" _mubu_note="">
              <outline text="这种思维方式旨在缩小可能性，找到唯一的、最佳的答案。它强调逻辑、准确性和速度。" _mubu_text="%3Cspan%3E%E8%BF%99%E7%A7%8D%E6%80%9D%E7%BB%B4%E6%96%B9%E5%BC%8F%E6%97%A8%E5%9C%A8%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%BC%A9%E5%B0%8F%E5%8F%AF%E8%83%BD%E6%80%A7%EF%BC%8C%E6%89%BE%E5%88%B0%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%94%AF%E4%B8%80%E7%9A%84%E3%80%81%E6%9C%80%E4%BD%B3%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%AD%94%E6%A1%88%3C/span%3E%3Cspan%3E%E3%80%82%E5%AE%83%E5%BC%BA%E8%B0%83%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%80%BB%E8%BE%91%E3%80%81%E5%87%86%E7%A1%AE%E6%80%A7%E5%92%8C%E9%80%9F%E5%BA%A6%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="比如，做AP考试的选择题时，你需要从四个选项中选出唯一正确的答案，这就是典型的聚合思维。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%EF%BC%8C%E5%81%9AAP%E8%80%83%E8%AF%95%E7%9A%84%E9%80%89%E6%8B%A9%E9%A2%98%E6%97%B6%EF%BC%8C%E4%BD%A0%E9%9C%80%E8%A6%81%E4%BB%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%9B%9B%E4%B8%AA%E9%80%89%E9%A1%B9%E4%B8%AD%E9%80%89%E5%87%BA%E5%94%AF%E4%B8%80%E6%AD%A3%E7%A1%AE%3C/span%3E%3Cspan%3E%E7%9A%84%E7%AD%94%E6%A1%88%EF%BC%8C%E8%BF%99%E5%B0%B1%E6%98%AF%E5%85%B8%E5%9E%8B%E7%9A%84%E8%81%9A%E5%90%88%E6%80%9D%E7%BB%B4%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Divergent Thinking (发散思维) 探索可能性，产生创造性的想法；头脑风暴和天马行空" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EDivergent%20%3C/span%3E%3Cspan%20class=%22bold%22%3EThinking%20(%E5%8F%91%E6%95%A3%E6%80%9D%E7%BB%B4)%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8E%A2%E7%B4%A2%E5%8F%AF%E8%83%BD%E6%80%A7%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BA%A7%E7%94%9F%E5%88%9B%E9%80%A0%E6%80%A7%E7%9A%84%E6%83%B3%E6%B3%95%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A4%B4%E8%84%91%E9%A3%8E%E6%9A%B4%E5%92%8C%E5%A4%A9%E9%A9%AC%E8%A1%8C%E7%A9%BA%3C/span%3E" _note="" _mubu_note="">
              <outline text="这种思维方式旨在探索多种可能性，产生创造性的、新颖的想法。它不追求唯一答案，而是追求数量和多样性。" _mubu_text="%3Cspan%3E%E8%BF%99%E7%A7%8D%E6%80%9D%E7%BB%B4%E6%96%B9%E5%BC%8F%E6%97%A8%E5%9C%A8%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%8E%A2%E7%B4%A2%E5%A4%9A%E7%A7%8D%E5%8F%AF%E8%83%BD%E6%80%A7%EF%BC%8C%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E4%BA%A7%E7%94%9F%E5%88%9B%E9%80%A0%E6%80%A7%E7%9A%84%E3%80%81%E6%96%B0%E9%A2%96%E7%9A%84%E6%83%B3%E6%B3%95%3C/span%3E%3Cspan%3E%E3%80%82%E5%AE%83%E4%B8%8D%E8%BF%BD%E6%B1%82%E5%94%AF%E4%B8%80%E7%AD%94%E6%A1%88%EF%BC%8C%E8%80%8C%E6%98%AF%E8%BF%BD%E6%B1%82%E6%95%B0%E9%87%8F%E5%92%8C%E5%A4%9A%E6%A0%B7%E6%80%A7%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="比如，老师让你思考“一块砖头有多少种用途？”，你需要天马行空地想出各种答案（盖房子、当武器、做哑铃、当画板...），这就是发散思维。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%EF%BC%8C%E8%80%81%E5%B8%88%E8%AE%A9%E4%BD%A0%E6%80%9D%E8%80%83%E2%80%9C%E4%B8%80%E5%9D%97%E7%A0%96%E5%A4%B4%E6%9C%89%E5%A4%9A%E5%B0%91%E7%A7%8D%E7%94%A8%E9%80%94%EF%BC%9F%E2%80%9D%EF%BC%8C%E4%BD%A0%E9%9C%80%E8%A6%81%E5%A4%A9%E9%A9%AC%E8%A1%8C%E7%A9%BA%E5%9C%B0%E6%83%B3%E5%87%BA%E5%90%84%E7%A7%8D%E7%AD%94%E6%A1%88%EF%BC%88%E7%9B%96%E6%88%BF%E5%AD%90%E3%80%81%E5%BD%93%E6%AD%A6%E5%99%A8%E3%80%81%E5%81%9A%E5%93%91%E9%93%83%E3%80%81%E5%BD%93%E7%94%BB%E6%9D%BF...%EF%BC%89%EF%BC%8C%E8%BF%99%E5%B0%B1%E6%98%AF%E5%8F%91%E6%95%A3%E6%80%9D%E7%BB%B4%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Brainstorming (头脑风暴) 就是一个典型的发散思维活动。发散思维是 Creativity (创造力) 的核心。" _mubu_text="%3Cspan%20class=%22bold%22%3EBrainstorming%20(%E5%A4%B4%E8%84%91%E9%A3%8E%E6%9A%B4)%3C/span%3E%3Cspan%3E%20%E5%B0%B1%E6%98%AF%E4%B8%80%E4%B8%AA%E5%85%B8%E5%9E%8B%E7%9A%84%E5%8F%91%E6%95%A3%E6%80%9D%E7%BB%B4%E6%B4%BB%E5%8A%A8%E3%80%82%E5%8F%91%E6%95%A3%E6%80%9D%E7%BB%B4%E6%98%AF%20%3C/span%3E%3Cspan%20class=%22bold%22%3ECreativity%20(%E5%88%9B%E9%80%A0%E5%8A%9B)%3C/span%3E%3Cspan%3E%20%E7%9A%84%E6%A0%B8%E5%BF%83%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="两种策略 Strategy" _mubu_text="%3Cspan%3E%E4%B8%A4%E7%A7%8D%E7%AD%96%E7%95%A5%20Strategy%3C/span%3E" _note="" _mubu_note="">
            <outline text="Algorithm (算法) 按部就班，可能很慢，但可靠；去货架上一个一个搜薯片" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EAlgorithm%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E7%AE%97%E6%B3%95)%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8C%89%E9%83%A8%E5%B0%B1%E7%8F%AD%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%8F%AF%E8%83%BD%3C/span%3E%3Cspan%20class=%22underline%22%3E%E5%BE%88%E6%85%A2%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BD%86%3C/span%3E%3Cspan%20class=%22underline%22%3E%E5%8F%AF%E9%9D%A0%3C/span%3E%3Cspan%3E%EF%BC%9B%E5%8E%BB%E8%B4%A7%E6%9E%B6%E4%B8%8A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%80%E4%B8%AA%E4%B8%80%E4%B8%AA%E6%90%9C%E8%96%AF%E7%89%87%3C/span%3E" _note="" _mubu_note="">
              <outline text="这是一套保证能得到正确答案的、按部就班的程序或规则。" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AF%E4%B8%80%E5%A5%97%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BF%9D%E8%AF%81%E8%83%BD%E5%BE%97%E5%88%B0%E6%AD%A3%E7%A1%AE%E7%AD%94%E6%A1%88%E7%9A%84%E3%80%81%E6%8C%89%E9%83%A8%E5%B0%B1%E7%8F%AD%E7%9A%84%E7%A8%8B%E5%BA%8F%E6%88%96%E8%A7%84%E5%88%99%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="它可能很慢，但非常可靠。" _mubu_text="%3Cspan%3E%E5%AE%83%E5%8F%AF%E8%83%BD%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BE%88%E6%85%A2%EF%BC%8C%E4%BD%86%E9%9D%9E%E5%B8%B8%E5%8F%AF%E9%9D%A0%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="你想在超市里找薯片，使用算法就是一排一排货架挨个找，直到找到为止。" _mubu_text="%3Cspan%3E%E4%BD%A0%E6%83%B3%E5%9C%A8%E8%B6%85%E5%B8%82%E9%87%8C%E6%89%BE%E8%96%AF%E7%89%87%EF%BC%8C%E4%BD%BF%E7%94%A8%E7%AE%97%E6%B3%95%E5%B0%B1%E6%98%AF%3C/span%3E%3Cspan%20class=%22underline%22%3E%E4%B8%80%E6%8E%92%E4%B8%80%E6%8E%92%E8%B4%A7%E6%9E%B6%E6%8C%A8%E4%B8%AA%E6%89%BE%EF%BC%8C%E7%9B%B4%E5%88%B0%E6%89%BE%E5%88%B0%E4%B8%BA%E6%AD%A2%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Heuristics (启发法) 经验法则，快速简化问题，缩小范围，不保证找到答案；直接去零食区找" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EHeuristics%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E5%90%AF%E5%8F%91%E6%B3%95)%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%BB%8F%E9%AA%8C%E6%B3%95%E5%88%99%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22underline%22%3E%E5%BF%AB%E9%80%9F%E7%AE%80%E5%8C%96%3C/span%3E%3Cspan%3E%E9%97%AE%E9%A2%98%EF%BC%8C%3C/span%3E%3Cspan%20class=%22underline%22%3E%E7%BC%A9%E5%B0%8F%3C/span%3E%3Cspan%3E%E8%8C%83%E5%9B%B4%EF%BC%8C%3C/span%3E%3Cspan%20class=%22underline%22%3E%E4%B8%8D%E4%BF%9D%E8%AF%81%E6%89%BE%E5%88%B0%3C/span%3E%3Cspan%3E%E7%AD%94%E6%A1%88%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%9B%B4%E6%8E%A5%E5%8E%BB%E9%9B%B6%E9%A3%9F%E5%8C%BA%E6%89%BE%3C/span%3E" _note="" _mubu_note="">
              <outline text="Top-Down Processing的体现" _mubu_text="%3Cspan%3ETop-Down%20Processing%E7%9A%84%E4%BD%93%E7%8E%B0%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Representative Heuristic (代表性启发法) 一个安静、喜欢读书的Steve，是农民还是Librarian？" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ERepresentative%20%3C/span%3E%3Cspan%3EHeuristic%20(%E4%BB%A3%E8%A1%A8%E6%80%A7%E5%90%AF%E5%8F%91%E6%B3%95)%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%80%E4%B8%AA%E5%AE%89%E9%9D%99%E3%80%81%E5%96%9C%E6%AC%A2%E8%AF%BB%E4%B9%A6%E7%9A%84Steve%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%98%AF%E5%86%9C%E6%B0%91%E8%BF%98%E6%98%AFLibrarian%EF%BC%9F%3C/span%3E" _note="" _mubu_note="">
                <outline text="我们倾向于根据一个事物与我们心中原型 (prototype) 的相似程度来进行判断和分类。" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E5%80%BE%E5%90%91%E4%BA%8E%E6%A0%B9%E6%8D%AE%E4%B8%80%E4%B8%AA%E4%BA%8B%E7%89%A9%E4%B8%8E%E6%88%91%E4%BB%AC%E5%BF%83%E4%B8%AD%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%8E%9F%E5%9E%8B%20(prototype)%3C/span%3E%3Cspan%3E%20%E7%9A%84%E7%9B%B8%E4%BC%BC%E7%A8%8B%E5%BA%A6%E6%9D%A5%E8%BF%9B%E8%A1%8C%E5%88%A4%E6%96%AD%E5%92%8C%E5%88%86%E7%B1%BB%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="一个安静、喜欢读书的Steve，你觉得他更可能是图书管理员还是农民？很多人会选图书管理员，因为这个描述更符合我们对图书管理员的“原型”或 刻板印象 (Stereotype) ；但我们忽略了基础概率——现实中农民的数量远多于图书管理员。这种思维捷径有时会让我们做出错误的判断。" _mubu_text="%3Cspan%3E%E4%B8%80%E4%B8%AA%E5%AE%89%E9%9D%99%E3%80%81%E5%96%9C%E6%AC%A2%E8%AF%BB%E4%B9%A6%E7%9A%84Steve%EF%BC%8C%E4%BD%A0%E8%A7%89%E5%BE%97%E4%BB%96%E6%9B%B4%E5%8F%AF%E8%83%BD%E6%98%AF%E5%9B%BE%E4%B9%A6%E7%AE%A1%E7%90%86%E5%91%98%E8%BF%98%E6%98%AF%E5%86%9C%E6%B0%91%EF%BC%9F%E5%BE%88%E5%A4%9A%E4%BA%BA%E4%BC%9A%E9%80%89%E5%9B%BE%E4%B9%A6%E7%AE%A1%E7%90%86%E5%91%98%EF%BC%8C%E5%9B%A0%E4%B8%BA%E8%BF%99%E4%B8%AA%E6%8F%8F%E8%BF%B0%E6%9B%B4%E7%AC%A6%E5%90%88%E6%88%91%E4%BB%AC%E5%AF%B9%E5%9B%BE%E4%B9%A6%E7%AE%A1%E7%90%86%E5%91%98%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E2%80%9C%E5%8E%9F%E5%9E%8B%E2%80%9D%3C/span%3E%3Cspan%3E%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E5%88%BB%E6%9D%BF%E5%8D%B0%E8%B1%A1%20(Stereotype)%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%EF%BC%9B%E4%BD%86%E6%88%91%E4%BB%AC%E5%BF%BD%E7%95%A5%E4%BA%86%E5%9F%BA%E7%A1%80%E6%A6%82%E7%8E%87%E2%80%94%E2%80%94%E7%8E%B0%E5%AE%9E%E4%B8%AD%E5%86%9C%E6%B0%91%E7%9A%84%E6%95%B0%E9%87%8F%E8%BF%9C%E5%A4%9A%E4%BA%8E%E5%9B%BE%E4%B9%A6%E7%AE%A1%E7%90%86%E5%91%98%E3%80%82%E8%BF%99%E7%A7%8D%E6%80%9D%E7%BB%B4%E6%8D%B7%E5%BE%84%E6%9C%89%E6%97%B6%E4%BC%9A%E8%AE%A9%E6%88%91%E4%BB%AC%E5%81%9A%E5%87%BA%E9%94%99%E8%AF%AF%E7%9A%84%E5%88%A4%E6%96%AD%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="Availability Heuristic (可得性启发法) 飞机很危险！因为我们容易想到飞机失事，但是车祸更多" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EAvailability%20%3C/span%3E%3Cspan%3EHeuristic%20(%E5%8F%AF%E5%BE%97%E6%80%A7%E5%90%AF%E5%8F%91%E6%B3%95)%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%A3%9E%E6%9C%BA%E5%BE%88%E5%8D%B1%E9%99%A9%EF%BC%81%3C/span%3E%3Cspan%3E%E5%9B%A0%E4%B8%BA%E6%88%91%E4%BB%AC%E5%AE%B9%E6%98%93%E6%83%B3%E5%88%B0%E9%A3%9E%E6%9C%BA%E5%A4%B1%E4%BA%8B%EF%BC%8C%E4%BD%86%E6%98%AF%E8%BD%A6%E7%A5%B8%E6%9B%B4%E5%A4%9A%3C/span%3E" _note="" _mubu_note="">
                <outline text="我们倾向于根据一个事件或例证在我们脑海中出现的难易程度来判断其发生的频率或可能性。" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E5%80%BE%E5%90%91%E4%BA%8E%E6%A0%B9%E6%8D%AE%E4%B8%80%E4%B8%AA%E4%BA%8B%E4%BB%B6%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BE%8B%E8%AF%81%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%9C%A8%E6%88%91%E4%BB%AC%E8%84%91%E6%B5%B7%E4%B8%AD%E5%87%BA%E7%8E%B0%E7%9A%84%E9%9A%BE%E6%98%93%E7%A8%8B%E5%BA%A6%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9D%A5%E5%88%A4%E6%96%AD%E5%85%B6%E5%8F%91%E7%94%9F%E7%9A%84%E9%A2%91%E7%8E%87%E6%88%96%E5%8F%AF%E8%83%BD%E6%80%A7%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="如果一个东西因为新闻、电视广告等原因被反复提及，它就会在你的记忆中变得非常“鲜活”和“可得”，让你高估它的普遍性。" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E4%B8%80%E4%B8%AA%E4%B8%9C%E8%A5%BF%E5%9B%A0%E4%B8%BA%E6%96%B0%E9%97%BB%E3%80%81%E7%94%B5%E8%A7%86%E5%B9%BF%E5%91%8A%E7%AD%89%E5%8E%9F%E5%9B%A0%E8%A2%AB%E5%8F%8D%E5%A4%8D%E6%8F%90%E5%8F%8A%EF%BC%8C%E5%AE%83%E5%B0%B1%E4%BC%9A%E5%9C%A8%E4%BD%A0%E7%9A%84%E8%AE%B0%E5%BF%86%E4%B8%AD%E5%8F%98%E5%BE%97%E9%9D%9E%E5%B8%B8%E2%80%9C%E9%B2%9C%E6%B4%BB%E2%80%9D%E5%92%8C%E2%80%9C%E5%8F%AF%E5%BE%97%E2%80%9D%EF%BC%8C%E8%AE%A9%E4%BD%A0%E9%AB%98%E4%BC%B0%E5%AE%83%E7%9A%84%E6%99%AE%E9%81%8D%E6%80%A7%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="比如，因为新闻总是报道飞机失事，所以很多人会觉得坐飞机比坐汽车更危险，尽管数据显示汽车事故的死亡率要高得多。这是因为飞机失事的画面更容易“pop into mind”。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%EF%BC%8C%E5%9B%A0%E4%B8%BA%E6%96%B0%E9%97%BB%E6%80%BB%E6%98%AF%E6%8A%A5%E9%81%93%E9%A3%9E%E6%9C%BA%E5%A4%B1%E4%BA%8B%EF%BC%8C%E6%89%80%E4%BB%A5%E5%BE%88%E5%A4%9A%E4%BA%BA%E4%BC%9A%E8%A7%89%E5%BE%97%E5%9D%90%E9%A3%9E%E6%9C%BA%E6%AF%94%E5%9D%90%E6%B1%BD%E8%BD%A6%E6%9B%B4%E5%8D%B1%E9%99%A9%EF%BC%8C%E5%B0%BD%E7%AE%A1%E6%95%B0%E6%8D%AE%E6%98%BE%E7%A4%BA%E6%B1%BD%E8%BD%A6%E4%BA%8B%E6%95%85%E7%9A%84%E6%AD%BB%E4%BA%A1%E7%8E%87%E8%A6%81%E9%AB%98%E5%BE%97%E5%A4%9A%E3%80%82%E8%BF%99%E6%98%AF%E5%9B%A0%E4%B8%BA%E9%A3%9E%E6%9C%BA%E5%A4%B1%E4%BA%8B%E7%9A%84%E7%94%BB%E9%9D%A2%E6%9B%B4%E5%AE%B9%E6%98%93%E2%80%9Cpop%20into%20mind%E2%80%9D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="更容易想到，所以会觉得可能性更高。" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3E%E6%9B%B4%E5%AE%B9%E6%98%93%E6%83%B3%E5%88%B0%EF%BC%8C%E6%89%80%E4%BB%A5%E4%BC%9A%E8%A7%89%E5%BE%97%E5%8F%AF%E8%83%BD%E6%80%A7%E6%9B%B4%E9%AB%98%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
          </outline>
        </outline>
        <outline text="3. Impediments to Problem Solving" _mubu_text="%3Cspan%3E3.%20Impediments%20to%20Problem%20Solving%3C/span%3E" _note="" _mubu_note="">
          <outline text="Mental Set (思维定势) ：有成功的经验，不愿意探索更好地方法，导致思维僵化；数学公式不适用" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EMental%20Set%3C/span%3E%3Cspan%20class=%22bold%22%3E%20(%E6%80%9D%E7%BB%B4%E5%AE%9A%E5%8A%BF)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9C%89%E6%88%90%E5%8A%9F%E7%9A%84%E7%BB%8F%E9%AA%8C%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%B8%8D%E6%84%BF%E6%84%8F%E6%8E%A2%E7%B4%A2%E6%9B%B4%E5%A5%BD%E5%9C%B0%E6%96%B9%E6%B3%95%EF%BC%8C%E5%AF%BC%E8%87%B4%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%80%9D%E7%BB%B4%E5%83%B5%E5%8C%96%3C/span%3E%3Cspan%3E%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%95%B0%E5%AD%A6%E5%85%AC%E5%BC%8F%E4%B8%8D%E9%80%82%E7%94%A8%3C/span%3E" _note="" _mubu_note="">
            <outline text="倾向于固守过去成功的经验和方法来解决新问题，即使有更好的方法存在。这会导致思维僵化。" _mubu_text="%3Cspan%3E%E5%80%BE%E5%90%91%E4%BA%8E%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%9B%BA%E5%AE%88%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E8%BF%87%E5%8E%BB%E6%88%90%E5%8A%9F%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%9A%84%E7%BB%8F%E9%AA%8C%E5%92%8C%E6%96%B9%E6%B3%95%3C/span%3E%3Cspan%3E%E6%9D%A5%E8%A7%A3%E5%86%B3%E6%96%B0%E9%97%AE%E9%A2%98%EF%BC%8C%E5%8D%B3%E4%BD%BF%E6%9C%89%E6%9B%B4%E5%A5%BD%E7%9A%84%E6%96%B9%E6%B3%95%E5%AD%98%E5%9C%A8%E3%80%82%E8%BF%99%E4%BC%9A%E5%AF%BC%E8%87%B4%E6%80%9D%E7%BB%B4%E5%83%B5%E5%8C%96%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="比如，你用某个数学公式解决了一系列问题，当遇到一个新问题时，即使这个公式不适用，你还是会下意识地先去套用它。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%EF%BC%8C%E4%BD%A0%E7%94%A8%E6%9F%90%E4%B8%AA%E6%95%B0%E5%AD%A6%E5%85%AC%E5%BC%8F%E8%A7%A3%E5%86%B3%E4%BA%86%E4%B8%80%E7%B3%BB%E5%88%97%E9%97%AE%E9%A2%98%EF%BC%8C%E5%BD%93%E9%81%87%E5%88%B0%E4%B8%80%E4%B8%AA%E6%96%B0%E9%97%AE%E9%A2%98%E6%97%B6%EF%BC%8C%E5%8D%B3%E4%BD%BF%E8%BF%99%E4%B8%AA%E5%85%AC%E5%BC%8F%E4%B8%8D%E9%80%82%E7%94%A8%EF%BC%8C%E4%BD%A0%E8%BF%98%E6%98%AF%E4%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%8B%E6%84%8F%E8%AF%86%E5%9C%B0%E5%85%88%E5%8E%BB%E5%A5%97%E7%94%A8%E5%AE%83%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Functional Fixedness (功能固着)：只能看到常规用途，想不到其他潜在用途；" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EFunctional%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EFixedness%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E5%8A%9F%E8%83%BD%E5%9B%BA%E7%9D%80)%3C/span%3E%3Cspan%3E%EF%BC%9A%E5%8F%AA%E8%83%BD%E7%9C%8B%E5%88%B0%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%B8%B8%E8%A7%84%E7%94%A8%E9%80%94%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%83%B3%E4%B8%8D%E5%88%B0%E5%85%B6%E4%BB%96%E6%BD%9C%E5%9C%A8%E7%94%A8%E9%80%94%EF%BC%9B%3C/span%3E" _note="" _mubu_note="">
            <outline text="这是Mental Set的一种特殊形式。它指的是我们只看到一个物体的常规用途，而想不到它的其他潜在用途。" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AFMental%20Set%E7%9A%84%E4%B8%80%E7%A7%8D%E7%89%B9%E6%AE%8A%E5%BD%A2%E5%BC%8F%E3%80%82%E5%AE%83%E6%8C%87%E7%9A%84%E6%98%AF%E6%88%91%E4%BB%AC%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%8F%AA%E7%9C%8B%E5%88%B0%E4%B8%80%E4%B8%AA%E7%89%A9%E4%BD%93%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%B8%B8%E8%A7%84%E7%94%A8%E9%80%94%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%8C%E8%80%8C%E6%83%B3%E4%B8%8D%E5%88%B0%E5%AE%83%E7%9A%84%E5%85%B6%E4%BB%96%E6%BD%9C%E5%9C%A8%E7%94%A8%E9%80%94%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="经典的“蜡烛问题”实验就是例子：给你一盒图钉、一根蜡烛和一盒火柴，要求你把蜡烛固定在墙上。很多人想不到可以把图钉倒出来，用图钉盒作为烛台。他们被图钉盒的“装图钉”这个功能给“固着”了。" _mubu_text="%3Cspan%3E%E7%BB%8F%E5%85%B8%E7%9A%84%E2%80%9C%E8%9C%A1%E7%83%9B%E9%97%AE%E9%A2%98%E2%80%9D%E5%AE%9E%E9%AA%8C%E5%B0%B1%E6%98%AF%E4%BE%8B%E5%AD%90%EF%BC%9A%E7%BB%99%E4%BD%A0%E4%B8%80%E7%9B%92%E5%9B%BE%E9%92%89%E3%80%81%E4%B8%80%E6%A0%B9%E8%9C%A1%E7%83%9B%E5%92%8C%E4%B8%80%E7%9B%92%E7%81%AB%E6%9F%B4%EF%BC%8C%E8%A6%81%E6%B1%82%E4%BD%A0%E6%8A%8A%E8%9C%A1%E7%83%9B%E5%9B%BA%E5%AE%9A%E5%9C%A8%E5%A2%99%E4%B8%8A%E3%80%82%E5%BE%88%E5%A4%9A%E4%BA%BA%E6%83%B3%E4%B8%8D%E5%88%B0%E5%8F%AF%E4%BB%A5%E6%8A%8A%E5%9B%BE%E9%92%89%E5%80%92%E5%87%BA%E6%9D%A5%EF%BC%8C%E7%94%A8%E5%9B%BE%E9%92%89%E7%9B%92%E4%BD%9C%E4%B8%BA%E7%83%9B%E5%8F%B0%E3%80%82%E4%BB%96%E4%BB%AC%E8%A2%AB%E5%9B%BE%E9%92%89%E7%9B%92%E7%9A%84%E2%80%9C%E8%A3%85%E5%9B%BE%E9%92%89%E2%80%9D%E8%BF%99%E4%B8%AA%E5%8A%9F%E8%83%BD%E7%BB%99%E2%80%9C%E5%9B%BA%E7%9D%80%E2%80%9D%E4%BA%86%E3%80%82%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22ANPOtfV6Ho%22%2C%22oh%22%3A822%2C%22ow%22%3A659%2C%22uri%22%3A%22document_image%2F33585682_82b9dcd4-03fe-42a9-b395-7ce31c16ec1a.png%22%2C%22w%22%3A320%7D%5D"/>
          </outline>
          <outline text="Confirmation Bias (证实性偏见) ：看到支持我们信念的证据，忽略或者贬低与信念相悖的证据；星座好灵啊" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EConfirmation%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EBias%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E8%AF%81%E5%AE%9E%E6%80%A7%E5%81%8F%E8%A7%81)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%9C%8B%E5%88%B0%E6%94%AF%E6%8C%81%3C/span%3E%3Cspan%3E%E6%88%91%E4%BB%AC%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BF%A1%E5%BF%B5%E7%9A%84%E8%AF%81%E6%8D%AE%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%BD%E7%95%A5%3C/span%3E%3Cspan%3E%E6%88%96%E8%80%85%E8%B4%AC%E4%BD%8E%E4%B8%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BF%A1%E5%BF%B5%E7%9B%B8%E6%82%96%E7%9A%84%E8%AF%81%E6%8D%AE%3C/span%3E%3Cspan%3E%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%98%9F%E5%BA%A7%E5%A5%BD%E7%81%B5%E5%95%8A%3C/span%3E" _note="" _mubu_note="">
            <outline text="我们倾向于寻找、解释和记住那些支持我们已有信念的证据，而忽略或贬低那些与我们信念相悖的证据。" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E5%80%BE%E5%90%91%E4%BA%8E%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%AF%BB%E6%89%BE%E3%80%81%E8%A7%A3%E9%87%8A%E5%92%8C%E8%AE%B0%E4%BD%8F%E9%82%A3%E4%BA%9B%E6%94%AF%E6%8C%81%E6%88%91%E4%BB%AC%E5%B7%B2%E6%9C%89%E4%BF%A1%E5%BF%B5%E7%9A%84%E8%AF%81%E6%8D%AE%EF%BC%8C%E8%80%8C%E5%BF%BD%E7%95%A5%E6%88%96%E8%B4%AC%E4%BD%8E%E9%82%A3%E4%BA%9B%E4%B8%8E%E6%88%91%E4%BB%AC%E4%BF%A1%E5%BF%B5%E7%9B%B8%E6%82%96%E7%9A%84%E8%AF%81%E6%8D%AE%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="比如，如果你相信某个星座的运势，你就会特别留意生活中符合运势描述的事件，而自动忽略那些不符合的。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%EF%BC%8C%E5%A6%82%E6%9E%9C%E4%BD%A0%E7%9B%B8%E4%BF%A1%E6%9F%90%E4%B8%AA%E6%98%9F%E5%BA%A7%E7%9A%84%E8%BF%90%E5%8A%BF%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BD%A0%E5%B0%B1%E4%BC%9A%E7%89%B9%E5%88%AB%E7%95%99%E6%84%8F%E7%94%9F%E6%B4%BB%E4%B8%AD%E7%AC%A6%E5%90%88%E8%BF%90%E5%8A%BF%E6%8F%8F%E8%BF%B0%E7%9A%84%E4%BA%8B%E4%BB%B6%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%80%8C%E8%87%AA%E5%8A%A8%E5%BF%BD%E7%95%A5%E9%82%A3%E4%BA%9B%E4%B8%8D%E7%AC%A6%E5%90%88%E7%9A%84%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Hindsight Bias (后见之明) ：马后炮；你就该听我的，买这只股票就好了！" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EHindsight%20Bias%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E5%90%8E%E8%A7%81%E4%B9%8B%E6%98%8E)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%A9%AC%E5%90%8E%E7%82%AE%3C/span%3E%3Cspan%3E%EF%BC%9B%E4%BD%A0%E5%B0%B1%E8%AF%A5%E5%90%AC%E6%88%91%E7%9A%84%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B9%B0%E8%BF%99%E5%8F%AA%E8%82%A1%E7%A5%A8%E5%B0%B1%E5%A5%BD%E4%BA%86%EF%BC%81%3C/span%3E" _note="" _mubu_note="">
            <outline text="也就是我们常说的“马后炮”或 &quot;I-knew-it-all-along&quot; phenomenon。" _mubu_text="%3Cspan%3E%E4%B9%9F%E5%B0%B1%E6%98%AF%E6%88%91%E4%BB%AC%E5%B8%B8%E8%AF%B4%E7%9A%84%E2%80%9C%E9%A9%AC%E5%90%8E%E7%82%AE%E2%80%9D%E6%88%96%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%22I-knew-it-all-along%22%20phenomenon%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="在事情发生之后，我们倾向于认为自己“早就知道了”这个结果，觉得事情的发生是显而易见和可预测的。" _mubu_text="%3Cspan%3E%E5%9C%A8%E4%BA%8B%E6%83%85%E5%8F%91%E7%94%9F%E4%B9%8B%E5%90%8E%EF%BC%8C%E6%88%91%E4%BB%AC%E5%80%BE%E5%90%91%E4%BA%8E%E8%AE%A4%E4%B8%BA%E8%87%AA%E5%B7%B1%E2%80%9C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%97%A9%E5%B0%B1%E7%9F%A5%E9%81%93%E4%BA%86%3C/span%3E%3Cspan%3E%E2%80%9D%E8%BF%99%E4%B8%AA%E7%BB%93%E6%9E%9C%EF%BC%8C%E8%A7%89%E5%BE%97%E4%BA%8B%E6%83%85%E7%9A%84%E5%8F%91%E7%94%9F%E6%98%AF%E6%98%BE%E8%80%8C%E6%98%93%E8%A7%81%E5%92%8C%E5%8F%AF%E9%A2%84%E6%B5%8B%E7%9A%84%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Gambler&apos;s Fallacy (赌徒谬误) ：独立事件不以个人意志为转移；“已经9次抛硬币是正面了，下一次一定是反面，梭哈！”" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EGambler&apos;s%20Fallacy%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E8%B5%8C%E5%BE%92%E8%B0%AC%E8%AF%AF)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%8B%AC%E7%AB%8B%E4%BA%8B%E4%BB%B6%3C/span%3E%3Cspan%3E%E4%B8%8D%E4%BB%A5%E4%B8%AA%E4%BA%BA%E6%84%8F%E5%BF%97%E4%B8%BA%E8%BD%AC%E7%A7%BB%EF%BC%9B%E2%80%9C%E5%B7%B2%E7%BB%8F%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E9%E6%AC%A1%E6%8A%9B%E7%A1%AC%E5%B8%81%E6%98%AF%E6%AD%A3%E9%9D%A2%E4%BA%86%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%B8%8B%E4%B8%80%E6%AC%A1%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%80%E5%AE%9A%E6%98%AF%E5%8F%8D%E9%9D%A2%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22bold%20underline%22%3E%E6%A2%AD%E5%93%88%EF%BC%81%3C/span%3E%3Cspan%3E%E2%80%9D%3C/span%3E" _note="" _mubu_note="">
            <outline text="一种错误的信念，认为如果某个随机事件在短期内发生的频率高于正常水平，那么它在未来发生的频率就会降低（反之亦然）。" _mubu_text="%3Cspan%3E%E4%B8%80%E7%A7%8D%E9%94%99%E8%AF%AF%E7%9A%84%E4%BF%A1%E5%BF%B5%EF%BC%8C%E8%AE%A4%E4%B8%BA%E5%A6%82%E6%9E%9C%E6%9F%90%E4%B8%AA%E9%9A%8F%E6%9C%BA%E4%BA%8B%E4%BB%B6%E5%9C%A8%E7%9F%AD%E6%9C%9F%E5%86%85%E5%8F%91%E7%94%9F%E7%9A%84%E9%A2%91%E7%8E%87%E9%AB%98%E4%BA%8E%E6%AD%A3%E5%B8%B8%E6%B0%B4%E5%B9%B3%EF%BC%8C%E9%82%A3%E4%B9%88%E5%AE%83%E5%9C%A8%E6%9C%AA%E6%9D%A5%E5%8F%91%E7%94%9F%E7%9A%84%E9%A2%91%E7%8E%87%E5%B0%B1%E4%BC%9A%E9%99%8D%E4%BD%8E%EF%BC%88%E5%8F%8D%E4%B9%8B%E4%BA%A6%E7%84%B6%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="比如，连续抛硬币5次都是正面，赌徒会觉得下一次“该”是反面了。但实际上，每一次抛硬币都是独立的随机事件，概率永远是50%。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%EF%BC%8C%E8%BF%9E%E7%BB%AD%E6%8A%9B%E7%A1%AC%E5%B8%815%E6%AC%A1%E9%83%BD%E6%98%AF%E6%AD%A3%E9%9D%A2%EF%BC%8C%E8%B5%8C%E5%BE%92%E4%BC%9A%E8%A7%89%E5%BE%97%E4%B8%8B%E4%B8%80%E6%AC%A1%E2%80%9C%E8%AF%A5%E2%80%9D%E6%98%AF%E5%8F%8D%E9%9D%A2%E4%BA%86%E3%80%82%E4%BD%86%E5%AE%9E%E9%99%85%E4%B8%8A%EF%BC%8C%E6%AF%8F%E4%B8%80%E6%AC%A1%E6%8A%9B%E7%A1%AC%E5%B8%81%E9%83%BD%E6%98%AF%E7%8B%AC%E7%AB%8B%E7%9A%84%E9%9A%8F%E6%9C%BA%E4%BA%8B%E4%BB%B6%EF%BC%8C%E6%A6%82%E7%8E%87%E6%B0%B8%E8%BF%9C%E6%98%AF50%25%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Sunk-cost Fallacy (沉没成本谬误)：投入了那么多了，继续干吧，尽管不明智，但不想止损；“这电影真烂，但是来都来啦……”" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ESunk-cost%20Fallacy%3C/span%3E%3Cspan%20class=%22bold%22%3E%20(%E6%B2%89%E6%B2%A1%E6%88%90%E6%9C%AC%E8%B0%AC%E8%AF%AF)%3C/span%3E%3Cspan%3E%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8A%95%E5%85%A5%E4%BA%86%E9%82%A3%E4%B9%88%E5%A4%9A%E4%BA%86%3C/span%3E%3Cspan%3E%EF%BC%8C%E7%BB%A7%E7%BB%AD%E5%B9%B2%E5%90%A7%EF%BC%8C%E5%B0%BD%E7%AE%A1%E4%B8%8D%E6%98%8E%E6%99%BA%EF%BC%8C%E4%BD%86%E4%B8%8D%E6%83%B3%E6%AD%A2%E6%8D%9F%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E2%80%9C%E8%BF%99%E7%94%B5%E5%BD%B1%E7%9C%9F%E7%83%82%EF%BC%8C%E4%BD%86%E6%98%AF%E6%9D%A5%E9%83%BD%E6%9D%A5%E5%95%A6%E2%80%A6%E2%80%A6%E2%80%9D%3C/span%3E" _note="" _mubu_note="">
            <outline text="因为已经在某个项目上投入了金钱、时间或努力（这些都是“沉没成本”），所以即使继续下去是不明智的，人们也倾向于继续投入，不愿“止损”。" _mubu_text="%3Cspan%3E%E5%9B%A0%E4%B8%BA%E5%B7%B2%E7%BB%8F%E5%9C%A8%E6%9F%90%E4%B8%AA%E9%A1%B9%E7%9B%AE%E4%B8%8A%E6%8A%95%E5%85%A5%E4%BA%86%E9%87%91%E9%92%B1%E3%80%81%E6%97%B6%E9%97%B4%E6%88%96%E5%8A%AA%E5%8A%9B%EF%BC%88%E8%BF%99%E4%BA%9B%E9%83%BD%E6%98%AF%E2%80%9C%E6%B2%89%E6%B2%A1%E6%88%90%E6%9C%AC%E2%80%9D%EF%BC%89%EF%BC%8C%E6%89%80%E4%BB%A5%E5%8D%B3%E4%BD%BF%E7%BB%A7%E7%BB%AD%E4%B8%8B%E5%8E%BB%E6%98%AF%E4%B8%8D%E6%98%8E%E6%99%BA%E7%9A%84%EF%BC%8C%E4%BA%BA%E4%BB%AC%E4%B9%9F%E5%80%BE%E5%90%91%E4%BA%8E%E7%BB%A7%E7%BB%AD%E6%8A%95%E5%85%A5%EF%BC%8C%E4%B8%8D%E6%84%BF%E2%80%9C%E6%AD%A2%E6%8D%9F%E2%80%9D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="比如，你看一部很难看的电影，但因为已经花了钱买票，就强迫自己看完。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%EF%BC%8C%E4%BD%A0%E7%9C%8B%E4%B8%80%E9%83%A8%E5%BE%88%E9%9A%BE%E7%9C%8B%E7%9A%84%E7%94%B5%E5%BD%B1%EF%BC%8C%E4%BD%86%E5%9B%A0%E4%B8%BA%E5%B7%B2%E7%BB%8F%E8%8A%B1%E4%BA%86%E9%92%B1%E4%B9%B0%E7%A5%A8%EF%BC%8C%E5%B0%B1%E5%BC%BA%E8%BF%AB%E8%87%AA%E5%B7%B1%E7%9C%8B%E5%AE%8C%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="4. Others Matters" _mubu_text="%3Cspan%3E4.%20Others%20Matters%3C/span%3E" _note="" _mubu_note="">
          <outline text="Priming (启动效应) ：先前看到的会影响我们后续的反应；“香蕉”，Y_L___，YELLOW！" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EPriming%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E5%90%AF%E5%8A%A8%E6%95%88%E5%BA%94)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%E5%85%88%E5%89%8D%E7%9C%8B%E5%88%B0%E7%9A%84%E4%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BD%B1%E5%93%8D%E6%88%91%E4%BB%AC%E5%90%8E%E7%BB%AD%3C/span%3E%3Cspan%3E%E7%9A%84%E5%8F%8D%E5%BA%94%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E2%80%9C%E9%A6%99%E8%95%89%E2%80%9D%EF%BC%8CY_L___%EF%BC%8CYELLOW%EF%BC%81%3C/span%3E" _note="" _mubu_note="">
            <outline text="先前的刺激会无意识地影响我们对后续刺激的反应。" _mubu_text="%3Cspan%3E%E5%85%88%E5%89%8D%E7%9A%84%E5%88%BA%E6%BF%80%E4%BC%9A%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%97%A0%E6%84%8F%E8%AF%86%E5%9C%B0%E5%BD%B1%E5%93%8D%3C/span%3E%3Cspan%3E%E6%88%91%E4%BB%AC%E5%AF%B9%E5%90%8E%E7%BB%AD%E5%88%BA%E6%BF%80%E7%9A%84%E5%8F%8D%E5%BA%94%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="比如，如果让你先看一张黄色的图片或者“香蕉”这个词，然后让你快速填词 Y_L___，你很可能会填 YELLOW。你的大脑被之前的刺激“启动”了。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%EF%BC%8C%E5%A6%82%E6%9E%9C%E8%AE%A9%E4%BD%A0%E5%85%88%E7%9C%8B%E4%B8%80%E5%BC%A0%E9%BB%84%E8%89%B2%E7%9A%84%E5%9B%BE%E7%89%87%E6%88%96%E8%80%85%E2%80%9C%E9%A6%99%E8%95%89%E2%80%9D%E8%BF%99%E4%B8%AA%E8%AF%8D%EF%BC%8C%E7%84%B6%E5%90%8E%E8%AE%A9%E4%BD%A0%E5%BF%AB%E9%80%9F%E5%A1%AB%E8%AF%8D%20Y_L___%EF%BC%8C%E4%BD%A0%E5%BE%88%E5%8F%AF%E8%83%BD%E4%BC%9A%E5%A1%AB%20YELLOW%E3%80%82%E4%BD%A0%E7%9A%84%E5%A4%A7%E8%84%91%E8%A2%AB%E4%B9%8B%E5%89%8D%E7%9A%84%E5%88%BA%E6%BF%80%E2%80%9C%E5%90%AF%E5%8A%A8%E2%80%9D%E4%BA%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Framing (框架效应) ：不同的表述方法会影响人们的判断；死亡率10%，好危险 vs 存活率 90%，好安全" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EFraming%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E6%A1%86%E6%9E%B6%E6%95%88%E5%BA%94)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%E4%B8%8D%E5%90%8C%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A1%A8%E8%BF%B0%E6%96%B9%E6%B3%95%3C/span%3E%3Cspan%3E%E4%BC%9A%E5%BD%B1%E5%93%8D%E4%BA%BA%E4%BB%AC%E7%9A%84%E5%88%A4%E6%96%AD%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%AD%BB%E4%BA%A1%E7%8E%8710%25%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%A5%BD%E5%8D%B1%E9%99%A9%20vs%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%AD%98%E6%B4%BB%E7%8E%87%2090%25%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%A5%BD%E5%AE%89%E5%85%A8%3C/span%3E" _note="" _mubu_note="">
            <outline text="同一个问题，用不同的表述方式呈现，会显著影响人们的决策和判断。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%90%8C%E4%B8%80%E4%B8%AA%E9%97%AE%E9%A2%98%EF%BC%8C%E7%94%A8%E4%B8%8D%E5%90%8C%E7%9A%84%E8%A1%A8%E8%BF%B0%E6%96%B9%E5%BC%8F%E5%91%88%E7%8E%B0%EF%BC%8C%E4%BC%9A%E6%98%BE%E8%91%97%E5%BD%B1%E5%93%8D%E4%BA%BA%E4%BB%AC%E7%9A%84%E5%86%B3%E7%AD%96%E5%92%8C%E5%88%A4%E6%96%AD%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="PPT里的例子非常经典：" _mubu_text="%3Cspan%3EPPT%E9%87%8C%E7%9A%84%E4%BE%8B%E5%AD%90%E9%9D%9E%E5%B8%B8%E7%BB%8F%E5%85%B8%EF%BC%9A%3C/span%3E" _note="" _mubu_note="">
              <outline text="“接受这个手术的病人，90%的人都活了下来。” (听起来很安全)" _mubu_text="%3Cspan%3E%E2%80%9C%E6%8E%A5%E5%8F%97%E8%BF%99%E4%B8%AA%E6%89%8B%E6%9C%AF%E7%9A%84%E7%97%85%E4%BA%BA%EF%BC%8C90%25%E7%9A%84%E4%BA%BA%E9%83%BD%E6%B4%BB%E4%BA%86%E4%B8%8B%E6%9D%A5%E3%80%82%E2%80%9D%20(%E5%90%AC%E8%B5%B7%E6%9D%A5%E5%BE%88%E5%AE%89%E5%85%A8)%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="“接受这个手术的病人，10%的人都死了。” (听起来很危险)" _mubu_text="%3Cspan%3E%E2%80%9C%E6%8E%A5%E5%8F%97%E8%BF%99%E4%B8%AA%E6%89%8B%E6%9C%AF%E7%9A%84%E7%97%85%E4%BA%BA%EF%BC%8C10%25%E7%9A%84%E4%BA%BA%E9%83%BD%E6%AD%BB%E4%BA%86%E3%80%82%E2%80%9D%20(%E5%90%AC%E8%B5%B7%E6%9D%A5%E5%BE%88%E5%8D%B1%E9%99%A9)%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="虽然两句话说的是同一个事实，但积极框架（强调生存）和消极框架（强调死亡）会引导我们做出完全不同的选择。" _mubu_text="%3Cspan%3E%E8%99%BD%E7%84%B6%E4%B8%A4%E5%8F%A5%E8%AF%9D%E8%AF%B4%E7%9A%84%E6%98%AF%E5%90%8C%E4%B8%80%E4%B8%AA%E4%BA%8B%E5%AE%9E%EF%BC%8C%E4%BD%86%E7%A7%AF%E6%9E%81%E6%A1%86%E6%9E%B6%EF%BC%88%E5%BC%BA%E8%B0%83%E7%94%9F%E5%AD%98%EF%BC%89%E5%92%8C%E6%B6%88%E6%9E%81%E6%A1%86%E6%9E%B6%EF%BC%88%E5%BC%BA%E8%B0%83%E6%AD%BB%E4%BA%A1%EF%BC%89%E4%BC%9A%E5%BC%95%E5%AF%BC%E6%88%91%E4%BB%AC%E5%81%9A%E5%87%BA%E5%AE%8C%E5%85%A8%E4%B8%8D%E5%90%8C%E7%9A%84%E9%80%89%E6%8B%A9%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
      </outline>
      <outline text="2.3 记忆介绍 Introduction to Memory（800字）" _mubu_text="%3Cspan%3E2.3%20%E8%AE%B0%E5%BF%86%E4%BB%8B%E7%BB%8D%20Introduction%20to%20Memory%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E800%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="What is Memory? 记录、储存并在需要时提取信息。" _mubu_text="%3Cspan%3EWhat%20is%20Memory?%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%AE%B0%E5%BD%95%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%82%A8%E5%AD%98%3C/span%3E%3Cspan%3E%E5%B9%B6%E5%9C%A8%E9%9C%80%E8%A6%81%E6%97%B6%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%8F%90%E5%8F%96%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note="">
          <outline text="The processes that allow us to record and later retrieve information" _mubu_text="%3Cspan%3EThe%20processes%20that%20allow%20us%20to%20record%20and%20later%20retrieve%20information%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="记录、储存并在需要时提取信息。" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E8%AE%B0%E5%BD%95%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%82%A8%E5%AD%98%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%B9%B6%E5%9C%A8%E9%9C%80%E8%A6%81%E6%97%B6%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E6%8F%90%E5%8F%96%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="通过信息的编码、储存和提取而得以持续学习的过程" _mubu_text="%3Cspan%3E%E9%80%9A%E8%BF%87%E4%BF%A1%E6%81%AF%E7%9A%84%E7%BC%96%E7%A0%81%E3%80%81%E5%82%A8%E5%AD%98%E5%92%8C%E6%8F%90%E5%8F%96%E8%80%8C%E5%BE%97%E4%BB%A5%E6%8C%81%E7%BB%AD%E5%AD%A6%E4%B9%A0%E7%9A%84%E8%BF%87%E7%A8%8B%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Information-Processing Models" _mubu_text="%3Cspan%3EInformation-Processing%20Models%3C/span%3E" _note="" _mubu_note="">
          <outline text="3 Stages, Encoding - Storage - Retrieval" _mubu_text="%3Cspan%3E3%20Stages,%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EEncoding%20%3C/span%3E%3Cspan%3E-%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EStorage%20%3C/span%3E%3Cspan%3E-%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3ERetrieval%3C/span%3E" _note="" _mubu_note="">
            <outline text="Encoding 编码" _mubu_text="%3Cspan%3EEncoding%20%E7%BC%96%E7%A0%81%3C/span%3E" _note="" _mubu_note="">
              <outline text="将外界信息转换成大脑可以处理和储存的形式" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B0%86%E5%A4%96%E7%95%8C%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E8%BD%AC%E6%8D%A2%E6%88%90%E5%A4%A7%E8%84%91%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%8F%AF%E4%BB%A5%E5%A4%84%E7%90%86%E5%92%8C%E5%82%A8%E5%AD%98%E7%9A%84%E5%BD%A2%E5%BC%8F%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="用键盘打字，把外界信息变成电子信号" _mubu_text="%3Cspan%3E%E7%94%A8%E9%94%AE%E7%9B%98%E6%89%93%E5%AD%97%EF%BC%8C%E6%8A%8A%E5%A4%96%E7%95%8C%E4%BF%A1%E6%81%AF%E5%8F%98%E6%88%90%E7%94%B5%E5%AD%90%E4%BF%A1%E5%8F%B7%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Storage 储存" _mubu_text="%3Cspan%3EStorage%20%E5%82%A8%E5%AD%98%3C/span%3E" _note="" _mubu_note="">
              <outline text="保持在记忆系统中的过程。" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E4%BF%9D%E6%8C%81%E5%9C%A8%E8%AE%B0%E5%BF%86%E7%B3%BB%E7%BB%9F%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%B8%AD%3C/span%3E%3Cspan%3E%E7%9A%84%E8%BF%87%E7%A8%8B%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="就像把文件保存到硬盘上" _mubu_text="%3Cspan%3E%E5%B0%B1%E5%83%8F%E6%8A%8A%E6%96%87%E4%BB%B6%E4%BF%9D%E5%AD%98%E5%88%B0%E7%A1%AC%E7%9B%98%E4%B8%8A%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Retrieval 提取" _mubu_text="%3Cspan%3ERetrieval%20%E6%8F%90%E5%8F%96%3C/span%3E" _note="" _mubu_note="">
              <outline text="需要时从记忆库中找到并调出已储存信息的过程。" _mubu_text="%3Cspan%3E%E9%9C%80%E8%A6%81%E6%97%B6%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BB%8E%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E8%AE%B0%E5%BF%86%E5%BA%93%E4%B8%AD%E6%89%BE%E5%88%B0%E5%B9%B6%E8%B0%83%E5%87%BA%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%B7%B2%E5%82%A8%E5%AD%98%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%E7%9A%84%E8%BF%87%E7%A8%8B%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="就像打开一个文件，读取里面的内容" _mubu_text="%3Cspan%3E%E5%B0%B1%E5%83%8F%E6%89%93%E5%BC%80%E4%B8%80%E4%B8%AA%E6%96%87%E4%BB%B6%EF%BC%8C%E8%AF%BB%E5%8F%96%E9%87%8C%E9%9D%A2%E7%9A%84%E5%86%85%E5%AE%B9%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="2 Pathways" _mubu_text="%3Cspan%3E2%20Pathways%3C/span%3E" _note="" _mubu_note="">
            <outline text="Automatic Processing 不费吹灰之力就能记住的，不需要刻意编码；今天在路上看到好几次同一个朋友" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EAutomatic%20%3C/span%3E%3Cspan%3EProcessing%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%8D%E8%B4%B9%E5%90%B9%E7%81%B0%E4%B9%8B%E5%8A%9B%3C/span%3E%3Cspan%3E%E5%B0%B1%E8%83%BD%E8%AE%B0%E4%BD%8F%E7%9A%84%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%8D%E9%9C%80%E8%A6%81%E5%88%BB%E6%84%8F%E7%BC%96%E7%A0%81%3C/span%3E%3Cspan%3E%EF%BC%9B%E4%BB%8A%E5%A4%A9%E5%9C%A8%E8%B7%AF%E4%B8%8A%E7%9C%8B%E5%88%B0%E5%A5%BD%E5%87%A0%E6%AC%A1%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%90%8C%E4%B8%80%E4%B8%AA%E6%9C%8B%E5%8F%8B%3C/span%3E" _note="" _mubu_note="">
              <outline text="很多信息是我们不费吹灰之力、无意识地就记住了的" _mubu_text="%3Cspan%3E%E5%BE%88%E5%A4%9A%E4%BF%A1%E6%81%AF%E6%98%AF%E6%88%91%E4%BB%AC%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E4%B8%8D%E8%B4%B9%E5%90%B9%E7%81%B0%E4%B9%8B%E5%8A%9B%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%81%E6%97%A0%E6%84%8F%E8%AF%86%E5%9C%B0%3C/span%3E%3Cspan%3E%E5%B0%B1%E8%AE%B0%E4%BD%8F%E4%BA%86%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Space (空间) 你记得你把书放在桌子的哪个位置。" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ESpace%20(%E7%A9%BA%E9%97%B4)%3C/span%3E%3Cspan%3E%20%E4%BD%A0%E8%AE%B0%E5%BE%97%E4%BD%A0%E6%8A%8A%E4%B9%A6%E6%94%BE%E5%9C%A8%E6%A1%8C%E5%AD%90%E7%9A%84%E5%93%AA%E4%B8%AA%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BD%8D%E7%BD%AE%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Time (时间) 你大概记得今天都发生了什么事，能回忆起事件的顺序。" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ETime%20(%E6%97%B6%E9%97%B4)%3C/span%3E%3Cspan%3E%20%E4%BD%A0%E5%A4%A7%E6%A6%82%E8%AE%B0%E5%BE%97%E4%BB%8A%E5%A4%A9%E9%83%BD%E5%8F%91%E7%94%9F%E4%BA%86%E4%BB%80%E4%B9%88%E4%BA%8B%EF%BC%8C%E8%83%BD%E5%9B%9E%E5%BF%86%E8%B5%B7%E4%BA%8B%E4%BB%B6%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E9%A1%BA%E5%BA%8F%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Frequency (频率) 你记得今天在路上看到好几次同一个朋友。 这些信息的编码是自动完成的，不需要你刻意去背。" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EFrequency%20(%E9%A2%91%E7%8E%87)%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E4%BD%A0%E8%AE%B0%E5%BE%97%E4%BB%8A%E5%A4%A9%E5%9C%A8%E8%B7%AF%E4%B8%8A%E7%9C%8B%E5%88%B0%E5%A5%BD%E5%87%A0%E6%AC%A1%E5%90%8C%E4%B8%80%E4%B8%AA%E6%9C%8B%E5%8F%8B%E3%80%82%20%E8%BF%99%E4%BA%9B%E4%BF%A1%E6%81%AF%E7%9A%84%E7%BC%96%E7%A0%81%E6%98%AF%E8%87%AA%E5%8A%A8%E5%AE%8C%E6%88%90%E7%9A%84%EF%BC%8C%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%B8%8D%E9%9C%80%E8%A6%81%E4%BD%A0%E5%88%BB%E6%84%8F%E5%8E%BB%E8%83%8C%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Effortful Processing 有意识地努力记住的，需要集中注意力；复习、练习" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EEffortful%20%3C/span%3E%3Cspan%3EProcessing%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9C%89%E6%84%8F%E8%AF%86%E5%9C%B0%3C/span%3E%3Cspan%3E%E5%8A%AA%E5%8A%9B%E8%AE%B0%E4%BD%8F%E7%9A%84%EF%BC%8C%E9%9C%80%E8%A6%81%E9%9B%86%E4%B8%AD%E6%B3%A8%E6%84%8F%E5%8A%9B%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A4%8D%E4%B9%A0%E3%80%81%E7%BB%83%E4%B9%A0%3C/span%3E" _note="" _mubu_note="">
              <outline text="有意识地努力、集中注意力去记" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3E%E6%9C%89%E6%84%8F%E8%AF%86%E5%9C%B0%E5%8A%AA%E5%8A%9B%3C/span%3E%3Cspan%20class=%22bold%22%3E%E3%80%81%E9%9B%86%E4%B8%AD%E6%B3%A8%E6%84%8F%E5%8A%9B%3C/span%3E%3Cspan%3E%E5%8E%BB%E8%AE%B0%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="这通常涉及到复习、练习和思考" _mubu_text="%3Cspan%3E%E8%BF%99%E9%80%9A%E5%B8%B8%E6%B6%89%E5%8F%8A%E5%88%B0%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%A4%8D%E4%B9%A0%E3%80%81%E7%BB%83%E4%B9%A0%E5%92%8C%E6%80%9D%E8%80%83%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="合起来：Parallel Processing 同时处理自动的和费力地（双轨处理）" _mubu_text="%3Cspan%3E%E5%90%88%E8%B5%B7%E6%9D%A5%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EParallel%20%3C/span%3E%3Cspan%3EProcessing%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%90%8C%E6%97%B6%E5%A4%84%E7%90%86%E8%87%AA%E5%8A%A8%E7%9A%84%E5%92%8C%E8%B4%B9%E5%8A%9B%E5%9C%B0%3C/span%3E%3Cspan%3E%EF%BC%88%E5%8F%8C%E8%BD%A8%E5%A4%84%E7%90%86%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
              <outline text="这种双轨处理的方式，被称为 Parallel Processing (平行加工) ，意味着我们的大脑可以同时处理多种信息（一些是自动的，一些是费力的）。" _mubu_text="%3Cspan%3E%E8%BF%99%E7%A7%8D%E5%8F%8C%E8%BD%A8%E5%A4%84%E7%90%86%E7%9A%84%E6%96%B9%E5%BC%8F%EF%BC%8C%E8%A2%AB%E7%A7%B0%E4%B8%BA%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EParallel%20Processing%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E5%B9%B3%E8%A1%8C%E5%8A%A0%E5%B7%A5)%3C/span%3E%3Cspan%3E%20%EF%BC%8C%E6%84%8F%E5%91%B3%E7%9D%80%E6%88%91%E4%BB%AC%E7%9A%84%E5%A4%A7%E8%84%91%E5%8F%AF%E4%BB%A5%E5%90%8C%E6%97%B6%E5%A4%84%E7%90%86%E5%A4%9A%E7%A7%8D%E4%BF%A1%E6%81%AF%EF%BC%88%E4%B8%80%E4%BA%9B%E6%98%AF%E8%87%AA%E5%8A%A8%E7%9A%84%EF%BC%8C%E4%B8%80%E4%BA%9B%E6%98%AF%E8%B4%B9%E5%8A%9B%E7%9A%84%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="Level of Processing Models" _mubu_text="%3Cspan%3ELevel%20of%20Processing%20Models%3C/span%3E" _note="" _mubu_note="">
          <outline text="3 Level of Processing, Structural, Phonemic, Semantic" _mubu_text="%3Cspan%3E3%20Level%20of%20Processing,%20Structural,%20Phonemic,%20Semantic%3C/span%3E" _note="" _mubu_note="">
            <outline text="Archive" _mubu_text="%3Cspan%3EArchive%3C/span%3E" _note="" _mubu_note="">
              <outline text="图" _mubu_text="%3Cspan%3E%E5%9B%BE%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22QoKPiFFDPC%22%2C%22oh%22%3A423%2C%22ow%22%3A852%2C%22uri%22%3A%22document_image%2F33585682_e161cebd-0570-4e98-98e6-936564c2d989.png%22%2C%22w%22%3A400%7D%5D"/>
              <outline text="Structural Processing " _mubu_text="%3Cspan%3EStructural%20Processing%20%3C/span%3E" _note="" _mubu_note="">
                <outline text="结构加工 / Shallow Processing" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E7%BB%93%E6%9E%84%E5%8A%A0%E5%B7%A5%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E/%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EShallow%3C/span%3E%3Cspan%20class=%22bold%22%3E%20Processing%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="最浅的加工" _mubu_text="%3Cspan%20class=%22bold%20text-color-green%22%3E%E6%9C%80%E6%B5%85%3C/span%3E%3Cspan%3E%E7%9A%84%E5%8A%A0%E5%B7%A5%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="只关注信息表面的、物理的特征。" _mubu_text="%3Cspan%3E%E5%8F%AA%E5%85%B3%E6%B3%A8%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%20class=%22bold%20underline%22%3E%E8%A1%A8%E9%9D%A2%E7%9A%84%E3%80%81%E7%89%A9%E7%90%86%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%89%B9%E5%BE%81%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="E.g. 看到 &quot;Peter Parker&quot; 这个词，你只注意它是不是大写的，或者它有多少个字母。这种记忆非常短暂。" _mubu_text="%3Cspan%3EE.g.%20%E7%9C%8B%E5%88%B0%20%22Peter%20Parker%22%20%E8%BF%99%E4%B8%AA%E8%AF%8D%EF%BC%8C%E4%BD%A0%E5%8F%AA%E6%B3%A8%E6%84%8F%E5%AE%83%E6%98%AF%E4%B8%8D%E6%98%AF%3C/span%3E%3Cspan%20class=%22italic%22%3E%E5%A4%A7%E5%86%99%E7%9A%84%EF%BC%8C%E6%88%96%E8%80%85%E5%AE%83%E6%9C%89%E5%A4%9A%E5%B0%91%E4%B8%AA%E5%AD%97%E6%AF%8D%3C/span%3E%3Cspan%3E%E3%80%82%E8%BF%99%E7%A7%8D%E8%AE%B0%E5%BF%86%E9%9D%9E%E5%B8%B8%E7%9F%AD%E6%9A%82%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="Phonemic Processing" _mubu_text="%3Cspan%3EPhonemic%20Processing%3C/span%3E" _note="" _mubu_note="">
                <outline text="语音加工 / Intermediate Processing" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E8%AF%AD%E9%9F%B3%E5%8A%A0%E5%B7%A5%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E/%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EIntermediate%3C/span%3E%3Cspan%20class=%22bold%22%3E%20Processing%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="中等深度的加工。" _mubu_text="%3Cspan%20class=%22bold%20text-color-green%22%3E%E4%B8%AD%E7%AD%89%E6%B7%B1%E5%BA%A6%3C/span%3E%3Cspan%3E%E7%9A%84%E5%8A%A0%E5%B7%A5%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="你关注信息听起来是怎样的。" _mubu_text="%3Cspan%3E%E4%BD%A0%E5%85%B3%E6%B3%A8%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%20class=%22bold%20underline%22%3E%E5%90%AC%E8%B5%B7%E6%9D%A5%E6%98%AF%E6%80%8E%E6%A0%B7%E7%9A%84%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="E.g. 你注意到 &quot;Peter Parker&quot; 这两个词读起来有alliteration。这比只看形状要深一些，记忆效果稍好。" _mubu_text="%3Cspan%3EE.g.%20%E4%BD%A0%E6%B3%A8%E6%84%8F%E5%88%B0%20%22Peter%20Parker%22%20%E8%BF%99%E4%B8%A4%E4%B8%AA%E8%AF%8D%3C/span%3E%3Cspan%20class=%22italic%22%3E%E8%AF%BB%E8%B5%B7%E6%9D%A5%E6%9C%89alliteration%3C/span%3E%3Cspan%3E%E3%80%82%E8%BF%99%E6%AF%94%E5%8F%AA%E7%9C%8B%E5%BD%A2%E7%8A%B6%E8%A6%81%E6%B7%B1%E4%B8%80%E4%BA%9B%EF%BC%8C%E8%AE%B0%E5%BF%86%E6%95%88%E6%9E%9C%E7%A8%8D%E5%A5%BD%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="Semantic Processing" _mubu_text="%3Cspan%3ESemantic%20Processing%3C/span%3E" _note="" _mubu_note="">
                <outline text="语义加工 / Deep Processing" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E8%AF%AD%E4%B9%89%E5%8A%A0%E5%B7%A5%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E/%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EDeep%3C/span%3E%3Cspan%20class=%22bold%22%3E%20Processing%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="最深的加工水平。" _mubu_text="%3Cspan%20class=%22bold%20text-color-green%22%3E%E6%9C%80%E6%B7%B1%3C/span%3E%3Cspan%3E%E7%9A%84%E5%8A%A0%E5%B7%A5%E6%B0%B4%E5%B9%B3%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="你关注信息的意义，并把它和你已有的知识联系起来。" _mubu_text="%3Cspan%3E%E4%BD%A0%E5%85%B3%E6%B3%A8%E4%BF%A1%E6%81%AF%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%20underline%22%3E%E6%84%8F%E4%B9%89%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%B9%B6%E6%8A%8A%E5%AE%83%E5%92%8C%E4%BD%A0%E5%B7%B2%E6%9C%89%E7%9A%84%E7%9F%A5%E8%AF%86%E8%81%94%E7%B3%BB%E8%B5%B7%E6%9D%A5%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="E.g. 你思考 &quot;Peter Parker&quot; 是谁，然后想起“哦，他是蜘蛛侠”。你把这个新信息和你脑中关于“蜘蛛侠”的知识网络连接了起来。" _mubu_text="%3Cspan%3EE.g.%20%E4%BD%A0%E6%80%9D%E8%80%83%20%22Peter%20Parker%22%20%E6%98%AF%E8%B0%81%EF%BC%8C%E7%84%B6%E5%90%8E%E6%83%B3%E8%B5%B7%E2%80%9C%E5%93%A6%EF%BC%8C%E4%BB%96%E6%98%AF%E8%9C%98%E8%9B%9B%E4%BE%A0%E2%80%9D%E3%80%82%E4%BD%A0%E6%8A%8A%E8%BF%99%E4%B8%AA%E6%96%B0%E4%BF%A1%E6%81%AF%E5%92%8C%E4%BD%A0%E8%84%91%E4%B8%AD%E5%85%B3%E4%BA%8E%E2%80%9C%E8%9C%98%E8%9B%9B%E4%BE%A0%E2%80%9D%E7%9A%84%E7%9F%A5%E8%AF%86%E7%BD%91%E7%BB%9C%E8%BF%9E%E6%8E%A5%E4%BA%86%E8%B5%B7%E6%9D%A5%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="这是最有效的记忆方式。" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3E%E8%BF%99%E6%98%AF%E6%9C%80%E6%9C%89%E6%95%88%E7%9A%84%E8%AE%B0%E5%BF%86%E6%96%B9%E5%BC%8F%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="Self-reference effect (自我参照效应) 是深度加工的一个特例：如果信息与我们自身相关，我们会记得特别牢。" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ESelf-reference%20effect%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E8%87%AA%E6%88%91%E5%8F%82%E7%85%A7%E6%95%88%E5%BA%94)%3C/span%3E%3Cspan%3E%20%E6%98%AF%E6%B7%B1%E5%BA%A6%E5%8A%A0%E5%B7%A5%E7%9A%84%E4%B8%80%E4%B8%AA%E7%89%B9%E4%BE%8B%EF%BC%9A%E5%A6%82%E6%9E%9C%3C/span%3E%3Cspan%20class=%22underline%22%3E%E4%BF%A1%E6%81%AF%E4%B8%8E%E6%88%91%E4%BB%AC%E8%87%AA%E8%BA%AB%E7%9B%B8%E5%85%B3%EF%BC%8C%E6%88%91%E4%BB%AC%E4%BC%9A%E8%AE%B0%E5%BE%97%E7%89%B9%E5%88%AB%E7%89%A2%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="Alias" _mubu_text="%3Cspan%3EAlias%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22rwHfcqrLUJ%22%2C%22oh%22%3A322%2C%22ow%22%3A669%2C%22uri%22%3A%22document_image%2F33585682_08dbfc2f-0255-4ac7-cab3-19e5bc84ffad.png%22%2C%22w%22%3A400%7D%5D"/>
              </outline>
            </outline>
          </outline>
          <outline text="Structural Processing 结构加工 最浅的加工，只关注表面的物理的特征；Peter Parker，oh，首字母大写" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EStructural%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EProcessing%20%E7%BB%93%E6%9E%84%E5%8A%A0%E5%B7%A5%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9C%80%E6%B5%85%3C/span%3E%3Cspan%3E%E7%9A%84%E5%8A%A0%E5%B7%A5%EF%BC%8C%E5%8F%AA%E5%85%B3%E6%B3%A8%E8%A1%A8%E9%9D%A2%E7%9A%84%E7%89%A9%E7%90%86%E7%9A%84%E7%89%B9%E5%BE%81%EF%BC%9BPeter%20Parker%EF%BC%8Coh%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%A6%96%E5%AD%97%E6%AF%8D%E5%A4%A7%E5%86%99%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Phonemic Processing 语音加工 中等深度的加工，关注信息听起来是怎样的；Peter Parker，oh，两个p" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EPhonemic%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EProcessing%20%E8%AF%AD%E9%9F%B3%E5%8A%A0%E5%B7%A5%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%AD%E7%AD%89%3C/span%3E%3Cspan%3E%E6%B7%B1%E5%BA%A6%E7%9A%84%E5%8A%A0%E5%B7%A5%EF%BC%8C%E5%85%B3%E6%B3%A8%E4%BF%A1%E6%81%AF%E5%90%AC%E8%B5%B7%E6%9D%A5%E6%98%AF%E6%80%8E%E6%A0%B7%E7%9A%84%EF%BC%9BPeter%20Parker%EF%BC%8Coh%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%A4%E4%B8%AAp%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Semantic Processing 语义加工 最深的加工水平，关乎意义，最有效的记忆方式（Self-Reference effect，如果和我们有关，就会记得特别牢）；他是蜘蛛侠！" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ESemantic%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EProcessing%20%E8%AF%AD%E4%B9%89%E5%8A%A0%E5%B7%A5%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9C%80%E6%B7%B1%3C/span%3E%3Cspan%3E%E7%9A%84%E5%8A%A0%E5%B7%A5%E6%B0%B4%E5%B9%B3%EF%BC%8C%E5%85%B3%E4%B9%8E%E6%84%8F%E4%B9%89%EF%BC%8C%E6%9C%80%E6%9C%89%E6%95%88%E7%9A%84%E8%AE%B0%E5%BF%86%E6%96%B9%E5%BC%8F%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3ESelf-Reference%20effect%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%A6%82%E6%9E%9C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%92%8C%E6%88%91%E4%BB%AC%E6%9C%89%E5%85%B3%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%B0%B1%E4%BC%9A%E8%AE%B0%E5%BE%97%E7%89%B9%E5%88%AB%E7%89%A2%EF%BC%89%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%BB%96%E6%98%AF%E8%9C%98%E8%9B%9B%E4%BE%A0%EF%BC%81%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
      <outline text="2.4 编码记忆 Encoding Memories（1750字）" _mubu_text="%3Cspan%3E2.4%20%E7%BC%96%E7%A0%81%E8%AE%B0%E5%BF%86%20Encoding%20Memories%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E1750%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="3. Multi-store Model of Memory 三阶记忆模型" _mubu_text="%3Cspan%3E3.%20Multi-store%20Model%20of%20Memory%20%E4%B8%89%E9%98%B6%E8%AE%B0%E5%BF%86%E6%A8%A1%E5%9E%8B%3C/span%3E" _note="" _mubu_note="">
          <outline text="Sensory Memory 感觉记忆" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ESensory%20%3C/span%3E%3Cspan%20class=%22bold%22%3EMemory%3C/span%3E%3Cspan%3E%20%E6%84%9F%E8%A7%89%E8%AE%B0%E5%BF%86%3C/span%3E" _note="" _mubu_note="">
            <outline text="极短地（&lt;1秒到几秒）保存所有感官接收到的原始信息，让你决定要不要关注它" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E6%9E%81%E7%9F%AD%3C/span%3E%3Cspan%3E%E5%9C%B0%EF%BC%88&amp;lt;1%E7%A7%92%E5%88%B0%E5%87%A0%E7%A7%92%EF%BC%89%E4%BF%9D%E5%AD%98%E6%89%80%E6%9C%89%E6%84%9F%E5%AE%98%E6%8E%A5%E6%94%B6%E5%88%B0%E7%9A%84%E5%8E%9F%E5%A7%8B%E4%BF%A1%E6%81%AF%EF%BC%8C%E8%AE%A9%E4%BD%A0%E5%86%B3%E5%AE%9A%E8%A6%81%E4%B8%8D%E8%A6%81%E5%85%B3%E6%B3%A8%E5%AE%83%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="容量大，但是很快衰减" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E5%AE%B9%E9%87%8F%E5%A4%A7%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BD%86%E6%98%AF%E5%BE%88%E5%BF%AB%E8%A1%B0%E5%87%8F%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Iconic Memory (图像记忆) ：视觉的感觉记忆；点燃的烟花棒会看到完整光轨" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EIconic%20Memory%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E5%9B%BE%E5%83%8F%E8%AE%B0%E5%BF%86)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A7%86%E8%A7%89%E7%9A%84%E6%84%9F%E8%A7%89%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%EF%BC%9B%E7%82%B9%E7%87%83%E7%9A%84%E7%83%9F%E8%8A%B1%E6%A3%92%E4%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%9C%8B%E5%88%B0%E5%AE%8C%E6%95%B4%E5%85%89%E8%BD%A8%3C/span%3E" _note="" _mubu_note="">
              <outline text="它就像你快速晃动一根点燃的烟花棒时，会看到一条完整的光轨一样。这个视觉印象会在你的视网膜上停留不到一秒钟。" _mubu_text="%3Cspan%3E%E5%AE%83%E5%B0%B1%E5%83%8F%E4%BD%A0%E5%BF%AB%E9%80%9F%E6%99%83%E5%8A%A8%E4%B8%80%E6%A0%B9%E7%82%B9%E7%87%83%E7%9A%84%E7%83%9F%E8%8A%B1%E6%A3%92%E6%97%B6%EF%BC%8C%E4%BC%9A%E7%9C%8B%E5%88%B0%E4%B8%80%E6%9D%A1%E5%AE%8C%E6%95%B4%E7%9A%84%E5%85%89%E8%BD%A8%E4%B8%80%E6%A0%B7%E3%80%82%E8%BF%99%E4%B8%AA%E8%A7%86%E8%A7%89%E5%8D%B0%E8%B1%A1%E4%BC%9A%E5%9C%A8%E4%BD%A0%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A7%86%E7%BD%91%E8%86%9C%E4%B8%8A%E5%81%9C%E7%95%99%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%B8%8D%E5%88%B0%E4%B8%80%E7%A7%92%E9%92%9F%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Echoic Memory (声像记忆) ：听觉的感觉记忆；老师点你回答问题，你可以重复播放刚刚那句话" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EEchoic%20Memory%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E5%A3%B0%E5%83%8F%E8%AE%B0%E5%BF%86)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%90%AC%E8%A7%89%E7%9A%84%E6%84%9F%E8%A7%89%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%EF%BC%9B%E8%80%81%E5%B8%88%E7%82%B9%E4%BD%A0%E5%9B%9E%E7%AD%94%E9%97%AE%E9%A2%98%EF%BC%8C%E4%BD%A0%E5%8F%AF%E4%BB%A5%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%87%8D%E5%A4%8D%E6%92%AD%E6%94%BE%E5%88%9A%E5%88%9A%E9%82%A3%E5%8F%A5%E8%AF%9D%3C/span%3E" _note="" _mubu_note="">
              <outline text="比如老师刚刚说了一句话，你当时走神了没听清，但你可以在接下来的3-4秒内，在脑海里“回放”刚才的声音，从而理解它的意思。这就是为什么别人问你“刚才我说什么了？”你有时能答出来的原因。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%E8%80%81%E5%B8%88%E5%88%9A%E5%88%9A%E8%AF%B4%E4%BA%86%E4%B8%80%E5%8F%A5%E8%AF%9D%EF%BC%8C%E4%BD%A0%E5%BD%93%E6%97%B6%E8%B5%B0%E7%A5%9E%E4%BA%86%E6%B2%A1%E5%90%AC%E6%B8%85%EF%BC%8C%E4%BD%86%E4%BD%A0%E5%8F%AF%E4%BB%A5%E5%9C%A8%E6%8E%A5%E4%B8%8B%E6%9D%A5%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E3-4%E7%A7%92%3C/span%3E%3Cspan%3E%E5%86%85%EF%BC%8C%E5%9C%A8%E8%84%91%E6%B5%B7%E9%87%8C%E2%80%9C%E5%9B%9E%E6%94%BE%E2%80%9D%E5%88%9A%E6%89%8D%E7%9A%84%E5%A3%B0%E9%9F%B3%EF%BC%8C%E4%BB%8E%E8%80%8C%E7%90%86%E8%A7%A3%E5%AE%83%E7%9A%84%E6%84%8F%E6%80%9D%E3%80%82%E8%BF%99%E5%B0%B1%E6%98%AF%E4%B8%BA%E4%BB%80%E4%B9%88%E5%88%AB%E4%BA%BA%E9%97%AE%E4%BD%A0%E2%80%9C%E5%88%9A%E6%89%8D%E6%88%91%E8%AF%B4%E4%BB%80%E4%B9%88%E4%BA%86%EF%BC%9F%E2%80%9D%E4%BD%A0%E6%9C%89%E6%97%B6%E8%83%BD%E7%AD%94%E5%87%BA%E6%9D%A5%E7%9A%84%E5%8E%9F%E5%9B%A0%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="Short-Term Memory / Working Memory 短期记忆 / 工作记忆" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EShort-Term%20%3C/span%3E%3Cspan%20class=%22bold%22%3EMemory%20/%20Working%20Memory%3C/span%3E%3Cspan%3E%20%E7%9F%AD%E6%9C%9F%E8%AE%B0%E5%BF%86%20/%20%E5%B7%A5%E4%BD%9C%E8%AE%B0%E5%BF%86%3C/span%3E" _note="" _mubu_note="">
            <outline text="短期记忆" _mubu_text="%3Cspan%3E%E7%9F%AD%E6%9C%9F%E8%AE%B0%E5%BF%86%3C/span%3E" _note="" _mubu_note="">
              <outline text="信息被我们注意到，会从sensory memory来到STM" _mubu_text="%3Cspan%3E%E4%BF%A1%E6%81%AF%E8%A2%AB%E6%88%91%E4%BB%AC%E6%B3%A8%E6%84%8F%E5%88%B0%EF%BC%8C%E4%BC%9A%E4%BB%8Esensory%20memory%E6%9D%A5%E5%88%B0STM%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="容量有限，信息可以在这里被主动使用和加工" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E5%AE%B9%E9%87%8F%E6%9C%89%E9%99%90%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BF%A1%E6%81%AF%E5%8F%AF%E4%BB%A5%E5%9C%A8%E8%BF%99%E9%87%8C%E8%A2%AB%E4%B8%BB%E5%8A%A8%E4%BD%BF%E7%94%A8%E5%92%8C%E5%8A%A0%E5%B7%A5%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="容量小：7±2个信息单元（7组数字，7个单词）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%AE%B9%E9%87%8F%E5%B0%8F%3C/span%3E%3Cspan%3E%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E7%C2%B12%3C/span%3E%3Cspan%3E%E4%B8%AA%E4%BF%A1%E6%81%AF%E5%8D%95%E5%85%83%EF%BC%887%E7%BB%84%E6%95%B0%E5%AD%97%EF%BC%8C7%E4%B8%AA%E5%8D%95%E8%AF%8D%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="时间较短：不进行复述，最多只能停留20-30秒" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%97%B6%E9%97%B4%E8%BE%83%E7%9F%AD%3C/span%3E%3Cspan%3E%EF%BC%9A%E4%B8%8D%E8%BF%9B%E8%A1%8C%E5%A4%8D%E8%BF%B0%EF%BC%8C%E6%9C%80%E5%A4%9A%E5%8F%AA%E8%83%BD%E5%81%9C%E7%95%99%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E20-30%E7%A7%92%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="工作记忆" _mubu_text="%3Cspan%3E%E5%B7%A5%E4%BD%9C%E8%AE%B0%E5%BF%86%3C/span%3E" _note="" _mubu_note="">
              <outline text="另一个模型，让STM好听一些（体现其主动加工的能力）" _mubu_text="%3Cspan%3E%E5%8F%A6%E4%B8%80%E4%B8%AA%E6%A8%A1%E5%9E%8B%EF%BC%8C%E8%AE%A9STM%E5%A5%BD%E5%90%AC%E4%B8%80%E4%BA%9B%EF%BC%88%E4%BD%93%E7%8E%B0%E5%85%B6%E4%B8%BB%E5%8A%A8%E5%8A%A0%E5%B7%A5%E7%9A%84%E8%83%BD%E5%8A%9B%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Central Executive (中央执行系统) 分配注意力，协调下面两个“员工”的工作，并从长时记忆中提取信息来辅助当前任务。" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ECentral%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EExecutive%20(%E4%B8%AD%E5%A4%AE%E6%89%A7%E8%A1%8C%E7%B3%BB%E7%BB%9F)%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%88%86%E9%85%8D%E6%B3%A8%E6%84%8F%E5%8A%9B%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%8D%8F%E8%B0%83%E4%B8%8B%E9%9D%A2%E4%B8%A4%E4%B8%AA%E2%80%9C%E5%91%98%E5%B7%A5%E2%80%9D%E7%9A%84%E5%B7%A5%E4%BD%9C%EF%BC%8C%E5%B9%B6%E4%BB%8E%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%95%BF%E6%97%B6%E8%AE%B0%E5%BF%86%E4%B8%AD%E6%8F%90%E5%8F%96%E4%BF%A1%E6%81%AF%E6%9D%A5%E8%BE%85%E5%8A%A9%E5%BD%93%E5%89%8D%E4%BB%BB%E5%8A%A1%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Phonological Loop (语音回路) 处理声音和语言信息的“内部耳朵和嘴巴”。它让你可以在脑海里默念一个电话号码来记住它。" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EPhonological%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3ELoop%20(%E8%AF%AD%E9%9F%B3%E5%9B%9E%E8%B7%AF)%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%84%E7%90%86%E5%A3%B0%E9%9F%B3%E5%92%8C%E8%AF%AD%E8%A8%80%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%E7%9A%84%E2%80%9C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%86%85%E9%83%A8%E8%80%B3%E6%9C%B5%3C/span%3E%3Cspan%3E%E5%92%8C%E5%98%B4%E5%B7%B4%E2%80%9D%E3%80%82%E5%AE%83%E8%AE%A9%E4%BD%A0%E5%8F%AF%E4%BB%A5%E5%9C%A8%E8%84%91%E6%B5%B7%E9%87%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%BB%98%E5%BF%B5%E4%B8%80%E4%B8%AA%E7%94%B5%E8%AF%9D%E5%8F%B7%E7%A0%81%3C/span%3E%3Cspan%3E%E6%9D%A5%E8%AE%B0%E4%BD%8F%E5%AE%83%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Visuospatial Sketchpad (视觉空间画板) 处理视觉和空间信息的“内部眼睛”。它让你可以在脑海里想象一张地图，或者在脑中旋转一个三维物体。" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EVisuospatial%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3ESketchpad%20(%E8%A7%86%E8%A7%89%E7%A9%BA%E9%97%B4%E7%94%BB%E6%9D%BF)%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%84%E7%90%86%E8%A7%86%E8%A7%89%E5%92%8C%E7%A9%BA%E9%97%B4%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%E7%9A%84%E2%80%9C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%86%85%E9%83%A8%E7%9C%BC%E7%9D%9B%3C/span%3E%3Cspan%3E%E2%80%9D%E3%80%82%E5%AE%83%E8%AE%A9%E4%BD%A0%E5%8F%AF%E4%BB%A5%E5%9C%A8%E8%84%91%E6%B5%B7%E9%87%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%83%B3%E8%B1%A1%E4%B8%80%E5%BC%A0%E5%9C%B0%E5%9B%BE%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%88%96%E8%80%85%E5%9C%A8%E8%84%91%E4%B8%AD%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%97%8B%E8%BD%AC%E4%B8%80%E4%B8%AA%E4%B8%89%E7%BB%B4%E7%89%A9%E4%BD%93%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="Long-Term Memory 长期记忆" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ELong-Term%20%3C/span%3E%3Cspan%20class=%22bold%22%3EMemory%3C/span%3E%3Cspan%3E%20%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%3C/span%3E" _note="" _mubu_note="">
            <outline text="如果信息在短时记忆/工作记忆中经过充分的加工和复述 (rehearsal) ，它就有可能被转存到长时记忆中。" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E4%BF%A1%E6%81%AF%E5%9C%A8%E7%9F%AD%E6%97%B6%E8%AE%B0%E5%BF%86/%E5%B7%A5%E4%BD%9C%E8%AE%B0%E5%BF%86%E4%B8%AD%E7%BB%8F%E8%BF%87%E5%85%85%E5%88%86%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%8A%A0%E5%B7%A5%E5%92%8C%E5%A4%8D%E8%BF%B0%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(rehearsal)%3C/span%3E%3Cspan%3E%20%EF%BC%8C%E5%AE%83%E5%B0%B1%E6%9C%89%E5%8F%AF%E8%83%BD%E8%A2%AB%E8%BD%AC%E5%AD%98%E5%88%B0%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%95%BF%E6%97%B6%E8%AE%B0%E5%BF%86%E4%B8%AD%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="长时记忆是我们知识、技能和经验的永久储存库。它的容量和时长被认为是几乎无限的。" _mubu_text="%3Cspan%3E%E9%95%BF%E6%97%B6%E8%AE%B0%E5%BF%86%E6%98%AF%E6%88%91%E4%BB%AC%E7%9F%A5%E8%AF%86%E3%80%81%E6%8A%80%E8%83%BD%E5%92%8C%E7%BB%8F%E9%AA%8C%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E6%B0%B8%E4%B9%85%E5%82%A8%E5%AD%98%E5%BA%93%3C/span%3E%3Cspan%3E%E3%80%82%E5%AE%83%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%AE%B9%E9%87%8F%E5%92%8C%E6%97%B6%E9%95%BF%E8%A2%AB%E8%AE%A4%E4%B8%BA%E6%98%AF%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E5%87%A0%E4%B9%8E%E6%97%A0%E9%99%90%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%9A%84%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Archive" _mubu_text="%3Cspan%3EArchive%3C/span%3E" _note="" _mubu_note="">
            <outline text="Introduction" _mubu_text="%3Cspan%3EIntroduction%3C/span%3E" _note="" _mubu_note="">
              <outline text="三阶段记忆模型。它认为记忆有三个“仓库”，信息需要依次通过它们。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%B8%89%E9%98%B6%E6%AE%B5%E8%AE%B0%E5%BF%86%E6%A8%A1%E5%9E%8B%3C/span%3E%3Cspan%3E%E3%80%82%E5%AE%83%E8%AE%A4%E4%B8%BA%E8%AE%B0%E5%BF%86%E6%9C%89%E4%B8%89%E4%B8%AA%E2%80%9C%E4%BB%93%E5%BA%93%E2%80%9D%EF%BC%8C%E4%BF%A1%E6%81%AF%E9%9C%80%E8%A6%81%E4%BE%9D%E6%AC%A1%E9%80%9A%E8%BF%87%E5%AE%83%E4%BB%AC%E3%80%82%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%229nPEtSgrxo%22%2C%22oh%22%3A237%2C%22ow%22%3A970%2C%22uri%22%3A%22document_image%2F33585682_d2ed7ebc-a22d-4a77-ba42-b83cd774d27e.png%22%2C%22w%22%3A400%7D%5D"/>
              <outline text="| Category | Duration | Capacity |
| --- | --- | --- |
| Sensory Memory | ≤ 1s​ | +∞ |
| STM​ | ≤ 30s​ | 7±2​ |
| ​LTM | ​+∞ | +∞ |" _mubu_text="%3Cdiv%20class=%22table-container%22%3E%3Ctable%20class=%22auto-table%22%20border=%221%22%20cellspacing=%220%22%20style=%22border-collapse:%20collapse;%22%3E%3Cthead%3E%3Ctr%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%220%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%220%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cb%3ECategory%3C/b%3E%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%221%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cb%3EDuration%3C/b%3E%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%222%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cb%3ECapacity%3C/b%3E%3C/span%3E%3C/th%3E%3C/tr%3E%3C/thead%3E%3Ctbody%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%221%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3ESensory%20Memory%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E2%89%A4%201s%E2%80%8B%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E+%E2%88%9E%3C/span%3E%3C/td%3E%3C/tr%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%222%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3ESTM%E2%80%8B%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E2%89%A4%2030s%E2%80%8B%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E7%C2%B12%E2%80%8B%3C/span%3E%3C/td%3E%3C/tr%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%223%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E2%80%8BLTM%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E2%80%8B+%E2%88%9E%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E+%E2%88%9E%3C/span%3E%3C/td%3E%3C/tr%3E%3C/tbody%3E%3C/table%3E%3C/div%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Sensory Memory 感觉记忆" _mubu_text="%3Cspan%20class=%22bold%22%3ESensory%20Memory%3C/span%3E%3Cspan%3E%20%E6%84%9F%E8%A7%89%E8%AE%B0%E5%BF%86%3C/span%3E" _note="" _mubu_note="">
              <outline text="记忆系统的“接待大厅”。它会极短暂地（&lt;1秒到几秒） 保存所有从感官接收到的原始信息，让你有时间决定是否要关注它。" _mubu_text="%3Cspan%3E%E8%AE%B0%E5%BF%86%E7%B3%BB%E7%BB%9F%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E2%80%9C%E6%8E%A5%E5%BE%85%E5%A4%A7%E5%8E%85%E2%80%9D%3C/span%3E%3Cspan%3E%E3%80%82%E5%AE%83%E4%BC%9A%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%9E%81%E7%9F%AD%E6%9A%82%E5%9C%B0%EF%BC%88&amp;lt;1%E7%A7%92%E5%88%B0%E5%87%A0%E7%A7%92%EF%BC%89%3C/span%3E%3Cspan%3E%20%E4%BF%9D%E5%AD%98%E6%89%80%E6%9C%89%E4%BB%8E%E6%84%9F%E5%AE%98%E6%8E%A5%E6%94%B6%E5%88%B0%E7%9A%84%E5%8E%9F%E5%A7%8B%E4%BF%A1%E6%81%AF%EF%BC%8C%E8%AE%A9%E4%BD%A0%E6%9C%89%E6%97%B6%E9%97%B4%E5%86%B3%E5%AE%9A%E6%98%AF%E5%90%A6%E8%A6%81%E5%85%B3%E6%B3%A8%E5%AE%83%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="它的容量很大，但信息衰减得非常快。" _mubu_text="%3Cspan%3E%E5%AE%83%E7%9A%84%E5%AE%B9%E9%87%8F%E5%BE%88%E5%A4%A7%EF%BC%8C%E4%BD%86%E4%BF%A1%E6%81%AF%E8%A1%B0%E5%87%8F%E5%BE%97%E9%9D%9E%E5%B8%B8%E5%BF%AB%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="它主要分为两种：" _mubu_text="%3Cspan%3E%E5%AE%83%E4%B8%BB%E8%A6%81%E5%88%86%E4%B8%BA%E4%B8%A4%E7%A7%8D%EF%BC%9A%3C/span%3E" _note="" _mubu_note="">
                <outline text="Iconic Memory (图像记忆) ：视觉的感觉记忆。它就像你快速晃动一根点燃的烟花棒时，会看到一条完整的光轨一样。这个视觉印象会在你的视网膜上停留不到一秒钟。" _mubu_text="%3Cspan%20class=%22bold%22%3EIconic%20Memory%20(%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%9B%BE%E5%83%8F%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%AE%B0%E5%BF%86)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E8%A7%86%E8%A7%89%E7%9A%84%E6%84%9F%E8%A7%89%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%E3%80%82%E5%AE%83%E5%B0%B1%E5%83%8F%E4%BD%A0%E5%BF%AB%E9%80%9F%E6%99%83%E5%8A%A8%E4%B8%80%E6%A0%B9%E7%82%B9%E7%87%83%E7%9A%84%E7%83%9F%E8%8A%B1%E6%A3%92%E6%97%B6%EF%BC%8C%E4%BC%9A%E7%9C%8B%E5%88%B0%E4%B8%80%E6%9D%A1%E5%AE%8C%E6%95%B4%E7%9A%84%E5%85%89%E8%BD%A8%E4%B8%80%E6%A0%B7%E3%80%82%E8%BF%99%E4%B8%AA%E8%A7%86%E8%A7%89%E5%8D%B0%E8%B1%A1%E4%BC%9A%E5%9C%A8%E4%BD%A0%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A7%86%E7%BD%91%E8%86%9C%E4%B8%8A%E5%81%9C%E7%95%99%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%B8%8D%E5%88%B0%E4%B8%80%E7%A7%92%E9%92%9F%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="Echoic Memory (声像记忆) ：听觉的感觉记忆。比如老师刚刚说了一句话，你当时走神了没听清，但你可以在接下来的3-4秒内，在脑海里“回放”刚才的声音，从而理解它的意思。这就是为什么别人问你“刚才我说什么了？”你有时能答出来的原因。" _mubu_text="%3Cspan%20class=%22bold%22%3EEchoic%20Memory%20(%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%A3%B0%E5%83%8F%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%AE%B0%E5%BF%86)%3C/span%3E%3Cspan%3E%20%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%90%AC%E8%A7%89%E7%9A%84%E6%84%9F%E8%A7%89%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%E3%80%82%E6%AF%94%E5%A6%82%E8%80%81%E5%B8%88%E5%88%9A%E5%88%9A%E8%AF%B4%E4%BA%86%E4%B8%80%E5%8F%A5%E8%AF%9D%EF%BC%8C%E4%BD%A0%E5%BD%93%E6%97%B6%E8%B5%B0%E7%A5%9E%E4%BA%86%E6%B2%A1%E5%90%AC%E6%B8%85%EF%BC%8C%E4%BD%86%E4%BD%A0%E5%8F%AF%E4%BB%A5%E5%9C%A8%E6%8E%A5%E4%B8%8B%E6%9D%A5%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E3-4%E7%A7%92%3C/span%3E%3Cspan%3E%E5%86%85%EF%BC%8C%E5%9C%A8%E8%84%91%E6%B5%B7%E9%87%8C%E2%80%9C%E5%9B%9E%E6%94%BE%E2%80%9D%E5%88%9A%E6%89%8D%E7%9A%84%E5%A3%B0%E9%9F%B3%EF%BC%8C%E4%BB%8E%E8%80%8C%E7%90%86%E8%A7%A3%E5%AE%83%E7%9A%84%E6%84%8F%E6%80%9D%E3%80%82%E8%BF%99%E5%B0%B1%E6%98%AF%E4%B8%BA%E4%BB%80%E4%B9%88%E5%88%AB%E4%BA%BA%E9%97%AE%E4%BD%A0%E2%80%9C%E5%88%9A%E6%89%8D%E6%88%91%E8%AF%B4%E4%BB%80%E4%B9%88%E4%BA%86%EF%BC%9F%E2%80%9D%E4%BD%A0%E6%9C%89%E6%97%B6%E8%83%BD%E7%AD%94%E5%87%BA%E6%9D%A5%E7%9A%84%E5%8E%9F%E5%9B%A0%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="感官记忆" _mubu_text="%3Cspan%3E%E6%84%9F%E5%AE%98%E8%AE%B0%E5%BF%86%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22Q8gvL29jbY%22%2C%22oh%22%3A338%2C%22ow%22%3A1050%2C%22uri%22%3A%22document_image%2F33585682_a6652cba-99df-47f7-eaa0-fd2f8416f1be.png%22%2C%22w%22%3A400%7D%5D"/>
              </outline>
            </outline>
            <outline text="Short Term Memory 短期记忆（Working Memory）" _mubu_text="%3Cspan%20class=%22bold%22%3EShort%20Term%20Memory%3C/span%3E%3Cspan%3E%20%E7%9F%AD%E6%9C%9F%E8%AE%B0%E5%BF%86%EF%BC%88Working%20Memory%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
              <outline text="STM" _mubu_text="%3Cspan%3ESTM%3C/span%3E" _note="" _mubu_note="">
                <outline text="如果信息在感觉记忆阶段被我们注意 (attention) 到了，它就会进入短时记忆。" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E4%BF%A1%E6%81%AF%E5%9C%A8%E6%84%9F%E8%A7%89%E8%AE%B0%E5%BF%86%E9%98%B6%E6%AE%B5%E8%A2%AB%E6%88%91%E4%BB%AC%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E6%B3%A8%E6%84%8F%3C/span%3E%3Cspan%20class=%22bold%22%3E%20(attention)%3C/span%3E%3Cspan%3E%20%E5%88%B0%E4%BA%86%EF%BC%8C%E5%AE%83%E5%B0%B1%E4%BC%9A%E8%BF%9B%E5%85%A5%E7%9F%AD%E6%97%B6%E8%AE%B0%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="这是一个容量有限的“临时工作台”。信息在这里可以被主动地使用和加工。" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AF%E4%B8%80%E4%B8%AA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%AE%B9%E9%87%8F%E6%9C%89%E9%99%90%3C/span%3E%3Cspan%3E%E7%9A%84%E2%80%9C%E4%B8%B4%E6%97%B6%E5%B7%A5%E4%BD%9C%E5%8F%B0%E2%80%9D%E3%80%82%E4%BF%A1%E6%81%AF%E5%9C%A8%E8%BF%99%E9%87%8C%E5%8F%AF%E4%BB%A5%E8%A2%AB%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%B8%BB%E5%8A%A8%E5%9C%B0%E4%BD%BF%E7%94%A8%E5%92%8C%E5%8A%A0%E5%B7%A5%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="容量：7±2 个信息单元（比如7个数字、7个字母）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%AE%B9%E9%87%8F%EF%BC%9A%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E7%C2%B12%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%3E%E4%B8%AA%E4%BF%A1%E6%81%AF%E5%8D%95%E5%85%83%EF%BC%88%E6%AF%94%E5%A6%827%E4%B8%AA%E6%95%B0%E5%AD%97%E3%80%817%E4%B8%AA%E5%AD%97%E6%AF%8D%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="时长：如果不进行复述，信息在这里只能停留大约 20-30秒。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%97%B6%E9%95%BF%3C/span%3E%3Cspan%3E%EF%BC%9A%E5%A6%82%E6%9E%9C%E4%B8%8D%E8%BF%9B%E8%A1%8C%E5%A4%8D%E8%BF%B0%EF%BC%8C%E4%BF%A1%E6%81%AF%E5%9C%A8%E8%BF%99%E9%87%8C%E5%8F%AA%E8%83%BD%E5%81%9C%E7%95%99%E5%A4%A7%E7%BA%A6%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E20-30%E7%A7%92%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="Working Memory" _mubu_text="%3Cspan%3EWorking%20Memory%3C/span%3E" _note="" _mubu_note="">
                <outline text="“短时记忆”这个词太被动了，不能体现它主动加工信息的功能。" _mubu_text="%3Cspan%3E%E2%80%9C%E7%9F%AD%E6%97%B6%E8%AE%B0%E5%BF%86%E2%80%9D%E8%BF%99%E4%B8%AA%E8%AF%8D%E5%A4%AA%E8%A2%AB%E5%8A%A8%E4%BA%86%EF%BC%8C%E4%B8%8D%E8%83%BD%E4%BD%93%E7%8E%B0%E5%AE%83%E4%B8%BB%E5%8A%A8%E5%8A%A0%E5%B7%A5%E4%BF%A1%E6%81%AF%E7%9A%84%E5%8A%9F%E8%83%BD%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="于是他们提出了 Working Memory (工作记忆) 模型，可以看作是STM的升级版和详细版。" _mubu_text="%3Cspan%3E%E4%BA%8E%E6%98%AF%E4%BB%96%E4%BB%AC%E6%8F%90%E5%87%BA%E4%BA%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EWorking%20Memory%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(%E5%B7%A5%E4%BD%9C%E8%AE%B0%E5%BF%86)%3C/span%3E%3Cspan%3E%20%E6%A8%A1%E5%9E%8B%EF%BC%8C%E5%8F%AF%E4%BB%A5%E7%9C%8B%E4%BD%9C%E6%98%AFSTM%E7%9A%84%E5%8D%87%E7%BA%A7%E7%89%88%E5%92%8C%E8%AF%A6%E7%BB%86%E7%89%88%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="Three Parts" _mubu_text="%3Cspan%3EThree%20Parts%3C/span%3E" _note="" _mubu_note="">
                  <outline text="Central Executive (中央执行系统) 分配注意力，协调下面两个“员工”的工作，并从长时记忆中提取信息来辅助当前任务。" _mubu_text="%3Cspan%20class=%22bold%22%3ECentral%20Executive%20(%E4%B8%AD%E5%A4%AE%E6%89%A7%E8%A1%8C%E7%B3%BB%E7%BB%9F)%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E5%88%86%E9%85%8D%E6%B3%A8%E6%84%8F%E5%8A%9B%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%8D%8F%E8%B0%83%E4%B8%8B%E9%9D%A2%E4%B8%A4%E4%B8%AA%E2%80%9C%E5%91%98%E5%B7%A5%E2%80%9D%E7%9A%84%E5%B7%A5%E4%BD%9C%EF%BC%8C%E5%B9%B6%E4%BB%8E%E9%95%BF%E6%97%B6%E8%AE%B0%E5%BF%86%E4%B8%AD%E6%8F%90%E5%8F%96%E4%BF%A1%E6%81%AF%E6%9D%A5%E8%BE%85%E5%8A%A9%E5%BD%93%E5%89%8D%E4%BB%BB%E5%8A%A1%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                  <outline text="Phonological Loop (语音回路) 处理声音和语言信息的“内部耳朵和嘴巴”。它让你可以在脑海里默念一个电话号码来记住它。" _mubu_text="%3Cspan%20class=%22bold%22%3EPhonological%20Loop%20(%E8%AF%AD%E9%9F%B3%E5%9B%9E%E8%B7%AF)%3C/span%3E%3Cspan%3E%20%E5%A4%84%E7%90%86%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%A3%B0%E9%9F%B3%E5%92%8C%E8%AF%AD%E8%A8%80%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%E7%9A%84%E2%80%9C%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%86%85%E9%83%A8%E8%80%B3%E6%9C%B5%E5%92%8C%E5%98%B4%E5%B7%B4%3C/span%3E%3Cspan%3E%E2%80%9D%E3%80%82%E5%AE%83%E8%AE%A9%E4%BD%A0%E5%8F%AF%E4%BB%A5%E5%9C%A8%E8%84%91%E6%B5%B7%E9%87%8C%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E9%BB%98%E5%BF%B5%3C/span%3E%3Cspan%3E%E4%B8%80%E4%B8%AA%E7%94%B5%E8%AF%9D%E5%8F%B7%E7%A0%81%E6%9D%A5%E8%AE%B0%E4%BD%8F%E5%AE%83%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                  <outline text="Visuospatial Sketchpad (视觉空间画板) 处理视觉和空间信息的“内部眼睛”。它让你可以在脑海里想象一张地图，或者在脑中旋转一个三维物体。" _mubu_text="%3Cspan%20class=%22bold%22%3EVisuospatial%20Sketchpad%20(%E8%A7%86%E8%A7%89%E7%A9%BA%E9%97%B4%E7%94%BB%E6%9D%BF)%3C/span%3E%3Cspan%3E%20%E5%A4%84%E7%90%86%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%A7%86%E8%A7%89%E5%92%8C%E7%A9%BA%E9%97%B4%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%E7%9A%84%E2%80%9C%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%86%85%E9%83%A8%E7%9C%BC%E7%9D%9B%3C/span%3E%3Cspan%3E%E2%80%9D%E3%80%82%E5%AE%83%E8%AE%A9%E4%BD%A0%E5%8F%AF%E4%BB%A5%E5%9C%A8%E8%84%91%E6%B5%B7%E9%87%8C%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E6%83%B3%E8%B1%A1%3C/span%3E%3Cspan%3E%E4%B8%80%E5%BC%A0%E5%9C%B0%E5%9B%BE%EF%BC%8C%E6%88%96%E8%80%85%E5%9C%A8%E8%84%91%E4%B8%AD%E6%97%8B%E8%BD%AC%E4%B8%80%E4%B8%AA%E4%B8%89%E7%BB%B4%E7%89%A9%E4%BD%93%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                </outline>
              </outline>
            </outline>
            <outline text="Long Term Memory 长期记忆" _mubu_text="%3Cspan%20class=%22bold%22%3ELong%20Term%20Memory%3C/span%3E%3Cspan%3E%20%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%3C/span%3E" _note="" _mubu_note="">
              <outline text="如果信息在短时记忆/工作记忆中经过充分的加工和复述 (rehearsal) ，它就有可能被转存到长时记忆中。" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E4%BF%A1%E6%81%AF%E5%9C%A8%E7%9F%AD%E6%97%B6%E8%AE%B0%E5%BF%86/%E5%B7%A5%E4%BD%9C%E8%AE%B0%E5%BF%86%E4%B8%AD%E7%BB%8F%E8%BF%87%E5%85%85%E5%88%86%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%8A%A0%E5%B7%A5%E5%92%8C%E5%A4%8D%E8%BF%B0%20(rehearsal)%3C/span%3E%3Cspan%3E%20%EF%BC%8C%E5%AE%83%E5%B0%B1%E6%9C%89%E5%8F%AF%E8%83%BD%E8%A2%AB%E8%BD%AC%E5%AD%98%E5%88%B0%E9%95%BF%E6%97%B6%E8%AE%B0%E5%BF%86%E4%B8%AD%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="长时记忆是我们知识、技能和经验的永久储存库。它的容量和时长被认为是几乎无限的。" _mubu_text="%3Cspan%3E%E9%95%BF%E6%97%B6%E8%AE%B0%E5%BF%86%E6%98%AF%E6%88%91%E4%BB%AC%E7%9F%A5%E8%AF%86%E3%80%81%E6%8A%80%E8%83%BD%E5%92%8C%E7%BB%8F%E9%AA%8C%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E6%B0%B8%E4%B9%85%E5%82%A8%E5%AD%98%E5%BA%93%3C/span%3E%3Cspan%3E%E3%80%82%E5%AE%83%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%AE%B9%E9%87%8F%E5%92%8C%E6%97%B6%E9%95%BF%E8%A2%AB%E8%AE%A4%E4%B8%BA%E6%98%AF%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E5%87%A0%E4%B9%8E%E6%97%A0%E9%99%90%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%9A%84%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="4. Mnemonic Devices 助记方法" _mubu_text="%3Cspan%3E4.%20Mnemonic%20Devices%20%E5%8A%A9%E8%AE%B0%E6%96%B9%E6%B3%95%3C/span%3E" _note="" _mubu_note="">
          <outline text="Chunking（组块法） 将信息组织成更大的单元；记手机号把11个数字变成三组，理论上就可以记住2串手机号啦" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EChunking%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%88%E7%BB%84%E5%9D%97%E6%B3%95%EF%BC%89%3C/span%3E%3Cspan%3E%20%E5%B0%86%E4%BF%A1%E6%81%AF%E7%BB%84%E7%BB%87%E6%88%90%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9B%B4%E5%A4%A7%E7%9A%84%E5%8D%95%E5%85%83%3C/span%3E%3Cspan%3E%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%AE%B0%E6%89%8B%E6%9C%BA%E5%8F%B7%E6%8A%8A11%E4%B8%AA%E6%95%B0%E5%AD%97%E5%8F%98%E6%88%90%E4%B8%89%E7%BB%84%3C/span%3E%3Cspan%3E%EF%BC%8C%E7%90%86%E8%AE%BA%E4%B8%8A%E5%B0%B1%E5%8F%AF%E4%BB%A5%E8%AE%B0%E4%BD%8F2%E4%B8%B2%E6%89%8B%E6%9C%BA%E5%8F%B7%E5%95%A6%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Spacing Effect（间隔效应）分散学习好过集中学习；不要临时抱佛脚" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ESpacing%20Effect%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%88%E9%97%B4%E9%9A%94%E6%95%88%E5%BA%94%EF%BC%89%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%88%86%E6%95%A3%E5%AD%A6%E4%B9%A0%3C/span%3E%3Cspan%3E%E5%A5%BD%E8%BF%87%E9%9B%86%E4%B8%AD%E5%AD%A6%E4%B9%A0%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%8D%E8%A6%81%E4%B8%B4%E6%97%B6%E6%8A%B1%E4%BD%9B%E8%84%9A%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Method of Loci（记忆宫殿）用一个熟悉的物理空间，将项目和特定位置联系起来；“走”一遍这个空间，就能在相应的位置“看到”" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EMethod%20of%20Loci%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%88%E8%AE%B0%E5%BF%86%E5%AE%AB%E6%AE%BF%EF%BC%89%3C/span%3E%3Cspan%3E%E7%94%A8%E4%B8%80%E4%B8%AA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%86%9F%E6%82%89%E7%9A%84%E7%89%A9%E7%90%86%E7%A9%BA%E9%97%B4%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%B0%86%E9%A1%B9%E7%9B%AE%E5%92%8C%E7%89%B9%E5%AE%9A%E4%BD%8D%E7%BD%AE%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%81%94%E7%B3%BB%E8%B5%B7%E6%9D%A5%3C/span%3E%3Cspan%3E%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E2%80%9C%E8%B5%B0%E2%80%9D%E4%B8%80%E9%81%8D%E8%BF%99%E4%B8%AA%E7%A9%BA%E9%97%B4%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%B0%B1%E8%83%BD%E5%9C%A8%E7%9B%B8%E5%BA%94%E7%9A%84%E4%BD%8D%E7%BD%AE%E2%80%9C%E7%9C%8B%E5%88%B0%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Archive" _mubu_text="%3Cspan%3EArchive%3C/span%3E" _note="" _mubu_note="">
            <outline text="Introduction" _mubu_text="%3Cspan%3EIntroduction%3C/span%3E" _note="" _mubu_note="">
              <outline text="既然我们知道了记忆的原理，" _mubu_text="%3Cspan%3E%E6%97%A2%E7%84%B6%E6%88%91%E4%BB%AC%E7%9F%A5%E9%81%93%E4%BA%86%E8%AE%B0%E5%BF%86%E7%9A%84%E5%8E%9F%E7%90%86%EF%BC%8C%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="就可以利用一些策略来帮助我们更好地进行Effortful Processing" _mubu_text="%3Cspan%3E%E5%B0%B1%E5%8F%AF%E4%BB%A5%E5%88%A9%E7%94%A8%E4%B8%80%E4%BA%9B%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%AD%96%E7%95%A5%3C/span%3E%3Cspan%3E%E6%9D%A5%E5%B8%AE%E5%8A%A9%E6%88%91%E4%BB%AC%E6%9B%B4%E5%A5%BD%E5%9C%B0%E8%BF%9B%E8%A1%8C%3C/span%3E%3Cspan%20class=%22bold%22%3EEffortful%20Processing%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="从而更有效地记忆" _mubu_text="%3Cspan%3E%E4%BB%8E%E8%80%8C%E6%9B%B4%E6%9C%89%E6%95%88%E5%9C%B0%E8%AE%B0%E5%BF%86%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Chunking (组块法)" _mubu_text="%3Cspan%20class=%22bold%22%3EChunking%20(%E7%BB%84%E5%9D%97%E6%B3%95)%3C/span%3E" _note="" _mubu_note="">
              <outline text="将零散的信息组织成更大、更有意义的单元。这能有效克服短时记忆7±2的容量限制。" _mubu_text="%3Cspan%3E%E5%B0%86%E9%9B%B6%E6%95%A3%E7%9A%84%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%BB%84%E7%BB%87%E6%88%90%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E6%9B%B4%E5%A4%A7%E3%80%81%E6%9B%B4%E6%9C%89%E6%84%8F%E4%B9%89%E7%9A%84%E5%8D%95%E5%85%83%3C/span%3E%3Cspan%3E%E3%80%82%E8%BF%99%E8%83%BD%E6%9C%89%E6%95%88%E5%85%8B%E6%9C%8D%E7%9F%AD%E6%97%B6%E8%AE%B0%E5%BF%867%C2%B12%E7%9A%84%E5%AE%B9%E9%87%8F%E9%99%90%E5%88%B6%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="电话号码：我们不会去记11个独立的数字，而是会把它分成 xxx-xxxx-xxxx 这样的组块。" _mubu_text="%3Cspan%3E%E7%94%B5%E8%AF%9D%E5%8F%B7%E7%A0%81%EF%BC%9A%E6%88%91%E4%BB%AC%E4%B8%8D%E4%BC%9A%E5%8E%BB%E8%AE%B011%E4%B8%AA%E7%8B%AC%E7%AB%8B%E7%9A%84%E6%95%B0%E5%AD%97%EF%BC%8C%E8%80%8C%E6%98%AF%E4%BC%9A%E6%8A%8A%E5%AE%83%E5%88%86%E6%88%90%20%3C/span%3E%3Cspan%20class=%22codespan%22%3Exxx-xxxx-xxxx%3C/span%3E%3Cspan%3E%20%E8%BF%99%E6%A0%B7%E7%9A%84%E7%BB%84%E5%9D%97%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Spacing Effect (间隔效应)" _mubu_text="%3Cspan%20class=%22bold%22%3ESpacing%20Effect%20(%E9%97%B4%E9%9A%94%E6%95%88%E5%BA%94)%3C/span%3E" _note="" _mubu_note="">
              <outline text="分散学习的效果远好于集中学习 。" _mubu_text="%3Cspan%20class=%22bold%20text-color-green%22%3E%E5%88%86%E6%95%A3%E5%AD%A6%E4%B9%A0%3C/span%3E%3Cspan%3E%E7%9A%84%E6%95%88%E6%9E%9C%E8%BF%9C%E5%A5%BD%E4%BA%8E%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E9%9B%86%E4%B8%AD%E5%AD%A6%E4%B9%A0%3C/span%3E%3Cspan%3E%20%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="与其在考试前一晚通宵复习，不如把学习时间分散到几天或几周，每次学习一小段时间。这能带来更持久的记忆。" _mubu_text="%3Cspan%3E%E4%B8%8E%E5%85%B6%E5%9C%A8%E8%80%83%E8%AF%95%E5%89%8D%E4%B8%80%E6%99%9A%E9%80%9A%E5%AE%B5%E5%A4%8D%E4%B9%A0%EF%BC%8C%E4%B8%8D%E5%A6%82%E6%8A%8A%E5%AD%A6%E4%B9%A0%E6%97%B6%E9%97%B4%E5%88%86%E6%95%A3%E5%88%B0%E5%87%A0%E5%A4%A9%E6%88%96%E5%87%A0%E5%91%A8%EF%BC%8C%E6%AF%8F%E6%AC%A1%E5%AD%A6%E4%B9%A0%E4%B8%80%E5%B0%8F%E6%AE%B5%E6%97%B6%E9%97%B4%E3%80%82%E8%BF%99%E8%83%BD%E5%B8%A6%E6%9D%A5%E6%9B%B4%E6%8C%81%E4%B9%85%E7%9A%84%E8%AE%B0%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="所以，不要临时抱佛脚 （心理学教我学习） ！" _mubu_text="%3Cspan%3E%E6%89%80%E4%BB%A5%EF%BC%8C%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%B8%8D%E8%A6%81%E4%B8%B4%E6%97%B6%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E6%8A%B1%E4%BD%9B%E8%84%9A%3C/span%3E%3Cspan%3E%20%EF%BC%88%E5%BF%83%E7%90%86%E5%AD%A6%E6%95%99%E6%88%91%E5%AD%A6%E4%B9%A0%EF%BC%89%20%EF%BC%81%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Method of Loci (位置记忆法 / 记忆宫殿)" _mubu_text="%3Cspan%20class=%22bold%22%3EMethod%20of%20Loci%20(%E4%BD%8D%E7%BD%AE%E8%AE%B0%E5%BF%86%E6%B3%95%20/%20%E8%AE%B0%E5%BF%86%E5%AE%AB%E6%AE%BF)%3C/span%3E" _note="" _mubu_note="">
              <outline text="这是一种古老而强大的记忆术。它将需要记忆的项目与你非常熟悉的一个物理空间（比如你的家）中的特定位置联系起来。" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AF%E4%B8%80%E7%A7%8D%E5%8F%A4%E8%80%81%E8%80%8C%E5%BC%BA%E5%A4%A7%E7%9A%84%E8%AE%B0%E5%BF%86%E6%9C%AF%E3%80%82%E5%AE%83%E5%B0%86%3C/span%3E%3Cspan%20class=%22bold%22%3E%E9%9C%80%E8%A6%81%E8%AE%B0%E5%BF%86%E7%9A%84%E9%A1%B9%E7%9B%AE%E4%B8%8E%E4%BD%A0%E9%9D%9E%E5%B8%B8%E7%86%9F%E6%82%89%E7%9A%84%E4%B8%80%E4%B8%AA%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E7%89%A9%E7%90%86%E7%A9%BA%E9%97%B4%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%88%E6%AF%94%E5%A6%82%E4%BD%A0%E7%9A%84%E5%AE%B6%EF%BC%89%E4%B8%AD%E7%9A%84%E7%89%B9%E5%AE%9A%E4%BD%8D%E7%BD%AE%E8%81%94%E7%B3%BB%E8%B5%B7%E6%9D%A5%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="要回忆时，你就在脑海里“走”一遍这个空间，就能在相应的位置“看到”你要记的东西。" _mubu_text="%3Cspan%3E%E8%A6%81%E5%9B%9E%E5%BF%86%E6%97%B6%EF%BC%8C%E4%BD%A0%E5%B0%B1%E5%9C%A8%E8%84%91%E6%B5%B7%E9%87%8C%E2%80%9C%E8%B5%B0%E2%80%9D%E4%B8%80%E9%81%8D%E8%BF%99%E4%B8%AA%E7%A9%BA%E9%97%B4%EF%BC%8C%E5%B0%B1%E8%83%BD%E5%9C%A8%E7%9B%B8%E5%BA%94%E7%9A%84%E4%BD%8D%E7%BD%AE%E2%80%9C%E7%9C%8B%E5%88%B0%E2%80%9D%E4%BD%A0%E8%A6%81%E8%AE%B0%E7%9A%84%E4%B8%9C%E8%A5%BF%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="我试过，曾经在晚自习教室建了一个记忆宫殿，主要还是要让东西出现的很离奇。比如我想象了一个巨大的香蕉，上面写了一个同学的身份证号的一部分，还是正面一部分，反面一部分，然后剩下的6位在教室里，很大地竖着。我现在还记得：200902265434 :D" _mubu_text="%3Cspan%3E%E6%88%91%E8%AF%95%E8%BF%87%EF%BC%8C%E6%9B%BE%E7%BB%8F%E5%9C%A8%E6%99%9A%E8%87%AA%E4%B9%A0%E6%95%99%E5%AE%A4%E5%BB%BA%E4%BA%86%E4%B8%80%E4%B8%AA%E8%AE%B0%E5%BF%86%E5%AE%AB%E6%AE%BF%EF%BC%8C%E4%B8%BB%E8%A6%81%E8%BF%98%E6%98%AF%E8%A6%81%E8%AE%A9%E4%B8%9C%E8%A5%BF%E5%87%BA%E7%8E%B0%E7%9A%84%E5%BE%88%E7%A6%BB%E5%A5%87%E3%80%82%E6%AF%94%E5%A6%82%E6%88%91%E6%83%B3%E8%B1%A1%E4%BA%86%E4%B8%80%E4%B8%AA%E5%B7%A8%E5%A4%A7%E7%9A%84%E9%A6%99%E8%95%89%EF%BC%8C%E4%B8%8A%E9%9D%A2%E5%86%99%E4%BA%86%E4%B8%80%E4%B8%AA%E5%90%8C%E5%AD%A6%E7%9A%84%E8%BA%AB%E4%BB%BD%E8%AF%81%E5%8F%B7%E7%9A%84%E4%B8%80%E9%83%A8%E5%88%86%EF%BC%8C%E8%BF%98%E6%98%AF%E6%AD%A3%E9%9D%A2%E4%B8%80%E9%83%A8%E5%88%86%EF%BC%8C%E5%8F%8D%E9%9D%A2%E4%B8%80%E9%83%A8%E5%88%86%EF%BC%8C%E7%84%B6%E5%90%8E%E5%89%A9%E4%B8%8B%E7%9A%846%E4%BD%8D%E5%9C%A8%E6%95%99%E5%AE%A4%E9%87%8C%EF%BC%8C%E5%BE%88%E5%A4%A7%E5%9C%B0%E7%AB%96%E7%9D%80%E3%80%82%E6%88%91%E7%8E%B0%E5%9C%A8%E8%BF%98%E8%AE%B0%E5%BE%97%EF%BC%9A200902265434%20:D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
      </outline>
      <outline text="2.5 存储记忆 Storing Memories（1550字）" _mubu_text="%3Cspan%3E2.5%20%E5%AD%98%E5%82%A8%E8%AE%B0%E5%BF%86%20Storing%20Memories%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E1550%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="Rehearsal 复述" _mubu_text="%3Cspan%3ERehearsal%20%E5%A4%8D%E8%BF%B0%3C/span%3E" _note="" _mubu_note="">
          <outline text="如果要把记忆从 STM 到 LTM，就需要复述" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E8%A6%81%E6%8A%8A%E8%AE%B0%E5%BF%86%E4%BB%8E%20STM%20%E5%88%B0%20LTM%EF%BC%8C%E5%B0%B1%E9%9C%80%E8%A6%81%E5%A4%8D%E8%BF%B0%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Maintenance Rehearsal 维持复述 简单重复，延长信息在短期记忆中停留的时间；面包、牛奶、鸡蛋、冰淇淋…" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EMaintenance%20Rehearsal%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%BB%B4%E6%8C%81%E5%A4%8D%E8%BF%B0%3C/span%3E%3Cspan%3E%20%E7%AE%80%E5%8D%95%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%87%8D%E5%A4%8D%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BB%B6%E9%95%BF%3C/span%3E%3Cspan%3E%E4%BF%A1%E6%81%AF%E5%9C%A8%E7%9F%AD%E6%9C%9F%E8%AE%B0%E5%BF%86%E4%B8%AD%E5%81%9C%E7%95%99%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%97%B6%E9%97%B4%3C/span%3E%3Cspan%3E%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%9D%A2%E5%8C%85%E3%80%81%E7%89%9B%E5%A5%B6%E3%80%81%E9%B8%A1%E8%9B%8B%E3%80%81%E5%86%B0%E6%B7%87%E6%B7%8B%E2%80%A6%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Elaborative Rehearsal 拓展复述 用语义处理，将新的信息和已有的知识进行深度连接，effortful processing；乳制品、清洁用品…" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EElaborative%20Rehearsal%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%8B%93%E5%B1%95%E5%A4%8D%E8%BF%B0%3C/span%3E%3Cspan%3E%20%E7%94%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%AF%AD%E4%B9%89%E5%A4%84%E7%90%86%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%B0%86%E6%96%B0%E7%9A%84%E4%BF%A1%E6%81%AF%E5%92%8C%E5%B7%B2%E6%9C%89%E7%9A%84%E7%9F%A5%E8%AF%86%E8%BF%9B%E8%A1%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%B7%B1%E5%BA%A6%E8%BF%9E%E6%8E%A5%3C/span%3E%3Cspan%3E%EF%BC%8Ceffortful%20processing%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B9%B3%E5%88%B6%E5%93%81%E3%80%81%E6%B8%85%E6%B4%81%E7%94%A8%E5%93%81%E2%80%A6%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Archive" _mubu_text="%3Cspan%3EArchive%3C/span%3E" _note="" _mubu_note="">
            <outline text="From STM to LTM" _mubu_text="%3Cspan%3EFrom%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3ESTM%3C/span%3E%3Cspan%3E%20to%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3ELTM%3C/span%3E" _note="" _mubu_note="">
              <outline text="如果要存储信息，必须把记忆从短期记忆（Short-Term Memory，STM）进入到更持久的长期记忆（Long-Term Memory，LTM）" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E8%A6%81%E5%AD%98%E5%82%A8%E4%BF%A1%E6%81%AF%EF%BC%8C%E5%BF%85%E9%A1%BB%E6%8A%8A%E8%AE%B0%E5%BF%86%E4%BB%8E%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%9F%AD%E6%9C%9F%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%EF%BC%88Short-Term%20Memory%EF%BC%8CSTM%EF%BC%89%E8%BF%9B%E5%85%A5%E5%88%B0%E6%9B%B4%E6%8C%81%E4%B9%85%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%EF%BC%88Long-Term%20Memory%EF%BC%8CLTM%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="需要使用一个关键的动作——复述（Rehearsal）" _mubu_text="%3Cspan%3E%E9%9C%80%E8%A6%81%E4%BD%BF%E7%94%A8%E4%B8%80%E4%B8%AA%E5%85%B3%E9%94%AE%E7%9A%84%E5%8A%A8%E4%BD%9C%E2%80%94%E2%80%94%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%A4%8D%E8%BF%B0%EF%BC%88Rehearsal%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="两种重要的复述方法：Maintenance &amp; Elaborative" _mubu_text="%3Cspan%3E%E4%B8%A4%E7%A7%8D%E9%87%8D%E8%A6%81%E7%9A%84%E5%A4%8D%E8%BF%B0%E6%96%B9%E6%B3%95%EF%BC%9AMaintenance%20&amp;amp;%20Elaborative%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Maintenance Rehearsal" _mubu_text="%3Cspan%20class=%22text-color-green%22%3EMaintenance%3C/span%3E%3Cspan%3E%20Rehearsal%3C/span%3E" _note="" _mubu_note="">
              <outline text="简单的重复（基础、机械的记忆方法）" _mubu_text="%3Cspan%3E%E7%AE%80%E5%8D%95%E7%9A%84%E9%87%8D%E5%A4%8D%EF%BC%88%E5%9F%BA%E7%A1%80%E3%80%81%E6%9C%BA%E6%A2%B0%E7%9A%84%E8%AE%B0%E5%BF%86%E6%96%B9%E6%B3%95%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="你去超市前，为了不忘记要买的东西，嘴里不停地念叨：“面包、牛奶、鸡蛋、冰淇淋...”" _mubu_text="%3Cspan%3E%E4%BD%A0%E5%8E%BB%E8%B6%85%E5%B8%82%E5%89%8D%EF%BC%8C%E4%B8%BA%E4%BA%86%3C/span%3E%3Cspan%20class=%22underline%22%3E%E4%B8%8D%E5%BF%98%E8%AE%B0%E8%A6%81%E4%B9%B0%E7%9A%84%E4%B8%9C%E8%A5%BF%EF%BC%8C%E5%98%B4%E9%87%8C%E4%B8%8D%E5%81%9C%E5%9C%B0%E5%BF%B5%E5%8F%A8%EF%BC%9A%E2%80%9C%E9%9D%A2%E5%8C%85%E3%80%81%E7%89%9B%E5%A5%B6%E3%80%81%E9%B8%A1%E8%9B%8B%E3%80%81%E5%86%B0%E6%B7%87%E6%B7%8B...%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="简单的重复，其主要作用是延长信息在短期记忆中的停留时间。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%AE%80%E5%8D%95%E7%9A%84%E9%87%8D%E5%A4%8D%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%85%B6%E4%B8%BB%E8%A6%81%E4%BD%9C%E7%94%A8%E6%98%AF%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E5%BB%B6%E9%95%BF%E4%BF%A1%E6%81%AF%E5%9C%A8%E7%9F%AD%E6%9C%9F%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%B8%AD%E7%9A%84%E5%81%9C%E7%95%99%E6%97%B6%E9%97%B4%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="你并没有真正地“保存”它" _mubu_text="%3Cspan%3E%E4%BD%A0%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E5%B9%B6%E6%B2%A1%E6%9C%89%E7%9C%9F%E6%AD%A3%E5%9C%B0%E2%80%9C%E4%BF%9D%E5%AD%98%E2%80%9D%3C/span%3E%3Cspan%3E%E5%AE%83%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="临时记电话号码或者验证码很有用，但没有和已有记忆建立深刻的链接" _mubu_text="%3Cspan%3E%E4%B8%B4%E6%97%B6%E8%AE%B0%E7%94%B5%E8%AF%9D%E5%8F%B7%E7%A0%81%E6%88%96%E8%80%85%E9%AA%8C%E8%AF%81%E7%A0%81%E5%BE%88%E6%9C%89%E7%94%A8%EF%BC%8C%E4%BD%86%E6%B2%A1%E6%9C%89%E5%92%8C%E5%B7%B2%E6%9C%89%E8%AE%B0%E5%BF%86%E5%BB%BA%E7%AB%8B%E6%B7%B1%E5%88%BB%E7%9A%84%E9%93%BE%E6%8E%A5%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="一旦分心，信息就很容易丢失，很难形成稳固的长期记忆" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E4%B8%80%E6%97%A6%E5%88%86%E5%BF%83%EF%BC%8C%E4%BF%A1%E6%81%AF%E5%B0%B1%E5%BE%88%E5%AE%B9%E6%98%93%E4%B8%A2%E5%A4%B1%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%BE%88%E9%9A%BE%E5%BD%A2%E6%88%90%E7%A8%B3%E5%9B%BA%E7%9A%84%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Elaborative Rehearsal" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3EElaborative%3C/span%3E%3Cspan%3E%20Rehearsal%3C/span%3E" _note="" _mubu_note="">
              <outline text="Semantic - a level of processing" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ESemantic%3C/span%3E%3Cspan%3E%20-%20a%20level%20of%20processing%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="将新信息与你已经知道的知识进行深度连接。需要进行effortful processing。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B0%86%E6%96%B0%E4%BF%A1%E6%81%AF%E4%B8%8E%E4%BD%A0%E5%B7%B2%E7%BB%8F%E7%9F%A5%E9%81%93%E7%9A%84%E7%9F%A5%E8%AF%86%E8%BF%9B%E8%A1%8C%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E6%B7%B1%E5%BA%A6%E8%BF%9E%E6%8E%A5%3C/span%3E%3Cspan%3E%E3%80%82%E9%9C%80%E8%A6%81%E8%BF%9B%E8%A1%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3Eeffortful%20%3C/span%3E%3Cspan%3Eprocessing%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Strategies" _mubu_text="%3Cspan%3EStrategies%3C/span%3E" _note="" _mubu_note="">
                <outline text="组织信息Organizing information: 把要买的东西分类成“乳制品”、“清洁用品”等。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%BB%84%E7%BB%87%E4%BF%A1%E6%81%AFOrganizing%20information%3C/span%3E%3Cspan%3E:%20%E6%8A%8A%E8%A6%81%E4%B9%B0%E7%9A%84%E4%B8%9C%E8%A5%BF%E5%88%86%E7%B1%BB%E6%88%90%E2%80%9C%E4%B9%B3%E5%88%B6%E5%93%81%E2%80%9D%E3%80%81%E2%80%9C%E6%B8%85%E6%B4%81%E7%94%A8%E5%93%81%E2%80%9D%E7%AD%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="思考例子Thinking of examples: 不只是背定义，而是为它想一个生活中的例子。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%80%9D%E8%80%83%E4%BE%8B%E5%AD%90Thinking%20of%20examples%3C/span%3E%3Cspan%3E:%20%E4%B8%8D%E5%8F%AA%E6%98%AF%E8%83%8C%E5%AE%9A%E4%B9%89%EF%BC%8C%E8%80%8C%E6%98%AF%E4%B8%BA%E5%AE%83%E6%83%B3%E4%B8%80%E4%B8%AA%E7%94%9F%E6%B4%BB%E4%B8%AD%E7%9A%84%E4%BE%8B%E5%AD%90%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="创造图像Creating an image: 想象一个滑稽的画面。记忆宫殿" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%88%9B%E9%80%A0%E5%9B%BE%E5%83%8FCreating%20an%20image%3C/span%3E%3Cspan%3E:%20%E6%83%B3%E8%B1%A1%E4%B8%80%E4%B8%AA%E6%BB%91%E7%A8%BD%E7%9A%84%E7%94%BB%E9%9D%A2%E3%80%82%3C/span%3E%3Cspan%20class=%22italic%20text-color-blue%22%3E%E8%AE%B0%E5%BF%86%E5%AE%AB%E6%AE%BF%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="使用助记符Using a mnemonic device: 比如用“My Very Educated Mother Just Served Us Noodles”来记太阳系八大行星的顺序。神了！" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BD%BF%E7%94%A8%E5%8A%A9%E8%AE%B0%E7%AC%A6Using%20a%20mnemonic%20device%3C/span%3E%3Cspan%3E:%20%E6%AF%94%E5%A6%82%E7%94%A8%E2%80%9CMy%20Very%20Educated%20Mother%20Just%20Served%20Us%20Noodles%E2%80%9D%E6%9D%A5%E8%AE%B0%E5%A4%AA%E9%98%B3%E7%B3%BB%E5%85%AB%E5%A4%A7%E8%A1%8C%E6%98%9F%E7%9A%84%E9%A1%BA%E5%BA%8F%E3%80%82%3C/span%3E%3Cspan%20class=%22italic%20text-color-blue%22%3E%E7%A5%9E%E4%BA%86%EF%BC%81%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="Diagram" _mubu_text="%3Cspan%3EDiagram%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22o0zoC8hIb3%22%2C%22oh%22%3A1080%2C%22ow%22%3A1920%2C%22uri%22%3A%22document_image%2F33585682_7b664911-174b-4af6-f42a-0d2dfd011d38.png%22%2C%22w%22%3A400%7D%5D"/>
          </outline>
        </outline>
        <outline text="Biological Basis for Memory 生物学基础" _mubu_text="%3Cspan%3EBiological%20Basis%20for%20Memory%20%E7%94%9F%E7%89%A9%E5%AD%A6%E5%9F%BA%E7%A1%80%3C/span%3E" _note="" _mubu_note="">
          <outline text="Long-term Potentiation（LTP）长时程增强效应 重复刺激会让synaptic connection更强更有效率；这世上本没有路，走的人多了，也便成了路" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ELong-term%20Potentiation%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%88LTP%EF%BC%89%E9%95%BF%E6%97%B6%E7%A8%8B%E5%A2%9E%E5%BC%BA%E6%95%88%E5%BA%94%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%87%8D%E5%A4%8D%E5%88%BA%E6%BF%80%3C/span%3E%3Cspan%3E%E4%BC%9A%E8%AE%A9%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Esynaptic%20connection%3C/span%3E%3Cspan%3E%E6%9B%B4%E5%BC%BA%E6%9B%B4%E6%9C%89%E6%95%88%E7%8E%87%EF%BC%9B%E8%BF%99%E4%B8%96%E4%B8%8A%E6%9C%AC%E6%B2%A1%E6%9C%89%E8%B7%AF%EF%BC%8C%E8%B5%B0%E7%9A%84%E4%BA%BA%E5%A4%9A%E4%BA%86%EF%BC%8C%E4%B9%9F%E4%BE%BF%E6%88%90%E4%BA%86%E8%B7%AF%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Memory Consolidation 记忆巩固 将脆弱的短期记忆转化为稳定持久的长期记忆的过程，使用Hippocampus" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EMemory%20Consolidation%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%AE%B0%E5%BF%86%E5%B7%A9%E5%9B%BA%3C/span%3E%3Cspan%3E%20%E5%B0%86%E8%84%86%E5%BC%B1%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%9F%AD%E6%9C%9F%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%E8%BD%AC%E5%8C%96%E4%B8%BA%E7%A8%B3%E5%AE%9A%E6%8C%81%E4%B9%85%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%E7%9A%84%E8%BF%87%E7%A8%8B%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BD%BF%E7%94%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EHippocampus%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Neural Networks &amp; Priming 记忆网络 记忆像是一个联想网络，每一个概念或者记忆都是其中一个节点，所以激活一个节点，周围其他节点会priming" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ENeural%20Networks%20&amp;amp;%20Priming%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%AE%B0%E5%BF%86%E7%BD%91%E7%BB%9C%3C/span%3E%3Cspan%3E%20%E8%AE%B0%E5%BF%86%E5%83%8F%E6%98%AF%E4%B8%80%E4%B8%AA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%81%94%E6%83%B3%E7%BD%91%E7%BB%9C%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%AF%8F%E4%B8%80%E4%B8%AA%E6%A6%82%E5%BF%B5%E6%88%96%E8%80%85%E8%AE%B0%E5%BF%86%E9%83%BD%E6%98%AF%E5%85%B6%E4%B8%AD%E4%B8%80%E4%B8%AA%E8%8A%82%E7%82%B9%EF%BC%8C%E6%89%80%E4%BB%A5%E6%BF%80%E6%B4%BB%E4%B8%80%E4%B8%AA%E8%8A%82%E7%82%B9%EF%BC%8C%E5%91%A8%E5%9B%B4%E5%85%B6%E4%BB%96%E8%8A%82%E7%82%B9%E4%BC%9Apriming%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Archive" _mubu_text="%3Cspan%3EArchive%3C/span%3E" _note="" _mubu_note="">
            <outline text="长时程增强效应 Long-term Potentiation" _mubu_text="%3Cspan%3E%E9%95%BF%E6%97%B6%E7%A8%8B%E5%A2%9E%E5%BC%BA%E6%95%88%E5%BA%94%20Long-term%20Potentiation%3C/span%3E" _note="" _mubu_note="">
              <outline text="当一个神经元持续、重复地刺激另一个神经元时，它们之间的突触连接 synaptic connection 会变得更强、更有效率。" _mubu_text="%3Cspan%3E%E5%BD%93%E4%B8%80%E4%B8%AA%E7%A5%9E%E7%BB%8F%E5%85%83%E6%8C%81%E7%BB%AD%E3%80%81%E9%87%8D%E5%A4%8D%E5%9C%B0%E5%88%BA%E6%BF%80%E5%8F%A6%E4%B8%80%E4%B8%AA%E7%A5%9E%E7%BB%8F%E5%85%83%E6%97%B6%EF%BC%8C%E5%AE%83%E4%BB%AC%E4%B9%8B%E9%97%B4%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E7%AA%81%E8%A7%A6%E8%BF%9E%E6%8E%A5%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3Esynaptic%20connection%20%E4%BC%9A%E5%8F%98%E5%BE%97%E6%9B%B4%E5%BC%BA%E3%80%81%E6%9B%B4%E6%9C%89%E6%95%88%E7%8E%87%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="这世上本没有路，走的人多了，也便成了路" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E8%BF%99%E4%B8%96%E4%B8%8A%E6%9C%AC%E6%B2%A1%E6%9C%89%E8%B7%AF%EF%BC%8C%E8%B5%B0%E7%9A%84%E4%BA%BA%E5%A4%9A%E4%BA%86%EF%BC%8C%E4%B9%9F%E4%BE%BF%E6%88%90%E4%BA%86%E8%B7%AF%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="每一次你进行有效的学习和复习，实际上就是在你的大脑中不断地触发和巩固 LTP。" _mubu_text="%3Cspan%3E%E6%AF%8F%E4%B8%80%E6%AC%A1%E4%BD%A0%E8%BF%9B%E8%A1%8C%E6%9C%89%E6%95%88%E7%9A%84%E5%AD%A6%E4%B9%A0%E5%92%8C%E5%A4%8D%E4%B9%A0%EF%BC%8C%E5%AE%9E%E9%99%85%E4%B8%8A%E5%B0%B1%E6%98%AF%E5%9C%A8%E4%BD%A0%E7%9A%84%E5%A4%A7%E8%84%91%E4%B8%AD%E4%B8%8D%E6%96%AD%E5%9C%B0%E8%A7%A6%E5%8F%91%E5%92%8C%E5%B7%A9%E5%9B%BA%20LTP%E3%80%82%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22aLT45HeyoG%22%2C%22oh%22%3A1200%2C%22ow%22%3A1600%2C%22uri%22%3A%22document_image%2F33585682_a36d4d18-3539-453a-ef1e-87fe96b83c36.jpeg%22%2C%22w%22%3A400%7D%5D"/>
            </outline>
            <outline text="记忆巩固 Memory Consolidation" _mubu_text="%3Cspan%3E%E8%AE%B0%E5%BF%86%E5%B7%A9%E5%9B%BA%20Memory%20Consolidation%3C/span%3E" _note="" _mubu_note="">
              <outline text="将脆弱的短期记忆转化为稳定、持久的长期记忆的过程" _mubu_text="%3Cspan%3E%E5%B0%86%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%84%86%E5%BC%B1%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E7%9F%AD%E6%9C%9F%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%BD%AC%E5%8C%96%E4%B8%BA%E7%A8%B3%E5%AE%9A%E3%80%81%E6%8C%81%E4%B9%85%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%E7%9A%84%E8%BF%87%E7%A8%8B%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="电脑把 RAM 里的临时数据写入硬盘进行永久保存" _mubu_text="%3Cspan%3E%E7%94%B5%E8%84%91%E6%8A%8A%20RAM%20%E9%87%8C%E7%9A%84%E4%B8%B4%E6%97%B6%E6%95%B0%E6%8D%AE%E5%86%99%E5%85%A5%E7%A1%AC%E7%9B%98%E8%BF%9B%E8%A1%8C%E6%B0%B8%E4%B9%85%E4%BF%9D%E5%AD%98%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="河马校园！Hippocampus！" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E6%B2%B3%E9%A9%AC%E6%A0%A1%E5%9B%AD%EF%BC%81Hippocampus%EF%BC%81%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%227DI2VbZOqE%22%2C%22oh%22%3A600%2C%22ow%22%3A600%2C%22uri%22%3A%22document_image%2F33585682_53c00f65-f336-4b62-e925-a17b750cd5db.jpeg%22%2C%22w%22%3A400%7D%5D"/>
            </outline>
            <outline text="Neural Networks &amp; Priming" _mubu_text="%3Cspan%3ENeural%20Networks%20&amp;amp;%20Priming%3C/span%3E" _note="" _mubu_note="">
              <outline text="记忆并不是像书本一样孤立地存放在某个地方，而是以一个巨大的、相互关联的联想网络 Associative Model of Memory 形式存在的。" _mubu_text="%3Cspan%3E%E8%AE%B0%E5%BF%86%E5%B9%B6%E4%B8%8D%E6%98%AF%E5%83%8F%E4%B9%A6%E6%9C%AC%E4%B8%80%E6%A0%B7%E5%AD%A4%E7%AB%8B%E5%9C%B0%E5%AD%98%E6%94%BE%E5%9C%A8%E6%9F%90%E4%B8%AA%E5%9C%B0%E6%96%B9%EF%BC%8C%E8%80%8C%E6%98%AF%E4%BB%A5%E4%B8%80%E4%B8%AA%E5%B7%A8%E5%A4%A7%E7%9A%84%E3%80%81%E7%9B%B8%E4%BA%92%E5%85%B3%E8%81%94%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E8%81%94%E6%83%B3%E7%BD%91%E7%BB%9C%3C/span%3E%3Cspan%20class=%22bold%22%3E%20Associative%20Model%20of%20Memory%3C/span%3E%3Cspan%3E%20%E5%BD%A2%E5%BC%8F%E5%AD%98%E5%9C%A8%E7%9A%84%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="每个概念或记忆都是网络中的一个节点。" _mubu_text="%3Cspan%3E%E6%AF%8F%E4%B8%AA%E6%A6%82%E5%BF%B5%E6%88%96%E8%AE%B0%E5%BF%86%E9%83%BD%E6%98%AF%E7%BD%91%E7%BB%9C%E4%B8%AD%E7%9A%84%3C/span%3E%3Cspan%20class=%22underline%22%3E%E4%B8%80%E4%B8%AA%E8%8A%82%E7%82%B9%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="当你激活一个节点时，与之相关的其他节点也会被“预激活”，这就是启动效应 Priming。" _mubu_text="%3Cspan%3E%E5%BD%93%E4%BD%A0%E6%BF%80%E6%B4%BB%E4%B8%80%E4%B8%AA%E8%8A%82%E7%82%B9%E6%97%B6%EF%BC%8C%E4%B8%8E%E4%B9%8B%E7%9B%B8%E5%85%B3%E7%9A%84%E5%85%B6%E4%BB%96%E8%8A%82%E7%82%B9%E4%B9%9F%E4%BC%9A%E8%A2%AB%3C/span%3E%3Cspan%20class=%22underline%22%3E%E2%80%9C%E9%A2%84%E6%BF%80%E6%B4%BB%E2%80%9D%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%BF%99%E5%B0%B1%E6%98%AF%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%90%AF%E5%8A%A8%E6%95%88%E5%BA%94%20Priming%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="所以你想到黄色，有关banana的区域就会被激活" _mubu_text="%3Cspan%3E%E6%89%80%E4%BB%A5%E4%BD%A0%E6%83%B3%E5%88%B0%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%BB%84%E8%89%B2%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%9C%89%E5%85%B3%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3Ebanana%3C/span%3E%3Cspan%3E%E7%9A%84%E5%8C%BA%E5%9F%9F%E5%B0%B1%E4%BC%9A%E8%A2%AB%E6%BF%80%E6%B4%BB%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="| Memory Storage | S/L | E/I |
| --- | --- | --- |
| Hippocampus | LTM | Explicit |
| Cerebellum | LTM | Implicit |
| Frontal Lobes（Prefrontal Cortex） | STM | - - |
| Amygdala | LTM | Emotion related |" _mubu_text="%3Cdiv%20class=%22table-container%22%3E%3Ctable%20class=%22auto-table%22%20border=%221%22%20cellspacing=%220%22%20style=%22border-collapse:%20collapse;%22%3E%3Cthead%3E%3Ctr%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%220%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%220%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%3Cb%3EMemory%20Storage%3C/b%3E%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%221%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3ES/L%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%222%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3EE/I%3C/span%3E%3C/th%3E%3C/tr%3E%3C/thead%3E%3Ctbody%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%221%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3EHippocampus%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3ELTM%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3EExplicit%3C/span%3E%3C/td%3E%3C/tr%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%222%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3ECerebellum%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3ELTM%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3EImplicit%3C/span%3E%3C/td%3E%3C/tr%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%223%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3EFrontal%20Lobes%EF%BC%88Prefrontal%20Cortex%EF%BC%89%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3ESTM%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E-%20-%3C/span%3E%3C/td%3E%3C/tr%3E%3Ctr%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%224%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3EAmygdala%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3ELTM%3C/span%3E%3C/td%3E%3Ctd%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3EEmotion%20related%3C/span%3E%3C/td%3E%3C/tr%3E%3C/tbody%3E%3C/table%3E%3C/div%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Types of LTM 长期记忆的类型" _mubu_text="%3Cspan%3ETypes%20of%20LTM%20%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%E7%9A%84%E7%B1%BB%E5%9E%8B%3C/span%3E" _note="" _mubu_note="">
          <outline text="Explicit Memory 外显记忆 - 可以回忆并能用语言清晰表达出来的记忆" _mubu_text="%3Cspan%20class=%22bold%20underline%22%3EExplicit%20Memory%20%E5%A4%96%E6%98%BE%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%20-%20%E5%8F%AF%E4%BB%A5%E5%9B%9E%E5%BF%86%E5%B9%B6%E8%83%BD%E7%94%A8%E8%AF%AD%E8%A8%80%E6%B8%85%E6%99%B0%E8%A1%A8%E8%BE%BE%E5%87%BA%E6%9D%A5%E7%9A%84%E8%AE%B0%E5%BF%86%3C/span%3E" _note="" _mubu_note="">
            <outline text="Semantic Memory 语义记忆 一般性的概念，不依赖个人经历；地球是圆的" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ESemantic%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EMemory%20%E8%AF%AD%E4%B9%89%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%80%E8%88%AC%E6%80%A7%3C/span%3E%3Cspan%3E%E7%9A%84%E6%A6%82%E5%BF%B5%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E4%B8%8D%E4%BE%9D%E8%B5%96%E4%B8%AA%E4%BA%BA%E7%BB%8F%E5%8E%86%3C/span%3E%3Cspan%3E%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%9C%B0%E7%90%83%E6%98%AF%E5%9C%86%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Episodic Memory 情景记忆 关于个人亲身经历的具体事件的记忆，回忆的时候会再次经历；人生剧集" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EEpisodic%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EMemory%20%E6%83%85%E6%99%AF%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%20%E5%85%B3%E4%BA%8E%E4%B8%AA%E4%BA%BA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BA%B2%E8%BA%AB%E7%BB%8F%E5%8E%86%3C/span%3E%3Cspan%3E%E7%9A%84%E5%85%B7%E4%BD%93%E4%BA%8B%E4%BB%B6%E7%9A%84%E8%AE%B0%E5%BF%86%EF%BC%8C%E5%9B%9E%E5%BF%86%E7%9A%84%E6%97%B6%E5%80%99%E4%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E5%86%8D%E6%AC%A1%E7%BB%8F%E5%8E%86%3C/span%3E%3Cspan%3E%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%BA%BA%E7%94%9F%E5%89%A7%E9%9B%86%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Autobiographic Memory 自传记忆 关键词：Better Memory about your self，包含语义记忆和场景记忆" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EAutobiographic%20%3C/span%3E%3Cspan%20class=%22bold%22%3EMemory%20%E8%87%AA%E4%BC%A0%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%20%E5%85%B3%E9%94%AE%E8%AF%8D%EF%BC%9ABetter%20Memory%20about%20your%20self%EF%BC%8C%E5%8C%85%E5%90%AB%E8%AF%AD%E4%B9%89%E8%AE%B0%E5%BF%86%E5%92%8C%E5%9C%BA%E6%99%AF%E8%AE%B0%E5%BF%86%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Implicit Memory 内隐记忆 - 如何做某事的技能记忆（无法语言表述）" _mubu_text="%3Cspan%20class=%22bold%20underline%22%3EImplicit%20Memory%20%E5%86%85%E9%9A%90%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%20-%20%E5%A6%82%E4%BD%95%E5%81%9A%E6%9F%90%E4%BA%8B%E7%9A%84%E6%8A%80%E8%83%BD%E8%AE%B0%E5%BF%86%EF%BC%88%E6%97%A0%E6%B3%95%E8%AF%AD%E8%A8%80%E8%A1%A8%E8%BF%B0%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="Procedural Memory - 如何做某事，如骑车；“我就是会骑，没法表述出来我是怎么骑的”" _mubu_text="%3Cspan%3EProcedural%20Memory%20-%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A6%82%E4%BD%95%E5%81%9A%E6%9F%90%E4%BA%8B%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%A6%82%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%AA%91%E8%BD%A6%3C/span%3E%3Cspan%3E%EF%BC%9B%E2%80%9C%E6%88%91%E5%B0%B1%E6%98%AF%E4%BC%9A%E9%AA%91%EF%BC%8C%E6%B2%A1%E6%B3%95%E8%A1%A8%E8%BF%B0%E5%87%BA%E6%9D%A5%E6%88%91%E6%98%AF%E6%80%8E%E4%B9%88%E9%AA%91%E7%9A%84%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Prospective Memory 前瞻记忆 - 记得去记得某事（意图和未来时间结合）" _mubu_text="%3Cspan%20class=%22bold%20underline%22%3EProspective%20Memory%20%E5%89%8D%E7%9E%BB%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%20-%20%E8%AE%B0%E5%BE%97%E5%8E%BB%E8%AE%B0%E5%BE%97%E6%9F%90%E4%BA%8B%EF%BC%88%E6%84%8F%E5%9B%BE%E5%92%8C%E6%9C%AA%E6%9D%A5%E6%97%B6%E9%97%B4%E7%BB%93%E5%90%88%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="记住未来某个动作；下午要去取快递！" _mubu_text="%3Cspan%3E%E8%AE%B0%E4%BD%8F%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9C%AA%E6%9D%A5%E6%9F%90%E4%B8%AA%E5%8A%A8%E4%BD%9C%3C/span%3E%3Cspan%3E%EF%BC%9B%E4%B8%8B%E5%8D%88%E8%A6%81%E5%8E%BB%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%8F%96%E5%BF%AB%E9%80%92%3C/span%3E%3Cspan%3E%EF%BC%81%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Archive" _mubu_text="%3Cspan%3EArchive%3C/span%3E" _note="" _mubu_note="">
            <outline text="外显记忆 (Explicit Memory)" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%A4%96%E6%98%BE%E8%AE%B0%E5%BF%86%20(Explicit%20Memory)%3C/span%3E" _note="" _mubu_note="">
              <outline text="Introduction" _mubu_text="%3Cspan%20class=%22bold%22%3EIntroduction%3C/span%3E" _note="" _mubu_note="">
                <outline text="陈述性记忆 (Declarative Memory)，指的是那些我们可以有意识地回忆 (conscious recall) 并且能够用语言清晰表达出来的记忆。" _mubu_text="%3Cspan%3E%E9%99%88%E8%BF%B0%E6%80%A7%E8%AE%B0%E5%BF%86%20(Declarative%20Memory)%EF%BC%8C%E6%8C%87%E7%9A%84%E6%98%AF%E9%82%A3%E4%BA%9B%E6%88%91%E4%BB%AC%E5%8F%AF%E4%BB%A5%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%9C%89%E6%84%8F%E8%AF%86%E5%9C%B0%E5%9B%9E%E5%BF%86%20(conscious%20recall)%3C/span%3E%3Cspan%3E%20%E5%B9%B6%E4%B8%94%E8%83%BD%E5%A4%9F%E7%94%A8%E8%AF%AD%E8%A8%80%E6%B8%85%E6%99%B0%E8%A1%A8%E8%BE%BE%E5%87%BA%E6%9D%A5%E7%9A%84%E8%AE%B0%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="比如，“我记得昨天晚餐吃了什么”或者“我知道中国的首都是北京”。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%EF%BC%8C%E2%80%9C%E6%88%91%E8%AE%B0%E5%BE%97%E6%98%A8%E5%A4%A9%E6%99%9A%E9%A4%90%E5%90%83%E4%BA%86%E4%BB%80%E4%B9%88%E2%80%9D%E6%88%96%E8%80%85%E2%80%9C%E6%88%91%E7%9F%A5%E9%81%93%E4%B8%AD%E5%9B%BD%E7%9A%84%E9%A6%96%E9%83%BD%E6%98%AF%E5%8C%97%E4%BA%AC%E2%80%9D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="语义记忆 Semantic Memory: 这种记忆是关于事实、概念和一般知识的。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AF%AD%E4%B9%89%E8%AE%B0%E5%BF%86%20Semantic%20Memory%3C/span%3E%3Cspan%3E:%20%E8%BF%99%E7%A7%8D%E8%AE%B0%E5%BF%86%E6%98%AF%E5%85%B3%E4%BA%8E%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BA%8B%E5%AE%9E%E3%80%81%E6%A6%82%E5%BF%B5%E5%92%8C%E4%B8%80%E8%88%AC%E7%9F%A5%E8%AF%86%3C/span%3E%3Cspan%3E%E7%9A%84%E3%80%82%3C/span%3E" _note="" _mubu_note="">
                <outline text="它不依赖于个人经历。" _mubu_text="%3Cspan%3E%E5%AE%83%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E4%B8%8D%E4%BE%9D%E8%B5%96%3C/span%3E%3Cspan%3E%E4%BA%8E%E4%B8%AA%E4%BA%BA%E7%BB%8F%E5%8E%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="比如你知道地球是圆的，1+1=2。这些都是语义记忆。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%E4%BD%A0%E7%9F%A5%E9%81%93%E5%9C%B0%E7%90%83%E6%98%AF%E5%9C%86%E7%9A%84%EF%BC%8C1+1=2%E3%80%82%E8%BF%99%E4%BA%9B%E9%83%BD%E6%98%AF%E8%AF%AD%E4%B9%89%E8%AE%B0%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="情景记忆 Episodic Memory: 这是关于个人亲身经历的具体事件的记忆。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%83%85%E6%99%AF%E8%AE%B0%E5%BF%86%20Episodic%20Memory%3C/span%3E%3Cspan%3E:%20%E8%BF%99%E6%98%AF%E5%85%B3%E4%BA%8E%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%B8%AA%E4%BA%BA%E4%BA%B2%E8%BA%AB%E7%BB%8F%E5%8E%86%E7%9A%84%E5%85%B7%E4%BD%93%E4%BA%8B%E4%BB%B6%3C/span%3E%3Cspan%3E%E7%9A%84%E8%AE%B0%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note="">
                <outline text="它带有时间的、空间的和情感的标签，就像是你人生的“剧集”。" _mubu_text="%3Cspan%3E%E5%AE%83%E5%B8%A6%E6%9C%89%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%97%B6%E9%97%B4%E7%9A%84%E3%80%81%E7%A9%BA%E9%97%B4%E7%9A%84%E5%92%8C%E6%83%85%E6%84%9F%3C/span%3E%3Cspan%3E%E7%9A%84%E6%A0%87%E7%AD%BE%EF%BC%8C%E5%B0%B1%E5%83%8F%E6%98%AF%E4%BD%A0%E4%BA%BA%E7%94%9F%E7%9A%84%E2%80%9C%E5%89%A7%E9%9B%86%E2%80%9D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="回忆的时候会再次经历。" _mubu_text="%3Cspan%20class=%22italic%22%3E%E5%9B%9E%E5%BF%86%E7%9A%84%E6%97%B6%E5%80%99%E4%BC%9A%3C/span%3E%3Cspan%20class=%22italic%20text-color-yellow%22%3E%E5%86%8D%E6%AC%A1%E7%BB%8F%E5%8E%86%3C/span%3E%3Cspan%20class=%22italic%22%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="可以这么理解" _mubu_text="%3Cspan%3E%E5%8F%AF%E4%BB%A5%E8%BF%99%E4%B9%88%E7%90%86%E8%A7%A3%3C/span%3E" _note="" _mubu_note="">
                <outline text="语义记忆就是一段文字，" _mubu_text="%3Cspan%3E%E8%AF%AD%E4%B9%89%E8%AE%B0%E5%BF%86%E5%B0%B1%E6%98%AF%E4%B8%80%E6%AE%B5%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%96%87%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="情景记忆是一个场景中的 画面、声音、带来的情绪等，" _mubu_text="%3Cspan%3E%E6%83%85%E6%99%AF%E8%AE%B0%E5%BF%86%E6%98%AF%E4%B8%80%E4%B8%AA%E5%9C%BA%E6%99%AF%E4%B8%AD%E7%9A%84%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E7%94%BB%E9%9D%A2%E3%80%81%E5%A3%B0%E9%9F%B3%E3%80%81%E5%B8%A6%E6%9D%A5%E7%9A%84%E6%83%85%E7%BB%AA%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%AD%89%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E" _note="" _mubu_note="">
                  <outline text="尽管可以用语言描述出来，但是本质是一个多维度的视频" _mubu_text="%3Cspan%3E%E5%B0%BD%E7%AE%A1%E5%8F%AF%E4%BB%A5%E7%94%A8%E8%AF%AD%E8%A8%80%E6%8F%8F%E8%BF%B0%E5%87%BA%E6%9D%A5%EF%BC%8C%E4%BD%86%E6%98%AF%E6%9C%AC%E8%B4%A8%E6%98%AF%E4%B8%80%E4%B8%AA%3C/span%3E%3Cspan%20class=%22italic%22%3E%E5%A4%9A%E7%BB%B4%E5%BA%A6%E7%9A%84%E8%A7%86%E9%A2%91%3C/span%3E" _note="" _mubu_note=""/>
                </outline>
              </outline>
              <outline text="自传记忆 Autobiographic Memory: 自传记忆包含了语义记忆和情景记忆，" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%87%AA%E4%BC%A0%E8%AE%B0%E5%BF%86%20Autobiographic%20Memory%3C/span%3E%3Cspan%3E:%20%E8%87%AA%E4%BC%A0%E8%AE%B0%E5%BF%86%E5%8C%85%E5%90%AB%E4%BA%86%E8%AF%AD%E4%B9%89%E8%AE%B0%E5%BF%86%E5%92%8C%E6%83%85%E6%99%AF%E8%AE%B0%E5%BF%86%EF%BC%8C%3C/span%3E" _note="" _mubu_note="">
                <outline text="两种记忆共同构成了关于自己的故事。" _mubu_text="%3Cspan%3E%E4%B8%A4%E7%A7%8D%E8%AE%B0%E5%BF%86%E5%85%B1%E5%90%8C%E6%9E%84%E6%88%90%E4%BA%86%E5%85%B3%E4%BA%8E%E8%87%AA%E5%B7%B1%E7%9A%84%E6%95%85%E4%BA%8B%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="Key words: Better Memory about your self, not others." _mubu_text="%3Cspan%20class=%22bold%22%3EKey%20words:%20Better%20Memory%20about%20your%20self,%20not%20others.%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="内隐记忆 (Implicit Memory)" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%86%85%E9%9A%90%E8%AE%B0%E5%BF%86%20(Implicit%20Memory)%3C/span%3E" _note="" _mubu_note="">
              <outline text="Procedural Memory" _mubu_text="%3Cspan%3EProcedural%20Memory%3C/span%3E" _note="" _mubu_note="">
                <outline text="如何做某事 (how-to) 的技能记忆。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%A6%82%E4%BD%95%E5%81%9A%E6%9F%90%E4%BA%8B%20(how-to)%3C/span%3E%3Cspan%3E%20%E7%9A%84%E6%8A%80%E8%83%BD%E8%AE%B0%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="一旦学会，我们就可以自动化地完成，而不需要有意识地去思考每一步。" _mubu_text="%3Cspan%3E%E4%B8%80%E6%97%A6%E5%AD%A6%E4%BC%9A%EF%BC%8C%E6%88%91%E4%BB%AC%E5%B0%B1%E5%8F%AF%E4%BB%A5%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%87%AA%E5%8A%A8%E5%8C%96%E5%9C%B0%3C/span%3E%3Cspan%3E%E5%AE%8C%E6%88%90%EF%BC%8C%E8%80%8C%E4%B8%8D%E9%9C%80%E8%A6%81%E6%9C%89%E6%84%8F%E8%AF%86%E5%9C%B0%E5%8E%BB%E6%80%9D%E8%80%83%E6%AF%8F%E4%B8%80%E6%AD%A5%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="比如骑自行车、打字、弹钢琴或者开车。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%E9%AA%91%E8%87%AA%E8%A1%8C%E8%BD%A6%E3%80%81%E6%89%93%E5%AD%97%E3%80%81%E5%BC%B9%E9%92%A2%E7%90%B4%E6%88%96%E8%80%85%E5%BC%80%E8%BD%A6%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="你可能无法清晰地用语言描述出骑车时身体肌肉如何协调，但你就是会骑。" _mubu_text="%3Cspan%3E%E4%BD%A0%E5%8F%AF%E8%83%BD%E6%97%A0%E6%B3%95%E6%B8%85%E6%99%B0%E5%9C%B0%E7%94%A8%E8%AF%AD%E8%A8%80%E6%8F%8F%E8%BF%B0%E5%87%BA%E9%AA%91%E8%BD%A6%E6%97%B6%E8%BA%AB%E4%BD%93%E8%82%8C%E8%82%89%E5%A6%82%E4%BD%95%E5%8D%8F%E8%B0%83%EF%BC%8C%E4%BD%86%E4%BD%A0%E5%B0%B1%E6%98%AF%E4%BC%9A%E9%AA%91%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="前瞻性记忆 (Prospective Memory)" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%89%8D%E7%9E%BB%E6%80%A7%E8%AE%B0%E5%BF%86%20(Prospective%20Memory)%3C/span%3E" _note="" _mubu_note="">
              <outline text="它关注的是“记得去记得” (remembering to remember) 。" _mubu_text="%3Cspan%3E%E5%AE%83%E5%85%B3%E6%B3%A8%E7%9A%84%E6%98%AF%3C/span%3E%3Cspan%20class=%22bold%22%3E%E2%80%9C%E8%AE%B0%E5%BE%97%E5%8E%BB%E8%AE%B0%E5%BE%97%E2%80%9D%20(remembering%20to%20remember)%3C/span%3E%3Cspan%3E%20%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="也就是说，记住在未来某个时间点或某个情境下执行一个预定的动作。" _mubu_text="%3Cspan%3E%E4%B9%9F%E5%B0%B1%E6%98%AF%E8%AF%B4%EF%BC%8C%E8%AE%B0%E4%BD%8F%E5%9C%A8%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%9C%AA%E6%9D%A5%E6%9F%90%E4%B8%AA%E6%97%B6%E9%97%B4%E7%82%B9%E6%88%96%E6%9F%90%E4%B8%AA%E6%83%85%E5%A2%83%E4%B8%8B%E6%89%A7%E8%A1%8C%E4%B8%80%E4%B8%AA%E9%A2%84%E5%AE%9A%E7%9A%84%E5%8A%A8%E4%BD%9C%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="比如，记住下午要去取快递，或者记住在朋友生日时给他打电话。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%EF%BC%8C%E8%AE%B0%E4%BD%8F%E4%B8%8B%E5%8D%88%E8%A6%81%E5%8E%BB%E5%8F%96%E5%BF%AB%E9%80%92%EF%BC%8C%E6%88%96%E8%80%85%E8%AE%B0%E4%BD%8F%E5%9C%A8%E6%9C%8B%E5%8F%8B%E7%94%9F%E6%97%A5%E6%97%B6%E7%BB%99%E4%BB%96%E6%89%93%E7%94%B5%E8%AF%9D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="将意图和未来的提示（做什么和什么时候做）结合起来" _mubu_text="%3Cspan%3E%E5%B0%86%E6%84%8F%E5%9B%BE%E5%92%8C%E6%9C%AA%E6%9D%A5%E7%9A%84%E6%8F%90%E7%A4%BA%EF%BC%88%E5%81%9A%E4%BB%80%E4%B9%88%E5%92%8C%E4%BB%80%E4%B9%88%E6%97%B6%E5%80%99%E5%81%9A%EF%BC%89%E7%BB%93%E5%90%88%E8%B5%B7%E6%9D%A5%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="总结" _mubu_text="%3Cspan%3E%E6%80%BB%E7%BB%93%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22Pra7FEBdBH%22%2C%22oh%22%3A764%2C%22ow%22%3A1413%2C%22uri%22%3A%22document_image%2F33585682_77767c8c-30fc-480b-dc72-23fdf6cdffe5.png%22%2C%22w%22%3A400%7D%5D"/>
          </outline>
        </outline>
      </outline>
      <outline text="2.6 Retrieving Memories（950字）" _mubu_text="%3Cspan%3E2.6%20Retrieving%20Memories%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E950%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="How to Retrieval 如何提取记忆？" _mubu_text="%3Cspan%3EHow%20to%20Retrieval%20%E5%A6%82%E4%BD%95%E6%8F%90%E5%8F%96%E8%AE%B0%E5%BF%86%EF%BC%9F%3C/span%3E" _note="" _mubu_note="">
          <outline text="Retrieval Cues 提取线索 “钓”出特定信息的刺激物，可以是外部的（气味），也可以是内部的（情绪），强大线索会让回忆简单" _mubu_text="%3Cspan%20class=%22bold%22%3ERetrieval%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3ECues%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%8F%90%E5%8F%96%E7%BA%BF%E7%B4%A2%3C/span%3E%3Cspan%3E%20%E2%80%9C%E9%92%93%E2%80%9D%E5%87%BA%E7%89%B9%E5%AE%9A%E4%BF%A1%E6%81%AF%E7%9A%84%E5%88%BA%E6%BF%80%E7%89%A9%EF%BC%8C%E5%8F%AF%E4%BB%A5%E6%98%AF%E5%A4%96%E9%83%A8%E7%9A%84%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B0%94%E5%91%B3%3C/span%3E%3Cspan%3E%EF%BC%89%EF%BC%8C%E4%B9%9F%E5%8F%AF%E4%BB%A5%E6%98%AF%E5%86%85%E9%83%A8%E7%9A%84%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%83%85%E7%BB%AA%3C/span%3E%3Cspan%3E%EF%BC%89%EF%BC%8C%E5%BC%BA%E5%A4%A7%E7%BA%BF%E7%B4%A2%E4%BC%9A%E8%AE%A9%E5%9B%9E%E5%BF%86%E7%AE%80%E5%8D%95%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Recall 回忆 没有或者很少提示的情况下提取信息；填空题或者简答题，更难" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ERecall%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%9B%9E%E5%BF%86%3C/span%3E%3Cspan%3E%20%E6%B2%A1%E6%9C%89%E6%88%96%E8%80%85%3C/span%3E%3Cspan%20class=%22underline%20text-color-yellow%22%3E%E5%BE%88%E5%B0%91%E6%8F%90%E7%A4%BA%3C/span%3E%3Cspan%3E%E7%9A%84%E6%83%85%E5%86%B5%E4%B8%8B%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8F%90%E5%8F%96%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A1%AB%E7%A9%BA%E9%A2%98%E6%88%96%E8%80%85%E7%AE%80%E7%AD%94%E9%A2%98%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9B%B4%E9%9A%BE%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Recognition 再认 信息再次出现时，辨认出它是自己曾经学过的；选择题，正确答案就在眼前" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ERecognition%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%86%8D%E8%AE%A4%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22underline%20text-color-yellow%22%3E%E4%BF%A1%E6%81%AF%E5%86%8D%E6%AC%A1%3C/span%3E%3Cspan%3E%E5%87%BA%E7%8E%B0%E6%97%B6%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%BE%A8%E8%AE%A4%E5%87%BA%3C/span%3E%3Cspan%3E%E5%AE%83%E6%98%AF%E8%87%AA%E5%B7%B1%E6%9B%BE%E7%BB%8F%E5%AD%A6%E8%BF%87%E7%9A%84%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%80%89%E6%8B%A9%E9%A2%98%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%AD%A3%E7%A1%AE%E7%AD%94%E6%A1%88%E5%B0%B1%E5%9C%A8%E7%9C%BC%E5%89%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Archive" _mubu_text="%3Cspan%3EArchive%3C/span%3E" _note="" _mubu_note="">
            <outline text="Retrieval Cues" _mubu_text="%3Cspan%20class=%22bold%22%3ERetrieval%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3ECues%3C/span%3E" _note="" _mubu_note="">
              <outline text="帮助我们从记忆大海中“钓”出特定信息的刺激物。" _mubu_text="%3Cspan%3E%E5%B8%AE%E5%8A%A9%E6%88%91%E4%BB%AC%E4%BB%8E%E8%AE%B0%E5%BF%86%E5%A4%A7%E6%B5%B7%E4%B8%AD%E2%80%9C%E9%92%93%E2%80%9D%E5%87%BA%E7%89%B9%E5%AE%9A%E4%BF%A1%E6%81%AF%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%88%BA%E6%BF%80%E7%89%A9%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="线索可以是外部的（比如一个特定的场景、一种气味、一首歌）" _mubu_text="%3Cspan%3E%E7%BA%BF%E7%B4%A2%E5%8F%AF%E4%BB%A5%E6%98%AF%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E5%A4%96%E9%83%A8%E7%9A%84%3C/span%3E%3Cspan%3E%EF%BC%88%E6%AF%94%E5%A6%82%3C/span%3E%3Cspan%20class=%22underline%22%3E%E4%B8%80%E4%B8%AA%E7%89%B9%E5%AE%9A%E7%9A%84%E5%9C%BA%E6%99%AF%E3%80%81%E4%B8%80%E7%A7%8D%E6%B0%94%E5%91%B3%E3%80%81%E4%B8%80%E9%A6%96%E6%AD%8C%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="也可以是内部的（比如一种情绪、一个想法）。" _mubu_text="%3Cspan%3E%E4%B9%9F%E5%8F%AF%E4%BB%A5%E6%98%AF%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E5%86%85%E9%83%A8%E7%9A%84%3C/span%3E%3Cspan%3E%EF%BC%88%E6%AF%94%E5%A6%82%3C/span%3E%3Cspan%20class=%22underline%22%3E%E4%B8%80%E7%A7%8D%E6%83%85%E7%BB%AA%E3%80%81%E4%B8%80%E4%B8%AA%E6%83%B3%E6%B3%95%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="强大的线索能让回忆变得轻而易举。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BC%BA%E5%A4%A7%E7%9A%84%E7%BA%BF%E7%B4%A2%3C/span%3E%3Cspan%3E%E8%83%BD%E8%AE%A9%E5%9B%9E%E5%BF%86%E5%8F%98%E5%BE%97%3C/span%3E%3Cspan%20class=%22underline%22%3E%E8%BD%BB%E8%80%8C%E6%98%93%E4%B8%BE%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="回忆 (Recall) vs. 再认 (Recognition)" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%9B%9E%E5%BF%86%20(Recall)%20vs.%20%E5%86%8D%E8%AE%A4%20(Recognition)%3C/span%3E" _note="" _mubu_note="">
              <outline text="回忆 Recall（写作单词，需要写下来的背单词方法）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%9B%9E%E5%BF%86%20Recall%3C/span%3E%3Cspan%3E%EF%BC%88%E5%86%99%E4%BD%9C%E5%8D%95%E8%AF%8D%EF%BC%8C%E9%9C%80%E8%A6%81%E5%86%99%E4%B8%8B%E6%9D%A5%E7%9A%84%E8%83%8C%E5%8D%95%E8%AF%8D%E6%96%B9%E6%B3%95%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
                <outline text="指的是在没有或很少有提示的情况下" _mubu_text="%3Cspan%3E%E6%8C%87%E7%9A%84%E6%98%AF%E5%9C%A8%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E6%B2%A1%E6%9C%89%E6%88%96%E5%BE%88%E5%B0%91%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%9C%89%E6%8F%90%E7%A4%BA%3C/span%3E%3Cspan%3E%E7%9A%84%E6%83%85%E5%86%B5%E4%B8%8B%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="独立地从记忆中提取信息。" _mubu_text="%3Cspan%3E%E7%8B%AC%E7%AB%8B%E5%9C%B0%E4%BB%8E%E8%AE%B0%E5%BF%86%E4%B8%AD%E6%8F%90%E5%8F%96%E4%BF%A1%E6%81%AF%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="比如，考试中的填空题或简答题。这通常更困难。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%EF%BC%8C%E8%80%83%E8%AF%95%E4%B8%AD%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E5%A1%AB%E7%A9%BA%E9%A2%98%E6%88%96%E7%AE%80%E7%AD%94%E9%A2%98%E3%80%82%E8%BF%99%E9%80%9A%E5%B8%B8%E6%9B%B4%E5%9B%B0%E9%9A%BE%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="再认 Recognition（扇贝单词，认不认识的背单词方法）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%86%8D%E8%AE%A4%20Recognition%3C/span%3E%3Cspan%3E%EF%BC%88%E6%89%87%E8%B4%9D%E5%8D%95%E8%AF%8D%EF%BC%8C%E8%AE%A4%E4%B8%8D%E8%AE%A4%E8%AF%86%E7%9A%84%E8%83%8C%E5%8D%95%E8%AF%8D%E6%96%B9%E6%B3%95%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
                <outline text="指的是在信息再次出现时" _mubu_text="%3Cspan%3E%E6%8C%87%E7%9A%84%E6%98%AF%E5%9C%A8%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%86%8D%E6%AC%A1%E5%87%BA%E7%8E%B0%E6%97%B6%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="辨认出它是自己曾经学习过的" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E8%BE%A8%E8%AE%A4%E5%87%BA%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%AE%83%E6%98%AF%E8%87%AA%E5%B7%B1%E6%9B%BE%E7%BB%8F%E5%AD%A6%E4%B9%A0%E8%BF%87%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="比如，考试中的选择题，正确答案就在眼前，你只需要认出它。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%EF%BC%8C%E8%80%83%E8%AF%95%E4%B8%AD%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E9%80%89%E6%8B%A9%E9%A2%98%EF%BC%8C%E6%AD%A3%E7%A1%AE%E7%AD%94%E6%A1%88%E5%B0%B1%E5%9C%A8%E7%9C%BC%E5%89%8D%EF%BC%8C%E4%BD%A0%E5%8F%AA%E9%9C%80%E8%A6%81%E8%AE%A4%E5%87%BA%E5%AE%83%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="这通常比回忆要容易。" _mubu_text="%3Cspan%3E%E8%BF%99%E9%80%9A%E5%B8%B8%E6%AF%94%E5%9B%9E%E5%BF%86%E8%A6%81%E5%AE%B9%E6%98%93%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
          </outline>
        </outline>
        <outline text="Context Dependent" _mubu_text="%3Cspan%3EContext%20Dependent%3C/span%3E" _note="" _mubu_note="">
          <outline text="Context-Dependent Memory 情景依赖记忆 编码和提取的环境相同，记忆提取效果更好；灯光桌椅布局都是外部提取线索" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EContext-Dependent%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EMemory%20%E6%83%85%E6%99%AF%E4%BE%9D%E8%B5%96%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%20%E7%BC%96%E7%A0%81%E5%92%8C%E6%8F%90%E5%8F%96%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%8E%AF%E5%A2%83%E7%9B%B8%E5%90%8C%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%AE%B0%E5%BF%86%E6%8F%90%E5%8F%96%E6%95%88%E6%9E%9C%E6%9B%B4%E5%A5%BD%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%81%AF%E5%85%89%E6%A1%8C%E6%A4%85%E5%B8%83%E5%B1%80%3C/span%3E%3Cspan%3E%E9%83%BD%E6%98%AF%E5%A4%96%E9%83%A8%E6%8F%90%E5%8F%96%E7%BA%BF%E7%B4%A2%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="State-Dependent Memory 状态依赖记忆 编码和提取的状态相同，记忆提取效果更好；喝一杯咖啡（咖啡因兴奋状态）" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EState-Dependent%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EMemory%20%E7%8A%B6%E6%80%81%E4%BE%9D%E8%B5%96%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%20%E7%BC%96%E7%A0%81%E5%92%8C%E6%8F%90%E5%8F%96%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%8A%B6%E6%80%81%E7%9B%B8%E5%90%8C%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%AE%B0%E5%BF%86%E6%8F%90%E5%8F%96%E6%95%88%E6%9E%9C%E6%9B%B4%E5%A5%BD%EF%BC%9B%E5%96%9D%E4%B8%80%E6%9D%AF%E5%92%96%E5%95%A1%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%92%96%E5%95%A1%E5%9B%A0%E5%85%B4%E5%A5%8B%3C/span%3E%3Cspan%3E%E7%8A%B6%E6%80%81%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Mood-Congruent Memory 心境一致性记忆 我们更容易回忆起与当前情绪相似的记忆；开心的时候想开心的事，悲伤的时候我怎么这么难啊！" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EMood-Congruent%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EMemory%20%E5%BF%83%E5%A2%83%E4%B8%80%E8%87%B4%E6%80%A7%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%20%E6%88%91%E4%BB%AC%E6%9B%B4%E5%AE%B9%E6%98%93%E5%9B%9E%E5%BF%86%E8%B5%B7%E4%B8%8E%E5%BD%93%E5%89%8D%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%83%85%E7%BB%AA%E7%9B%B8%E4%BC%BC%3C/span%3E%3Cspan%3E%E7%9A%84%E8%AE%B0%E5%BF%86%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BC%80%E5%BF%83%3C/span%3E%3Cspan%3E%E7%9A%84%E6%97%B6%E5%80%99%E6%83%B3%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%BC%80%E5%BF%83%3C/span%3E%3Cspan%3E%E7%9A%84%E4%BA%8B%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%82%B2%E4%BC%A4%3C/span%3E%3Cspan%3E%E7%9A%84%E6%97%B6%E5%80%99%E6%88%91%E6%80%8E%E4%B9%88%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%BF%99%E4%B9%88%E9%9A%BE%3C/span%3E%3Cspan%3E%E5%95%8A%EF%BC%81%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Testing Effect 测试效应 通过自我测试来提取记忆的行为，加固LTP；反复阅读材料，做习题，考自己，解释概念…… 还不快去做CB~" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ETesting%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EEffect%20%E6%B5%8B%E8%AF%95%E6%95%88%E5%BA%94%3C/span%3E%3Cspan%3E%20%E9%80%9A%E8%BF%87%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%87%AA%E6%88%91%E6%B5%8B%E8%AF%95%3C/span%3E%3Cspan%3E%E6%9D%A5%E6%8F%90%E5%8F%96%E8%AE%B0%E5%BF%86%E7%9A%84%E8%A1%8C%E4%B8%BA%EF%BC%8C%E5%8A%A0%E5%9B%BA%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3ELTP%3C/span%3E%3Cspan%3E%EF%BC%9B%E5%8F%8D%E5%A4%8D%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%98%85%E8%AF%BB%3C/span%3E%3Cspan%3E%E6%9D%90%E6%96%99%EF%BC%8C%E5%81%9A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B9%A0%E9%A2%98%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%80%83%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%87%AA%E5%B7%B1%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%A7%A3%E9%87%8A%3C/span%3E%3Cspan%3E%E6%A6%82%E5%BF%B5%E2%80%A6%E2%80%A6%20%E8%BF%98%E4%B8%8D%E5%BF%AB%E5%8E%BB%E5%81%9ACB~%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Archive" _mubu_text="%3Cspan%3EArchive%3C/span%3E" _note="" _mubu_note="">
            <outline text="情境依赖记忆 (Context-Dependent Memory)" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E6%83%85%E5%A2%83%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BE%9D%E8%B5%96%E8%AE%B0%E5%BF%86%20(%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EContext%3C/span%3E%3Cspan%20class=%22bold%22%3E-Dependent%20Memory)%3C/span%3E" _note="" _mubu_note="">
              <outline text="当提取信息时的物理环境与编码（学习）信息时的环境相同时，记忆效果会更好。" _mubu_text="%3Cspan%3E%E5%BD%93%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%8F%90%E5%8F%96%E4%BF%A1%E6%81%AF%E6%97%B6%E7%9A%84%E7%89%A9%E7%90%86%E7%8E%AF%E5%A2%83%3C/span%3E%3Cspan%3E%E4%B8%8E%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%BC%96%E7%A0%81%EF%BC%88%E5%AD%A6%E4%B9%A0%EF%BC%89%E4%BF%A1%E6%81%AF%E6%97%B6%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E7%8E%AF%E5%A2%83%E7%9B%B8%E5%90%8C%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%97%B6%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%AE%B0%E5%BF%86%E6%95%88%E6%9E%9C%E4%BC%9A%E6%9B%B4%E5%A5%BD%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="在同一个 AP 教室里学习和考试，你可能会更容易想起复习过的内容。因为教室里的环境（灯光、桌椅、布局）都成了你记忆的外部提取线索。" _mubu_text="%3Cspan%3E%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%90%8C%E4%B8%80%E4%B8%AA%20AP%20%E6%95%99%E5%AE%A4%E9%87%8C%E5%AD%A6%E4%B9%A0%E5%92%8C%E8%80%83%E8%AF%95%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BD%A0%E5%8F%AF%E8%83%BD%E4%BC%9A%E6%9B%B4%E5%AE%B9%E6%98%93%E6%83%B3%E8%B5%B7%E5%A4%8D%E4%B9%A0%E8%BF%87%E7%9A%84%E5%86%85%E5%AE%B9%E3%80%82%E5%9B%A0%E4%B8%BA%E6%95%99%E5%AE%A4%E9%87%8C%E7%9A%84%E7%8E%AF%E5%A2%83%EF%BC%88%E7%81%AF%E5%85%89%E3%80%81%E6%A1%8C%E6%A4%85%E3%80%81%E5%B8%83%E5%B1%80%EF%BC%89%E9%83%BD%E6%88%90%E4%BA%86%E4%BD%A0%E8%AE%B0%E5%BF%86%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%A4%96%E9%83%A8%E6%8F%90%E5%8F%96%E7%BA%BF%E7%B4%A2%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22MM44Rbpblf%22%2C%22oh%22%3A366%2C%22ow%22%3A544%2C%22uri%22%3A%22document_image%2F33585682_cac8499c-2bb5-45d1-efa8-d75f1372fe66.png%22%2C%22w%22%3A400%7D%5D"/>
            </outline>
            <outline text="状态依赖记忆 (State-Dependent Memory)" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E7%8A%B6%E6%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BE%9D%E8%B5%96%E8%AE%B0%E5%BF%86%20(%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EState%3C/span%3E%3Cspan%20class=%22bold%22%3E-Dependent%20Memory)%3C/span%3E" _note="" _mubu_note="">
              <outline text="当提取信息时的生理或心理状态与编码信息时的状态相同时，记忆效果会更好。" _mubu_text="%3Cspan%3E%E5%BD%93%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%8F%90%E5%8F%96%E4%BF%A1%E6%81%AF%E6%97%B6%E7%9A%84%E7%94%9F%E7%90%86%E6%88%96%E5%BF%83%E7%90%86%E7%8A%B6%E6%80%81%3C/span%3E%3Cspan%3E%E4%B8%8E%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%BC%96%E7%A0%81%E4%BF%A1%E6%81%AF%E6%97%B6%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E7%8A%B6%E6%80%81%E7%9B%B8%E5%90%8C%E6%97%B6%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%AE%B0%E5%BF%86%E6%95%88%E6%9E%9C%E4%BC%9A%E6%9B%B4%E5%A5%BD%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="如果你学习时习惯喝咖啡保持清醒（处于咖啡因兴奋状态），那么考试前也喝一杯咖啡，可能会帮助你更好地回忆起知识。反之，状态不匹配则可能抑制回忆。" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E4%BD%A0%E5%AD%A6%E4%B9%A0%E6%97%B6%E4%B9%A0%E6%83%AF%E5%96%9D%E5%92%96%E5%95%A1%E4%BF%9D%E6%8C%81%E6%B8%85%E9%86%92%EF%BC%88%E5%A4%84%E4%BA%8E%E5%92%96%E5%95%A1%E5%9B%A0%E5%85%B4%E5%A5%8B%E7%8A%B6%E6%80%81%EF%BC%89%EF%BC%8C%E9%82%A3%E4%B9%88%E8%80%83%E8%AF%95%E5%89%8D%E4%B9%9F%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%96%9D%E4%B8%80%E6%9D%AF%E5%92%96%E5%95%A1%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%8F%AF%E8%83%BD%E4%BC%9A%E5%B8%AE%E5%8A%A9%E4%BD%A0%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%9B%B4%E5%A5%BD%E5%9C%B0%E5%9B%9E%E5%BF%86%E8%B5%B7%E7%9F%A5%E8%AF%86%3C/span%3E%3Cspan%3E%E3%80%82%E5%8F%8D%E4%B9%8B%EF%BC%8C%E7%8A%B6%E6%80%81%E4%B8%8D%E5%8C%B9%E9%85%8D%E5%88%99%E5%8F%AF%E8%83%BD%E6%8A%91%E5%88%B6%E5%9B%9E%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%228XSk3Qj9Hs%22%2C%22oh%22%3A513%2C%22ow%22%3A590%2C%22uri%22%3A%22document_image%2F33585682_0636233e-2a1a-40de-8342-c25ba78cccd7.png%22%2C%22w%22%3A400%7D%5D"/>
            </outline>
            <outline text="心境一致性记忆 (Mood-Congruent Memory)" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%BF%83%E5%A2%83%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%B8%80%E8%87%B4%E6%80%A7%E8%AE%B0%E5%BF%86%20(%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EMood%3C/span%3E%3Cspan%20class=%22bold%22%3E-Congruent%20Memory)%3C/span%3E" _note="" _mubu_note="">
              <outline text="这个效应指的是，我们当前的情绪状态会影响我们回忆起哪些内容。" _mubu_text="%3Cspan%3E%E8%BF%99%E4%B8%AA%E6%95%88%E5%BA%94%E6%8C%87%E7%9A%84%E6%98%AF%EF%BC%8C%E6%88%91%E4%BB%AC%E5%BD%93%E5%89%8D%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%83%85%E7%BB%AA%E7%8A%B6%E6%80%81%3C/span%3E%3Cspan%3E%E4%BC%9A%E5%BD%B1%E5%93%8D%E6%88%91%E4%BB%AC%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%9B%9E%E5%BF%86%E8%B5%B7%E5%93%AA%E4%BA%9B%E5%86%85%E5%AE%B9%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="具体来说，我们更容易回忆起与当前情绪相一致的记忆。" _mubu_text="%3Cspan%3E%E5%85%B7%E4%BD%93%E6%9D%A5%E8%AF%B4%EF%BC%8C%E6%88%91%E4%BB%AC%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%9B%B4%E5%AE%B9%E6%98%93%E5%9B%9E%E5%BF%86%E8%B5%B7%E4%B8%8E%E5%BD%93%E5%89%8D%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E6%83%85%E7%BB%AA%E7%9B%B8%E4%B8%80%E8%87%B4%E7%9A%84%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="当你开心的时候，你会更容易想起过去那些快乐的时光；而当你感到悲伤时，那些令人沮丧的往事似乎更容易涌上心头。情绪本身也成了一种强大的内部提取线索（情绪是Cue）。" _mubu_text="%3Cspan%3E%E5%BD%93%E4%BD%A0%E5%BC%80%E5%BF%83%E7%9A%84%E6%97%B6%E5%80%99%EF%BC%8C%E4%BD%A0%E4%BC%9A%E6%9B%B4%E5%AE%B9%E6%98%93%E6%83%B3%E8%B5%B7%E8%BF%87%E5%8E%BB%E9%82%A3%E4%BA%9B%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%BF%AB%E4%B9%90%E7%9A%84%E6%97%B6%E5%85%89%3C/span%3E%3Cspan%3E%EF%BC%9B%E8%80%8C%E5%BD%93%E4%BD%A0%E6%84%9F%E5%88%B0%E6%82%B2%E4%BC%A4%E6%97%B6%EF%BC%8C%E9%82%A3%E4%BA%9B%E4%BB%A4%E4%BA%BA%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%B2%AE%E4%B8%A7%3C/span%3E%3Cspan%3E%E7%9A%84%E5%BE%80%E4%BA%8B%E4%BC%BC%E4%B9%8E%E6%9B%B4%E5%AE%B9%E6%98%93%E6%B6%8C%E4%B8%8A%E5%BF%83%E5%A4%B4%E3%80%82%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E6%83%85%E7%BB%AA%E6%9C%AC%E8%BA%AB%E4%B9%9F%E6%88%90%E4%BA%86%E4%B8%80%E7%A7%8D%E5%BC%BA%E5%A4%A7%E7%9A%84%E5%86%85%E9%83%A8%E6%8F%90%E5%8F%96%E7%BA%BF%E7%B4%A2%3C/span%3E%3Cspan%20class=%22bold%22%3E%EF%BC%88%E6%83%85%E7%BB%AA%E6%98%AFCue%EF%BC%89%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="测试效应 (Testing Effect)" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E6%B5%8B%E8%AF%95%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%95%88%E5%BA%94%20(Testing%20Effect)%3C/span%3E" _note="" _mubu_note="">
              <outline text="指的是通过自我测试来提取记忆的行为，本身就能极大地增强长期记忆。" _mubu_text="%3Cspan%3E%E6%8C%87%E7%9A%84%E6%98%AF%3C/span%3E%3Cspan%20class=%22bold%22%3E%E9%80%9A%E8%BF%87%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E8%87%AA%E6%88%91%E6%B5%8B%E8%AF%95%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%9D%A5%E6%8F%90%E5%8F%96%E8%AE%B0%E5%BF%86%E7%9A%84%E8%A1%8C%E4%B8%BA%EF%BC%8C%E6%9C%AC%E8%BA%AB%E5%B0%B1%E8%83%BD%E6%9E%81%E5%A4%A7%E5%9C%B0%E5%A2%9E%E5%BC%BA%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="相比于反复阅读材料，做练习题、考自己、或者尝试向别人解释一个概念（这都是测试形式）是一种更高效的学习方式。" _mubu_text="%3Cspan%3E%E7%9B%B8%E6%AF%94%E4%BA%8E%E5%8F%8D%E5%A4%8D%E9%98%85%E8%AF%BB%E6%9D%90%E6%96%99%EF%BC%8C%E5%81%9A%E7%BB%83%E4%B9%A0%E9%A2%98%E3%80%81%E8%80%83%E8%87%AA%E5%B7%B1%E3%80%81%E6%88%96%E8%80%85%E5%B0%9D%E8%AF%95%E5%90%91%E5%88%AB%E4%BA%BA%E8%A7%A3%E9%87%8A%E4%B8%80%E4%B8%AA%E6%A6%82%E5%BF%B5%EF%BC%88%E8%BF%99%E9%83%BD%E6%98%AF%E6%B5%8B%E8%AF%95%E5%BD%A2%E5%BC%8F%EF%BC%89%E6%98%AF%E4%B8%80%E7%A7%8D%E6%9B%B4%E9%AB%98%E6%95%88%E7%9A%84%E5%AD%A6%E4%B9%A0%E6%96%B9%E5%BC%8F%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="每一次成功的提取，都像是在加固那条神经通路（LTP）。" _mubu_text="%3Cspan%3E%E6%AF%8F%E4%B8%80%E6%AC%A1%E6%88%90%E5%8A%9F%E7%9A%84%E6%8F%90%E5%8F%96%EF%BC%8C%E9%83%BD%E5%83%8F%E6%98%AF%E5%9C%A8%E5%8A%A0%E5%9B%BA%E9%82%A3%E6%9D%A1%E7%A5%9E%E7%BB%8F%E9%80%9A%E8%B7%AF%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3ELTP%3C/span%3E%3Cspan%3E%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
      </outline>
      <outline text="2.7 Forgetting and Other Memory Challenges（3710字）" _mubu_text="%3Cspan%3E2.7%20Forgetting%20and%20Other%20Memory%20Challenges%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E3710%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="Forgetting Curve 遗忘曲线 新记忆以指数级损失，24小时忘记70%内容，使用分布式学习而不是Cramming；考完试就还给老师了" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EForgetting%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3ECurve%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E9%81%97%E5%BF%98%E6%9B%B2%E7%BA%BF%3C/span%3E%3Cspan%3E%20%E6%96%B0%E8%AE%B0%E5%BF%86%E4%BB%A5%E6%8C%87%E6%95%B0%E7%BA%A7%E6%8D%9F%E5%A4%B1%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E24%E5%B0%8F%E6%97%B6%E5%BF%98%E8%AE%B070%25%E5%86%85%E5%AE%B9%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BD%BF%E7%94%A8%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%88%86%E5%B8%83%E5%BC%8F%E5%AD%A6%E4%B9%A0%E8%80%8C%E4%B8%8D%E6%98%AFCramming%3C/span%3E%3Cspan%3E%EF%BC%9B%E8%80%83%E5%AE%8C%E8%AF%95%E5%B0%B1%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%BF%98%E7%BB%99%E8%80%81%E5%B8%88%3C/span%3E%3Cspan%3E%E4%BA%86%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="Serial Position Effect 系列位置效应 记住列表时，容易记住开头结尾，中间最容易被忘记，因为Primacy Effect（首因效应）和Recency Effect（近因效应）" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ESerial%20Position%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EEffect%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%B3%BB%E5%88%97%E4%BD%8D%E7%BD%AE%E6%95%88%E5%BA%94%3C/span%3E%3Cspan%3E%20%E8%AE%B0%E4%BD%8F%E5%88%97%E8%A1%A8%E6%97%B6%EF%BC%8C%E5%AE%B9%E6%98%93%E8%AE%B0%E4%BD%8F%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BC%80%E5%A4%B4%E7%BB%93%E5%B0%BE%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%AD%E9%97%B4%E6%9C%80%E5%AE%B9%E6%98%93%E8%A2%AB%E5%BF%98%E8%AE%B0%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%9B%A0%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EPrimacy%20Effect%3C/span%3E%3Cspan%3E%EF%BC%88%E9%A6%96%E5%9B%A0%E6%95%88%E5%BA%94%EF%BC%89%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3ERecency%20Effect%3C/span%3E%3Cspan%3E%EF%BC%88%E8%BF%91%E5%9B%A0%E6%95%88%E5%BA%94%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="Retrieval Failure 提取失败 - 编码失败、舌尖现象、干扰理论、压抑、痕迹衰退理论" _mubu_text="%3Cspan%20class=%22bold%20underline%22%3ERetrieval%3C/span%3E%3Cspan%20class=%22underline%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20underline%22%3EFailure%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%8F%90%E5%8F%96%E5%A4%B1%E8%B4%A5%3C/span%3E%3Cspan%3E%20-%20%E7%BC%96%E7%A0%81%E5%A4%B1%E8%B4%A5%E3%80%81%E8%88%8C%E5%B0%96%E7%8E%B0%E8%B1%A1%E3%80%81%E5%B9%B2%E6%89%B0%E7%90%86%E8%AE%BA%E3%80%81%E5%8E%8B%E6%8A%91%E3%80%81%E7%97%95%E8%BF%B9%E8%A1%B0%E9%80%80%E7%90%86%E8%AE%BA%3C/span%3E" _note="" _mubu_note="">
          <outline text="忘记，很多时候是缺少了线索而提取失败" _mubu_text="%3Cspan%3E%E5%BF%98%E8%AE%B0%EF%BC%8C%E5%BE%88%E5%A4%9A%E6%97%B6%E5%80%99%E6%98%AF%E7%BC%BA%E5%B0%91%E4%BA%86%E7%BA%BF%E7%B4%A2%E8%80%8C%E6%8F%90%E5%8F%96%E5%A4%B1%E8%B4%A5%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Encoding Failure 编码失败 没记住，记忆没有存入长期记忆中，自然无从提取；硬币头像看哪边" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EEncoding%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EFailure%20%E7%BC%96%E7%A0%81%E5%A4%B1%E8%B4%A5%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%B2%A1%E8%AE%B0%E4%BD%8F%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%B2%A1%E6%9C%89%E5%AD%98%E5%85%A5%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%E4%B8%AD%EF%BC%8C%E8%87%AA%E7%84%B6%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%97%A0%E4%BB%8E%E6%8F%90%E5%8F%96%3C/span%3E%3Cspan%3E%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%A1%AC%E5%B8%81%E5%A4%B4%E5%83%8F%E7%9C%8B%E5%93%AA%E8%BE%B9%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Tip-of-the-Tongue State 舌尖现象 感觉自己知道，能回忆起细节，但是就是说不出信息本身 - avaliable不代表retrievable，过一会就想起来" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ETip-of-the-Tongue%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EState%20%E8%88%8C%E5%B0%96%E7%8E%B0%E8%B1%A1%3C/span%3E%3Cspan%3E%20%E6%84%9F%E8%A7%89%E8%87%AA%E5%B7%B1%E7%9F%A5%E9%81%93%EF%BC%8C%E8%83%BD%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%9B%9E%E5%BF%86%E8%B5%B7%E7%BB%86%3C/span%3E%3Cspan%3E%E8%8A%82%EF%BC%8C%E4%BD%86%E6%98%AF%E5%B0%B1%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%AF%B4%E4%B8%8D%E5%87%BA%E4%BF%A1%E6%81%AF%E6%9C%AC%E8%BA%AB%3C/span%3E%3Cspan%3E%20-%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Eavaliable%3C/span%3E%3Cspan%3E%E4%B8%8D%E4%BB%A3%E8%A1%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Eretrievable%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%BF%87%E4%B8%80%E4%BC%9A%E5%B0%B1%E6%83%B3%E8%B5%B7%E6%9D%A5%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Interference Theory 干扰理论 一些记忆会干扰其他记忆的提取，前摄干扰（Proactive）旧的干扰新的，后摄干扰（Retroactive）新的干扰旧的" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EInterference%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3ETheory%20%E5%B9%B2%E6%89%B0%E7%90%86%E8%AE%BA%3C/span%3E%3Cspan%3E%20%E4%B8%80%E4%BA%9B%E8%AE%B0%E5%BF%86%E4%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%B9%B2%E6%89%B0%E5%85%B6%E4%BB%96%E8%AE%B0%E5%BF%86%E7%9A%84%E6%8F%90%E5%8F%96%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22underline%20text-color-red%22%3E%E5%89%8D%E6%91%84%E5%B9%B2%E6%89%B0%EF%BC%88Proactive%EF%BC%89%E6%97%A7%E7%9A%84%E5%B9%B2%E6%89%B0%E6%96%B0%E7%9A%84%EF%BC%8C%E5%90%8E%E6%91%84%E5%B9%B2%E6%89%B0%EF%BC%88Retroactive%EF%BC%89%E6%96%B0%E7%9A%84%E5%B9%B2%E6%89%B0%E6%97%A7%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Repression 压抑 人们可能会无意识地将那些引起创伤、焦虑或痛苦的记忆、想法或感觉从意识中排除出去，以此来保护自己，有争议" _mubu_text="%3Cspan%3ERepression%20%E5%8E%8B%E6%8A%91%20%E4%BA%BA%E4%BB%AC%E5%8F%AF%E8%83%BD%E4%BC%9A%E6%97%A0%E6%84%8F%E8%AF%86%E5%9C%B0%E5%B0%86%E9%82%A3%E4%BA%9B%E5%BC%95%E8%B5%B7%E5%88%9B%E4%BC%A4%E3%80%81%E7%84%A6%E8%99%91%E6%88%96%E7%97%9B%E8%8B%A6%E7%9A%84%E8%AE%B0%E5%BF%86%E3%80%81%E6%83%B3%E6%B3%95%E6%88%96%E6%84%9F%E8%A7%89%E4%BB%8E%E6%84%8F%E8%AF%86%E4%B8%AD%E6%8E%92%E9%99%A4%E5%87%BA%E5%8E%BB%EF%BC%8C%E4%BB%A5%E6%AD%A4%E6%9D%A5%E4%BF%9D%E6%8A%A4%E8%87%AA%E5%B7%B1%EF%BC%8C%3C/span%3E%3Cspan%20class=%22underline%22%3E%E6%9C%89%E4%BA%89%E8%AE%AE%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Trace Decay Theory 痕迹衰退理论 记忆像是一条生理痕迹，会褪色 - 难以解释为什么有些很久以前的记忆仍历历在目，而记不起昨天早上吃了什么" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ETrace%20Decay%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3ETheory%20%E7%97%95%E8%BF%B9%E8%A1%B0%E9%80%80%E7%90%86%E8%AE%BA%3C/span%3E%3Cspan%3E%20%E8%AE%B0%E5%BF%86%E5%83%8F%E6%98%AF%E4%B8%80%E6%9D%A1%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%94%9F%E7%90%86%E7%97%95%E8%BF%B9%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BC%9A%E8%A4%AA%E8%89%B2%20-%20%E9%9A%BE%E4%BB%A5%E8%A7%A3%E9%87%8A%E4%B8%BA%E4%BB%80%E4%B9%88%E6%9C%89%E4%BA%9B%E5%BE%88%E4%B9%85%E4%BB%A5%E5%89%8D%E7%9A%84%E8%AE%B0%E5%BF%86%E4%BB%8D%E5%8E%86%E5%8E%86%E5%9C%A8%E7%9B%AE%EF%BC%8C%E8%80%8C%E8%AE%B0%E4%B8%8D%E8%B5%B7%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%98%A8%E5%A4%A9%E6%97%A9%E4%B8%8A%E5%90%83%E4%BA%86%E4%BB%80%E4%B9%88%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Amnesia 遗忘症 - 逆行，顺行，婴儿" _mubu_text="%3Cspan%20class=%22underline%22%3EAmnesia%3C/span%3E%3Cspan%3E%20%E9%81%97%E5%BF%98%E7%97%87%20-%20%E9%80%86%E8%A1%8C%EF%BC%8C%E9%A1%BA%E8%A1%8C%EF%BC%8C%E5%A9%B4%E5%84%BF%3C/span%3E" _note="" _mubu_note="">
          <outline text="Retrograde Amnesia 逆行性遗忘症 无法回忆起创伤之前的记忆，retro 忘记了过去；车祸忘记以前的事情" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ERetrograde%20%3C/span%3E%3Cspan%20class=%22bold%22%3EAmnesia%20%E9%80%86%E8%A1%8C%E6%80%A7%E9%81%97%E5%BF%98%E7%97%87%3C/span%3E%3Cspan%3E%20%E6%97%A0%E6%B3%95%E5%9B%9E%E5%BF%86%E8%B5%B7%E5%88%9B%E4%BC%A4%E4%B9%8B%E5%89%8D%E7%9A%84%E8%AE%B0%E5%BF%86%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3Eretro%20%E5%BF%98%E8%AE%B0%E4%BA%86%E8%BF%87%E5%8E%BB%3C/span%3E%3Cspan%3E%EF%BC%9B%E8%BD%A6%E7%A5%B8%E5%BF%98%E8%AE%B0%E4%BB%A5%E5%89%8D%E7%9A%84%E4%BA%8B%E6%83%85%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Anterograde Amnesia 顺行性遗忘症 无法形成新的长期记忆，antero 每天都是车祸后的那一天，可以procedual memories" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EAnterograde%20%3C/span%3E%3Cspan%20class=%22bold%22%3EAmnesia%20%E9%A1%BA%E8%A1%8C%E6%80%A7%E9%81%97%E5%BF%98%E7%97%87%3C/span%3E%3Cspan%3E%20%E6%97%A0%E6%B3%95%E5%BD%A2%E6%88%90%E6%96%B0%E7%9A%84%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3Eantero%20%E6%AF%8F%E5%A4%A9%E9%83%BD%E6%98%AF%E8%BD%A6%E7%A5%B8%E5%90%8E%E7%9A%84%E9%82%A3%E4%B8%80%E5%A4%A9%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%8F%AF%E4%BB%A5procedual%20memories%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Infantile Amnesia 婴儿期遗忘症 记不起3-4岁前发生的事情，海马体不成熟，语言发展不完全，自我意识尚未形成" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EInfantile%20%3C/span%3E%3Cspan%20class=%22bold%22%3EAmnesia%20%E5%A9%B4%E5%84%BF%E6%9C%9F%E9%81%97%E5%BF%98%E7%97%87%3C/span%3E%3Cspan%3E%20%E8%AE%B0%E4%B8%8D%E8%B5%B73-4%E5%B2%81%E5%89%8D%E5%8F%91%E7%94%9F%E7%9A%84%E4%BA%8B%E6%83%85%EF%BC%8C%E6%B5%B7%E9%A9%AC%E4%BD%93%E4%B8%8D%E6%88%90%E7%86%9F%EF%BC%8C%E8%AF%AD%E8%A8%80%E5%8F%91%E5%B1%95%E4%B8%8D%E5%AE%8C%E5%85%A8%EF%BC%8C%E8%87%AA%E6%88%91%E6%84%8F%E8%AF%86%E5%B0%9A%E6%9C%AA%E5%BD%A2%E6%88%90%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Alzheimer&apos;s Disease 阿尔兹海默症 神经退行性疾病，对记忆毁灭性破坏，丧失记忆、认知能力下降和行为改变；不认识家人、忘记重要个人信息、丧失自理能力。" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EAlzheimer&apos;s%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EDisease%20%E9%98%BF%E5%B0%94%E5%85%B9%E6%B5%B7%E9%BB%98%E7%97%87%3C/span%3E%3Cspan%3E%20%E7%A5%9E%E7%BB%8F%E9%80%80%E8%A1%8C%E6%80%A7%E7%96%BE%E7%97%85%EF%BC%8C%E5%AF%B9%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%AE%B0%E5%BF%86%E6%AF%81%E7%81%AD%E6%80%A7%3C/span%3E%3Cspan%3E%E7%A0%B4%E5%9D%8F%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%A7%E5%A4%B1%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%AE%A4%E7%9F%A5%E8%83%BD%E5%8A%9B%E4%B8%8B%E9%99%8D%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E8%A1%8C%E4%B8%BA%E6%94%B9%E5%8F%98%3C/span%3E%3Cspan%3E%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%8D%E8%AE%A4%E8%AF%86%E5%AE%B6%E4%BA%BA%3C/span%3E%3Cspan%3E%E3%80%81%E5%BF%98%E8%AE%B0%E9%87%8D%E8%A6%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%B8%AA%E4%BA%BA%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%E3%80%81%E4%B8%A7%E5%A4%B1%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%87%AA%E7%90%86%E8%83%BD%E5%8A%9B%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="Memory Distortion 记忆扭曲" _mubu_text="%3Cspan%20class=%22bold%20underline%22%3EMemory%20Distortion%3C/span%3E%3Cspan%20class=%22bold%22%3E%20%E8%AE%B0%E5%BF%86%E6%89%AD%E6%9B%B2%3C/span%3E" _note="" _mubu_note="">
          <outline text="Misinformation Effect 错误信息效应 接触到对于某事件误导性的信息，被整合到记忆中；打、殴打，殴打好疼啊！车祸hit 和 smashed，哪个车速快" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EMisinformation%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EEffect%20%E9%94%99%E8%AF%AF%E4%BF%A1%E6%81%AF%E6%95%88%E5%BA%94%3C/span%3E%3Cspan%3E%20%E6%8E%A5%E8%A7%A6%E5%88%B0%E5%AF%B9%E4%BA%8E%E6%9F%90%E4%BA%8B%E4%BB%B6%E8%AF%AF%E5%AF%BC%E6%80%A7%E7%9A%84%E4%BF%A1%E6%81%AF%EF%BC%8C%E8%A2%AB%E6%95%B4%E5%90%88%E5%88%B0%E8%AE%B0%E5%BF%86%E4%B8%AD%EF%BC%9B%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%89%93%E3%80%81%E6%AE%B4%E6%89%93%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%AE%B4%E6%89%93%E5%A5%BD%E7%96%BC%E5%95%8A%EF%BC%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%BD%A6%E7%A5%B8hit%20%E5%92%8C%20smashed%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%93%AA%E4%B8%AA%E8%BD%A6%E9%80%9F%E5%BF%AB%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Constructive Memory 建构性记忆 记忆可以被主动建构，我们会用已有的知识、信念、经验和期望去填补空白。" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3EConstructive%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EMemory%20%E5%BB%BA%E6%9E%84%E6%80%A7%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%20%E8%AE%B0%E5%BF%86%E5%8F%AF%E4%BB%A5%E8%A2%AB%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%BB%E5%8A%A8%E5%BB%BA%E6%9E%84%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%88%91%E4%BB%AC%E4%BC%9A%E7%94%A8%E5%B7%B2%E6%9C%89%E7%9A%84%E7%9F%A5%E8%AF%86%E3%80%81%E4%BF%A1%E5%BF%B5%E3%80%81%E7%BB%8F%E9%AA%8C%E5%92%8C%E6%9C%9F%E6%9C%9B%E5%8E%BB%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A1%AB%E8%A1%A5%E7%A9%BA%E7%99%BD%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note="">
            <outline text="Imagination Inflation 想象没发生的事情，会让我们大大增加这是真实的信心" _mubu_text="%3Cspan%20class=%22underline%22%3EImagination%20Inflation%3C/span%3E%3Cspan%3E%20%E6%83%B3%E8%B1%A1%E6%B2%A1%E5%8F%91%E7%94%9F%E7%9A%84%E4%BA%8B%E6%83%85%EF%BC%8C%E4%BC%9A%E8%AE%A9%E6%88%91%E4%BB%AC%E5%A4%A7%E5%A4%A7%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A2%9E%E5%8A%A0%3C/span%3E%3Cspan%3E%E8%BF%99%E6%98%AF%E7%9C%9F%E5%AE%9E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BF%A1%E5%BF%83%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Source Amnesia 来源性遗忘 记住事件本身，但是忘记何时何地如何获得，Déjà vu（既视感）忘记了记忆来源，归因于真实经历" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ESource%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EAmnesia%20%E6%9D%A5%E6%BA%90%E6%80%A7%E9%81%97%E5%BF%98%3C/span%3E%3Cspan%3E%20%E8%AE%B0%E4%BD%8F%E4%BA%8B%E4%BB%B6%E6%9C%AC%E8%BA%AB%EF%BC%8C%E4%BD%86%E6%98%AF%E5%BF%98%E8%AE%B0%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%BD%95%E6%97%B6%E4%BD%95%E5%9C%B0%E5%A6%82%E4%BD%95%E8%8E%B7%E5%BE%97%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3ED%C3%A9j%C3%A0%20vu%3C/span%3E%3Cspan%3E%EF%BC%88%E6%97%A2%E8%A7%86%E6%84%9F%EF%BC%89%E5%BF%98%E8%AE%B0%E4%BA%86%E8%AE%B0%E5%BF%86%E6%9D%A5%E6%BA%90%EF%BC%8C%E5%BD%92%E5%9B%A0%E4%BA%8E%E7%9C%9F%E5%AE%9E%E7%BB%8F%E5%8E%86%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Archive" _mubu_text="%3Cspan%3EArchive%3C/span%3E" _note="" _mubu_note="">
          <outline text="遗忘曲线 (Forgetting Curve)" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%81%97%E5%BF%98%E6%9B%B2%E7%BA%BF%20(Forgetting%20Curve)%3C/span%3E" _note="" _mubu_note="">
            <outline text="赫尔曼·艾宾浩斯 (Hermann Ebbinghaus) 最早提出的" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%B5%AB%E5%B0%94%E6%9B%BC%C2%B7%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E8%89%BE%E5%AE%BE%E6%B5%A9%E6%96%AF%3C/span%3E%3Cspan%20class=%22bold%22%3E%20(Hermann%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EEbbinghaus%3C/span%3E%3Cspan%20class=%22bold%22%3E)%20%E6%9C%80%E6%97%A9%E6%8F%90%E5%87%BA%E7%9A%84%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="核心思想" _mubu_text="%3Cspan%3E%E6%A0%B8%E5%BF%83%E6%80%9D%E6%83%B3%3C/span%3E" _note="" _mubu_note="">
              <outline text="遗忘在学习之后会立即发生，并且速度非常快" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E9%81%97%E5%BF%98%E5%9C%A8%E5%AD%A6%E4%B9%A0%E4%B9%8B%E5%90%8E%E4%BC%9A%E7%AB%8B%E5%8D%B3%E5%8F%91%E7%94%9F%EF%BC%8C%E5%B9%B6%E4%B8%94%E9%80%9F%E5%BA%A6%E9%9D%9E%E5%B8%B8%E5%BF%AB%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="之后遗忘的速度会逐渐减慢" _mubu_text="%3Cspan%3E%E4%B9%8B%E5%90%8E%E9%81%97%E5%BF%98%E7%9A%84%E9%80%9F%E5%BA%A6%E4%BC%9A%E9%80%90%E6%B8%90%E5%87%8F%E6%85%A2%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="这是一种指数级 (exponential) 的损失。" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AF%E4%B8%80%E7%A7%8D%E6%8C%87%E6%95%B0%E7%BA%A7%20(%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3Eexponential%3C/span%3E%3Cspan%3E)%20%E7%9A%84%E6%8D%9F%E5%A4%B1%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="具体表现" _mubu_text="%3Cspan%3E%E5%85%B7%E4%BD%93%E8%A1%A8%E7%8E%B0%3C/span%3E" _note="" _mubu_note="">
              <outline text="研究发现我们在学习新知识的24小时内，可能会忘记高达70%的内容" _mubu_text="%3Cspan%3E%E7%A0%94%E7%A9%B6%E5%8F%91%E7%8E%B0%E6%88%91%E4%BB%AC%E5%9C%A8%E5%AD%A6%E4%B9%A0%E6%96%B0%E7%9F%A5%E8%AF%86%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E24%E5%B0%8F%E6%97%B6%E5%86%85%EF%BC%8C%E5%8F%AF%E8%83%BD%E4%BC%9A%E5%BF%98%E8%AE%B0%E9%AB%98%E8%BE%BE70%25%E7%9A%84%E5%86%85%E5%AE%B9%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="这听起来很吓人，但也很真实。" _mubu_text="%3Cspan%3E%E8%BF%99%E5%90%AC%E8%B5%B7%E6%9D%A5%E5%BE%88%E5%90%93%E4%BA%BA%EF%BC%8C%E4%BD%86%E4%B9%9F%E5%BE%88%E7%9C%9F%E5%AE%9E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="比如你周一学了一个新的数学公式，如果没有复习，可能到周二下午就忘得差不多了。" _mubu_text="%3Cspan%3E%E6%AF%94%E5%A6%82%E4%BD%A0%E5%91%A8%E4%B8%80%E5%AD%A6%E4%BA%86%E4%B8%80%E4%B8%AA%E6%96%B0%E7%9A%84%E6%95%B0%E5%AD%A6%E5%85%AC%E5%BC%8F%EF%BC%8C%E5%A6%82%E6%9E%9C%E6%B2%A1%E6%9C%89%E5%A4%8D%E4%B9%A0%EF%BC%8C%E5%8F%AF%E8%83%BD%E5%88%B0%E5%91%A8%E4%BA%8C%E4%B8%8B%E5%8D%88%E5%B0%B1%E5%BF%98%E5%BE%97%E5%B7%AE%E4%B8%8D%E5%A4%9A%E4%BA%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="启示" _mubu_text="%3Cspan%3E%E5%90%AF%E7%A4%BA%3C/span%3E" _note="" _mubu_note="">
              <outline text="使用分布式学习 (Distributed Learning / Spacing Effect)" _mubu_text="%3Cspan%3E%E4%BD%BF%E7%94%A8%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E5%88%86%E5%B8%83%E5%BC%8F%E5%AD%A6%E4%B9%A0%3C/span%3E%3Cspan%20class=%22bold%22%3E%20(Distributed%20Learning%20/%20Spacing%20Effect)%3C/span%3E" _note="" _mubu_note="">
                <outline text="把学习时间分散开，比如每天学习一小时，连续学一周。" _mubu_text="%3Cspan%3E%E6%8A%8A%E5%AD%A6%E4%B9%A0%E6%97%B6%E9%97%B4%E5%88%86%E6%95%A3%E5%BC%80%EF%BC%8C%E6%AF%94%E5%A6%82%E6%AF%8F%E5%A4%A9%E5%AD%A6%E4%B9%A0%E4%B8%80%E5%B0%8F%E6%97%B6%EF%BC%8C%E8%BF%9E%E7%BB%AD%E5%AD%A6%E4%B8%80%E5%91%A8%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="这种方式可以有效地对抗遗忘曲线，因为你每次复习都在把记忆重新拉回到一个高点。" _mubu_text="%3Cspan%3E%E8%BF%99%E7%A7%8D%E6%96%B9%E5%BC%8F%E5%8F%AF%E4%BB%A5%E6%9C%89%E6%95%88%E5%9C%B0%E5%AF%B9%E6%8A%97%E9%81%97%E5%BF%98%E6%9B%B2%E7%BA%BF%EF%BC%8C%E5%9B%A0%E4%B8%BA%E4%BD%A0%E6%AF%8F%E6%AC%A1%E5%A4%8D%E4%B9%A0%E9%83%BD%E5%9C%A8%E6%8A%8A%E8%AE%B0%E5%BF%86%E9%87%8D%E6%96%B0%E6%8B%89%E5%9B%9E%E5%88%B0%E4%B8%80%E4%B8%AA%E9%AB%98%E7%82%B9%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="而不是集中练习 (Mass Practice / Cramming)" _mubu_text="%3Cspan%3E%E8%80%8C%E4%B8%8D%E6%98%AF%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E9%9B%86%E4%B8%AD%E7%BB%83%E4%B9%A0%3C/span%3E%3Cspan%20class=%22bold%22%3E%20(Mass%20Practice%20/%20Cramming)%3C/span%3E" _note="" _mubu_note="">
                <outline text="考前通宵抱佛脚。" _mubu_text="%3Cspan%3E%E8%80%83%E5%89%8D%3C/span%3E%3Cspan%20class=%22underline%22%3E%E9%80%9A%E5%AE%B5%E6%8A%B1%E4%BD%9B%E8%84%9A%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="这种方式短期效果可能还行，但因为没有经过巩固，遗忘得非常快。" _mubu_text="%3Cspan%3E%E8%BF%99%E7%A7%8D%E6%96%B9%E5%BC%8F%E7%9F%AD%E6%9C%9F%E6%95%88%E6%9E%9C%E5%8F%AF%E8%83%BD%E8%BF%98%E8%A1%8C%EF%BC%8C%E4%BD%86%E5%9B%A0%E4%B8%BA%3C/span%3E%3Cspan%20class=%22underline%22%3E%E6%B2%A1%E6%9C%89%E7%BB%8F%E8%BF%87%E5%B7%A9%E5%9B%BA%EF%BC%8C%E9%81%97%E5%BF%98%E5%BE%97%E9%9D%9E%E5%B8%B8%E5%BF%AB%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="考完试可能就立刻还给老师了。" _mubu_text="%3Cspan%3E%E8%80%83%E5%AE%8C%E8%AF%95%E5%8F%AF%E8%83%BD%E5%B0%B1%E7%AB%8B%E5%88%BB%E8%BF%98%E7%BB%99%E8%80%81%E5%B8%88%E4%BA%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
          </outline>
          <outline text="系列位置效应 (Serial Position Effect)" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B3%BB%E5%88%97%E4%BD%8D%E7%BD%AE%E6%95%88%E5%BA%94%20(Serial%20Position%20Effect)%3C/span%3E" _note="" _mubu_note="">
            <outline text="当我们需要记忆一个列表时，我们记忆效果的分布规律。" _mubu_text="%3Cspan%3E%E5%BD%93%E6%88%91%E4%BB%AC%E9%9C%80%E8%A6%81%E8%AE%B0%E5%BF%86%E4%B8%80%E4%B8%AA%E5%88%97%E8%A1%A8%E6%97%B6%EF%BC%8C%E6%88%91%E4%BB%AC%E8%AE%B0%E5%BF%86%E6%95%88%E6%9E%9C%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%88%86%E5%B8%83%E8%A7%84%E5%BE%8B%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="核心思想" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A0%B8%E5%BF%83%E6%80%9D%E6%83%B3%3C/span%3E" _note="" _mubu_note="">
              <outline text="当我们试图回忆一个长列表（比如一串单词、一个购物清单）时" _mubu_text="%3Cspan%3E%E5%BD%93%E6%88%91%E4%BB%AC%E8%AF%95%E5%9B%BE%E5%9B%9E%E5%BF%86%E4%B8%80%E4%B8%AA%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%95%BF%E5%88%97%E8%A1%A8%3C/span%3E%3Cspan%3E%EF%BC%88%E6%AF%94%E5%A6%82%E4%B8%80%E4%B8%B2%E5%8D%95%E8%AF%8D%E3%80%81%E4%B8%80%E4%B8%AA%E8%B4%AD%E7%89%A9%E6%B8%85%E5%8D%95%EF%BC%89%E6%97%B6%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="我们最容易记住开头和结尾的项目，而中间的项目最容易被忘记。" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%9C%80%E5%AE%B9%E6%98%93%E8%AE%B0%E4%BD%8F%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%BC%80%E5%A4%B4%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E7%BB%93%E5%B0%BE%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%9A%84%E9%A1%B9%E7%9B%AE%EF%BC%8C%E8%80%8C%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E4%B8%AD%E9%97%B4%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%9A%84%E9%A1%B9%E7%9B%AE%E6%9C%80%E5%AE%B9%E6%98%93%E8%A2%AB%E5%BF%98%E8%AE%B0%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="原因" _mubu_text="%3Cspan%3E%E5%8E%9F%E5%9B%A0%3C/span%3E" _note="" _mubu_note="">
              <outline text="首因效应 (Primacy Effect)" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E9%A6%96%3C/span%3E%3Cspan%3E%E5%9B%A0%E6%95%88%E5%BA%94%20(%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EPrimacy%3C/span%3E%3Cspan%3E%20Effect)%3C/span%3E" _note="" _mubu_note="">
                <outline text="我们对列表开头的项目有更好的回忆。" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E5%AF%B9%E5%88%97%E8%A1%A8%E5%BC%80%E5%A4%B4%E7%9A%84%E9%A1%B9%E7%9B%AE%E6%9C%89%E6%9B%B4%E5%A5%BD%E7%9A%84%E5%9B%9E%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="这是因为在列表刚开始时，我们的注意力最集中" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AF%E5%9B%A0%E4%B8%BA%E5%9C%A8%E5%88%97%E8%A1%A8%E5%88%9A%E5%BC%80%E5%A7%8B%E6%97%B6%EF%BC%8C%E6%88%91%E4%BB%AC%E7%9A%84%E6%B3%A8%E6%84%8F%E5%8A%9B%E6%9C%80%E9%9B%86%E4%B8%AD%3C/span%3E" _note="" _mubu_note="">
                  <outline text="有更多的时间在脑海里复述 (rehearsal) 这些项目，" _mubu_text="%3Cspan%3E%E6%9C%89%E6%9B%B4%E5%A4%9A%E7%9A%84%E6%97%B6%E9%97%B4%E5%9C%A8%E8%84%91%E6%B5%B7%E9%87%8C%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E5%A4%8D%E8%BF%B0%20(rehearsal)%20%3C/span%3E%3Cspan%3E%E8%BF%99%E4%BA%9B%E9%A1%B9%E7%9B%AE%EF%BC%8C%3C/span%3E" _note="" _mubu_note=""/>
                  <outline text="从而将它们转入了长期记忆 (long-term memory)。" _mubu_text="%3Cspan%3E%E4%BB%8E%E8%80%8C%E5%B0%86%E5%AE%83%E4%BB%AC%E8%BD%AC%E5%85%A5%E4%BA%86%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%20(long-term%20memory%3C/span%3E%3Cspan%3E)%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                </outline>
              </outline>
              <outline text="近因效应 (Recency Effect)" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E8%BF%91%3C/span%3E%3Cspan%3E%E5%9B%A0%E6%95%88%E5%BA%94%20(%3C/span%3E%3Cspan%20class=%22text-color-green%22%3ERecency%3C/span%3E%3Cspan%3E%20Effect)%3C/span%3E" _note="" _mubu_note="">
                <outline text="我们对列表结尾的项目也有更好的回忆。" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E5%AF%B9%E5%88%97%E8%A1%A8%E7%BB%93%E5%B0%BE%E7%9A%84%E9%A1%B9%E7%9B%AE%E4%B9%9F%E6%9C%89%E6%9B%B4%E5%A5%BD%E7%9A%84%E5%9B%9E%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="这是因为这些项目是最后进入我们脑海的，它们还停留在我们的工作记忆 (working memory) 或短期记忆中，所以提取起来非常容易。" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AF%E5%9B%A0%E4%B8%BA%E8%BF%99%E4%BA%9B%E9%A1%B9%E7%9B%AE%E6%98%AF%E6%9C%80%E5%90%8E%E8%BF%9B%E5%85%A5%E6%88%91%E4%BB%AC%E8%84%91%E6%B5%B7%E7%9A%84%EF%BC%8C%E5%AE%83%E4%BB%AC%E8%BF%98%E5%81%9C%E7%95%99%E5%9C%A8%E6%88%91%E4%BB%AC%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%B7%A5%E4%BD%9C%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%20(working%20memory)%20%E6%88%96%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%9F%AD%E6%9C%9F%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%E4%B8%AD%EF%BC%8C%E6%89%80%E4%BB%A5%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E6%8F%90%E5%8F%96%E8%B5%B7%E6%9D%A5%E9%9D%9E%E5%B8%B8%E5%AE%B9%3C/span%3E%3Cspan%3E%E6%98%93%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="苹果、香蕉、橙子、葡萄、草莓、西瓜、胡萝卜、黄瓜、土豆、生菜、菠菜、豆腐、米饭、面条、意大利面、巧克力、饼干、糖果、冰淇淋、酸奶、果汁、矿泉水、啤酒、红酒、酱油、盐、糖、食用油、鸡肉、牛肉、鱼肉、虾、火腿、奶酪、黄油、果酱、蜂蜜、咖啡、茶叶、玉米、蘑菇、蒜、姜、辣椒、茄子、豆芽、卷心菜、南瓜、梨" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E8%8B%B9%E6%9E%9C%E3%80%81%E9%A6%99%E8%95%89%E3%80%81%E6%A9%99%E5%AD%90%3C/span%3E%3Cspan%3E%E3%80%81%E8%91%A1%E8%90%84%E3%80%81%E8%8D%89%E8%8E%93%E3%80%81%E8%A5%BF%E7%93%9C%E3%80%81%E8%83%A1%E8%90%9D%E5%8D%9C%E3%80%81%E9%BB%84%E7%93%9C%E3%80%81%E5%9C%9F%E8%B1%86%E3%80%81%E7%94%9F%E8%8F%9C%E3%80%81%E8%8F%A0%E8%8F%9C%E3%80%81%E8%B1%86%E8%85%90%E3%80%81%E7%B1%B3%E9%A5%AD%E3%80%81%E9%9D%A2%E6%9D%A1%E3%80%81%E6%84%8F%E5%A4%A7%E5%88%A9%E9%9D%A2%E3%80%81%E5%B7%A7%E5%85%8B%E5%8A%9B%E3%80%81%E9%A5%BC%E5%B9%B2%E3%80%81%E7%B3%96%E6%9E%9C%E3%80%81%E5%86%B0%E6%B7%87%E6%B7%8B%E3%80%81%E9%85%B8%E5%A5%B6%E3%80%81%E6%9E%9C%E6%B1%81%E3%80%81%E7%9F%BF%E6%B3%89%E6%B0%B4%E3%80%81%E5%95%A4%E9%85%92%E3%80%81%E7%BA%A2%E9%85%92%E3%80%81%E9%85%B1%E6%B2%B9%E3%80%81%E7%9B%90%E3%80%81%E7%B3%96%E3%80%81%E9%A3%9F%E7%94%A8%E6%B2%B9%E3%80%81%E9%B8%A1%E8%82%89%E3%80%81%E7%89%9B%E8%82%89%E3%80%81%E9%B1%BC%E8%82%89%E3%80%81%E8%99%BE%E3%80%81%E7%81%AB%E8%85%BF%E3%80%81%E5%A5%B6%E9%85%AA%E3%80%81%E9%BB%84%E6%B2%B9%E3%80%81%E6%9E%9C%E9%85%B1%E3%80%81%E8%9C%82%E8%9C%9C%E3%80%81%E5%92%96%E5%95%A1%E3%80%81%E8%8C%B6%E5%8F%B6%E3%80%81%E7%8E%89%E7%B1%B3%E3%80%81%E8%98%91%E8%8F%87%E3%80%81%E8%92%9C%E3%80%81%E5%A7%9C%E3%80%81%E8%BE%A3%E6%A4%92%E3%80%81%E8%8C%84%E5%AD%90%E3%80%81%E8%B1%86%E8%8A%BD%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%8D%B7%E5%BF%83%E8%8F%9C%E3%80%81%E5%8D%97%E7%93%9C%E3%80%81%E6%A2%A8%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="提取失败 (Retrieval Failure)" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%8F%90%E5%8F%96%E5%A4%B1%E8%B4%A5%20(Retrieval%20Failure)%3C/span%3E" _note="" _mubu_note="">
            <outline text="为什么会忘记？" _mubu_text="%3Cspan%3E%E4%B8%BA%E4%BB%80%E4%B9%88%E4%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E5%BF%98%E8%AE%B0%3C/span%3E%3Cspan%3E%EF%BC%9F%3C/span%3E" _note="" _mubu_note="">
              <outline text="很多时候我们忘记一个东西，" _mubu_text="%3Cspan%3E%E5%BE%88%E5%A4%9A%E6%97%B6%E5%80%99%E6%88%91%E4%BB%AC%E5%BF%98%E8%AE%B0%E4%B8%80%E4%B8%AA%E4%B8%9C%E8%A5%BF%EF%BC%8C%3C/span%3E" _note="" _mubu_note="">
                <outline text="并不是因为这段记忆从大脑里消失了，而是我们暂时“找不到”它了。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B9%B6%E4%B8%8D%E6%98%AF%E5%9B%A0%E4%B8%BA%E8%BF%99%E6%AE%B5%E8%AE%B0%E5%BF%86%E4%BB%8E%E5%A4%A7%E8%84%91%E9%87%8C%E6%B6%88%E5%A4%B1%E4%BA%86%EF%BC%8C%E8%80%8C%E6%98%AF%E6%88%91%E4%BB%AC%E6%9A%82%E6%97%B6%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E2%80%9C%E6%89%BE%E4%B8%8D%E5%88%B0%E2%80%9D%E5%AE%83%E4%BA%86%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="一本书放在图书馆的某个角落，书本身还在，但你忘了编好，所以找不到它。" _mubu_text="%3Cspan%3E%E4%B8%80%E6%9C%AC%E4%B9%A6%E6%94%BE%E5%9C%A8%E5%9B%BE%E4%B9%A6%E9%A6%86%E7%9A%84%E6%9F%90%E4%B8%AA%E8%A7%92%E8%90%BD%EF%BC%8C%E4%B9%A6%E6%9C%AC%E8%BA%AB%E8%BF%98%E5%9C%A8%EF%BC%8C%E4%BD%86%E4%BD%A0%E5%BF%98%E4%BA%86%E7%BC%96%E5%A5%BD%EF%BC%8C%E6%89%80%E4%BB%A5%E6%89%BE%E4%B8%8D%E5%88%B0%E5%AE%83%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="这种提取失败，是由于缺少了当初编码记忆时存在的 线索 (cues) 。" _mubu_text="%3Cspan%3E%E8%BF%99%E7%A7%8D%E6%8F%90%E5%8F%96%E5%A4%B1%E8%B4%A5%EF%BC%8C%E6%98%AF%E7%94%B1%E4%BA%8E%E7%BC%BA%E5%B0%91%E4%BA%86%E5%BD%93%E5%88%9D%E7%BC%96%E7%A0%81%E8%AE%B0%E5%BF%86%E6%97%B6%E5%AD%98%E5%9C%A8%E7%9A%84%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E7%BA%BF%E7%B4%A2%20(cues)%3C/span%3E%3Cspan%3E%20%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="1. 编码失败 (Encoding Failure)" _mubu_text="%3Cspan%20class=%22bold%22%3E1.%20%E7%BC%96%E7%A0%81%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E5%A4%B1%E8%B4%A5%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E(Encoding%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EFailure%3C/span%3E%3Cspan%20class=%22bold%22%3E)%3C/span%3E" _note="" _mubu_note="">
              <outline text="这是最直接的一种“遗忘”——直接没记住。" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AF%E6%9C%80%E7%9B%B4%E6%8E%A5%E7%9A%84%E4%B8%80%E7%A7%8D%E2%80%9C%E9%81%97%E5%BF%98%E2%80%9D%E2%80%94%E2%80%94%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E7%9B%B4%E6%8E%A5%E6%B2%A1%E8%AE%B0%E4%BD%8F%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="核心思想" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A0%B8%E5%BF%83%E6%80%9D%E6%83%B3%3C/span%3E" _note="" _mubu_note="">
                <outline text="如果信息从一开始就没有被有效地编码（也就是存入）到长期记忆中，" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E4%BF%A1%E6%81%AF%E4%BB%8E%E4%B8%80%E5%BC%80%E5%A7%8B%E5%B0%B1%E6%B2%A1%E6%9C%89%E8%A2%AB%E6%9C%89%E6%95%88%E5%9C%B0%E7%BC%96%E7%A0%81%EF%BC%88%E4%B9%9F%E5%B0%B1%E6%98%AF%E5%AD%98%E5%85%A5%EF%BC%89%E5%88%B0%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%E4%B8%AD%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="那自然也就无从提取。" _mubu_text="%3Cspan%3E%E9%82%A3%E8%87%AA%E7%84%B6%E4%B9%9F%E5%B0%B1%E6%97%A0%E4%BB%8E%E6%8F%90%E5%8F%96%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="你知道一美分硬币的林肯头像朝向哪边，或者上面的文字是什么吗？" _mubu_text="%3Cspan%3E%E4%BD%A0%E7%9F%A5%E9%81%93%E4%B8%80%E7%BE%8E%E5%88%86%E7%A1%AC%E5%B8%81%E7%9A%84%E6%9E%97%E8%82%AF%E5%A4%B4%E5%83%8F%E6%9C%9D%E5%90%91%E5%93%AA%E8%BE%B9%EF%BC%8C%E6%88%96%E8%80%85%E4%B8%8A%E9%9D%A2%E7%9A%84%E6%96%87%E5%AD%97%E6%98%AF%E4%BB%80%E4%B9%88%E5%90%97%EF%BC%9F%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="不能，因为我们的大脑为了节省资源，没有对这些不重要的信息进行深度处理和编码。所以，这不是忘记，而是“从未记过”。" _mubu_text="%3Cspan%3E%E4%B8%8D%E8%83%BD%EF%BC%8C%E5%9B%A0%E4%B8%BA%E6%88%91%E4%BB%AC%E7%9A%84%E5%A4%A7%E8%84%91%E4%B8%BA%E4%BA%86%E8%8A%82%E7%9C%81%E8%B5%84%E6%BA%90%EF%BC%8C%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%B2%A1%E6%9C%89%E5%AF%B9%E8%BF%99%E4%BA%9B%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3E%E4%B8%8D%E9%87%8D%E8%A6%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%9A%84%E4%BF%A1%E6%81%AF%E8%BF%9B%E8%A1%8C%E6%B7%B1%E5%BA%A6%E5%A4%84%E7%90%86%E5%92%8C%E7%BC%96%E7%A0%81%3C/span%3E%3Cspan%3E%E3%80%82%E6%89%80%E4%BB%A5%EF%BC%8C%E8%BF%99%E4%B8%8D%E6%98%AF%E5%BF%98%E8%AE%B0%EF%BC%8C%E8%80%8C%E6%98%AF%E2%80%9C%E4%BB%8E%E6%9C%AA%E8%AE%B0%E8%BF%87%E2%80%9D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="2. 舌尖现象 (Tip-of-the-Tongue State)" _mubu_text="%3Cspan%20class=%22bold%22%3E2.%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E8%88%8C%E5%B0%96%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%8E%B0%E8%B1%A1%20(%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3ETip-of-the-Tongue%3C/span%3E%3Cspan%20class=%22bold%22%3E%20State)%3C/span%3E" _note="" _mubu_note="">
              <outline text="核心思想" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A0%B8%E5%BF%83%E6%80%9D%E6%83%B3%3C/span%3E" _note="" _mubu_note="">
                <outline text="你明确地感觉到自己知道某个信息（比如一个人的名字、一个单词），甚至能回忆起和它相关的很多细节，但就是说不出那个关键的信息本身。" _mubu_text="%3Cspan%3E%E4%BD%A0%E6%98%8E%E7%A1%AE%E5%9C%B0%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%84%9F%E8%A7%89%E5%88%B0%E8%87%AA%E5%B7%B1%E7%9F%A5%E9%81%93%E6%9F%90%E4%B8%AA%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%EF%BC%88%E6%AF%94%E5%A6%82%E4%B8%80%E4%B8%AA%E4%BA%BA%E7%9A%84%E5%90%8D%E5%AD%97%E3%80%81%E4%B8%80%E4%B8%AA%E5%8D%95%E8%AF%8D%EF%BC%89%EF%BC%8C%E7%94%9A%E8%87%B3%E8%83%BD%E5%9B%9E%E5%BF%86%E8%B5%B7%E5%92%8C%E5%AE%83%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%9B%B8%E5%85%B3%E7%9A%84%E5%BE%88%E5%A4%9A%E7%BB%86%E8%8A%82%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BD%86%E5%B0%B1%E6%98%AF%E8%AF%B4%E4%B8%8D%E5%87%BA%E9%82%A3%E4%B8%AA%E5%85%B3%E9%94%AE%E7%9A%84%E4%BF%A1%E6%81%AF%E6%9C%AC%E8%BA%AB%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="感觉它就在嘴边，但就是出不来。" _mubu_text="%3Cspan%3E%E6%84%9F%E8%A7%89%E5%AE%83%E5%B0%B1%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%98%B4%E8%BE%B9%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%BD%86%E5%B0%B1%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%87%BA%E4%B8%8D%E6%9D%A5%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="原因" _mubu_text="%3Cspan%3E%E5%8E%9F%E5%9B%A0%3C/span%3E" _note="" _mubu_note="">
                <outline text="记忆的可用性 (available) 和可提取性 (retrievable) 是两回事。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%AE%B0%E5%BF%86%E7%9A%84%E5%8F%AF%E7%94%A8%E6%80%A7%20(%3C/span%3E%3Cspan%20class=%22bold%20text-color-green%22%3Eavailable%3C/span%3E%3Cspan%20class=%22bold%22%3E)%20%E5%92%8C%E5%8F%AF%E6%8F%90%E5%8F%96%E6%80%A7%20(%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3Eretrievable%3C/span%3E%3Cspan%20class=%22bold%22%3E)%20%E6%98%AF%E4%B8%A4%E5%9B%9E%E4%BA%8B%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="信息确实储存在你的大脑里（可用），但你暂时找不到正确的提取路径（不可提取）。" _mubu_text="%3Cspan%3E%E4%BF%A1%E6%81%AF%E7%A1%AE%E5%AE%9E%E5%82%A8%E5%AD%98%E5%9C%A8%E4%BD%A0%E7%9A%84%E5%A4%A7%E8%84%91%E9%87%8C%EF%BC%88%E5%8F%AF%E7%94%A8%EF%BC%89%EF%BC%8C%E4%BD%86%E4%BD%A0%E6%9A%82%E6%97%B6%E6%89%BE%E4%B8%8D%E5%88%B0%E6%AD%A3%E7%A1%AE%E7%9A%84%E6%8F%90%E5%8F%96%E8%B7%AF%E5%BE%84%EF%BC%88%E4%B8%8D%E5%8F%AF%E6%8F%90%E5%8F%96%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="通常过一会儿，或者得到某个线索后，这个信息就会突然冒出来。" _mubu_text="%3Cspan%3E%E9%80%9A%E5%B8%B8%E8%BF%87%E4%B8%80%E4%BC%9A%E5%84%BF%EF%BC%8C%E6%88%96%E8%80%85%E5%BE%97%E5%88%B0%E6%9F%90%E4%B8%AA%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E7%BA%BF%E7%B4%A2%3C/span%3E%3Cspan%3E%E5%90%8E%EF%BC%8C%E8%BF%99%E4%B8%AA%E4%BF%A1%E6%81%AF%E5%B0%B1%E4%BC%9A%E7%AA%81%E7%84%B6%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%86%92%E5%87%BA%E6%9D%A5%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="3. 干扰理论 (Interference Theory)" _mubu_text="%3Cspan%20class=%22bold%22%3E3.%20%E5%B9%B2%E6%89%B0%E7%90%86%E8%AE%BA%20(Interference%20Theory)%3C/span%3E" _note="" _mubu_note="">
              <outline text="核心思想：一些记忆会干扰其他记忆的提取，尤其当这些记忆相似时。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A0%B8%E5%BF%83%E6%80%9D%E6%83%B3%3C/span%3E%3Cspan%3E%EF%BC%9A%E4%B8%80%E4%BA%9B%E8%AE%B0%E5%BF%86%E4%BC%9A%E5%B9%B2%E6%89%B0%E5%85%B6%E4%BB%96%E8%AE%B0%E5%BF%86%E7%9A%84%E6%8F%90%E5%8F%96%EF%BC%8C%E5%B0%A4%E5%85%B6%E5%BD%93%E8%BF%99%E4%BA%9B%E8%AE%B0%E5%BF%86%E7%9B%B8%E4%BC%BC%E6%97%B6%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="干扰的种类" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%B9%B2%E6%89%B0%E7%9A%84%E7%A7%8D%E7%B1%BB%3C/span%3E" _note="" _mubu_note="">
                <outline text="前摄干扰 (Proactive Interference)" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3E%E5%89%8D%E6%91%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%B9%B2%E6%89%B0%20(%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EProactive%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EInterference)%3C/span%3E" _note="" _mubu_note="">
                  <outline text="旧的记忆干扰新的记忆的提取。" _mubu_text="%3Cspan%3E%E6%97%A7%E7%9A%84%E8%AE%B0%E5%BF%86%E5%B9%B2%E6%89%B0%E6%96%B0%E7%9A%84%E8%AE%B0%E5%BF%86%E7%9A%84%E6%8F%90%E5%8F%96%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                  <outline text="这里的 Pro 可以理解为 &quot;forward&quot;，即旧的记忆向前影响了新的。" _mubu_text="%3Cspan%3E%E8%BF%99%E9%87%8C%E7%9A%84%20Pro%20%E5%8F%AF%E4%BB%A5%E7%90%86%E8%A7%A3%E4%B8%BA%20%22forward%22%EF%BC%8C%E5%8D%B3%E6%97%A7%E7%9A%84%E8%AE%B0%E5%BF%86%E5%90%91%E5%89%8D%E5%BD%B1%E5%93%8D%E4%BA%86%E6%96%B0%E7%9A%84%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                  <outline text="例子：你搬家了，有了一个新地址。但在填写表格时，你可能会下意识地写出旧的地址。这就是旧地址的记忆干扰了你提取新地址。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BE%8B%E5%AD%90%3C/span%3E%3Cspan%3E%EF%BC%9A%E4%BD%A0%E6%90%AC%E5%AE%B6%E4%BA%86%EF%BC%8C%E6%9C%89%E4%BA%86%E4%B8%80%E4%B8%AA%E6%96%B0%E5%9C%B0%E5%9D%80%E3%80%82%E4%BD%86%E5%9C%A8%E5%A1%AB%E5%86%99%E8%A1%A8%E6%A0%BC%E6%97%B6%EF%BC%8C%E4%BD%A0%E5%8F%AF%E8%83%BD%E4%BC%9A%E4%B8%8B%E6%84%8F%E8%AF%86%E5%9C%B0%E5%86%99%E5%87%BA%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%97%A7%E7%9A%84%E5%9C%B0%E5%9D%80%3C/span%3E%3Cspan%3E%E3%80%82%E8%BF%99%E5%B0%B1%E6%98%AF%E6%97%A7%E5%9C%B0%E5%9D%80%E7%9A%84%E8%AE%B0%E5%BF%86%E5%B9%B2%E6%89%B0%E4%BA%86%E4%BD%A0%E6%8F%90%E5%8F%96%E6%96%B0%E5%9C%B0%E5%9D%80%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                  <outline text="我已经G11-4了，我还是经常写自己是G10-5班的呜呜呜呜呜呜呜。" _mubu_text="%3Cspan%3E%E6%88%91%E5%B7%B2%E7%BB%8FG11-4%E4%BA%86%EF%BC%8C%E6%88%91%E8%BF%98%E6%98%AF%E7%BB%8F%E5%B8%B8%E5%86%99%E8%87%AA%E5%B7%B1%E6%98%AFG10-5%E7%8F%AD%E7%9A%84%E5%91%9C%E5%91%9C%E5%91%9C%E5%91%9C%E5%91%9C%E5%91%9C%E5%91%9C%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                </outline>
                <outline text="后摄干扰 (Retroactive Interference)" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%90%8E%E6%91%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%B9%B2%E6%89%B0%20(%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3ERetroactive%3C/span%3E%3Cspan%20class=%22bold%22%3E%20Interference)%3C/span%3E" _note="" _mubu_note="">
                  <outline text="新的记忆干扰旧的记忆的提取。" _mubu_text="%3Cspan%3E%E6%96%B0%E7%9A%84%E8%AE%B0%E5%BF%86%E5%B9%B2%E6%89%B0%E6%97%A7%E7%9A%84%E8%AE%B0%E5%BF%86%E7%9A%84%E6%8F%90%E5%8F%96%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                  <outline text="这里的 Retro 可以理解为 &quot;backward&quot;，即新的记忆向后影响了旧的。" _mubu_text="%3Cspan%3E%E8%BF%99%E9%87%8C%E7%9A%84%20Retro%20%E5%8F%AF%E4%BB%A5%E7%90%86%E8%A7%A3%E4%B8%BA%20%22backward%22%EF%BC%8C%E5%8D%B3%E6%96%B0%E7%9A%84%E8%AE%B0%E5%BF%86%E5%90%91%E5%90%8E%E5%BD%B1%E5%93%8D%E4%BA%86%E6%97%A7%E7%9A%84%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                  <outline text="例子：一位音乐家学会了一首新曲子，结果发现这首新曲子让他很难回忆起之前弹得很熟练的一首旧曲子的旋律。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BE%8B%E5%AD%90%3C/span%3E%3Cspan%3E%EF%BC%9A%E4%B8%80%E4%BD%8D%E9%9F%B3%E4%B9%90%E5%AE%B6%E5%AD%A6%E4%BC%9A%E4%BA%86%E4%B8%80%E9%A6%96%E6%96%B0%E6%9B%B2%E5%AD%90%EF%BC%8C%E7%BB%93%E6%9E%9C%E5%8F%91%E7%8E%B0%E8%BF%99%E9%A6%96%E6%96%B0%E6%9B%B2%E5%AD%90%E8%AE%A9%E4%BB%96%E5%BE%88%E9%9A%BE%E5%9B%9E%E5%BF%86%E8%B5%B7%E4%B9%8B%E5%89%8D%E5%BC%B9%E5%BE%97%E5%BE%88%E7%86%9F%E7%BB%83%E7%9A%84%E4%B8%80%E9%A6%96%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%97%A7%E6%9B%B2%E5%AD%90%3C/span%3E%3Cspan%3E%E7%9A%84%E6%97%8B%E5%BE%8B%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                </outline>
              </outline>
            </outline>
            <outline text="4. 压抑 (Repression)" _mubu_text="%3Cspan%20class=%22bold%22%3E4.%20%E5%8E%8B%E6%8A%91%20(Repression)%3C/span%3E" _note="" _mubu_note="">
              <outline text="“动机性遗忘 (Motivated Forgetting)” - 这是由弗洛伊德提出的一个精神分析概念。" _mubu_text="%3Cspan%3E%E2%80%9C%E5%8A%A8%E6%9C%BA%E6%80%A7%E9%81%97%E5%BF%98%20(Motivated%20Forgetting)%E2%80%9D%20-%20%E8%BF%99%E6%98%AF%E7%94%B1%E5%BC%97%E6%B4%9B%E4%BC%8A%E5%BE%B7%E6%8F%90%E5%87%BA%E7%9A%84%E4%B8%80%E4%B8%AA%E7%B2%BE%E7%A5%9E%E5%88%86%E6%9E%90%E6%A6%82%E5%BF%B5%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="核心思想" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A0%B8%E5%BF%83%E6%80%9D%E6%83%B3%3C/span%3E" _note="" _mubu_note="">
                <outline text="人们可能会无意识地将那些引起创伤、焦虑或痛苦的记忆、想法或感觉从意识中排除出去，以此来保护自己。" _mubu_text="%3Cspan%3E%E4%BA%BA%E4%BB%AC%E5%8F%AF%E8%83%BD%E4%BC%9A%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%97%A0%E6%84%8F%E8%AF%86%E5%9C%B0%3C/span%3E%3Cspan%3E%E5%B0%86%E9%82%A3%E4%BA%9B%E5%BC%95%E8%B5%B7%E5%88%9B%E4%BC%A4%E3%80%81%E7%84%A6%E8%99%91%E6%88%96%E7%97%9B%E8%8B%A6%E7%9A%84%E8%AE%B0%E5%BF%86%E3%80%81%E6%83%B3%E6%B3%95%E6%88%96%E6%84%9F%E8%A7%89%E4%BB%8E%E6%84%8F%E8%AF%86%E4%B8%AD%E6%8E%92%E9%99%A4%E5%87%BA%E5%8E%BB%EF%BC%8C%E4%BB%A5%E6%AD%A4%E6%9D%A5%E4%BF%9D%E6%8A%A4%E8%87%AA%E5%B7%B1%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="这是一种 防御机制 (defense mechanism) 。" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AF%E4%B8%80%E7%A7%8D%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E9%98%B2%E5%BE%A1%E6%9C%BA%E5%88%B6%20(defense%20mechanism)%3C/span%3E%3Cspan%3E%20%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="需要注意的是，Repression 在现代心理学中是一个非常有争议的概念。" _mubu_text="%3Cspan%3E%E9%9C%80%E8%A6%81%E6%B3%A8%E6%84%8F%E7%9A%84%E6%98%AF%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-red%22%3ERepression%20%E5%9C%A8%E7%8E%B0%E4%BB%A3%E5%BF%83%E7%90%86%E5%AD%A6%E4%B8%AD%E6%98%AF%E4%B8%80%E4%B8%AA%E9%9D%9E%E5%B8%B8%E6%9C%89%E4%BA%89%E8%AE%AE%E7%9A%84%E6%A6%82%E5%BF%B5%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note="">
                <outline text="虽然很多人（比如创伤后应激障碍 PTSD 患者）会极力避免回忆创伤事件，但关于记忆是否真的能被完全“压抑”到无意识中，目前还缺乏有力的科学证据。" _mubu_text="%3Cspan%3E%E8%99%BD%E7%84%B6%E5%BE%88%E5%A4%9A%E4%BA%BA%EF%BC%88%E6%AF%94%E5%A6%82%E5%88%9B%E4%BC%A4%E5%90%8E%E5%BA%94%E6%BF%80%E9%9A%9C%E7%A2%8D%20PTSD%20%E6%82%A3%E8%80%85%EF%BC%89%E4%BC%9A%E6%9E%81%E5%8A%9B%E9%81%BF%E5%85%8D%E5%9B%9E%E5%BF%86%E5%88%9B%E4%BC%A4%E4%BA%8B%E4%BB%B6%EF%BC%8C%E4%BD%86%E5%85%B3%E4%BA%8E%E8%AE%B0%E5%BF%86%E6%98%AF%E5%90%A6%E7%9C%9F%E7%9A%84%E8%83%BD%E8%A2%AB%E5%AE%8C%E5%85%A8%E2%80%9C%E5%8E%8B%E6%8A%91%E2%80%9D%E5%88%B0%E6%97%A0%E6%84%8F%E8%AF%86%E4%B8%AD%EF%BC%8C%E7%9B%AE%E5%89%8D%E8%BF%98%E7%BC%BA%E4%B9%8F%E6%9C%89%E5%8A%9B%E7%9A%84%E7%A7%91%E5%AD%A6%E8%AF%81%E6%8D%AE%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="很多心理学家，比如 Elizabeth Loftus，认为所谓的“被压抑的记忆”很可能是被错误信息植入的虚假记忆。" _mubu_text="%3Cspan%3E%E5%BE%88%E5%A4%9A%E5%BF%83%E7%90%86%E5%AD%A6%E5%AE%B6%EF%BC%8C%E6%AF%94%E5%A6%82%20Elizabeth%20Loftus%EF%BC%8C%E8%AE%A4%E4%B8%BA%E6%89%80%E8%B0%93%E7%9A%84%E2%80%9C%E8%A2%AB%E5%8E%8B%E6%8A%91%E7%9A%84%E8%AE%B0%E5%BF%86%E2%80%9D%E5%BE%88%E5%8F%AF%E8%83%BD%E6%98%AF%E8%A2%AB%E9%94%99%E8%AF%AF%E4%BF%A1%E6%81%AF%E6%A4%8D%E5%85%A5%E7%9A%84%E8%99%9A%E5%81%87%E8%AE%B0%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="5. 痕迹衰退理论 (Trace Decay Theory)" _mubu_text="%3Cspan%20class=%22bold%22%3E5.%20%E7%97%95%E8%BF%B9%E8%A1%B0%E9%80%80%E7%90%86%E8%AE%BA%20(Trace%20Decay%20Theory)%3C/span%3E" _note="" _mubu_note="">
              <outline text="核心思想" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A0%B8%E5%BF%83%E6%80%9D%E6%83%B3%3C/span%3E" _note="" _mubu_note="">
                <outline text="记忆就像在我们大脑中留下的一条生理痕迹 (memory trace) 。" _mubu_text="%3Cspan%3E%E8%AE%B0%E5%BF%86%E5%B0%B1%E5%83%8F%E5%9C%A8%E6%88%91%E4%BB%AC%E5%A4%A7%E8%84%91%E4%B8%AD%E7%95%99%E4%B8%8B%E7%9A%84%E4%B8%80%E6%9D%A1%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%94%9F%E7%90%86%E7%97%95%E8%BF%B9%20(memory%20trace)%3C/span%3E%3Cspan%3E%20%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="随着时间的流逝，如果我们不去使用或复习这段记忆，这条痕迹就会像照片褪色一样，自动地、生物学地衰退和消失。" _mubu_text="%3Cspan%3E%E9%9A%8F%E7%9D%80%E6%97%B6%E9%97%B4%E7%9A%84%E6%B5%81%E9%80%9D%EF%BC%8C%E5%A6%82%E6%9E%9C%E6%88%91%E4%BB%AC%E4%B8%8D%E5%8E%BB%E4%BD%BF%E7%94%A8%E6%88%96%E5%A4%8D%E4%B9%A0%E8%BF%99%E6%AE%B5%E8%AE%B0%E5%BF%86%EF%BC%8C%E8%BF%99%E6%9D%A1%E7%97%95%E8%BF%B9%E5%B0%B1%E4%BC%9A%E5%83%8F%E7%85%A7%E7%89%87%E8%A4%AA%E8%89%B2%E4%B8%80%E6%A0%B7%EF%BC%8C%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%87%AA%E5%8A%A8%E5%9C%B0%E3%80%81%E7%94%9F%E7%89%A9%E5%AD%A6%E5%9C%B0%E8%A1%B0%E9%80%80%E5%92%8C%E6%B6%88%E5%A4%B1%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="缺陷" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%BC%BA%E9%99%B7%3C/span%3E" _note="" _mubu_note="">
                <outline text="这个理论很好理解，但它很难解释为什么有些很多年前的记忆我们依然记得很清楚，而有些昨天的记忆却模糊了。" _mubu_text="%3Cspan%3E%E8%BF%99%E4%B8%AA%E7%90%86%E8%AE%BA%E5%BE%88%E5%A5%BD%E7%90%86%E8%A7%A3%EF%BC%8C%E4%BD%86%E5%AE%83%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BE%88%E9%9A%BE%E8%A7%A3%E9%87%8A%3C/span%3E%3Cspan%3E%E4%B8%BA%E4%BB%80%E4%B9%88%E6%9C%89%E4%BA%9B%E5%BE%88%E5%A4%9A%E5%B9%B4%E5%89%8D%E7%9A%84%E8%AE%B0%E5%BF%86%E6%88%91%E4%BB%AC%E4%BE%9D%E7%84%B6%E8%AE%B0%E5%BE%97%E5%BE%88%E6%B8%85%E6%A5%9A%EF%BC%8C%E8%80%8C%E6%9C%89%E4%BA%9B%E6%98%A8%E5%A4%A9%E7%9A%84%E8%AE%B0%E5%BF%86%E5%8D%B4%E6%A8%A1%E7%B3%8A%E4%BA%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="它也无法解释像“舌尖现象”那样记忆明明存在只是提不出来的情况。" _mubu_text="%3Cspan%3E%E5%AE%83%E4%B9%9F%E6%97%A0%E6%B3%95%E8%A7%A3%E9%87%8A%E5%83%8F%E2%80%9C%E8%88%8C%E5%B0%96%E7%8E%B0%E8%B1%A1%E2%80%9D%E9%82%A3%E6%A0%B7%E8%AE%B0%E5%BF%86%E6%98%8E%E6%98%8E%E5%AD%98%E5%9C%A8%E5%8F%AA%E6%98%AF%E6%8F%90%E4%B8%8D%E5%87%BA%E6%9D%A5%E7%9A%84%E6%83%85%E5%86%B5%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
          </outline>
          <outline text="遗忘症 (Amnesia)" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%81%97%E5%BF%98%E7%97%87%20(Amnesia)%3C/span%3E" _note="" _mubu_note="">
            <outline text="逆行性遗忘症 (Retrograde Amnesia)" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3E%E9%80%86%E8%A1%8C%E6%80%A7%3C/span%3E%3Cspan%20class=%22bold%22%3E%E9%81%97%E5%BF%98%E7%97%87%20(%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3ERetrograde%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EAmnesia)%3C/span%3E" _note="" _mubu_note="">
              <outline text="患者无法回忆起创伤事件发生之前的记忆。" _mubu_text="%3Cspan%3E%E6%82%A3%E8%80%85%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%97%A0%E6%B3%95%E5%9B%9E%E5%BF%86%E8%B5%B7%E5%88%9B%E4%BC%A4%E4%BA%8B%E4%BB%B6%E5%8F%91%E7%94%9F%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%E4%B9%8B%E5%89%8D%3C/span%3E%3Cspan%3E%E7%9A%84%E8%AE%B0%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Retro 意味着“向后”，所以是忘记了过去。" _mubu_text="%3Cspan%20class=%22bold%22%3ERetro%3C/span%3E%3Cspan%3E%20%E6%84%8F%E5%91%B3%E7%9D%80%E2%80%9C%E5%90%91%E5%90%8E%E2%80%9D%EF%BC%8C%E6%89%80%E4%BB%A5%E6%98%AF%E5%BF%98%E8%AE%B0%E4%BA%86%E8%BF%87%E5%8E%BB%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="例子：电影里常见的桥段，一个人车祸醒来后，不记得自己是谁，不认识自己的家人。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BE%8B%E5%AD%90%3C/span%3E%3Cspan%3E%EF%BC%9A%E7%94%B5%E5%BD%B1%E9%87%8C%E5%B8%B8%E8%A7%81%E7%9A%84%E6%A1%A5%E6%AE%B5%EF%BC%8C%E4%B8%80%E4%B8%AA%E4%BA%BA%E8%BD%A6%E7%A5%B8%E9%86%92%E6%9D%A5%E5%90%8E%EF%BC%8C%E4%B8%8D%E8%AE%B0%E5%BE%97%E8%87%AA%E5%B7%B1%E6%98%AF%E8%B0%81%EF%BC%8C%E4%B8%8D%E8%AE%A4%E8%AF%86%E8%87%AA%E5%B7%B1%E7%9A%84%E5%AE%B6%E4%BA%BA%E3%80%82%3C/span%3E" _note="" _mubu_note="">
                <outline text="他丢失的是过去的记忆。" _mubu_text="%3Cspan%3E%E4%BB%96%E4%B8%A2%E5%A4%B1%E7%9A%84%E6%98%AF%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%BF%87%E5%8E%BB%E7%9A%84%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="Scott Bolzan 的案例，他因为一次意外，忘记了过去46年的所有事情。" _mubu_text="%3Cspan%3EScott%20Bolzan%20%E7%9A%84%E6%A1%88%E4%BE%8B%EF%BC%8C%E4%BB%96%E5%9B%A0%E4%B8%BA%E4%B8%80%E6%AC%A1%E6%84%8F%E5%A4%96%EF%BC%8C%E5%BF%98%E8%AE%B0%E4%BA%86%E8%BF%87%E5%8E%BB46%E5%B9%B4%E7%9A%84%E6%89%80%E6%9C%89%E4%BA%8B%E6%83%85%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="顺行性遗忘症 (Anterograde Amnesia)" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E9%A1%BA%E8%A1%8C%E6%80%A7%3C/span%3E%3Cspan%20class=%22bold%22%3E%E9%81%97%E5%BF%98%E7%97%87%20(%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EAnterograde%3C/span%3E%3Cspan%20class=%22bold%22%3E%20Amnesia)%3C/span%3E" _note="" _mubu_note="">
              <outline text="患者无法形成创伤事件发生之后新的长期记忆。" _mubu_text="%3Cspan%3E%E6%82%A3%E8%80%85%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%97%A0%E6%B3%95%E5%BD%A2%E6%88%90%E5%88%9B%E4%BC%A4%E4%BA%8B%E4%BB%B6%E5%8F%91%E7%94%9F%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E4%B9%8B%E5%90%8E%E6%96%B0%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Antero 意味着“向前”，所以是无法形成未来的新记忆。" _mubu_text="%3Cspan%20class=%22bold%22%3EAntero%3C/span%3E%3Cspan%3E%20%E6%84%8F%E5%91%B3%E7%9D%80%E2%80%9C%E5%90%91%E5%89%8D%E2%80%9D%EF%BC%8C%E6%89%80%E4%BB%A5%E6%98%AF%E6%97%A0%E6%B3%95%E5%BD%A2%E6%88%90%E6%9C%AA%E6%9D%A5%E7%9A%84%E6%96%B0%E8%AE%B0%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="例子：Henry Molaison" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BE%8B%E5%AD%90%EF%BC%9A%3C/span%3E%3Cspan%3EHenry%20Molaison%3C/span%3E" _note="" _mubu_note="">
                <outline text="他为了治疗严重的癫痫，切除了部分大脑，包括河马校园。" _mubu_text="%3Cspan%3E%E4%BB%96%E4%B8%BA%E4%BA%86%E6%B2%BB%E7%96%97%E4%B8%A5%E9%87%8D%E7%9A%84%E7%99%AB%E7%97%AB%EF%BC%8C%E5%88%87%E9%99%A4%E4%BA%86%E9%83%A8%E5%88%86%E5%A4%A7%E8%84%91%EF%BC%8C%E5%8C%85%E6%8B%AC%E6%B2%B3%E9%A9%AC%E6%A0%A1%E5%9B%AD%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="手术后，他的旧记忆都还在，智力也正常，但他失去了形成新的外显记忆 explicit memory 的能力。" _mubu_text="%3Cspan%3E%E6%89%8B%E6%9C%AF%E5%90%8E%EF%BC%8C%E4%BB%96%E7%9A%84%E6%97%A7%E8%AE%B0%E5%BF%86%E9%83%BD%E8%BF%98%E5%9C%A8%EF%BC%8C%E6%99%BA%E5%8A%9B%E4%B9%9F%E6%AD%A3%E5%B8%B8%EF%BC%8C%E4%BD%86%E4%BB%96%E5%A4%B1%E5%8E%BB%E4%BA%86%E5%BD%A2%E6%88%90%E6%96%B0%E7%9A%84%E5%A4%96%E6%98%BE%E8%AE%B0%E5%BF%86%20explicit%20memory%20%E7%9A%84%E8%83%BD%E5%8A%9B%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="他可以和你聊天，但你离开房间再回来，他就不记得见过你了。他每天都像活在“现在”，无法将新的经历存入长期记忆。" _mubu_text="%3Cspan%3E%E4%BB%96%E5%8F%AF%E4%BB%A5%E5%92%8C%E4%BD%A0%E8%81%8A%E5%A4%A9%EF%BC%8C%E4%BD%86%E4%BD%A0%E7%A6%BB%E5%BC%80%E6%88%BF%E9%97%B4%E5%86%8D%E5%9B%9E%E6%9D%A5%EF%BC%8C%E4%BB%96%E5%B0%B1%E4%B8%8D%E8%AE%B0%E5%BE%97%E8%A7%81%E8%BF%87%E4%BD%A0%E4%BA%86%E3%80%82%E4%BB%96%E6%AF%8F%E5%A4%A9%E9%83%BD%E5%83%8F%E6%B4%BB%E5%9C%A8%E2%80%9C%E7%8E%B0%E5%9C%A8%E2%80%9D%EF%BC%8C%E6%97%A0%E6%B3%95%E5%B0%86%E6%96%B0%E7%9A%84%E7%BB%8F%E5%8E%86%E5%AD%98%E5%85%A5%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="不过，他仍然可以学习新的程序性记忆 procedural memories，比如练习一项技能会越来越熟练，但他不记得自己练习过。" _mubu_text="%3Cspan%3E%E4%B8%8D%E8%BF%87%EF%BC%8C%E4%BB%96%E4%BB%8D%E7%84%B6%E5%8F%AF%E4%BB%A5%E5%AD%A6%E4%B9%A0%E6%96%B0%E7%9A%84%E7%A8%8B%E5%BA%8F%E6%80%A7%E8%AE%B0%E5%BF%86%20procedural%20memories%EF%BC%8C%E6%AF%94%E5%A6%82%E7%BB%83%E4%B9%A0%E4%B8%80%E9%A1%B9%E6%8A%80%E8%83%BD%E4%BC%9A%E8%B6%8A%E6%9D%A5%E8%B6%8A%E7%86%9F%E7%BB%83%EF%BC%8C%E4%BD%86%E4%BB%96%E4%B8%8D%E8%AE%B0%E5%BE%97%E8%87%AA%E5%B7%B1%E7%BB%83%E4%B9%A0%E8%BF%87%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="婴儿期遗忘症 (Infantile Amnesia)" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E5%A9%B4%E5%84%BF%E6%9C%9F%3C/span%3E%3Cspan%20class=%22bold%22%3E%E9%81%97%E5%BF%98%E7%97%87%20(%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EInfantile%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EAmnesia)%3C/span%3E" _note="" _mubu_note="">
              <outline text="核心思想" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A0%B8%E5%BF%83%E6%80%9D%E6%83%B3%3C/span%3E" _note="" _mubu_note="">
                <outline text="我们几乎无法回忆起3-4岁之前发生的个人经历（自传式记忆）。" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E5%87%A0%E4%B9%8E%E6%97%A0%E6%B3%95%E5%9B%9E%E5%BF%86%E8%B5%B7%3C/span%3E%3Cspan%20class=%22bold%22%3E3-4%E5%B2%81%E4%B9%8B%E5%89%8D%3C/span%3E%3Cspan%3E%E5%8F%91%E7%94%9F%E7%9A%84%E4%B8%AA%E4%BA%BA%E7%BB%8F%E5%8E%86%EF%BC%88%E8%87%AA%E4%BC%A0%E5%BC%8F%E8%AE%B0%E5%BF%86%EF%BC%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="原因" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%8E%9F%E5%9B%A0%3C/span%3E" _note="" _mubu_note="">
                <outline text="这并不是因为我们小时候没有记忆，而是因为当时大脑的几个关键结构还没有完全成熟。" _mubu_text="%3Cspan%3E%E8%BF%99%E5%B9%B6%E4%B8%8D%E6%98%AF%E5%9B%A0%E4%B8%BA%E6%88%91%E4%BB%AC%E5%B0%8F%E6%97%B6%E5%80%99%E6%B2%A1%E6%9C%89%E8%AE%B0%E5%BF%86%EF%BC%8C%E8%80%8C%E6%98%AF%E5%9B%A0%E4%B8%BA%E5%BD%93%E6%97%B6%E5%A4%A7%E8%84%91%E7%9A%84%E5%87%A0%E4%B8%AA%E5%85%B3%E9%94%AE%E7%BB%93%E6%9E%84%E8%BF%98%E6%B2%A1%E6%9C%89%E5%AE%8C%E5%85%A8%E6%88%90%E7%86%9F%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="海马体不成熟，在婴幼儿时期它还未发育完全。" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E6%B5%B7%E9%A9%AC%E4%BD%93%3C/span%3E%3Cspan%3E%E4%B8%8D%E6%88%90%E7%86%9F%EF%BC%8C%E5%9C%A8%E5%A9%B4%E5%B9%BC%E5%84%BF%E6%97%B6%E6%9C%9F%E5%AE%83%E8%BF%98%E6%9C%AA%E5%8F%91%E8%82%B2%E5%AE%8C%E5%85%A8%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="语言发展不完全：我们很多记忆是以语言故事的形式编码的，在没有语言的时期，很难形成可以被日后提取的叙事性记忆。" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E8%AF%AD%E8%A8%80%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%8F%91%E5%B1%95%E4%B8%8D%E5%AE%8C%E5%85%A8%3C/span%3E%3Cspan%3E%EF%BC%9A%E6%88%91%E4%BB%AC%E5%BE%88%E5%A4%9A%E8%AE%B0%E5%BF%86%E6%98%AF%E4%BB%A5%E8%AF%AD%E8%A8%80%E6%95%85%E4%BA%8B%E7%9A%84%E5%BD%A2%E5%BC%8F%E7%BC%96%E7%A0%81%E7%9A%84%EF%BC%8C%E5%9C%A8%E6%B2%A1%E6%9C%89%E8%AF%AD%E8%A8%80%E7%9A%84%E6%97%B6%E6%9C%9F%EF%BC%8C%E5%BE%88%E9%9A%BE%E5%BD%A2%E6%88%90%E5%8F%AF%E4%BB%A5%E8%A2%AB%E6%97%A5%E5%90%8E%3C/span%3E%3Cspan%20class=%22underline%22%3E%E6%8F%90%E5%8F%96%3C/span%3E%3Cspan%3E%E7%9A%84%E5%8F%99%E4%BA%8B%E6%80%A7%E8%AE%B0%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="自我意识 (Sense of Self) 尚未形成：婴幼儿还没有一个稳定的自我概念，而自传式记忆是围绕“我”的经历展开的。" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E%E8%87%AA%E6%88%91%E6%84%8F%E8%AF%86%20(Sense%20of%20Self)%3C/span%3E%3Cspan%3E%20%E5%B0%9A%E6%9C%AA%E5%BD%A2%E6%88%90%EF%BC%9A%E5%A9%B4%E5%B9%BC%E5%84%BF%E8%BF%98%E6%B2%A1%E6%9C%89%E4%B8%80%E4%B8%AA%E7%A8%B3%E5%AE%9A%E7%9A%84%E8%87%AA%E6%88%91%E6%A6%82%E5%BF%B5%EF%BC%8C%E8%80%8C%E8%87%AA%E4%BC%A0%E5%BC%8F%E8%AE%B0%E5%BF%86%E6%98%AF%E5%9B%B4%E7%BB%95%E2%80%9C%E6%88%91%E2%80%9D%E7%9A%84%E7%BB%8F%E5%8E%86%E5%B1%95%E5%BC%80%E7%9A%84%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
          </outline>
          <outline text="阿尔茨海默病 (Alzheimer’s Disease)" _mubu_text="%3Cspan%3E%E9%98%BF%E5%B0%94%E8%8C%A8%E6%B5%B7%E9%BB%98%E7%97%85%20(Alzheimer%E2%80%99s%20Disease)%3C/span%3E" _note="" _mubu_note="">
            <outline text="这是一种进行性的神经退行性疾病，对记忆的破坏是毁灭性的。" _mubu_text="%3Cspan%3E%E8%BF%99%E6%98%AF%E4%B8%80%E7%A7%8D%E8%BF%9B%E8%A1%8C%E6%80%A7%E7%9A%84%E7%A5%9E%E7%BB%8F%E9%80%80%E8%A1%8C%E6%80%A7%E7%96%BE%E7%97%85%EF%BC%8C%E5%AF%B9%E8%AE%B0%E5%BF%86%E7%9A%84%E7%A0%B4%E5%9D%8F%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E6%AF%81%E7%81%AD%E6%80%A7%E7%9A%84%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="核心特征" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A0%B8%E5%BF%83%E7%89%B9%E5%BE%81%3C/span%3E" _note="" _mubu_note="">
              <outline text="以记忆丧失、认知能力下降和行为改变为主要特征。" _mubu_text="%3Cspan%3E%E4%BB%A5%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%AE%B0%E5%BF%86%E4%B8%A7%E5%A4%B1%E3%80%81%E8%AE%A4%E7%9F%A5%E8%83%BD%E5%8A%9B%E4%B8%8B%E9%99%8D%E5%92%8C%E8%A1%8C%E4%B8%BA%E6%94%B9%E5%8F%98%3C/span%3E%3Cspan%3E%E4%B8%BA%E4%B8%BB%E8%A6%81%E7%89%B9%E5%BE%81%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="过程" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%BF%87%E7%A8%8B%3C/span%3E" _note="" _mubu_note="">
              <outline text="它通常从影响短期记忆开始，比如忘记最近发生的事。" _mubu_text="%3Cspan%3E%E5%AE%83%E9%80%9A%E5%B8%B8%E4%BB%8E%E5%BD%B1%E5%93%8D%E7%9F%AD%E6%9C%9F%E8%AE%B0%E5%BF%86%E5%BC%80%E5%A7%8B%EF%BC%8C%E6%AF%94%E5%A6%82%E5%BF%98%E8%AE%B0%E6%9C%80%E8%BF%91%E5%8F%91%E7%94%9F%E7%9A%84%E4%BA%8B%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="随着病情发展，长期记忆也会受到严重破坏，患者可能不认识家人，忘记重要的个人信息，最终丧失生活自理能力。" _mubu_text="%3Cspan%3E%E9%9A%8F%E7%9D%80%E7%97%85%E6%83%85%E5%8F%91%E5%B1%95%EF%BC%8C%E9%95%BF%E6%9C%9F%E8%AE%B0%E5%BF%86%E4%B9%9F%E4%BC%9A%E5%8F%97%E5%88%B0%E4%B8%A5%E9%87%8D%E7%A0%B4%E5%9D%8F%EF%BC%8C%E6%82%A3%E8%80%85%E5%8F%AF%E8%83%BD%E4%B8%8D%E8%AE%A4%E8%AF%86%E5%AE%B6%E4%BA%BA%EF%BC%8C%E5%BF%98%E8%AE%B0%E9%87%8D%E8%A6%81%E7%9A%84%E4%B8%AA%E4%BA%BA%E4%BF%A1%E6%81%AF%EF%BC%8C%E6%9C%80%E7%BB%88%E4%B8%A7%E5%A4%B1%E7%94%9F%E6%B4%BB%E8%87%AA%E7%90%86%E8%83%BD%E5%8A%9B%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="这背后涉及到大脑中β-淀粉样蛋白斑块 (amyloid plaques) 和 Tau蛋白缠结 (neurofibrillary tangles) 的异常积累，导致神经元死亡。" _mubu_text="%3Cspan%3E%E8%BF%99%E8%83%8C%E5%90%8E%E6%B6%89%E5%8F%8A%E5%88%B0%E5%A4%A7%E8%84%91%E4%B8%AD%3C/span%3E%3Cspan%20class=%22bold%22%3E%CE%B2-%E6%B7%80%E7%B2%89%E6%A0%B7%E8%9B%8B%E7%99%BD%E6%96%91%E5%9D%97%20(amyloid%20plaques)%3C/span%3E%3Cspan%3E%20%E5%92%8C%20%3C/span%3E%3Cspan%20class=%22bold%22%3ETau%E8%9B%8B%E7%99%BD%E7%BC%A0%E7%BB%93%20(neurofibrillary%20tangles)%3C/span%3E%3Cspan%3E%20%E7%9A%84%E5%BC%82%E5%B8%B8%E7%A7%AF%E7%B4%AF%EF%BC%8C%E5%AF%BC%E8%87%B4%E7%A5%9E%E7%BB%8F%E5%85%83%E6%AD%BB%E4%BA%A1%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="和ACh的缺失" _mubu_text="%3Cspan%3E%E5%92%8CACh%E7%9A%84%E7%BC%BA%E5%A4%B1%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="记忆扭曲 (Memory Distortion)" _mubu_text="%3Cspan%3E%E8%AE%B0%E5%BF%86%E6%89%AD%E6%9B%B2%20(Memory%20Distortion)%3C/span%3E" _note="" _mubu_note="">
            <outline text="错误信息效应 (Misinformation Effect)" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%94%99%E8%AF%AF%E4%BF%A1%E6%81%AF%E6%95%88%E5%BA%94%20(Misinformation%20Effect)%3C/span%3E" _note="" _mubu_note="">
              <outline text="“打”和“殴打” —— 好疼啊" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3E%E2%80%9C%E6%89%93%E2%80%9D%E5%92%8C%E2%80%9C%E6%AE%B4%E6%89%93%E2%80%9D%3C/span%3E%3Cspan%20class=%22bold%22%3E%20%E2%80%94%E2%80%94%20%E5%A5%BD%E7%96%BC%E5%95%8A%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="核心思想" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A0%B8%E5%BF%83%E6%80%9D%E6%83%B3%3C/span%3E" _note="" _mubu_note="">
                <outline text="当我们在一个事件发生后，接触到关于该事件的误导性信息，" _mubu_text="%3Cspan%3E%E5%BD%93%E6%88%91%E4%BB%AC%E5%9C%A8%E4%B8%80%E4%B8%AA%E4%BA%8B%E4%BB%B6%E5%8F%91%E7%94%9F%E5%90%8E%EF%BC%8C%E6%8E%A5%E8%A7%A6%E5%88%B0%E5%85%B3%E4%BA%8E%E8%AF%A5%E4%BA%8B%E4%BB%B6%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%AF%AF%E5%AF%BC%E6%80%A7%E4%BF%A1%E6%81%AF%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="这些错误信息就有可能被整合进我们对原始事件的记忆中，从而导致我们的记忆发生扭曲。" _mubu_text="%3Cspan%3E%E8%BF%99%E4%BA%9B%E9%94%99%E8%AF%AF%E4%BF%A1%E6%81%AF%E5%B0%B1%E6%9C%89%E5%8F%AF%E8%83%BD%E8%A2%AB%E6%95%B4%E5%90%88%E8%BF%9B%E6%88%91%E4%BB%AC%E5%AF%B9%E5%8E%9F%E5%A7%8B%E4%BA%8B%E4%BB%B6%E7%9A%84%E8%AE%B0%E5%BF%86%E4%B8%AD%EF%BC%8C%E4%BB%8E%E8%80%8C%E5%AF%BC%E8%87%B4%E6%88%91%E4%BB%AC%E7%9A%84%E8%AE%B0%E5%BF%86%E5%8F%91%E7%94%9F%E6%89%AD%E6%9B%B2%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="重要实验（Loftus &amp; Palmer, 1974）- 车祸的虚假记忆" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%87%8D%E8%A6%81%E5%AE%9E%E9%AA%8C%EF%BC%88Loftus%20&amp;amp;%20Palmer,%201974%EF%BC%89-%20%E8%BD%A6%E7%A5%B8%E7%9A%84%E8%99%9A%E5%81%87%E8%AE%B0%E5%BF%86%3C/span%3E" _note="" _mubu_note="">
                <outline text="研究者给参与者看一段车祸的视频。之后，他们问参与者问题，但使用了不同措辞的动词。" _mubu_text="%3Cspan%3E%E7%A0%94%E7%A9%B6%E8%80%85%E7%BB%99%E5%8F%82%E4%B8%8E%E8%80%85%E7%9C%8B%E4%B8%80%E6%AE%B5%E8%BD%A6%E7%A5%B8%E7%9A%84%E8%A7%86%E9%A2%91%E3%80%82%E4%B9%8B%E5%90%8E%EF%BC%8C%E4%BB%96%E4%BB%AC%E9%97%AE%E5%8F%82%E4%B8%8E%E8%80%85%E9%97%AE%E9%A2%98%EF%BC%8C%E4%BD%86%E4%BD%BF%E7%94%A8%E4%BA%86%E4%B8%8D%E5%90%8C%E6%8E%AA%E8%BE%9E%E7%9A%84%E5%8A%A8%E8%AF%8D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="一组被问：“你认为两车‘ 撞击 (hit) ’时速度有多快？”" _mubu_text="%3Cspan%3E%E4%B8%80%E7%BB%84%E8%A2%AB%E9%97%AE%EF%BC%9A%E2%80%9C%E4%BD%A0%E8%AE%A4%E4%B8%BA%E4%B8%A4%E8%BD%A6%E2%80%98%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%92%9E%E5%87%BB%20(hit)%3C/span%3E%3Cspan%3E%20%E2%80%99%E6%97%B6%E9%80%9F%E5%BA%A6%E6%9C%89%E5%A4%9A%E5%BF%AB%EF%BC%9F%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="另一组被问：“你认为两车‘ 猛撞 (smashed) ’时速度有多快？”" _mubu_text="%3Cspan%3E%E5%8F%A6%E4%B8%80%E7%BB%84%E8%A2%AB%E9%97%AE%EF%BC%9A%E2%80%9C%E4%BD%A0%E8%AE%A4%E4%B8%BA%E4%B8%A4%E8%BD%A6%E2%80%98%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%8C%9B%E6%92%9E%20(smashed)%3C/span%3E%3Cspan%3E%20%E2%80%99%E6%97%B6%E9%80%9F%E5%BA%A6%E6%9C%89%E5%A4%9A%E5%BF%AB%EF%BC%9F%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="结果显示，听到“猛撞”这个词的参与者，会估计出更高的车速。更厉害的是，一周后，当被问到“你是否在视频中看到了碎玻璃？”时（视频里其实没有），“SMASHED”组有更多的人声称看到了碎玻璃。" _mubu_text="%3Cspan%3E%E7%BB%93%E6%9E%9C%E6%98%BE%E7%A4%BA%EF%BC%8C%E5%90%AC%E5%88%B0%E2%80%9C%E7%8C%9B%E6%92%9E%E2%80%9D%E8%BF%99%E4%B8%AA%E8%AF%8D%E7%9A%84%E5%8F%82%E4%B8%8E%E8%80%85%EF%BC%8C%E4%BC%9A%E4%BC%B0%E8%AE%A1%E5%87%BA%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%9B%B4%E9%AB%98%E7%9A%84%E8%BD%A6%E9%80%9F%3C/span%3E%3Cspan%3E%E3%80%82%E6%9B%B4%E5%8E%89%E5%AE%B3%E7%9A%84%E6%98%AF%EF%BC%8C%E4%B8%80%E5%91%A8%E5%90%8E%EF%BC%8C%E5%BD%93%E8%A2%AB%E9%97%AE%E5%88%B0%E2%80%9C%E4%BD%A0%E6%98%AF%E5%90%A6%E5%9C%A8%E8%A7%86%E9%A2%91%E4%B8%AD%E7%9C%8B%E5%88%B0%E4%BA%86%E7%A2%8E%E7%8E%BB%E7%92%83%EF%BC%9F%E2%80%9D%E6%97%B6%EF%BC%88%E8%A7%86%E9%A2%91%E9%87%8C%E5%85%B6%E5%AE%9E%E6%B2%A1%E6%9C%89%EF%BC%89%EF%BC%8C%E2%80%9CSMASHED%E2%80%9D%E7%BB%84%E6%9C%89%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%9B%B4%E5%A4%9A%E7%9A%84%E4%BA%BA%E5%A3%B0%E7%A7%B0%E7%9C%8B%E5%88%B0%E4%BA%86%E7%A2%8E%E7%8E%BB%E7%92%83%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="结论" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%BB%93%E8%AE%BA%3C/span%3E" _note="" _mubu_note="">
                <outline text="仅仅是一个词的改变，就足以改变人们对事件的记忆。" _mubu_text="%3Cspan%3E%E4%BB%85%E4%BB%85%E6%98%AF%E4%B8%80%E4%B8%AA%E8%AF%8D%E7%9A%84%E6%94%B9%E5%8F%98%EF%BC%8C%E5%B0%B1%E8%B6%B3%E4%BB%A5%E6%94%B9%E5%8F%98%E4%BA%BA%E4%BB%AC%E5%AF%B9%E4%BA%8B%E4%BB%B6%E7%9A%84%E8%AE%B0%E5%BF%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="这在目击者证词 的可靠性研究中具有非常重要的意义。" _mubu_text="%3Cspan%3E%E8%BF%99%E5%9C%A8%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%9B%AE%E5%87%BB%E8%80%85%E8%AF%81%E8%AF%8D%3C/span%3E%3Cspan%3E%20%E7%9A%84%E5%8F%AF%E9%9D%A0%E6%80%A7%E7%A0%94%E7%A9%B6%E4%B8%AD%E5%85%B7%E6%9C%89%E9%9D%9E%E5%B8%B8%E9%87%8D%E8%A6%81%E7%9A%84%E6%84%8F%E4%B9%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="建构性记忆 (Constructive Memory)" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BB%BA%E6%9E%84%E6%80%A7%E8%AE%B0%E5%BF%86%20(Constructive%20Memory)%3C/span%3E" _note="" _mubu_note="">
              <outline text="核心思想" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A0%B8%E5%BF%83%E6%80%9D%E6%83%B3%3C/span%3E" _note="" _mubu_note="">
                <outline text="我们的记忆不是简单地从仓库里“提取”出来的，而是在每次回忆时被主动地“建构 (constructed)” 出来的。" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E7%9A%84%E8%AE%B0%E5%BF%86%E4%B8%8D%E6%98%AF%E7%AE%80%E5%8D%95%E5%9C%B0%E4%BB%8E%E4%BB%93%E5%BA%93%E9%87%8C%E2%80%9C%E6%8F%90%E5%8F%96%E2%80%9D%E5%87%BA%E6%9D%A5%E7%9A%84%EF%BC%8C%E8%80%8C%E6%98%AF%E5%9C%A8%E6%AF%8F%E6%AC%A1%E5%9B%9E%E5%BF%86%E6%97%B6%E8%A2%AB%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%B8%BB%E5%8A%A8%E5%9C%B0%E2%80%9C%E5%BB%BA%E6%9E%84%20(constructed)%E2%80%9D%3C/span%3E%3Cspan%3E%20%E5%87%BA%E6%9D%A5%E7%9A%84%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="在这个建构过程中，我们会用已有的知识、信念、经验和期望去填补记忆中的空白。" _mubu_text="%3Cspan%3E%E5%9C%A8%E8%BF%99%E4%B8%AA%E5%BB%BA%E6%9E%84%E8%BF%87%E7%A8%8B%E4%B8%AD%EF%BC%8C%E6%88%91%E4%BB%AC%E4%BC%9A%E7%94%A8%E5%B7%B2%E6%9C%89%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E7%9F%A5%E8%AF%86%E3%80%81%E4%BF%A1%E5%BF%B5%E3%80%81%E7%BB%8F%E9%AA%8C%E5%92%8C%E6%9C%9F%E6%9C%9B%3C/span%3E%3Cspan%3E%E5%8E%BB%E5%A1%AB%E8%A1%A5%E8%AE%B0%E5%BF%86%E4%B8%AD%E7%9A%84%E7%A9%BA%E7%99%BD%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="想象膨胀 (Imagination Inflation)" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%83%B3%E8%B1%A1%E8%86%A8%E8%83%80%20(Imagination%20Inflation)%3C/span%3E" _note="" _mubu_note="">
                <outline text="仅仅是想象一件从未发生过的事情，就会增加我们对这件事真的发生过的信心。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BB%85%E4%BB%85%E6%98%AF%E6%83%B3%E8%B1%A1%E4%B8%80%E4%BB%B6%E4%BB%8E%E6%9C%AA%E5%8F%91%E7%94%9F%E8%BF%87%E7%9A%84%E4%BA%8B%E6%83%85%EF%BC%8C%E5%B0%B1%E4%BC%9A%E5%A2%9E%E5%8A%A0%E6%88%91%E4%BB%AC%E5%AF%B9%E8%BF%99%E4%BB%B6%E4%BA%8B%E7%9C%9F%E7%9A%84%E5%8F%91%E7%94%9F%E8%BF%87%E7%9A%84%E4%BF%A1%E5%BF%83%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="如果你反复想象自己小时候在商场走丢过，即使这件事从未发生，你之后可能会觉得这件事真的发生过，甚至能“回忆”起一些细节。" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E4%BD%A0%E5%8F%8D%E5%A4%8D%E6%83%B3%E8%B1%A1%E8%87%AA%E5%B7%B1%E5%B0%8F%E6%97%B6%E5%80%99%E5%9C%A8%E5%95%86%E5%9C%BA%E8%B5%B0%E4%B8%A2%E8%BF%87%EF%BC%8C%E5%8D%B3%E4%BD%BF%E8%BF%99%E4%BB%B6%E4%BA%8B%E4%BB%8E%E6%9C%AA%E5%8F%91%E7%94%9F%EF%BC%8C%E4%BD%A0%E4%B9%8B%E5%90%8E%E5%8F%AF%E8%83%BD%E4%BC%9A%E8%A7%89%E5%BE%97%E8%BF%99%E4%BB%B6%E4%BA%8B%E7%9C%9F%E7%9A%84%E5%8F%91%E7%94%9F%E8%BF%87%EF%BC%8C%E7%94%9A%E8%87%B3%E8%83%BD%E2%80%9C%E5%9B%9E%E5%BF%86%E2%80%9D%E8%B5%B7%E4%B8%80%E4%BA%9B%E7%BB%86%E8%8A%82%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="骗兄弟可以，别把自己也骗了" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3E%E9%AA%97%E5%85%84%E5%BC%9F%E5%8F%AF%E4%BB%A5%EF%BC%8C%E5%88%AB%E6%8A%8A%E8%87%AA%E5%B7%B1%E4%B9%9F%E9%AA%97%E4%BA%86%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="来源性遗忘 (Source Amnesia / Source Misattribution)" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%9D%A5%E6%BA%90%E6%80%A7%E9%81%97%E5%BF%98%20(Source%20Amnesia%20/%20Source%20Misattribution)%3C/span%3E" _note="" _mubu_note="">
              <outline text="核心思想" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A0%B8%E5%BF%83%E6%80%9D%E6%83%B3%3C/span%3E" _note="" _mubu_note="">
                <outline text="我们能够记住某个信息或事件，但忘记了我们是在何时、何地、如何获得这个信息的。" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E8%83%BD%E5%A4%9F%E8%AE%B0%E4%BD%8F%E6%9F%90%E4%B8%AA%E4%BF%A1%E6%81%AF%E6%88%96%E4%BA%8B%E4%BB%B6%EF%BC%8C%E4%BD%86%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%BF%98%E8%AE%B0%E4%BA%86%E6%88%91%E4%BB%AC%E6%98%AF%E5%9C%A8%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E4%BD%95%E6%97%B6%E3%80%81%E4%BD%95%E5%9C%B0%E3%80%81%E5%A6%82%E4%BD%95%3C/span%3E%3Cspan%20class=%22bold%22%3E%E8%8E%B7%E5%BE%97%E8%BF%99%E4%B8%AA%E4%BF%A1%E6%81%AF%E7%9A%84%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="我们将记忆内容本身和它的来源弄混了。" _mubu_text="%3Cspan%3E%E6%88%91%E4%BB%AC%E5%B0%86%E8%AE%B0%E5%BF%86%E5%86%85%E5%AE%B9%E6%9C%AC%E8%BA%AB%E5%92%8C%E5%AE%83%E7%9A%84%E6%9D%A5%E6%BA%90%E5%BC%84%E6%B7%B7%E4%BA%86%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="记忆内容本身很清楚，但是忘记来源。" _mubu_text="%3Cspan%3E%E8%AE%B0%E5%BF%86%E5%86%85%E5%AE%B9%E6%9C%AC%E8%BA%AB%E5%BE%88%E6%B8%85%E6%A5%9A%EF%BC%8C%E4%BD%86%E6%98%AF%E5%BF%98%E8%AE%B0%E6%9D%A5%E6%BA%90%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="表现" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%A1%A8%E7%8E%B0%3C/span%3E" _note="" _mubu_note="">
                <outline text="你跟朋友讲了一个很有趣的冷知识，朋友问你是从哪知道的，你完全想不起来了" _mubu_text="%3Cspan%3E%E4%BD%A0%E8%B7%9F%E6%9C%8B%E5%8F%8B%E8%AE%B2%E4%BA%86%E4%B8%80%E4%B8%AA%E5%BE%88%E6%9C%89%E8%B6%A3%E7%9A%84%E5%86%B7%E7%9F%A5%E8%AF%86%EF%BC%8C%E6%9C%8B%E5%8F%8B%E9%97%AE%E4%BD%A0%E6%98%AF%E4%BB%8E%E5%93%AA%E7%9F%A5%E9%81%93%E7%9A%84%EF%BC%8C%E4%BD%A0%E5%AE%8C%E5%85%A8%E6%83%B3%E4%B8%8D%E8%B5%B7%E6%9D%A5%E4%BA%86%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="——是书上看的？听别人说的？还是网上刷到的？" _mubu_text="%3Cspan%3E%E2%80%94%E2%80%94%E6%98%AF%E4%B9%A6%E4%B8%8A%E7%9C%8B%E7%9A%84%EF%BC%9F%E5%90%AC%E5%88%AB%E4%BA%BA%E8%AF%B4%E7%9A%84%EF%BC%9F%E8%BF%98%E6%98%AF%E7%BD%91%E4%B8%8A%E5%88%B7%E5%88%B0%E7%9A%84%EF%BC%9F%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="逮虾户（Déjà vu）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%80%AE%E8%99%BE%E6%88%B7%EF%BC%88D%C3%A9j%C3%A0%20vu%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
                <outline text="既视感" _mubu_text="%3Cspan%3E%E6%97%A2%E8%A7%86%E6%84%9F%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="你进入一个新环境，感觉“我来过这里”，可能因为你现在的感官体验（比如某个场景、某种气味）触发了一段你之前在电影、梦境或图片中看到过的记忆，但你忘记了那个记忆的来源，错误地将其归因于“真实的经历”。" _mubu_text="%3Cspan%3E%E4%BD%A0%E8%BF%9B%E5%85%A5%E4%B8%80%E4%B8%AA%E6%96%B0%E7%8E%AF%E5%A2%83%EF%BC%8C%E6%84%9F%E8%A7%89%E2%80%9C%E6%88%91%E6%9D%A5%E8%BF%87%E8%BF%99%E9%87%8C%E2%80%9D%EF%BC%8C%E5%8F%AF%E8%83%BD%E5%9B%A0%E4%B8%BA%E4%BD%A0%E7%8E%B0%E5%9C%A8%E7%9A%84%E6%84%9F%E5%AE%98%E4%BD%93%E9%AA%8C%EF%BC%88%E6%AF%94%E5%A6%82%E6%9F%90%E4%B8%AA%E5%9C%BA%E6%99%AF%E3%80%81%E6%9F%90%E7%A7%8D%E6%B0%94%E5%91%B3%EF%BC%89%E8%A7%A6%E5%8F%91%E4%BA%86%E4%B8%80%E6%AE%B5%E4%BD%A0%E4%B9%8B%E5%89%8D%E5%9C%A8%E7%94%B5%E5%BD%B1%E3%80%81%E6%A2%A6%E5%A2%83%E6%88%96%E5%9B%BE%E7%89%87%E4%B8%AD%E7%9C%8B%E5%88%B0%E8%BF%87%E7%9A%84%E8%AE%B0%E5%BF%86%EF%BC%8C%E4%BD%86%E4%BD%A0%E5%BF%98%E8%AE%B0%E4%BA%86%E9%82%A3%E4%B8%AA%E8%AE%B0%E5%BF%86%E7%9A%84%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%9D%A5%E6%BA%90%3C/span%3E%3Cspan%3E%EF%BC%8C%E9%94%99%E8%AF%AF%E5%9C%B0%E5%B0%86%E5%85%B6%E5%BD%92%E5%9B%A0%E4%BA%8E%E2%80%9C%E7%9C%9F%E5%AE%9E%E7%9A%84%E7%BB%8F%E5%8E%86%E2%80%9D%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
          </outline>
        </outline>
      </outline>
      <outline text="2.8 Intelligence and Achievement（1250字）" _mubu_text="%3Cspan%3E2.8%20Intelligence%20and%20Achievement%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E1250%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="理论层面 Theoretical Perspectives on Intelligence" _mubu_text="%3Cspan%3E%E7%90%86%E8%AE%BA%E5%B1%82%E9%9D%A2%20Theoretical%20Perspectives%20on%20Intelligence%3C/span%3E" _note="" _mubu_note="">
          <outline text="心理学没有统一且标准的智力定义 adaptive learning mental culture" _mubu_text="%3Cspan%3E%E5%BF%83%E7%90%86%E5%AD%A6%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E6%B2%A1%E6%9C%89%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%BB%9F%E4%B8%80%E4%B8%94%E6%A0%87%E5%87%86%3C/span%3E%3Cspan%3E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%99%BA%E5%8A%9B%E5%AE%9A%E4%B9%89%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Eadaptive%20learning%20mental%20culture%3C/span%3E" _note="" _mubu_note="">
            <outline text="The ability to learn from experience, solve problems, adapt to new situations" _mubu_text="%3Cspan%3EThe%20ability%20to%20learn%20from%20experience,%20solve%20problems,%20adapt%20to%20new%20situations%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="一般普遍认为智力是适应性（adaptive）、涉及学习能力（learning ability）、多种心智过程（mental processes）和文化相关（culture specific）" _mubu_text="%3Cspan%3E%E4%B8%80%E8%88%AC%E6%99%AE%E9%81%8D%E8%AE%A4%E4%B8%BA%E6%99%BA%E5%8A%9B%E6%98%AF%E9%80%82%E5%BA%94%E6%80%A7%EF%BC%88adaptive%EF%BC%89%E3%80%81%E6%B6%89%E5%8F%8A%E5%AD%A6%E4%B9%A0%E8%83%BD%E5%8A%9B%EF%BC%88learning%20ability%EF%BC%89%E3%80%81%E5%A4%9A%E7%A7%8D%E5%BF%83%E6%99%BA%E8%BF%87%E7%A8%8B%EF%BC%88mental%20processes%EF%BC%89%E5%92%8C%E6%96%87%E5%8C%96%E7%9B%B8%E5%85%B3%EF%BC%88culture%20specific%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="一般智力 General Intelligence, g factor 共同的、底层的一般智力因素「好学生啥都好」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%B8%80%E8%88%AC%E6%99%BA%E5%8A%9B%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EGeneral%20Intelligence%3C/span%3E%3Cspan%20class=%22bold%22%3E,%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3Eg%20factor%3C/span%3E%3Cspan%3E%20%E5%85%B1%E5%90%8C%E7%9A%84%E3%80%81%E5%BA%95%E5%B1%82%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%80%E8%88%AC%E6%99%BA%E5%8A%9B%E5%9B%A0%E7%B4%A0%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A5%BD%E5%AD%A6%E7%94%9F%E5%95%A5%E9%83%BD%E5%A5%BD%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
            <outline text="查尔斯·斯皮尔曼 Charles Spearman 提出。" _mubu_text="%3Cspan%3E%E6%9F%A5%E5%B0%94%E6%96%AF%C2%B7%E6%96%AF%E7%9A%AE%E5%B0%94%E6%9B%BC%20Charles%20Spearman%20%E6%8F%90%E5%87%BA%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="在一项认知测试（比如词汇）中表现出色的人，往往在其他认知测试（比如数学或空间推理）中也表现得不错。" _mubu_text="%3Cspan%3E%E5%9C%A8%E4%B8%80%E9%A1%B9%E8%AE%A4%E7%9F%A5%E6%B5%8B%E8%AF%95%EF%BC%88%E6%AF%94%E5%A6%82%E8%AF%8D%E6%B1%87%EF%BC%89%E4%B8%AD%E8%A1%A8%E7%8E%B0%E5%87%BA%E8%89%B2%E7%9A%84%E4%BA%BA%EF%BC%8C%E5%BE%80%E5%BE%80%E5%9C%A8%E5%85%B6%E4%BB%96%E8%AE%A4%E7%9F%A5%E6%B5%8B%E8%AF%95%EF%BC%88%E6%AF%94%E5%A6%82%E6%95%B0%E5%AD%A6%E6%88%96%E7%A9%BA%E9%97%B4%E6%8E%A8%E7%90%86%EF%BC%89%E4%B8%AD%E4%B9%9F%E8%A1%A8%E7%8E%B0%E5%BE%97%E4%B8%8D%E9%94%99%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="他推断，这背后可能存在一个共同的、底层的一般智力因素，他称之为 g factor。" _mubu_text="%3Cspan%3E%E4%BB%96%E6%8E%A8%E6%96%AD%EF%BC%8C%E8%BF%99%E8%83%8C%E5%90%8E%E5%8F%AF%E8%83%BD%E5%AD%98%E5%9C%A8%E4%B8%80%E4%B8%AA%E5%85%B1%E5%90%8C%E7%9A%84%E3%80%81%E5%BA%95%E5%B1%82%E7%9A%84%E4%B8%80%E8%88%AC%E6%99%BA%E5%8A%9B%E5%9B%A0%E7%B4%A0%EF%BC%8C%E4%BB%96%E7%A7%B0%E4%B9%8B%E4%B8%BA%20g%20factor%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="细分 g factor 可以分成 2 种能力" _mubu_text="%3Cspan%3E%E7%BB%86%E5%88%86%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3Eg%20factor%3C/span%3E%3Cspan%3E%20%E5%8F%AF%E4%BB%A5%E5%88%86%E6%88%90%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%202%20%E7%A7%8D%E8%83%BD%E5%8A%9B%3C/span%3E" _note="" _mubu_note="">
            <outline text="流体智力 Fluid Intelligence, Gf 灵活思考和推理的能力，随老年下降「你比爷爷强🧒👍」" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E6%B5%81%E4%BD%93%3C/span%3E%3Cspan%3E%E6%99%BA%E5%8A%9B%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EFluid%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3EIntelligence,%20Gf%3C/span%3E%3Cspan%3E%20%E7%81%B5%E6%B4%BB%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%80%9D%E8%80%83%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%8E%A8%E7%90%86%3C/span%3E%3Cspan%3E%E7%9A%84%E8%83%BD%E5%8A%9B%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%9A%8F%E8%80%81%E5%B9%B4%E4%B8%8B%E9%99%8D%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%BD%A0%E6%AF%94%E7%88%B7%E7%88%B7%E5%BC%BA%F0%9F%A7%92%F0%9F%91%8D%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="指的是灵活思考和推理的能力，尤其是在面对全新问题时。" _mubu_text="%3Cspan%3E%E6%8C%87%E7%9A%84%E6%98%AF%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%81%B5%E6%B4%BB%E6%80%9D%E8%80%83%E5%92%8C%E6%8E%A8%E7%90%86%E7%9A%84%E8%83%BD%E5%8A%9B%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%B0%A4%E5%85%B6%E6%98%AF%E5%9C%A8%E9%9D%A2%E5%AF%B9%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%85%A8%E6%96%B0%E9%97%AE%E9%A2%98%3C/span%3E%3Cspan%3E%E6%97%B6%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="它会随着成年老化而下降 (tend to diminish with adult aging) 。" _mubu_text="%3Cspan%3E%E5%AE%83%3C/span%3E%3Cspan%20class=%22bold%22%3E%E4%BC%9A%E9%9A%8F%E7%9D%80%E6%88%90%E5%B9%B4%E8%80%81%E5%8C%96%E8%80%8C%E4%B8%8B%E9%99%8D%20(tend%20to%20diminish%20with%20adult%20aging)%3C/span%3E%3Cspan%3E%20%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="你比爷爷强👴👍" _mubu_text="%3Cspan%3E%E4%BD%A0%E6%AF%94%E7%88%B7%E7%88%B7%E5%BC%BA%F0%9F%91%B4%F0%9F%91%8D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="晶体智力 Crystallized Intelligence, Gc 后天积累的知识、技能和经验「爷爷比你强👴👍」" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E6%99%B6%E4%BD%93%3C/span%3E%3Cspan%3E%E6%99%BA%E5%8A%9B%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3ECrystallized%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3EIntelligence,%20Gc%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%90%8E%E5%A4%A9%3C/span%3E%3Cspan%3E%E7%A7%AF%E7%B4%AF%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%9F%A5%E8%AF%86%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%8A%80%E8%83%BD%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%BB%8F%E9%AA%8C%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%88%B7%E7%88%B7%E6%AF%94%E4%BD%A0%E5%BC%BA%F0%9F%91%B4%F0%9F%91%8D%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="后天积累的知识、技能和经验。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%90%8E%E5%A4%A9%E7%A7%AF%E7%B4%AF%E7%9A%84%E7%9F%A5%E8%AF%86%E3%80%81%E6%8A%80%E8%83%BD%E5%92%8C%E7%BB%8F%E9%AA%8C%3C/span%3E%3Cspan%3E%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="不断增长，包括你的词汇量、历史知识、专业技能等。" _mubu_text="%3Cspan%3E%E4%B8%8D%E6%96%AD%E5%A2%9E%E9%95%BF%EF%BC%8C%E5%8C%85%E6%8B%AC%E4%BD%A0%E7%9A%84%E8%AF%8D%E6%B1%87%E9%87%8F%E3%80%81%E5%8E%86%E5%8F%B2%E7%9F%A5%E8%AF%86%E3%80%81%E4%B8%93%E4%B8%9A%E6%8A%80%E8%83%BD%E7%AD%89%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="会随着年龄增长而提升 (tend to increase with age) " _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BC%9A%E9%9A%8F%E7%9D%80%E5%B9%B4%E9%BE%84%E5%A2%9E%E9%95%BF%E8%80%8C%E6%8F%90%E5%8D%87%20(tend%20to%20increase%20with%20age)%3C/span%3E%3Cspan%3E%20%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="图例" _mubu_text="%3Cspan%3E%E5%9B%BE%E4%BE%8B%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22u76TRbxVkc%22%2C%22oh%22%3A781%2C%22ow%22%3A1432%2C%22uri%22%3A%22document_image%2F33585682_c2a800be-be1c-4905-8a8b-0511bc9820c4.png%22%2C%22w%22%3A400%7D%5D"/>
          </outline>
        </outline>
        <outline text="心理测量学 Psychometrics 用科学、标准化的方法测量人的心理特质「智力、性格、兴趣」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BF%83%E7%90%86%E6%B5%8B%E9%87%8F%E5%AD%A6%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EPsychometrics%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E7%94%A8%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%A7%91%E5%AD%A6%E3%80%81%E6%A0%87%E5%87%86%E5%8C%96%3C/span%3E%3Cspan%3E%E7%9A%84%E6%96%B9%E6%B3%95%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%B5%8B%E9%87%8F%3C/span%3E%3Cspan%3E%E4%BA%BA%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%BF%83%E7%90%86%E7%89%B9%E8%B4%A8%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%99%BA%E5%8A%9B%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%80%A7%E6%A0%BC%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%85%B4%E8%B6%A3%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
          <outline text="这门学问的核心就是“心理测量 (Measurement Psychology) ”" _mubu_text="%3Cspan%3E%E8%BF%99%E9%97%A8%E5%AD%A6%E9%97%AE%E7%9A%84%E6%A0%B8%E5%BF%83%E5%B0%B1%E6%98%AF%E2%80%9C%E5%BF%83%E7%90%86%E6%B5%8B%E9%87%8F%20(Measurement%20Psychology)%20%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="致力于用科学、标准化的方法来测量人的各种心理特质，比如智力、性格、兴趣等" _mubu_text="%3Cspan%3E%E8%87%B4%E5%8A%9B%E4%BA%8E%E7%94%A8%E7%A7%91%E5%AD%A6%E3%80%81%E6%A0%87%E5%87%86%E5%8C%96%E7%9A%84%E6%96%B9%E6%B3%95%E6%9D%A5%E6%B5%8B%E9%87%8F%E4%BA%BA%E7%9A%84%E5%90%84%E7%A7%8D%E5%BF%83%E7%90%86%E7%89%B9%E8%B4%A8%EF%BC%8C%E6%AF%94%E5%A6%82%E6%99%BA%E5%8A%9B%E3%80%81%E6%80%A7%E6%A0%BC%E3%80%81%E5%85%B4%E8%B6%A3%E7%AD%89%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="发现人与人之间的 个体差异 (individual differences)" _mubu_text="%3Cspan%3E%E5%8F%91%E7%8E%B0%E4%BA%BA%E4%B8%8E%E4%BA%BA%E4%B9%8B%E9%97%B4%E7%9A%84%20%E4%B8%AA%E4%BD%93%E5%B7%AE%E5%BC%82%20(individual%20differences)%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="智力测试 Intelligence Test 评估个体心智能力，并将其与他人进行数值比较的方法「测智商」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%99%BA%E5%8A%9B%E6%B5%8B%E8%AF%95%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EIntelligence%20Test%3C/span%3E%3Cspan%3E%20%E8%AF%84%E4%BC%B0%E4%B8%AA%E4%BD%93%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%83%E6%99%BA%E8%83%BD%E5%8A%9B%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%B9%B6%E5%B0%86%E5%85%B6%E4%B8%8E%E4%BB%96%E4%BA%BA%E8%BF%9B%E8%A1%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%95%B0%E5%80%BC%E6%AF%94%E8%BE%83%3C/span%3E%3Cspan%3E%E7%9A%84%E6%96%B9%E6%B3%95%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%B5%8B%E6%99%BA%E5%95%86%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="智商 Intelligence Quotient, IQ" _mubu_text="%3Cspan%3E%E6%99%BA%E5%95%86%20Intelligence%20Quotient,%20IQ%3C/span%3E" _note="" _mubu_note="">
          <outline text="100分为平均值的正态分布" _mubu_text="%3Cspan%3E100%E5%88%86%E4%B8%BA%E5%B9%B3%E5%9D%87%E5%80%BC%E7%9A%84%E6%AD%A3%E6%80%81%E5%88%86%E5%B8%83%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22NGVnNTx7Yg%22%2C%22oh%22%3A772%2C%22ow%22%3A1289%2C%22uri%22%3A%22document_image%2F33585682_65f4f73b-7f03-4a69-a9c0-94c37e6778ec.png%22%2C%22w%22%3A400%7D%5D"/>
          <outline text="最初计算公式（很少使用）：IQ = (心理年龄 Mental Age / 生理年龄 Chronological Age) × 100" _mubu_text="%3Cspan%3E%E6%9C%80%E5%88%9D%E8%AE%A1%E7%AE%97%E5%85%AC%E5%BC%8F%EF%BC%88%E5%BE%88%E5%B0%91%E4%BD%BF%E7%94%A8%EF%BC%89%EF%BC%9AIQ%20=%20(%E5%BF%83%E7%90%86%E5%B9%B4%E9%BE%84%20Mental%20Age%20/%20%E7%94%9F%E7%90%86%E5%B9%B4%E9%BE%84%20Chronological%20Age)%20%C3%97%20100%3C/span%3E" _note="" _mubu_note="">
            <outline text="心理年龄指的是一个人在智力测试上的表现所对应的平均年龄水平。" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BF%83%E7%90%86%E5%B9%B4%E9%BE%84%3C/span%3E%3Cspan%3E%E6%8C%87%E7%9A%84%E6%98%AF%E4%B8%80%E4%B8%AA%E4%BA%BA%E5%9C%A8%E6%99%BA%E5%8A%9B%E6%B5%8B%E8%AF%95%E4%B8%8A%E7%9A%84%E8%A1%A8%E7%8E%B0%E6%89%80%E5%AF%B9%E5%BA%94%E7%9A%84%E5%B9%B3%E5%9D%87%E5%B9%B4%E9%BE%84%E6%B0%B4%E5%B9%B3%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="一个8岁的孩子（生理年龄），在测试中的表现和平均10岁的孩子一样好（心理年龄），那么他的IQ就是 (10 / 8) × 100 = 125。" _mubu_text="%3Cspan%3E%E4%B8%80%E4%B8%AA8%E5%B2%81%E7%9A%84%E5%AD%A9%E5%AD%90%EF%BC%88%E7%94%9F%E7%90%86%E5%B9%B4%E9%BE%84%EF%BC%89%EF%BC%8C%E5%9C%A8%E6%B5%8B%E8%AF%95%E4%B8%AD%E7%9A%84%E8%A1%A8%E7%8E%B0%E5%92%8C%E5%B9%B3%E5%9D%8710%E5%B2%81%E7%9A%84%E5%AD%A9%E5%AD%90%E4%B8%80%E6%A0%B7%E5%A5%BD%EF%BC%88%E5%BF%83%E7%90%86%E5%B9%B4%E9%BE%84%EF%BC%89%EF%BC%8C%E9%82%A3%E4%B9%88%E4%BB%96%E7%9A%84IQ%E5%B0%B1%E6%98%AF%20(10%20/%208)%20%C3%97%20100%20=%20125%E3%80%82%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22OcQbMGXKyg%22%2C%22oh%22%3A152%2C%22ow%22%3A948%2C%22uri%22%3A%22document_image%2F33585682_1808d293-54c2-433c-dd4c-5bb456c9f6f2.png%22%2C%22w%22%3A400%7D%5D"/>
          </outline>
          <outline text="现代计算方法：standardized score，分数为和你同年龄组的人进行比较" _mubu_text="%3Cspan%3E%E7%8E%B0%E4%BB%A3%E8%AE%A1%E7%AE%97%E6%96%B9%E6%B3%95%EF%BC%9Astandardized%20score%EF%BC%8C%E5%88%86%E6%95%B0%E4%B8%BA%E5%92%8C%E4%BD%A0%E5%90%8C%E5%B9%B4%E9%BE%84%E7%BB%84%E7%9A%84%E4%BA%BA%E8%BF%9B%E8%A1%8C%E6%AF%94%E8%BE%83%3C/span%3E" _note="" _mubu_note="">
            <outline text="现代的IQ测试，比如韦氏智力量表 (Wechsler Intelligence Scales) ，采用的是标准分数。你的分数是和你同年龄组的人进行比较得出的。" _mubu_text="%3Cspan%3E%E7%8E%B0%E4%BB%A3%E7%9A%84IQ%E6%B5%8B%E8%AF%95%EF%BC%8C%E6%AF%94%E5%A6%82%3C/span%3E%3Cspan%20class=%22bold%22%3E%E9%9F%A6%E6%B0%8F%E6%99%BA%E5%8A%9B%E9%87%8F%E8%A1%A8%20(Wechsler%20Intelligence%20Scales)%3C/span%3E%3Cspan%3E%20%EF%BC%8C%E9%87%87%E7%94%A8%E7%9A%84%E6%98%AF%E6%A0%87%E5%87%86%E5%88%86%E6%95%B0%E3%80%82%E4%BD%A0%E7%9A%84%E5%88%86%E6%95%B0%E6%98%AF%E5%92%8C%E4%BD%A0%E5%90%8C%E5%B9%B4%E9%BE%84%E7%BB%84%E7%9A%84%E4%BA%BA%E8%BF%9B%E8%A1%8C%E6%AF%94%E8%BE%83%E5%BE%97%E5%87%BA%E7%9A%84%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="弗林效应 Flynn Effect 全球范围内的IQ平均分一代比一代高「营养、医疗、科技、教育」" _mubu_text="%3Cspan%20class=%22bold%20underline%22%3E%E5%BC%97%E6%9E%97%E6%95%88%E5%BA%94%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-red%22%3EFlynn%20Effect%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%85%A8%E7%90%83%E8%8C%83%E5%9B%B4%3C/span%3E%3Cspan%3E%E5%86%85%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EIQ%E5%B9%B3%E5%9D%87%E5%88%86%E4%B8%80%E4%BB%A3%E6%AF%94%E4%B8%80%E4%BB%A3%E9%AB%98%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E8%90%A5%E5%85%BB%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%8C%BB%E7%96%97%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%A7%91%E6%8A%80%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%95%99%E8%82%B2%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22xvQWYNRrii%22%2C%22oh%22%3A417%2C%22ow%22%3A828%2C%22uri%22%3A%22document_image%2F33585682_46e4a244-dc07-466f-fb42-99036fd3bdc8.png%22%2C%22w%22%3A400%7D%5D">
            <outline text="原因" _mubu_text="%3Cspan%3E%E5%8E%9F%E5%9B%A0%3C/span%3E" _note="" _mubu_note="">
              <outline text="更好的营养（尤其在早期大脑发育阶段）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%9B%B4%E5%A5%BD%E7%9A%84%E8%90%A5%E5%85%BB%3C/span%3E%3Cspan%3E%EF%BC%88%E5%B0%A4%E5%85%B6%E5%9C%A8%E6%97%A9%E6%9C%9F%E5%A4%A7%E8%84%91%E5%8F%91%E8%82%B2%E9%98%B6%E6%AE%B5%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="更好的医疗、科技进步、更好的教育机会等等" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%9B%B4%E5%A5%BD%E7%9A%84%E5%8C%BB%E7%96%97%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%A7%91%E6%8A%80%E8%BF%9B%E6%AD%A5%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E6%9B%B4%E5%A5%BD%E7%9A%84%E6%95%99%E8%82%B2%E6%9C%BA%E4%BC%9A%3C/span%3E%3Cspan%3E%E7%AD%89%E7%AD%89%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="标准化" _mubu_text="%3Cspan%3E%E6%A0%87%E5%87%86%E5%8C%96%3C/span%3E" _note="" _mubu_note="">
              <outline text="为了保证IQ测试的平均分始终是100，测试机构必须定期重新标准化 (reworked/renormed) 试题，让标准变得更严格。" _mubu_text="%3Cspan%3E%E4%B8%BA%E4%BA%86%E4%BF%9D%E8%AF%81IQ%E6%B5%8B%E8%AF%95%E7%9A%84%E5%B9%B3%E5%9D%87%E5%88%86%E5%A7%8B%E7%BB%88%E6%98%AF100%EF%BC%8C%E6%B5%8B%E8%AF%95%E6%9C%BA%E6%9E%84%E5%BF%85%E9%A1%BB%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%AE%9A%E6%9C%9F%E9%87%8D%E6%96%B0%E6%A0%87%E5%87%86%E5%8C%96%20(reworked/renormed)%3C/span%3E%3Cspan%3E%20%E8%AF%95%E9%A2%98%EF%BC%8C%E8%AE%A9%E6%A0%87%E5%87%86%E5%8F%98%E5%BE%97%E6%9B%B4%E4%B8%A5%E6%A0%BC%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="心理和社会因素影响智力表现" _mubu_text="%3Cspan%3E%E5%BF%83%E7%90%86%E5%92%8C%E7%A4%BE%E4%BC%9A%E5%9B%A0%E7%B4%A0%E5%BD%B1%E5%93%8D%E6%99%BA%E5%8A%9B%E8%A1%A8%E7%8E%B0%3C/span%3E" _note="" _mubu_note="">
          <outline text="固定型思维 Fixed Mindset 智力是天生的、固定的，害怕挑战，因为失败 = 自己不聪明" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E5%9B%BA%E5%AE%9A%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%9E%8B%E6%80%9D%E7%BB%B4%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EFixed%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EMindset%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E6%99%BA%E5%8A%9B%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%A4%A9%E7%94%9F%E7%9A%84%3C/span%3E%3Cspan%3E%E3%80%81%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%9B%BA%E5%AE%9A%E7%9A%84%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%AE%B3%E6%80%95%E6%8C%91%E6%88%98%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%9B%A0%E4%B8%BA%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E5%A4%B1%E8%B4%A5%20=%20%E8%87%AA%E5%B7%B1%E4%B8%8D%E8%81%AA%E6%98%8E%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="成长型思维 Growth Mindset 可以通过努力和学习来提升，失败 = 学习和的成长机会" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E6%88%90%E9%95%BF%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%9E%8B%E6%80%9D%E7%BB%B4%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EGrowth%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EMindset%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E5%8F%AF%E4%BB%A5%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%80%9A%E8%BF%87%E5%8A%AA%E5%8A%9B%E5%92%8C%E5%AD%A6%E4%B9%A0%3C/span%3E%3Cspan%3E%E6%9D%A5%E6%8F%90%E5%8D%87%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E5%A4%B1%E8%B4%A5%20=%20%3C/span%3E%3Cspan%3E%E5%AD%A6%E4%B9%A0%E5%92%8C%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E6%88%90%E9%95%BF%E6%9C%BA%E4%BC%9A%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="刻板印象威胁 Stereotype Threat 刻板印象导致压力，损害表现「女生数学不好」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%88%BB%E6%9D%BF%E5%8D%B0%E8%B1%A1%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E5%A8%81%E8%83%81%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EStereotype%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EThreat%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%88%BB%E6%9D%BF%E5%8D%B0%E8%B1%A1%3C/span%3E%3Cspan%3E%E5%AF%BC%E8%87%B4%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%8E%8B%E5%8A%9B%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22underline%22%3E%E6%8D%9F%E5%AE%B3%E8%A1%A8%E7%8E%B0%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%A5%B3%E7%94%9F%E6%95%B0%E5%AD%A6%E4%B8%8D%E5%A5%BD%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="刻板印象提升 Stereotype Lift 相反的情况，刻板印象导致自信「亚洲人数学好好啊！🤩」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%88%BB%E6%9D%BF%E5%8D%B0%E8%B1%A1%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E6%8F%90%E5%8D%87%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EStereotype%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3ELift%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%9B%B8%E5%8F%8D%3C/span%3E%3Cspan%3E%E7%9A%84%E6%83%85%E5%86%B5%EF%BC%8C%E5%88%BB%E6%9D%BF%E5%8D%B0%E8%B1%A1%E5%AF%BC%E8%87%B4%E8%87%AA%E4%BF%A1%E3%80%8C%E4%BA%9A%E6%B4%B2%E4%BA%BA%E6%95%B0%E5%AD%A6%E5%A5%BD%E5%A5%BD%E5%95%8A%EF%BC%81%F0%9F%A4%A9%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="测试的类型 / 衡量标准" _mubu_text="%3Cspan%3E%E6%B5%8B%E8%AF%95%E7%9A%84%E7%B1%BB%E5%9E%8B%20/%20%E8%A1%A1%E9%87%8F%E6%A0%87%E5%87%86%3C/span%3E" _note="" _mubu_note="">
          <outline text="成就测试 Achievement Test 测量已经学会了什么「单元测、AP考试、期末考试」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%88%90%E5%B0%B1%E6%B5%8B%E8%AF%95%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EAchievement%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3ETest%3C/span%3E%3Cspan%3E%20%E6%B5%8B%E9%87%8F%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%B7%B2%E7%BB%8F%E5%AD%A6%E4%BC%9A%E4%BA%86%E4%BB%80%E4%B9%88%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E5%8D%95%E5%85%83%E6%B5%8B%E3%80%81AP%E8%80%83%E8%AF%95%E3%80%81%E6%9C%9F%E6%9C%AB%E8%80%83%E8%AF%95%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="能力倾向测试 Aptitude Test 预测未来学习新事物的潜力，而不是已有知识「SAT」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E8%83%BD%E5%8A%9B%E5%80%BE%E5%90%91%E6%B5%8B%E8%AF%95%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EAptitude%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3ETest%3C/span%3E%3Cspan%3E%20%E9%A2%84%E6%B5%8B%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9C%AA%E6%9D%A5%E5%AD%A6%E4%B9%A0%E6%96%B0%E4%BA%8B%E7%89%A9%3C/span%3E%3Cspan%3E%E7%9A%84%E6%BD%9C%E5%8A%9B%EF%BC%8C%E8%80%8C%3C/span%3E%3Cspan%20class=%22underline%22%3E%E4%B8%8D%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%E5%B7%B2%E6%9C%89%E7%9F%A5%E8%AF%86%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3ESAT%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="测试的三个标准" _mubu_text="%3Cspan%3E%E6%B5%8B%E8%AF%95%E7%9A%84%E4%B8%89%E4%B8%AA%E6%A0%87%E5%87%86%3C/span%3E" _note="" _mubu_note="">
            <outline text="标准化 Standardization 评分程序一致，考生条件相同，分数有可比性「Rubric改卷子」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%A0%87%E5%87%86%E5%8C%96%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EStandardization%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E8%AF%84%E5%88%86%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%A8%8B%E5%BA%8F%E4%B8%80%E8%87%B4%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%80%83%E7%94%9F%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9D%A1%E4%BB%B6%E7%9B%B8%E5%90%8C%3C/span%3E%3Cspan%3E%EF%BC%8C%E5%88%86%E6%95%B0%E6%9C%89%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%8F%AF%E6%AF%94%E6%80%A7%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3ERubric%E6%94%B9%E5%8D%B7%E5%AD%90%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="信度 Reliability 稳定性和一致性，测量工具本身，能力没变化重测分数应该相同" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BF%A1%E5%BA%A6%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EReliability%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E7%A8%B3%E5%AE%9A%E6%80%A7%3C/span%3E%3Cspan%3E%E5%92%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E4%B8%80%E8%87%B4%E6%80%A7%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%B5%8B%E9%87%8F%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%B7%A5%E5%85%B7%E6%9C%AC%E8%BA%AB%3C/span%3E%3Cspan%3E%EF%BC%8C%E8%83%BD%E5%8A%9B%E6%B2%A1%E5%8F%98%E5%8C%96%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E9%87%8D%E6%B5%8B%E5%88%86%E6%95%B0%E5%BA%94%E8%AF%A5%E7%9B%B8%E5%90%8C%3C/span%3E" _note="" _mubu_note="">
              <outline text="Test-Retest Reliability 同一组人不同时间测试两次，看同一人分数是否接近" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ETest-Retest%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EReliability%3C/span%3E%3Cspan%3E%20%E5%90%8C%E4%B8%80%E7%BB%84%E4%BA%BA%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E4%B8%8D%E5%90%8C%E6%97%B6%E9%97%B4%E6%B5%8B%E8%AF%95%E4%B8%A4%E6%AC%A1%3C/span%3E%3Cspan%3E%EF%BC%8C%E7%9C%8B%E5%90%8C%E4%B8%80%E4%BA%BA%E5%88%86%E6%95%B0%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%98%AF%E5%90%A6%E6%8E%A5%E8%BF%91%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Split-Half Reliability 比较奇数题和偶数题的相关性，高则表示在测量同样东西" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3ESplit-Half%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EReliability%3C/span%3E%3Cspan%3E%20%E6%AF%94%E8%BE%83%E5%A5%87%E6%95%B0%E9%A2%98%E5%92%8C%E5%81%B6%E6%95%B0%E9%A2%98%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E7%9B%B8%E5%85%B3%E6%80%A7%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%AB%98%3C/span%3E%3Cspan%3E%E5%88%99%E8%A1%A8%E7%A4%BA%E5%9C%A8%E6%B5%8B%E9%87%8F%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%90%8C%E6%A0%B7%E4%B8%9C%E8%A5%BF%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="效度 Validity 测试是否测到了想测量的东西，「不能站在体重秤上测量身高」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%95%88%E5%BA%A6%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3EValidity%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%20%3C/span%3E%3Cspan%3E%E6%B5%8B%E8%AF%95%E6%98%AF%E5%90%A6%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%B5%8B%E5%88%B0%E4%BA%86%E6%83%B3%E6%B5%8B%E9%87%8F%3C/span%3E%3Cspan%3E%E7%9A%84%E4%B8%9C%E8%A5%BF%EF%BC%8C%E3%80%8C%E4%B8%8D%E8%83%BD%E7%AB%99%E5%9C%A8%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%BD%93%E9%87%8D%E7%A7%A4%E4%B8%8A%E6%B5%8B%E9%87%8F%E8%BA%AB%E9%AB%98%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note="">
              <outline text="建构效度 Construct Validity 是否准确测量背后的心理学概念「焦虑、智力」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E5%BB%BA%E6%9E%84%E6%95%88%E5%BA%A6%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EConstruct%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EValidity%3C/span%3E%3Cspan%3E%20%E6%98%AF%E5%90%A6%E5%87%86%E7%A1%AE%E6%B5%8B%E9%87%8F%E8%83%8C%E5%90%8E%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%BF%83%E7%90%86%E5%AD%A6%E6%A6%82%E5%BF%B5%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E7%84%A6%E8%99%91%E3%80%81%E6%99%BA%E5%8A%9B%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="预测效度 Predictive Validity 分数能否有效预测未来的行为「SAT分数和GPA相关性」" _mubu_text="%3Cspan%20class=%22bold%22%3E%E9%A2%84%E6%B5%8B%E6%95%88%E5%BA%A6%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-yellow%22%3EPredictive%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3EValidity%3C/span%3E%3Cspan%3E%20%E5%88%86%E6%95%B0%E8%83%BD%E5%90%A6%E6%9C%89%E6%95%88%E9%A2%84%E6%B5%8B%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%9C%AA%E6%9D%A5%E7%9A%84%E8%A1%8C%E4%B8%BA%3C/span%3E%3Cspan%3E%E3%80%8C%3C/span%3E%3Cspan%20class=%22text-color-green%22%3ESAT%E5%88%86%E6%95%B0%E5%92%8CGPA%E7%9B%B8%E5%85%B3%E6%80%A7%3C/span%3E%3Cspan%3E%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="测试的伦理和偏见" _mubu_text="%3Cspan%3E%E6%B5%8B%E8%AF%95%E7%9A%84%E4%BC%A6%E7%90%86%E5%92%8C%E5%81%8F%E8%A7%81%3C/span%3E" _note="" _mubu_note="">
          <outline text="伦理 APA 制定了严格的标准，确保测试公平使用" _mubu_text="%3Cspan%20class=%22bold%22%3E%E4%BC%A6%E7%90%86%3C/span%3E%3Cspan%3E%20APA%20%E5%88%B6%E5%AE%9A%E4%BA%86%E4%B8%A5%E6%A0%BC%E7%9A%84%E6%A0%87%E5%87%86%EF%BC%8C%E7%A1%AE%E4%BF%9D%E6%B5%8B%E8%AF%95%E5%85%AC%E5%B9%B3%E4%BD%BF%E7%94%A8%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="社会文化偏见（对其他文化背景不公平）" _mubu_text="%3Cspan%3E%E7%A4%BE%E4%BC%9A%E6%96%87%E5%8C%96%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%81%8F%E8%A7%81%3C/span%3E%3Cspan%3E%EF%BC%88%E5%AF%B9%E5%85%B6%E4%BB%96%E6%96%87%E5%8C%96%E8%83%8C%E6%99%AF%E4%B8%8D%E5%85%AC%E5%B9%B3%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="系统性问题（因为贫困、歧视、教育资源不均等问题对个体智力分数产生的负面影响）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E7%B3%BB%E7%BB%9F%E6%80%A7%3C/span%3E%3Cspan%3E%E9%97%AE%E9%A2%98%EF%BC%88%E5%9B%A0%E4%B8%BA%E8%B4%AB%E5%9B%B0%E3%80%81%E6%AD%A7%E8%A7%86%E3%80%81%E6%95%99%E8%82%B2%E8%B5%84%E6%BA%90%E4%B8%8D%E5%9D%87%E7%AD%89%E9%97%AE%E9%A2%98%E5%AF%B9%E4%B8%AA%E4%BD%93%E6%99%BA%E5%8A%9B%E5%88%86%E6%95%B0%E4%BA%A7%E7%94%9F%E7%9A%84%E8%B4%9F%E9%9D%A2%E5%BD%B1%E5%93%8D%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="滥用（IQ曾经被作为歧视和限制某些群体的工具，需要警醒）" _mubu_text="%3Cspan%20class=%22bold%22%3E%E6%BB%A5%E7%94%A8%3C/span%3E%3Cspan%3E%EF%BC%88IQ%E6%9B%BE%E7%BB%8F%E8%A2%AB%E4%BD%9C%E4%B8%BA%E6%AD%A7%E8%A7%86%E5%92%8C%E9%99%90%E5%88%B6%E6%9F%90%E4%BA%9B%E7%BE%A4%E4%BD%93%E7%9A%84%E5%B7%A5%E5%85%B7%EF%BC%8C%E9%9C%80%E8%A6%81%E8%AD%A6%E9%86%92%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
    </outline>
    <outline text="Unit 3" _mubu_text="%3Cspan%3EUnit%203%3C/span%3E" _note="" _mubu_note="">
      <outline text="3.1 Themes and Methods" _mubu_text="%3Cspan%3E3.1%20Themes%20and%20Methods%3C/span%3E" _note="" _mubu_note="">
        <outline text="Nature &amp; Nurture 先天和后天" _mubu_text="%3Cspan%3ENature%20&amp;amp;%20Nurture%20%E5%85%88%E5%A4%A9%E5%92%8C%E5%90%8E%E5%A4%A9%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="Continuity &amp; Stages 连续的还是有stages" _mubu_text="%3Cspan%3EContinuity%20&amp;amp;%20Stages%20%E8%BF%9E%E7%BB%AD%E7%9A%84%E8%BF%98%E6%98%AF%E6%9C%89stages%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="Stability &amp; Changes 我们小时候的traits会伴随一生吗？还是会变得不同" _mubu_text="%3Cspan%3EStability%20&amp;amp;%20Changes%20%E6%88%91%E4%BB%AC%E5%B0%8F%E6%97%B6%E5%80%99%E7%9A%84traits%E4%BC%9A%E4%BC%B4%E9%9A%8F%E4%B8%80%E7%94%9F%E5%90%97%EF%BC%9F%E8%BF%98%E6%98%AF%E4%BC%9A%E5%8F%98%E5%BE%97%E4%B8%8D%E5%90%8C%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="Cross-Sectional: 某一刻，不同人群，一个数据点，sample size较大，快、便宜；Cohort Bias - 每一群人之间的相同（老年人都不太会用手机）" _mubu_text="%3Cspan%3ECross-Sectional:%20%E6%9F%90%E4%B8%80%E5%88%BB%EF%BC%8C%E4%B8%8D%E5%90%8C%E4%BA%BA%E7%BE%A4%EF%BC%8C%E4%B8%80%E4%B8%AA%E6%95%B0%E6%8D%AE%E7%82%B9%EF%BC%8Csample%20size%E8%BE%83%E5%A4%A7%EF%BC%8C%E5%BF%AB%E3%80%81%E4%BE%BF%E5%AE%9C%EF%BC%9BCohort%20Bias%20-%20%E6%AF%8F%E4%B8%80%E7%BE%A4%E4%BA%BA%E4%B9%8B%E9%97%B4%E7%9A%84%E7%9B%B8%E5%90%8C%EF%BC%88%E8%80%81%E5%B9%B4%E4%BA%BA%E9%83%BD%E4%B8%8D%E5%A4%AA%E4%BC%9A%E7%94%A8%E6%89%8B%E6%9C%BA%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="Longitudinal: 长期跟随，一/几种人群，很多数据点，sample size通常较小，深入；贵，花时间，会有成员退出问题。" _mubu_text="%3Cspan%3ELongitudinal:%20%E9%95%BF%E6%9C%9F%E8%B7%9F%E9%9A%8F%EF%BC%8C%E4%B8%80/%E5%87%A0%E7%A7%8D%E4%BA%BA%E7%BE%A4%EF%BC%8C%E5%BE%88%E5%A4%9A%E6%95%B0%E6%8D%AE%E7%82%B9%EF%BC%8Csample%20size%E9%80%9A%E5%B8%B8%E8%BE%83%E5%B0%8F%EF%BC%8C%E6%B7%B1%E5%85%A5%EF%BC%9B%E8%B4%B5%EF%BC%8C%E8%8A%B1%E6%97%B6%E9%97%B4%EF%BC%8C%E4%BC%9A%E6%9C%89%E6%88%90%E5%91%98%E9%80%80%E5%87%BA%E9%97%AE%E9%A2%98%E3%80%82%3C/span%3E" _note="" _mubu_note=""/>
      </outline>
      <outline text="3.2 物理发展" _mubu_text="%3Cspan%3E3.2%20%E7%89%A9%E7%90%86%E5%8F%91%E5%B1%95%3C/span%3E" _note="" _mubu_note="">
        <outline text="1. 产前 Prenatal" _mubu_text="%3Cspan%3E1.%20%E4%BA%A7%E5%89%8D%20Prenatal%3C/span%3E" _note="" _mubu_note="">
          <outline text="从受精到出生，主要基因控制" _mubu_text="%3Cspan%3E%E4%BB%8E%E5%8F%97%E7%B2%BE%E5%88%B0%E5%87%BA%E7%94%9F%EF%BC%8C%E4%B8%BB%E8%A6%81%E5%9F%BA%E5%9B%A0%E6%8E%A7%E5%88%B6%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="环境影响也重要 - Teratogens 致畸物；" _mubu_text="%3Cspan%3E%E7%8E%AF%E5%A2%83%E5%BD%B1%E5%93%8D%E4%B9%9F%E9%87%8D%E8%A6%81%20-%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3ETeratogens%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E8%87%B4%E7%95%B8%E7%89%A9%3C/span%3E%3Cspan%3E%EF%BC%9B%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Critical Period 关键期" _mubu_text="%3Cspan%3ECritical%20Period%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%85%B3%E9%94%AE%E6%9C%9F%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="喝酒、毒品、药物" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E5%96%9D%E9%85%92%E3%80%81%E6%AF%92%E5%93%81%E3%80%81%E8%8D%AF%E7%89%A9%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="2. Neonate 新生儿" _mubu_text="%3Cspan%3E2.%20Neonate%20%E6%96%B0%E7%94%9F%E5%84%BF%3C/span%3E" _note="" _mubu_note="">
          <outline text="出生 - 4周" _mubu_text="%3Cspan%3E%E5%87%BA%E7%94%9F%20-%204%E5%91%A8%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="天生偏好人脸" _mubu_text="%3Cspan%3E%E5%A4%A9%E7%94%9F%E5%81%8F%E5%A5%BD%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E4%BA%BA%E8%84%B8%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Visual Cliff - 6-14月就有深度视觉" _mubu_text="%3Cspan%3EVisual%20Cliff%20-%206-14%E6%9C%88%E5%B0%B1%E6%9C%89%E6%B7%B1%E5%BA%A6%E8%A7%86%E8%A7%89%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Reflexes 反射 - Rooting Reflex" _mubu_text="%3Cspan%3EReflexes%20%E5%8F%8D%E5%B0%84%20-%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3ERooting%3C/span%3E%3Cspan%3E%20Reflex%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%224Jv7TLpUU9%22%2C%22oh%22%3A356%2C%22ow%22%3A641%2C%22uri%22%3A%22document_image%2F956662fd-fbf1-45cf-840c-a439c87adda7-33585682.jpg%22%2C%22w%22%3A400%7D%5D"/>
          <outline text="Maturation 成熟 - 先会走再会跑，粗大运动到精细" _mubu_text="%3Cspan%3EMaturation%20%E6%88%90%E7%86%9F%20-%20%E5%85%88%E4%BC%9A%E8%B5%B0%E5%86%8D%E4%BC%9A%E8%B7%91%EF%BC%8C%E7%B2%97%E5%A4%A7%E8%BF%90%E5%8A%A8%E5%88%B0%E7%B2%BE%E7%BB%86%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Imprinting 印刻 - 某些动物 不是人类 对于第一个看到的物体强烈依恋" _mubu_text="%3Cspan%3EImprinting%20%E5%8D%B0%E5%88%BB%20-%20%E6%9F%90%E4%BA%9B%E5%8A%A8%E7%89%A9%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E4%B8%8D%E6%98%AF%E4%BA%BA%E7%B1%BB%3C/span%3E%3Cspan%3E%20%E5%AF%B9%E4%BA%8E%E7%AC%AC%E4%B8%80%E4%B8%AA%E7%9C%8B%E5%88%B0%E7%9A%84%E7%89%A9%E4%BD%93%E5%BC%BA%E7%83%88%E4%BE%9D%E6%81%8B%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%223zPdLMo30v%22%2C%22oh%22%3A336%2C%22ow%22%3A500%2C%22uri%22%3A%22document_image%2F33585682_1da01c23-49d1-43f3-c25f-f151f5675c4b.jpeg%22%2C%22w%22%3A400%7D%5D">
            <outline text="人类有Attachment，但是没有imprinting" _mubu_text="%3Cspan%3E%E4%BA%BA%E7%B1%BB%E6%9C%89Attachment%EF%BC%8C%E4%BD%86%E6%98%AF%E6%B2%A1%E6%9C%89imprinting%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="3. Adolescence 青春期" _mubu_text="%3Cspan%3E3.%20Adolescence%20%E9%9D%92%E6%98%A5%E6%9C%9F%3C/span%3E" _note="" _mubu_note="">
          <outline text="从童年到成年，以青春期（Puberty）的生理变化开始" _mubu_text="%3Cspan%3E%E4%BB%8E%E7%AB%A5%E5%B9%B4%E5%88%B0%E6%88%90%E5%B9%B4%EF%BC%8C%E4%BB%A5%E9%9D%92%E6%98%A5%E6%9C%9F%EF%BC%88Puberty%EF%BC%89%E7%9A%84%E7%94%9F%E7%90%86%E5%8F%98%E5%8C%96%E5%BC%80%E5%A7%8B%3C/span%3E" _note="" _mubu_note="">
            <outline text="性成熟，荷尔蒙激增，生长突增" _mubu_text="%3Cspan%3E%E6%80%A7%E6%88%90%E7%86%9F%EF%BC%8C%E8%8D%B7%E5%B0%94%E8%92%99%E6%BF%80%E5%A2%9E%EF%BC%8C%E7%94%9F%E9%95%BF%E7%AA%81%E5%A2%9E%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="第一性征发育（跟生殖有关），第二性征出现（喉结胡须乳房）" _mubu_text="%3Cspan%3E%E7%AC%AC%E4%B8%80%E6%80%A7%E5%BE%81%E5%8F%91%E8%82%B2%EF%BC%88%E8%B7%9F%E7%94%9F%E6%AE%96%E6%9C%89%E5%85%B3%EF%BC%89%EF%BC%8C%E7%AC%AC%E4%BA%8C%E6%80%A7%E5%BE%81%E5%87%BA%E7%8E%B0%EF%BC%88%E5%96%89%E7%BB%93%E8%83%A1%E9%A1%BB%E4%B9%B3%E6%88%BF%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="大脑发展" _mubu_text="%3Cspan%3E%E5%A4%A7%E8%84%91%E5%8F%91%E5%B1%95%3C/span%3E" _note="" _mubu_note="">
            <outline text="Limbic System（边缘系统，管情绪）和Amygdala（杏仁核）先发育" _mubu_text="%3Cspan%3ELimbic%20System%EF%BC%88%E8%BE%B9%E7%BC%98%E7%B3%BB%E7%BB%9F%EF%BC%8C%E7%AE%A1%E6%83%85%E7%BB%AA%EF%BC%89%E5%92%8CAmygdala%EF%BC%88%E6%9D%8F%E4%BB%81%E6%A0%B8%EF%BC%89%E5%85%88%E5%8F%91%E8%82%B2%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Prefrontal Cortex 前额叶皮层 25岁才成熟" _mubu_text="%3Cspan%3EPrefrontal%20Cortex%20%E5%89%8D%E9%A2%9D%E5%8F%B6%E7%9A%AE%E5%B1%82%2025%E5%B2%81%E6%89%8D%E6%88%90%E7%86%9F%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="更容易冲动，冒险和情绪化" _mubu_text="%3Cspan%3E%E6%9B%B4%E5%AE%B9%E6%98%93%E5%86%B2%E5%8A%A8%EF%BC%8C%E5%86%92%E9%99%A9%E5%92%8C%E6%83%85%E7%BB%AA%E5%8C%96%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Synaptic Pruning" _mubu_text="%3Cspan%3ESynaptic%20Pruning%3C/span%3E" _note="" _mubu_note="">
            <outline text="突触修建" _mubu_text="%3Cspan%3E%E7%AA%81%E8%A7%A6%E4%BF%AE%E5%BB%BA%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="用进废退，提高效率" _mubu_text="%3Cspan%3E%E7%94%A8%E8%BF%9B%E5%BA%9F%E9%80%80%EF%BC%8C%E6%8F%90%E9%AB%98%E6%95%88%E7%8E%87%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="4. Adulthood 成年期" _mubu_text="%3Cspan%3E4.%20Adulthood%20%E6%88%90%E5%B9%B4%E6%9C%9F%3C/span%3E" _note="" _mubu_note="">
          <outline text="生理巅峰于20岁，然后开始缓慢下降" _mubu_text="%3Cspan%3E%E7%94%9F%E7%90%86%E5%B7%85%E5%B3%B0%E4%BA%8E20%E5%B2%81%EF%BC%8C%E7%84%B6%E5%90%8E%E5%BC%80%E5%A7%8B%E7%BC%93%E6%85%A2%E4%B8%8B%E9%99%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="更年期 Menopause" _mubu_text="%3Cspan%3E%E6%9B%B4%E5%B9%B4%E6%9C%9F%20Menopause%3C/span%3E" _note="" _mubu_note="">
            <outline text="对女性来说，大约在50岁左右；伴随荷尔蒙变化，可能有生理和心理的不适；" _mubu_text="%3Cspan%3E%E5%AF%B9%E5%A5%B3%E6%80%A7%E6%9D%A5%E8%AF%B4%EF%BC%8C%E5%A4%A7%E7%BA%A6%E5%9C%A850%E5%B2%81%E5%B7%A6%E5%8F%B3%EF%BC%9B%E4%BC%B4%E9%9A%8F%E8%8D%B7%E5%B0%94%E8%92%99%E5%8F%98%E5%8C%96%EF%BC%8C%E5%8F%AF%E8%83%BD%E6%9C%89%E7%94%9F%E7%90%86%E5%92%8C%E5%BF%83%E7%90%86%E7%9A%84%E4%B8%8D%E9%80%82%EF%BC%9B%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="男性也会经历类似的过程，但是变化更平缓" _mubu_text="%3Cspan%3E%E7%94%B7%E6%80%A7%E4%B9%9F%E4%BC%9A%E7%BB%8F%E5%8E%86%E7%B1%BB%E4%BC%BC%E7%9A%84%E8%BF%87%E7%A8%8B%EF%BC%8C%E4%BD%86%E6%98%AF%E5%8F%98%E5%8C%96%E6%9B%B4%E5%B9%B3%E7%BC%93%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Social Clock" _mubu_text="%3Cspan%3ESocial%20Clock%3C/span%3E" _note="" _mubu_note="">
            <outline text="社会规定的完成某些人生大事的时间，比如结婚生子退休" _mubu_text="%3Cspan%3E%E7%A4%BE%E4%BC%9A%E8%A7%84%E5%AE%9A%E7%9A%84%E5%AE%8C%E6%88%90%E6%9F%90%E4%BA%9B%E4%BA%BA%E7%94%9F%E5%A4%A7%E4%BA%8B%E7%9A%84%E6%97%B6%E9%97%B4%EF%BC%8C%E6%AF%94%E5%A6%82%E7%BB%93%E5%A9%9A%E7%94%9F%E5%AD%90%E9%80%80%E4%BC%91%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="无形的社会压力" _mubu_text="%3Cspan%3E%E6%97%A0%E5%BD%A2%E7%9A%84%E7%A4%BE%E4%BC%9A%E5%8E%8B%E5%8A%9B%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
      </outline>
      <outline text="3.3 性别和取向" _mubu_text="%3Cspan%3E3.3%20%E6%80%A7%E5%88%AB%E5%92%8C%E5%8F%96%E5%90%91%3C/span%3E" _note="" _mubu_note=""/>
      <outline text="3.4 认知发展" _mubu_text="%3Cspan%3E3.4%20%E8%AE%A4%E7%9F%A5%E5%8F%91%E5%B1%95%3C/span%3E" _note="" _mubu_note="">
        <outline text="让皮亚杰 Jean Piaget" _mubu_text="%3Cspan%3E%E8%AE%A9%E7%9A%AE%E4%BA%9A%E6%9D%B0%20Jean%20Piaget%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22ZEwL9oGHQn%22%2C%22oh%22%3A411%2C%22ow%22%3A419%2C%22uri%22%3A%22document_image%2F33585682_056be438-98f2-4b52-ede3-38629dafd982.png%22%2C%22w%22%3A119%7D%5D"/>
        <outline text="Stage 1 Sensorimotor 0-2岁" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3EStage%201%20Sensorimotor%3C/span%3E%3Cspan%20class=%22bold%22%3E%200-2%E5%B2%81%3C/span%3E" _note="" _mubu_note="">
          <outline text="通过感官和动作认识世界，活在当下" _mubu_text="%3Cspan%3E%E9%80%9A%E8%BF%87%E6%84%9F%E5%AE%98%E5%92%8C%E5%8A%A8%E4%BD%9C%E8%AE%A4%E8%AF%86%E4%B8%96%E7%95%8C%EF%BC%8C%E6%B4%BB%E5%9C%A8%E5%BD%93%E4%B8%8B%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Object Permanence（物体是客观存在的），在8-10月学会" _mubu_text="%3Cspan%3EObject%20Permanence%EF%BC%88%E7%89%A9%E4%BD%93%E6%98%AF%E5%AE%A2%E8%A7%82%E5%AD%98%E5%9C%A8%E7%9A%84%EF%BC%89%EF%BC%8C%E5%9C%A88-10%E6%9C%88%E5%AD%A6%E4%BC%9A%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22EaQ3DVKkOb%22%2C%22oh%22%3A681%2C%22ow%22%3A1234%2C%22uri%22%3A%22document_image%2F182d8b9a-c60e-4a56-ba9a-eaf2122eb31d-33585682.jpg%22%2C%22w%22%3A262%7D%5D"/>
          <outline text="心理表征 - 知道「想」一些东西" _mubu_text="%3Cspan%3E%E5%BF%83%E7%90%86%E8%A1%A8%E5%BE%81%20-%20%E7%9F%A5%E9%81%93%E3%80%8C%E6%83%B3%E3%80%8D%E4%B8%80%E4%BA%9B%E4%B8%9C%E8%A5%BF%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Stage 2 Preoperational Stage 2-6、7岁" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3EStage%202%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3EPreoperational%20Stage%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E2-6%E3%80%817%E5%B2%81%3C/span%3E" _note="" _mubu_note="">
          <outline text="符号思维 Symbolic Thinking（语言、算数）" _mubu_text="%3Cspan%3E%E7%AC%A6%E5%8F%B7%E6%80%9D%E7%BB%B4%20Symbolic%20Thinking%EF%BC%88%E8%AF%AD%E8%A8%80%E3%80%81%E7%AE%97%E6%95%B0%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="词语代表物体和想法" _mubu_text="%3Cspan%3E%E8%AF%8D%E8%AF%AD%E4%BB%A3%E8%A1%A8%E7%89%A9%E4%BD%93%E5%92%8C%E6%83%B3%E6%B3%95%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Pretend Play" _mubu_text="%3Cspan%3EPretend%20Play%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="泛灵论 Animism（万物有灵）" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E6%B3%9B%E7%81%B5%E8%AE%BA%20Animism%EF%BC%88%E4%B8%87%E7%89%A9%E6%9C%89%E7%81%B5%EF%BC%89%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22B06lzGbaHP%22%2C%22oh%22%3A434%2C%22ow%22%3A404%2C%22uri%22%3A%22document_image%2F33585682_c7e1a398-b2f3-427d-cc24-f1c53b2ecf32.png%22%2C%22w%22%3A134%7D%5D"/>
          <outline text="自我中心主义 Egocentrism（三山实验）" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E8%87%AA%E6%88%91%E4%B8%AD%E5%BF%83%E4%B8%BB%E4%B9%89%20Egocentrism%EF%BC%88%E4%B8%89%E5%B1%B1%E5%AE%9E%E9%AA%8C%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="不可逆 Irreversibility（你有兄弟么？Jim。Jim有兄弟么？不知道。） + 守恒缺失 Lack of Conservation（橡皮泥变大了）" _mubu_text="%3Cspan%3E%E4%B8%8D%E5%8F%AF%E9%80%86%20Irreversibility%EF%BC%88%E4%BD%A0%E6%9C%89%E5%85%84%E5%BC%9F%E4%B9%88%EF%BC%9FJim%E3%80%82Jim%E6%9C%89%E5%85%84%E5%BC%9F%E4%B9%88%EF%BC%9F%E4%B8%8D%E7%9F%A5%E9%81%93%E3%80%82%EF%BC%89%20+%20%E5%AE%88%E6%81%92%E7%BC%BA%E5%A4%B1%20Lack%20of%20Conservation%EF%BC%88%E6%A9%A1%E7%9A%AE%E6%B3%A5%E5%8F%98%E5%A4%A7%E4%BA%86%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Stage 3 Concrete Operational Stage 6、7-11岁" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3EStage%203%20Concrete%20Operational%20Stage%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E6%E3%80%817-11%E5%B2%81%3C/span%3E" _note="" _mubu_note="">
          <outline text="逻辑和系统化" _mubu_text="%3Cspan%3E%E9%80%BB%E8%BE%91%E5%92%8C%E7%B3%BB%E7%BB%9F%E5%8C%96%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="可以逻辑推理，但是不能凭空想象或者「假设」" _mubu_text="%3Cspan%3E%E5%8F%AF%E4%BB%A5%E9%80%BB%E8%BE%91%E6%8E%A8%E7%90%86%EF%BC%8C%E4%BD%86%E6%98%AF%E4%B8%8D%E8%83%BD%E5%87%AD%E7%A9%BA%E6%83%B3%E8%B1%A1%E6%88%96%E8%80%85%E3%80%8C%E5%81%87%E8%AE%BE%E3%80%8D%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="可逆性和守恒（8+4=12，12-4=8）" _mubu_text="%3Cspan%3E%E5%8F%AF%E9%80%86%E6%80%A7%E5%92%8C%E5%AE%88%E6%81%92%EF%BC%888+4=12%EF%BC%8C12-4=8%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Theory of Mind - ToM（我们有不同的视角）" _mubu_text="%3Cspan%3ETheory%20of%20Mind%20-%20ToM%EF%BC%88%E6%88%91%E4%BB%AC%E6%9C%89%E4%B8%8D%E5%90%8C%E7%9A%84%E8%A7%86%E8%A7%92%EF%BC%89%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22mDIkchyb0N%22%2C%22oh%22%3A719%2C%22ow%22%3A1555%2C%22uri%22%3A%22document_image%2F33585682_b46d95c6-83ad-4067-cb54-966d8c58fc04.png%22%2C%22w%22%3A400%7D%5D"/>
        </outline>
        <outline text="Stage 4 Formal Operational Stage 12岁起" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3EStage%204%20Formal%20Operational%20Stage%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E12%E5%B2%81%E8%B5%B7%3C/span%3E" _note="" _mubu_note="">
          <outline text="从具体到抽象概念（正义、爱、自由；y=ax+b代数）" _mubu_text="%3Cspan%3E%E4%BB%8E%E5%85%B7%E4%BD%93%E5%88%B0%E6%8A%BD%E8%B1%A1%E6%A6%82%E5%BF%B5%EF%BC%88%E6%AD%A3%E4%B9%89%E3%80%81%E7%88%B1%E3%80%81%E8%87%AA%E7%94%B1%EF%BC%9By=ax+b%E4%BB%A3%E6%95%B0%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="可以假设性（科学课实验设计，哲学课假想命题思考）" _mubu_text="%3Cspan%3E%E5%8F%AF%E4%BB%A5%E5%81%87%E8%AE%BE%E6%80%A7%EF%BC%88%E7%A7%91%E5%AD%A6%E8%AF%BE%E5%AE%9E%E9%AA%8C%E8%AE%BE%E8%AE%A1%EF%BC%8C%E5%93%B2%E5%AD%A6%E8%AF%BE%E5%81%87%E6%83%B3%E5%91%BD%E9%A2%98%E6%80%9D%E8%80%83%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="批判皮亚杰" _mubu_text="%3Cspan%3E%E6%89%B9%E5%88%A4%E7%9A%AE%E4%BA%9A%E6%9D%B0%3C/span%3E" _note="" _mubu_note="">
          <outline text="现在人认为认知发展是一个平缓的斜坡，而不是piaget描述的阶梯状的跳跃" _mubu_text="%3Cspan%3E%E7%8E%B0%E5%9C%A8%E4%BA%BA%E8%AE%A4%E4%B8%BA%E8%AE%A4%E7%9F%A5%E5%8F%91%E5%B1%95%E6%98%AF%E4%B8%80%E4%B8%AA%E5%B9%B3%E7%BC%93%E7%9A%84%E6%96%9C%E5%9D%A1%EF%BC%8C%E8%80%8C%E4%B8%8D%E6%98%AFpiaget%E6%8F%8F%E8%BF%B0%E7%9A%84%E9%98%B6%E6%A2%AF%E7%8A%B6%E7%9A%84%E8%B7%B3%E8%B7%83%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="低估了孩子的能力" _mubu_text="%3Cspan%3E%E4%BD%8E%E4%BC%B0%E4%BA%86%E5%AD%A9%E5%AD%90%E7%9A%84%E8%83%BD%E5%8A%9B%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="认知发展不等于逻辑，因为哪怕成年人也不是天天逻辑逻辑" _mubu_text="%3Cspan%3E%E8%AE%A4%E7%9F%A5%E5%8F%91%E5%B1%95%E4%B8%8D%E7%AD%89%E4%BA%8E%E9%80%BB%E8%BE%91%EF%BC%8C%E5%9B%A0%E4%B8%BA%E5%93%AA%E6%80%95%E6%88%90%E5%B9%B4%E4%BA%BA%E4%B9%9F%E4%B8%8D%E6%98%AF%E5%A4%A9%E5%A4%A9%E9%80%BB%E8%BE%91%E9%80%BB%E8%BE%91%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Lev Vygotsky 维果斯基" _mubu_text="%3Cspan%3ELev%20Vygotsky%20%E7%BB%B4%E6%9E%9C%E6%96%AF%E5%9F%BA%3C/span%3E" _note="" _mubu_note="">
          <outline text="学生可以通过和他人交互学习" _mubu_text="%3Cspan%3E%E5%AD%A6%E7%94%9F%E5%8F%AF%E4%BB%A5%E9%80%9A%E8%BF%87%E5%92%8C%E4%BB%96%E4%BA%BA%E4%BA%A4%E4%BA%92%E5%AD%A6%E4%B9%A0%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="ZPD 最近发展区，在独立完成和一点点帮助完成的区域；" _mubu_text="%3Cspan%3EZPD%20%E6%9C%80%E8%BF%91%E5%8F%91%E5%B1%95%E5%8C%BA%EF%BC%8C%E5%9C%A8%E7%8B%AC%E7%AB%8B%E5%AE%8C%E6%88%90%E5%92%8C%E4%B8%80%E7%82%B9%E7%82%B9%E5%B8%AE%E5%8A%A9%E5%AE%8C%E6%88%90%E7%9A%84%E5%8C%BA%E5%9F%9F%EF%BC%9B%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Scaffolding 脚手架，就是那个帮助" _mubu_text="%3Cspan%3EScaffolding%20%E8%84%9A%E6%89%8B%E6%9E%B6%EF%BC%8C%E5%B0%B1%E6%98%AF%E9%82%A3%E4%B8%AA%E5%B8%AE%E5%8A%A9%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
      </outline>
      <outline text="3.5 语言发展" _mubu_text="%3Cspan%3E3.5%20%E8%AF%AD%E8%A8%80%E5%8F%91%E5%B1%95%3C/span%3E" _note="" _mubu_note="">
        <outline text="为什么研究语言：语言是思维的外壳" _mubu_text="%3Cspan%3E%E4%B8%BA%E4%BB%80%E4%B9%88%E7%A0%94%E7%A9%B6%E8%AF%AD%E8%A8%80%EF%BC%9A%E8%AF%AD%E8%A8%80%E6%98%AF%E6%80%9D%E7%BB%B4%E7%9A%84%E5%A4%96%E5%A3%B3%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="语言的基本单位" _mubu_text="%3Cspan%3E%E8%AF%AD%E8%A8%80%E7%9A%84%E5%9F%BA%E6%9C%AC%E5%8D%95%E4%BD%8D%3C/span%3E" _note="" _mubu_note="">
          <outline text="Phoneme 音位（最小的可以区分意义的声音单位）" _mubu_text="%3Cspan%3EPhoneme%20%E9%9F%B3%E4%BD%8D%EF%BC%88%E6%9C%80%E5%B0%8F%E7%9A%84%E5%8F%AF%E4%BB%A5%E5%8C%BA%E5%88%86%E6%84%8F%E4%B9%89%E7%9A%84%E5%A3%B0%E9%9F%B3%E5%8D%95%E4%BD%8D%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="/k/, /t/, /sh/" _mubu_text="%3Cspan%3E/k/,%20/t/,%20/sh/%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Morpheme 语素（最小的、携带意义的单位）" _mubu_text="%3Cspan%3EMorpheme%20%E8%AF%AD%E7%B4%A0%EF%BC%88%E6%9C%80%E5%B0%8F%E7%9A%84%E3%80%81%E6%90%BA%E5%B8%A6%E6%84%8F%E4%B9%89%E7%9A%84%E5%8D%95%E4%BD%8D%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="cat -s 表示复数" _mubu_text="%3Cspan%3Ecat%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E-s%3C/span%3E%3Cspan%3E%20%E8%A1%A8%E7%A4%BA%E5%A4%8D%E6%95%B0%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="un- believable un表示不" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3Eun-%3C/span%3E%3Cspan%3E%20believable%20un%E8%A1%A8%E7%A4%BA%E4%B8%8D%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Syntax 句法 如何将单词组成在一起" _mubu_text="%3Cspan%3ESyntax%20%E5%8F%A5%E6%B3%95%20%E5%A6%82%E4%BD%95%E5%B0%86%E5%8D%95%E8%AF%8D%E7%BB%84%E6%88%90%E5%9C%A8%E4%B8%80%E8%B5%B7%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Semantics 语义 这句话到底在说什么，不仅是声音、词和句子，更理解背后的意图" _mubu_text="%3Cspan%3ESemantics%20%E8%AF%AD%E4%B9%89%20%E8%BF%99%E5%8F%A5%E8%AF%9D%E5%88%B0%E5%BA%95%E5%9C%A8%E8%AF%B4%E4%BB%80%E4%B9%88%EF%BC%8C%E4%B8%8D%E4%BB%85%E6%98%AF%E5%A3%B0%E9%9F%B3%E3%80%81%E8%AF%8D%E5%92%8C%E5%8F%A5%E5%AD%90%EF%BC%8C%E6%9B%B4%E7%90%86%E8%A7%A3%E8%83%8C%E5%90%8E%E7%9A%84%E6%84%8F%E5%9B%BE%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="语言发展阶段" _mubu_text="%3Cspan%3E%E8%AF%AD%E8%A8%80%E5%8F%91%E5%B1%95%E9%98%B6%E6%AE%B5%3C/span%3E" _note="" _mubu_note="">
          <outline text="1. Cooing 咕咕咕 2月起" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E1.%20Cooing%20%E5%92%95%E5%92%95%E5%92%95%3C/span%3E%3Cspan%20class=%22bold%22%3E%202%E6%9C%88%E8%B5%B7%3C/span%3E" _note="" _mubu_note="">
            <outline text="婴儿在练习自己的发声器官" _mubu_text="%3Cspan%3E%E5%A9%B4%E5%84%BF%E5%9C%A8%E7%BB%83%E4%B9%A0%E8%87%AA%E5%B7%B1%E7%9A%84%E5%8F%91%E5%A3%B0%E5%99%A8%E5%AE%98%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="语言萌芽的迹象" _mubu_text="%3Cspan%3E%E8%AF%AD%E8%A8%80%E8%90%8C%E8%8A%BD%E7%9A%84%E8%BF%B9%E8%B1%A1%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="2. Babbling 牙牙学语 4月起" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E2.%20Babbling%20%E7%89%99%E7%89%99%E5%AD%A6%E8%AF%AD%3C/span%3E%3Cspan%20class=%22bold%22%3E%204%E6%9C%88%E8%B5%B7%3C/span%3E" _note="" _mubu_note="">
            <outline text="ba-ba-ba 辅音和元音结合" _mubu_text="%3Cspan%3Eba-ba-ba%20%E8%BE%85%E9%9F%B3%E5%92%8C%E5%85%83%E9%9F%B3%E7%BB%93%E5%90%88%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="练习Phonemes，10个月左右开始专精母语环境的Phonemes" _mubu_text="%3Cspan%3E%E7%BB%83%E4%B9%A0Phonemes%EF%BC%8C10%E4%B8%AA%E6%9C%88%E5%B7%A6%E5%8F%B3%E5%BC%80%E5%A7%8B%E4%B8%93%E7%B2%BE%E6%AF%8D%E8%AF%AD%E7%8E%AF%E5%A2%83%E7%9A%84Phonemes%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="3. One-Word Stage / Holophrase 单词句 1岁起" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E3.%20One-Word%20Stage%20/%20Holophrase%20%E5%8D%95%E8%AF%8D%E5%8F%A5%3C/span%3E%3Cspan%20class=%22bold%22%3E%201%E5%B2%81%E8%B5%B7%3C/span%3E" _note="" _mubu_note="">
            <outline text="一个有意义的词" _mubu_text="%3Cspan%3E%E4%B8%80%E4%B8%AA%E6%9C%89%E6%84%8F%E4%B9%89%E7%9A%84%E8%AF%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="一个单词表达一个句子" _mubu_text="%3Cspan%3E%E4%B8%80%E4%B8%AA%E5%8D%95%E8%AF%8D%E8%A1%A8%E8%BE%BE%E4%B8%80%E4%B8%AA%E5%8F%A5%E5%AD%90%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Go！+ 指着门：想要出门玩" _mubu_text="%3Cspan%3EGo%EF%BC%81+%20%E6%8C%87%E7%9D%80%E9%97%A8%EF%BC%9A%E6%83%B3%E8%A6%81%E5%87%BA%E9%97%A8%E7%8E%A9%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="声音和意义的联系，一个Milestone" _mubu_text="%3Cspan%3E%E5%A3%B0%E9%9F%B3%E5%92%8C%E6%84%8F%E4%B9%89%E7%9A%84%E8%81%94%E7%B3%BB%EF%BC%8C%E4%B8%80%E4%B8%AAMilestone%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="4. Two-Word Stage 双词句 大约2岁起" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E4.%20Two-Word%20Stage%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3E%E5%8F%8C%E8%AF%8D%E5%8F%A5%3C/span%3E%3Cspan%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3E%E5%A4%A7%E7%BA%A62%E5%B2%81%E8%B5%B7%3C/span%3E" _note="" _mubu_note="">
            <outline text="电报式语言 Telegraphic Speech" _mubu_text="%3Cspan%3E%E7%94%B5%E6%8A%A5%E5%BC%8F%E8%AF%AD%E8%A8%80%20Telegraphic%20Speech%3C/span%3E" _note="" _mubu_note="">
              <outline text="Get Ball, Mommy Go" _mubu_text="%3Cspan%3EGet%20Ball,%20Mommy%20Go%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="过度泛化 Overgeneralization" _mubu_text="%3Cspan%3E%E8%BF%87%E5%BA%A6%E6%B3%9B%E5%8C%96%20Overgeneralization%3C/span%3E" _note="" _mubu_note="">
              <outline text="goed, hitted" _mubu_text="%3Cspan%3Egoed,%20hitted%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="5. Full Sentence 完整句子阶段 2岁后" _mubu_text="%3Cspan%20class=%22bold%20text-color-blue%22%3E5.%20Full%20Sentence%20%E5%AE%8C%E6%95%B4%E5%8F%A5%E5%AD%90%E9%98%B6%E6%AE%B5%3C/span%3E%3Cspan%20class=%22bold%22%3E%202%E5%B2%81%E5%90%8E%3C/span%3E" _note="" _mubu_note="">
            <outline text="更长更复杂的句子，语言能力爆发期" _mubu_text="%3Cspan%3E%E6%9B%B4%E9%95%BF%E6%9B%B4%E5%A4%8D%E6%9D%82%E7%9A%84%E5%8F%A5%E5%AD%90%EF%BC%8C%E8%AF%AD%E8%A8%80%E8%83%BD%E5%8A%9B%E7%88%86%E5%8F%91%E6%9C%9F%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="掌握母语中80%的结构和词汇（6-8岁）" _mubu_text="%3Cspan%3E%E6%8E%8C%E6%8F%A1%E6%AF%8D%E8%AF%AD%E4%B8%AD80%25%E7%9A%84%E7%BB%93%E6%9E%84%E5%92%8C%E8%AF%8D%E6%B1%87%EF%BC%886-8%E5%B2%81%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="非口语手势" _mubu_text="%3Cspan%3E%E9%9D%9E%E5%8F%A3%E8%AF%AD%E6%89%8B%E5%8A%BF%3C/span%3E" _note="" _mubu_note="">
          <outline text="指、摆手、做手势、传递感情、指示方向" _mubu_text="%3Cspan%3E%E6%8C%87%E3%80%81%E6%91%86%E6%89%8B%E3%80%81%E5%81%9A%E6%89%8B%E5%8A%BF%E3%80%81%E4%BC%A0%E9%80%92%E6%84%9F%E6%83%85%E3%80%81%E6%8C%87%E7%A4%BA%E6%96%B9%E5%90%91%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="关键期" _mubu_text="%3Cspan%3E%E5%85%B3%E9%94%AE%E6%9C%9F%3C/span%3E" _note="" _mubu_note="">
          <outline text="7岁还没学会说话的会丧失语言能力" _mubu_text="%3Cspan%3E7%E5%B2%81%E8%BF%98%E6%B2%A1%E5%AD%A6%E4%BC%9A%E8%AF%B4%E8%AF%9D%E7%9A%84%E4%BC%9A%E4%B8%A7%E5%A4%B1%E8%AF%AD%E8%A8%80%E8%83%BD%E5%8A%9B%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22fdpgcIcqeD%22%2C%22oh%22%3A1010%2C%22ow%22%3A1741%2C%22uri%22%3A%22document_image%2F33585682_50b4d97c-44ce-4d97-a5a4-5e6f3ee35aba.png%22%2C%22w%22%3A343%7D%5D"/>
        </outline>
