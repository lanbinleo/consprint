            <outline text="检测睡眠周期 &amp; seizures 癫痫" _mubu_text="%3Cspan%3E%E6%A3%80%E6%B5%8B%E7%9D%A1%E7%9C%A0%E5%91%A8%E6%9C%9F%20&amp;amp;%20seizures%20%E7%99%AB%E7%97%AB%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="PET" _mubu_text="%3Cspan%3EPET%3C/span%3E" _note="" _mubu_note="">
            <outline text="metabolic activity 代谢活动" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3Emetabolic%3C/span%3E%3Cspan%3E%20activity%20%E4%BB%A3%E8%B0%A2%E6%B4%BB%E5%8A%A8%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="不如fMRI常考，记得有个PET就行" _mubu_text="%3Cspan%3E%E4%B8%8D%E5%A6%82fMRI%E5%B8%B8%E8%80%83%EF%BC%8C%E8%AE%B0%E5%BE%97%E6%9C%89%E4%B8%AAPET%E5%B0%B1%E8%A1%8C%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Neuroplasticity 神经可塑性" _mubu_text="%3Cspan%20class=%22text-color-red%22%3ENeuroplasticity%20%3C/span%3E%3Cspan%3E%E7%A5%9E%E7%BB%8F%E5%8F%AF%E5%A1%91%E6%80%A7%3C/span%3E" _note="" _mubu_note="">
          <outline text="Three Key Points" _mubu_text="%3Cspan%3EThree%20Key%20Points%3C/span%3E" _note="" _mubu_note="">
            <outline text="1. Brain is resistant to damage" _mubu_text="%3Cspan%3E1.%20Brain%20is%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20resistant%20%3C/span%3E%3Cspan%3Eto%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3Edamage%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="2. Plasticity: stronger when young / still exists in adults" _mubu_text="%3Cspan%3E2.%20Plasticity:%20stronger%20when%20young%20/%20still%20exists%20in%20adults%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="3. 原因 Formation of new synapses" _mubu_text="%3Cspan%3E3.%20%E5%8E%9F%E5%9B%A0%20Formation%20of%20new%20synapses%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Two Plasticity" _mubu_text="%3Cspan%3ETwo%20Plasticity%3C/span%3E" _note="" _mubu_note="">
            <outline text="Functional Plasticity 功能转移" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EFunctional%20%3C/span%3E%3Cspan%3EPlasticity%20%E5%8A%9F%E8%83%BD%E8%BD%AC%E7%A7%BB%3C/span%3E" _note="" _mubu_note="">
              <outline text="受伤的部分，把功能给到没受伤的部分" _mubu_text="%3Cspan%3E%E5%8F%97%E4%BC%A4%E7%9A%84%E9%83%A8%E5%88%86%EF%BC%8C%E6%8A%8A%E5%8A%9F%E8%83%BD%E7%BB%99%E5%88%B0%E6%B2%A1%E5%8F%97%E4%BC%A4%E7%9A%84%E9%83%A8%E5%88%86%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Structural Plasticity 物理结构改变" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EStructural%20%3C/span%3E%3Cspan%3EPlasticity%20%E7%89%A9%E7%90%86%E7%BB%93%E6%9E%84%E6%94%B9%E5%8F%98%3C/span%3E" _note="" _mubu_note="">
              <outline text="学习 - form 新的 connections" _mubu_text="%3Cspan%3E%E5%AD%A6%E4%B9%A0%20-%20form%20%E6%96%B0%E7%9A%84%20connections%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="Neurogenesis 神经发生" _mubu_text="%3Cspan%3ENeurogenesis%20%E7%A5%9E%E7%BB%8F%E5%8F%91%E7%94%9F%3C/span%3E" _note="" _mubu_note="">
          <outline text="构造新的brain cells的过程" _mubu_text="%3Cspan%3E%E6%9E%84%E9%80%A0%E6%96%B0%E7%9A%84brain%20cells%E7%9A%84%E8%BF%87%E7%A8%8B%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="来源：干细胞 stem cells" _mubu_text="%3Cspan%3E%E6%9D%A5%E6%BA%90%EF%BC%9A%E5%B9%B2%E7%BB%86%E8%83%9E%20stem%20cells%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Split Brain Patient 裂脑研究" _mubu_text="%3Cspan%3ESplit%20Brain%20Patient%20%E8%A3%82%E8%84%91%E7%A0%94%E7%A9%B6%3C/span%3E" _note="" _mubu_note="">
          <outline text="治疗 severe epilepsy 严重癫痫" _mubu_text="%3Cspan%3E%E6%B2%BB%E7%96%97%20severe%20epilepsy%20%E4%B8%A5%E9%87%8D%E7%99%AB%E7%97%AB%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="切断 corpus callosum Corpus Callosum 胼胝体" _mubu_text="%3Cspan%3E%E5%88%87%E6%96%AD%20corpus%20callosum%20%3C/span%3E%3Cspan%20class=%22node-mention%22%20id=%221klvsCaTPe%22%20spellcheck=%22false%22%20contenteditable=%22false%22%20data-doc=%221qN74cOm072%22%20data-node=%22F3P3E8gQJQ%22%20data-text=%22%255B%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Corpus%2520Callosum%2522%252C%2522style%2522%253A%257B%2522bold%2522%253Atrue%252C%2522color%2522%253A%2522%2523dc2d1e%2522%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522%2520%25E8%2583%25BC%25E8%2583%259D%25E4%25BD%2593%2522%252C%2522style%2522%253A%257B%257D%257D%255D%22%3E%3Cspan%20class=%22bold%20text-color-red%22%3ECorpus%20Callosum%3C/span%3E%3Cspan%3E%20%E8%83%BC%E8%83%9D%E4%BD%93%3C/span%3E%3C/span%3E%3Cspan%3E%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="发现：" _mubu_text="%3Cspan%3E%E5%8F%91%E7%8E%B0%EF%BC%9A%3C/span%3E" _note="" _mubu_note="">
            <outline text="两个半球没法共享信息" _mubu_text="%3Cspan%3E%E4%B8%A4%E4%B8%AA%E5%8D%8A%E7%90%83%E6%B2%A1%E6%B3%95%E5%85%B1%E4%BA%AB%E4%BF%A1%E6%81%AF%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Contralateral Organization Contralateral Control 对侧控制" _mubu_text="%3Cspan%3EContralateral%20Organization%20%3C/span%3E%3Cspan%20class=%22node-mention%22%20id=%22TjEQ5IluPz%22%20spellcheck=%22false%22%20contenteditable=%22false%22%20data-doc=%221qN74cOm072%22%20data-node=%22C2UKaFLGRs%22%20data-text=%22%255B%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Contralateral%2520Control%2520%25E5%25AF%25B9%25E4%25BE%25A7%25E6%258E%25A7%25E5%2588%25B6%2522%252C%2522style%2522%253A%257B%2522bold%2522%253Atrue%252C%2522underline%2522%253Atrue%257D%257D%255D%22%3E%3Cspan%20class=%22bold%20underline%22%3EContralateral%20Control%20%E5%AF%B9%E4%BE%A7%E6%8E%A7%E5%88%B6%3C/span%3E%3C/span%3E%3Cspan%3E%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="左脑 Language（多数人）Left hemisphere 偏分析" _mubu_text="%3Cspan%3E%E5%B7%A6%E8%84%91%20Language%EF%BC%88%E5%A4%9A%E6%95%B0%E4%BA%BA%EF%BC%89%3C/span%3E%3Cspan%20class=%22node-mention%22%20id=%22ebGvgfqjYc%22%20spellcheck=%22false%22%20contenteditable=%22false%22%20data-doc=%221qN74cOm072%22%20data-node=%22GMe8z8pMhN%22%20data-text=%22%255B%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Left%2520%2522%252C%2522style%2522%253A%257B%2522color%2522%253A%2522%2523ffaf38%2522%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522hemisphere%2520%25E5%2581%258F%25E5%2588%2586%25E6%259E%2590%2522%252C%2522style%2522%253A%257B%257D%257D%255D%22%3E%3Cspan%20class=%22text-color-yellow%22%3ELeft%20%3C/span%3E%3Cspan%3Ehemisphere%20%E5%81%8F%E5%88%86%E6%9E%90%3C/span%3E%3C/span%3E%3Cspan%3E%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="图像出现在left visual field 为什么不能说出来，但是可以用左手指出？" _mubu_text="%3Cspan%3E%E5%9B%BE%E5%83%8F%E5%87%BA%E7%8E%B0%E5%9C%A8left%20visual%20field%20%E4%B8%BA%E4%BB%80%E4%B9%88%E4%B8%8D%E8%83%BD%E8%AF%B4%E5%87%BA%E6%9D%A5%EF%BC%8C%E4%BD%86%E6%98%AF%E5%8F%AF%E4%BB%A5%E7%94%A8%E5%B7%A6%E6%89%8B%E6%8C%87%E5%87%BA%EF%BC%9F%3C/span%3E" _note="" _mubu_note="">
            <outline text="Visual field → opposite hemisphere（所以是右脑看到）" _mubu_text="%3Cspan%3EVisual%20field%20%E2%86%92%20opposite%20hemisphere%EF%BC%88%E6%89%80%E4%BB%A5%E6%98%AF%E5%8F%B3%E8%84%91%E7%9C%8B%E5%88%B0%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Language center usually in left hemisphere（右脑不会说话）" _mubu_text="%3Cspan%3ELanguage%20center%20usually%20in%20left%20hemisphere%EF%BC%88%E5%8F%B3%E8%84%91%E4%B8%8D%E4%BC%9A%E8%AF%B4%E8%AF%9D%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Corpus callosum is cut（还是对侧控制，能控制左手，因为 Medulla Oblongata 延髓 没有被切掉，这个才是负责对侧控制的）" _mubu_text="%3Cspan%3ECorpus%20callosum%20is%20cut%EF%BC%88%E8%BF%98%E6%98%AF%E5%AF%B9%E4%BE%A7%E6%8E%A7%E5%88%B6%EF%BC%8C%E8%83%BD%E6%8E%A7%E5%88%B6%E5%B7%A6%E6%89%8B%EF%BC%8C%E5%9B%A0%E4%B8%BA%20%3C/span%3E%3Cspan%20class=%22node-mention%22%20id=%22Bg0wcHAkW7%22%20spellcheck=%22false%22%20contenteditable=%22false%22%20data-doc=%221qN74cOm072%22%20data-node=%22YOd16uxfzA%22%20data-text=%22%255B%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Medulla%2520Oblongata%2522%252C%2522style%2522%253A%257B%2522color%2522%253A%2522%2523ffaf38%2522%257D%257D%252C%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522%2520%25E5%25BB%25B6%25E9%25AB%2593%2522%252C%2522style%2522%253A%257B%257D%257D%255D%22%3E%3Cspan%20class=%22text-color-yellow%22%3EMedulla%20Oblongata%3C/span%3E%3Cspan%3E%20%E5%BB%B6%E9%AB%93%3C/span%3E%3C/span%3E%3Cspan%3E%3C/span%3E%3Cspan%3E%20%E6%B2%A1%E6%9C%89%E8%A2%AB%E5%88%87%E6%8E%89%EF%BC%8C%E8%BF%99%E4%B8%AA%E6%89%8D%E6%98%AF%E8%B4%9F%E8%B4%A3%E5%AF%B9%E4%BE%A7%E6%8E%A7%E5%88%B6%E7%9A%84%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
      </outline>
      <outline text="1.5 睡眠 Sleep &amp; Dream（意识、睡眠、昼夜节律、睡眠周期、梦、障碍，700字）" _mubu_text="%3Cspan%3E1.5%20%E7%9D%A1%E7%9C%A0%20Sleep%20&amp;amp;%20Dream%EF%BC%88%E6%84%8F%E8%AF%86%E3%80%81%E7%9D%A1%E7%9C%A0%E3%80%81%E6%98%BC%E5%A4%9C%E8%8A%82%E5%BE%8B%E3%80%81%E7%9D%A1%E7%9C%A0%E5%91%A8%E6%9C%9F%E3%80%81%E6%A2%A6%E3%80%81%E9%9A%9C%E7%A2%8D%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E700%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="1. Consciousness 意识" _mubu_text="%3Cspan%3E1.%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EConsciousness%20%3C/span%3E%3Cspan%3E%E6%84%8F%E8%AF%86%3C/span%3E" _note="" _mubu_note="">
          <outline text="对自己与环境的觉知水平，subjective &amp; private" _mubu_text="%3Cspan%3E%E5%AF%B9%E8%87%AA%E5%B7%B1%E4%B8%8E%E7%8E%AF%E5%A2%83%E7%9A%84%E8%A7%89%E7%9F%A5%E6%B0%B4%E5%B9%B3%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Esubjective%20&amp;amp;%20private%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="2. Dual Processing 双重加工" _mubu_text="%3Cspan%3E2.%20Dual%20Processing%20%E5%8F%8C%E9%87%8D%E5%8A%A0%E5%B7%A5%3C/span%3E" _note="" _mubu_note="">
          <outline text="Conscious Mind (Explicit processing 显性加工）" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EConscious%20%3C/span%3E%3Cspan%3EMind%20(%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EExplicit%20%3C/span%3E%3Cspan%3Eprocessing%20%E6%98%BE%E6%80%A7%E5%8A%A0%E5%B7%A5%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="有意识 / Effortful / 需要注意力" _mubu_text="%3Cspan%3E%E6%9C%89%E6%84%8F%E8%AF%86%20/%20Effortful%20/%20%E9%9C%80%E8%A6%81%E6%B3%A8%E6%84%8F%E5%8A%9B%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="做题，写作文" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E5%81%9A%E9%A2%98%EF%BC%8C%E5%86%99%E4%BD%9C%E6%96%87%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Unconscious Mind (Implicit Processing 隐性加工）" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EUnconscious%20%3C/span%3E%3Cspan%3EMind%20(%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EImplicit%20%3C/span%3E%3Cspan%3EProcessing%20%E9%9A%90%E6%80%A7%E5%8A%A0%E5%B7%A5%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="无意识 / automatic" _mubu_text="%3Cspan%3E%E6%97%A0%E6%84%8F%E8%AF%86%20/%20automatic%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="走路，呼吸，习惯性反应" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E8%B5%B0%E8%B7%AF%EF%BC%8C%E5%91%BC%E5%90%B8%3C/span%3E%3Cspan%3E%EF%BC%8C%E4%B9%A0%E6%83%AF%E6%80%A7%E5%8F%8D%E5%BA%94%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="可以同时做" _mubu_text="%3Cspan%3E%E5%8F%AF%E4%BB%A5%E5%90%8C%E6%97%B6%E5%81%9A%3C/span%3E" _note="" _mubu_note="">
            <outline text="开车 + 听歌；" _mubu_text="%3Cspan%3E%E5%BC%80%E8%BD%A6%20+%20%E5%90%AC%E6%AD%8C%EF%BC%9B%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="但是不能开车 + 打电话，这样会分心" _mubu_text="%3Cspan%3E%E4%BD%86%E6%98%AF%E4%B8%8D%E8%83%BD%E5%BC%80%E8%BD%A6%20+%20%E6%89%93%E7%94%B5%E8%AF%9D%EF%BC%8C%E8%BF%99%E6%A0%B7%E4%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%88%86%E5%BF%83%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="3. Sleep = Altered State of Consciousness" _mubu_text="%3Cspan%3E3.%20Sleep%20=%20Altered%20State%20of%20Consciousness%3C/span%3E" _note="" _mubu_note="">
          <outline text="但是此时大脑还是active的，只是意识不在了" _mubu_text="%3Cspan%3E%E4%BD%86%E6%98%AF%E6%AD%A4%E6%97%B6%3C/span%3E%3Cspan%20class=%22text-color-red%22%3E%E5%A4%A7%E8%84%91%E8%BF%98%E6%98%AFactive%3C/span%3E%3Cspan%3E%E7%9A%84%EF%BC%8C%E5%8F%AA%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E6%84%8F%E8%AF%86%E4%B8%8D%E5%9C%A8%E4%BA%86%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="4. Circadian Rhythm 昼夜节律" _mubu_text="%3Cspan%3E4.%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3ECircadian%20%3C/span%3E%3Cspan%3ERhythm%20%E6%98%BC%E5%A4%9C%E8%8A%82%E5%BE%8B%3C/span%3E" _note="" _mubu_note="">
          <outline text="24小时的生物钟" _mubu_text="%3Cspan%3E24%E5%B0%8F%E6%97%B6%E7%9A%84%E7%94%9F%E7%89%A9%E9%92%9F%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="调节 sleep / body temperature / cortisol 皮质醇 / melatonin 褪黑素 / 其他激素" _mubu_text="%3Cspan%3E%E8%B0%83%E8%8A%82%20sleep%20/%20body%20temperature%20/%20%3C/span%3E%3Cspan%20class=%22bold%22%3Ecortisol%3C/span%3E%3Cspan%3E%20%E7%9A%AE%E8%B4%A8%E9%86%87%20/%20%3C/span%3E%3Cspan%20class=%22bold%22%3Emelatonin%3C/span%3E%3Cspan%3E%20%E8%A4%AA%E9%BB%91%E7%B4%A0%20/%20%E5%85%B6%E4%BB%96%E6%BF%80%E7%B4%A0%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="会被 Jet Lag 和 Shift Work 打乱" _mubu_text="%3Cspan%3E%E4%BC%9A%E8%A2%AB%20Jet%20Lag%20%E5%92%8C%20Shift%20Work%20%E6%89%93%E4%B9%B1%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="5. Sleep Cycle 睡眠周期" _mubu_text="%3Cspan%3E5.%20Sleep%20Cycle%20%E7%9D%A1%E7%9C%A0%E5%91%A8%E6%9C%9F%3C/span%3E" _note="" _mubu_note="">
          <outline text="90-110 minutes 一个周期" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E90-110%3C/span%3E%3Cspan%3E%20minutes%20%E4%B8%80%E4%B8%AA%E5%91%A8%E6%9C%9F%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="一晚上 3-5 cycles" _mubu_text="%3Cspan%3E%E4%B8%80%E6%99%9A%E4%B8%8A%203-5%20cycles%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="每个cycle不一定完全相同" _mubu_text="%3Cspan%3E%E6%AF%8F%E4%B8%AAcycle%E4%B8%8D%E4%B8%80%E5%AE%9A%E5%AE%8C%E5%85%A8%E7%9B%B8%E5%90%8C%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="图" _mubu_text="%3Cspan%3E%E5%9B%BE%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22XtmmLEBQKs%22%2C%22oh%22%3A567%2C%22ow%22%3A791%2C%22uri%22%3A%22document_image%2F33585682_f8482587-3a92-4ecf-e2a3-1db620975d0c.png%22%2C%22w%22%3A400%7D%5D"/>
          <outline text="NREM Sleep" _mubu_text="%3Cspan%20class=%22text-color-red%22%3ENREM%20%3C/span%3E%3Cspan%3ESleep%3C/span%3E" _note="" _mubu_note="">
            <outline text="Stage 1：Light Sleep 浅睡" _mubu_text="%3Cspan%20class=%22bold%20underline%22%3EStage%201%EF%BC%9ALight%20Sleep%20%E6%B5%85%E7%9D%A1%3C/span%3E" _note="" _mubu_note="">
              <outline text="刚入睡 / 容易被叫醒 / hypnic jerks 突然抖一下 / “我没睡！”" _mubu_text="%3Cspan%3E%E5%88%9A%E5%85%A5%E7%9D%A1%20/%20%E5%AE%B9%E6%98%93%E8%A2%AB%E5%8F%AB%E9%86%92%20/%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3Ehypnic%20jerks%3C/span%3E%3Cspan%3E%20%E7%AA%81%E7%84%B6%E6%8A%96%E4%B8%80%E4%B8%8B%20/%20%E2%80%9C%E6%88%91%E6%B2%A1%E7%9D%A1%EF%BC%81%E2%80%9D%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="刚睡着，容易醒来" _mubu_text="%3Cspan%3E%E5%88%9A%E7%9D%A1%E7%9D%80%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%AE%B9%E6%98%93%E9%86%92%E6%9D%A5%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Stage 2：Sleep Spindles 纺锤线睡眠" _mubu_text="%3Cspan%20class=%22bold%20underline%22%3EStage%202%EF%BC%9ASleep%20Spindles%20%E7%BA%BA%E9%94%A4%E7%BA%BF%E7%9D%A1%E7%9C%A0%3C/span%3E" _note="" _mubu_note="">
              <outline text="睡得最多的阶段 ≈ 45%" _mubu_text="%3Cspan%3E%E7%9D%A1%E5%BE%97%E6%9C%80%E5%A4%9A%E7%9A%84%E9%98%B6%E6%AE%B5%20%E2%89%88%2045%25%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="body temperature + heart rate⬇" _mubu_text="%3Cspan%3Ebody%20temperature%20+%20heart%20rate%E2%AC%87%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="sleep spindles (纺锤线睡眠波) + sleep talking" _mubu_text="%3Cspan%3Esleep%20spindles%20(%E7%BA%BA%E9%94%A4%E7%BA%BF%E7%9D%A1%E7%9C%A0%E6%B3%A2)%20+%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%20sleep%20talking%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Stage 3 / 4：Deep Sleep (Slow-Wave Sleep)" _mubu_text="%3Cspan%20class=%22bold%20underline%22%3EStage%203%20/%204%EF%BC%9ADeep%20Sleep%20(Slow-Wave%20Sleep)%3C/span%3E" _note="" _mubu_note="">
              <outline text="delta waves / 最难叫醒 / 醒来会迷糊 / growth hormone 分泌" _mubu_text="%3Cspan%3Edelta%20waves%20/%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E6%9C%80%E9%9A%BE%E5%8F%AB%E9%86%92%3C/span%3E%3Cspan%3E%20/%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E9%86%92%E6%9D%A5%E4%BC%9A%E8%BF%B7%E7%B3%8A%3C/span%3E%3Cspan%3E%20/%20growth%20hormone%20%E5%88%86%E6%B3%8C%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="修复身体最重要的阶段" _mubu_text="%3Cspan%3E%E4%BF%AE%E5%A4%8D%E8%BA%AB%E4%BD%93%E6%9C%80%E9%87%8D%E8%A6%81%E7%9A%84%E9%98%B6%E6%AE%B5%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="REM Sleep" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EREM%20%3C/span%3E%3Cspan%3ESleep%3C/span%3E" _note="" _mubu_note="">
            <outline text="Paradoxical Sleep (矛盾的睡眠)" _mubu_text="%3Cspan%3EParadoxical%20Sleep%20(%E7%9F%9B%E7%9B%BE%E7%9A%84%E7%9D%A1%E7%9C%A0)%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="brain waves 和清醒差不多，heart rate + blood pressure ⬆" _mubu_text="%3Cspan%3Ebrain%20waves%20%E5%92%8C%3C/span%3E%3Cspan%20class=%22underline%22%3E%E6%B8%85%E9%86%92%E5%B7%AE%E4%B8%8D%E5%A4%9A%3C/span%3E%3Cspan%3E%EF%BC%8Cheart%20rate%20+%20blood%20pressure%20%E2%AC%86%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="muscles paralyzed 肌肉麻痹（防止你在梦里的动作带进现实）" _mubu_text="%3Cspan%3Emuscles%20paralyzed%20%E8%82%8C%E8%82%89%E9%BA%BB%E7%97%B9%EF%BC%88%E9%98%B2%E6%AD%A2%E4%BD%A0%E5%9C%A8%E6%A2%A6%E9%87%8C%E7%9A%84%E5%8A%A8%E4%BD%9C%E5%B8%A6%E8%BF%9B%E7%8E%B0%E5%AE%9E%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="vivid dreams 做梦" _mubu_text="%3Cspan%3Evivid%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Edreams%20%3C/span%3E%3Cspan%3E%E5%81%9A%E6%A2%A6%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="REM Rebound" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EREM%20Rebound%3C/span%3E" _note="" _mubu_note="">
              <outline text="睡眠剥夺后，REM时间会变长+更频繁" _mubu_text="%3Cspan%3E%E7%9D%A1%E7%9C%A0%E5%89%A5%E5%A4%BA%E5%90%8E%EF%BC%8CREM%E6%97%B6%E9%97%B4%E4%BC%9A%E5%8F%98%E9%95%BF+%E6%9B%B4%E9%A2%91%E7%B9%81%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="梦更vivid" _mubu_text="%3Cspan%3E%E6%A2%A6%E6%9B%B4vivid%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="年级越大，总睡眠时间减少 awake 的时间更多" _mubu_text="%3Cspan%3E%E5%B9%B4%E7%BA%A7%E8%B6%8A%E5%A4%A7%EF%BC%8C%E6%80%BB%E7%9D%A1%E7%9C%A0%E6%97%B6%E9%97%B4%E5%87%8F%E5%B0%91%20awake%20%E7%9A%84%E6%97%B6%E9%97%B4%E6%9B%B4%E5%A4%9A%3C/span%3E" _note="" _mubu_note="">
            <outline text="图（上面年轻人，下面老人）" _mubu_text="%3Cspan%3E%E5%9B%BE%EF%BC%88%E4%B8%8A%E9%9D%A2%E5%B9%B4%E8%BD%BB%E4%BA%BA%EF%BC%8C%E4%B8%8B%E9%9D%A2%E8%80%81%E4%BA%BA%EF%BC%89%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22XxjXT68mOc%22%2C%22oh%22%3A494%2C%22ow%22%3A591%2C%22uri%22%3A%22document_image%2F33585682_8c8e226f-57da-45af-948c-c0fd13954e2a.png%22%2C%22w%22%3A283%7D%5D"/>
          </outline>
        </outline>
        <outline text="6. Dreams 做梦" _mubu_text="%3Cspan%3E6.%20Dreams%20%E5%81%9A%E6%A2%A6%3C/span%3E" _note="" _mubu_note="">
          <outline text="人人都会做梦 / REM最容易回忆梦 / NREM也会做梦，但是fragmented" _mubu_text="%3Cspan%3E%E4%BA%BA%E4%BA%BA%E9%83%BD%E4%BC%9A%E5%81%9A%E6%A2%A6%20/%20REM%E6%9C%80%E5%AE%B9%E6%98%93%E5%9B%9E%E5%BF%86%E6%A2%A6%20/%20NREM%E4%B9%9F%E4%BC%9A%E5%81%9A%E6%A2%A6%EF%BC%8C%E4%BD%86%E6%98%AFfragmented%3C/span%3E" _note="" _mubu_note=""/>
