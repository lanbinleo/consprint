    </outline>
    <outline text="Unit 1（4550字）" _mubu_text="%3Cspan%3EUnit%201%EF%BC%88%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E4550%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
      <outline text="1.1 先天后天 Nature vs. Nurture（先天后天、遗传倾向、进化论、表观遗传学、Twins，200字）" _mubu_text="%3Cspan%3E1.1%20%E5%85%88%E5%A4%A9%E5%90%8E%E5%A4%A9%20Nature%20vs.%20Nurture%EF%BC%88%E5%85%88%E5%A4%A9%E5%90%8E%E5%A4%A9%E3%80%81%E9%81%97%E4%BC%A0%E5%80%BE%E5%90%91%E3%80%81%E8%BF%9B%E5%8C%96%E8%AE%BA%E3%80%81%E8%A1%A8%E8%A7%82%E9%81%97%E4%BC%A0%E5%AD%A6%E3%80%81Twins%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E200%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="Everything psychological is also biological." _mubu_text="%3Cspan%20class=%22text-color-blue%22%3EEverything%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3Epsychological%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%20is%20also%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3Ebiological%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E.%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="先天 vs. 后天" _mubu_text="%3Cspan%3E%E5%85%88%E5%A4%A9%20vs.%20%E5%90%8E%E5%A4%A9%3C/span%3E" _note="" _mubu_note="">
          <outline text="先天 Nature" _mubu_text="%3Cspan%3E%E5%85%88%E5%A4%A9%20N%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3Ea%3C/span%3E%3Cspan%3Eture%3C/span%3E" _note="" _mubu_note="">
            <outline text="基因与遗传因素" _mubu_text="%3Cspan%3E%E5%9F%BA%E5%9B%A0%E4%B8%8E%E9%81%97%E4%BC%A0%E5%9B%A0%E7%B4%A0%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="诸如：inherited traits, brain structure, temperament, genetic predisposition (遗传易感性, e.g. anxiety, intelligence)" _mubu_text="%3Cspan%3E%E8%AF%B8%E5%A6%82%EF%BC%9Ainherited%20traits,%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%20brain%20structure%3C/span%3E%3Cspan%3E,%20temperament,%20genetic%20predisposition%20(%E9%81%97%E4%BC%A0%E6%98%93%E6%84%9F%E6%80%A7,%20e.g.%20anxiety,%20intelligence)%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="后天 Nurture" _mubu_text="%3Cspan%3E%E5%90%8E%E5%A4%A9%20N%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3Eur%3C/span%3E%3Cspan%3Eture%3C/span%3E" _note="" _mubu_note="">
            <outline text="环境影响" _mubu_text="%3Cspan%3E%E7%8E%AF%E5%A2%83%E5%BD%B1%E5%93%8D%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="诸如：parenting styles, education, culture, life experiences" _mubu_text="%3Cspan%3E%E8%AF%B8%E5%A6%82%EF%BC%9A%3C/span%3E%3Cspan%20class=%22text-color-green%22%3Eparenting%3C/span%3E%3Cspan%3E%20styles,%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3Eeducation%3C/span%3E%3Cspan%3E,%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3Eculture%3C/span%3E%3Cspan%3E,%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3Elife%20experiences%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
        </outline>
        <outline text="Genetic Predisposition" _mubu_text="%3Cspan%3EGenetic%20Predisposition%3C/span%3E" _note="" _mubu_note="">
          <outline text="遗传倾向，不是基因决定命运" _mubu_text="%3Cspan%3E%E9%81%97%E4%BC%A0%E5%80%BE%E5%90%91%EF%BC%8C%E4%B8%8D%E6%98%AF%E5%9F%BA%E5%9B%A0%E5%86%B3%E5%AE%9A%E5%91%BD%E8%BF%90%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="不是你生出来易怒就是废物" _mubu_text="%3Cspan%3E%E4%B8%8D%E6%98%AF%E4%BD%A0%E7%94%9F%E5%87%BA%E6%9D%A5%E6%98%93%E6%80%92%E5%B0%B1%E6%98%AF%E5%BA%9F%E7%89%A9%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="后天环境仍然可以让你改变，获得成功" _mubu_text="%3Cspan%3E%E5%90%8E%E5%A4%A9%E7%8E%AF%E5%A2%83%E4%BB%8D%E7%84%B6%E5%8F%AF%E4%BB%A5%E8%AE%A9%E4%BD%A0%E6%94%B9%E5%8F%98%EF%BC%8C%E8%8E%B7%E5%BE%97%E6%88%90%E5%8A%9F%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Evolutionary Psychology (Link: Evolutionary perspective)" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EEvolutionary%20Psychology%3C/span%3E%3Cspan%3E%20(Link:%20%3C/span%3E%3Cspan%20class=%22node-mention%22%20id=%22SKj2mdMNQg%22%20spellcheck=%22false%22%20contenteditable=%22false%22%20data-doc=%221qN74cOm072%22%20data-node=%22cn9cBEbxQM%22%20data-text=%22%255B%257B%2522type%2522%253A1%252C%2522text%2522%253A%2522Evolutionary%2520perspective%2522%252C%2522style%2522%253A%257B%257D%257D%255D%22%3E%3Cspan%3EEvolutionary%20perspective%3C/span%3E%3C/span%3E%3Cspan%3E%3C/span%3E%3Cspan%3E)%3C/span%3E" _note="" _mubu_note="">
          <outline text="进化心理学，核心来自Darwin的Natural Selection, 自然选择" _mubu_text="%3Cspan%3E%E8%BF%9B%E5%8C%96%E5%BF%83%E7%90%86%E5%AD%A6%EF%BC%8C%E6%A0%B8%E5%BF%83%E6%9D%A5%E8%87%AADarwin%E7%9A%84%3C/span%3E%3Cspan%20class=%22text-color-red%22%3ENatural%20Selectio%3C/span%3E%3Cspan%3En,%20%E8%87%AA%E7%84%B6%E9%80%89%E6%8B%A9%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="Core: 我们今天的很多行为，源于祖先生存和繁殖的需要" _mubu_text="%3Cspan%3ECore:%20%E6%88%91%E4%BB%AC%E4%BB%8A%E5%A4%A9%E7%9A%84%E5%BE%88%E5%A4%9A%E8%A1%8C%E4%B8%BA%EF%BC%8C%E6%BA%90%E4%BA%8E%E7%A5%96%E5%85%88%E7%94%9F%E5%AD%98%E5%92%8C%E7%B9%81%E6%AE%96%E7%9A%84%E9%9C%80%E8%A6%81%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="（可能有一些hindsight explanations，同时也不能直接test scientifically）" _mubu_text="%3Cspan%3E%EF%BC%88%E5%8F%AF%E8%83%BD%E6%9C%89%E4%B8%80%E4%BA%9Bhindsight%20explanations%EF%BC%8C%E5%90%8C%E6%97%B6%E4%B9%9F%E4%B8%8D%E8%83%BD%E7%9B%B4%E6%8E%A5test%20scientifically%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="优生学 Eugenics, by Galton，错误且歧视性的应用" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E4%BC%98%E7%94%9F%E5%AD%A6%20Eugenics,%20by%20Galton%3C/span%3E%3Cspan%3E%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E9%94%99%E8%AF%AF%3C/span%3E%3Cspan%3E%E4%B8%94%E6%AD%A7%E8%A7%86%E6%80%A7%E7%9A%84%E5%BA%94%E7%94%A8%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Epigenetics 表观遗传学" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EEpigenetics%3C/span%3E%3Cspan%3E%20%E8%A1%A8%E8%A7%82%E9%81%97%E4%BC%A0%E5%AD%A6%3C/span%3E" _note="" _mubu_note="">
          <outline text="环境可以 turn genes ON or OFF without changing DNA" _mubu_text="%3Cspan%3E%E7%8E%AF%E5%A2%83%E5%8F%AF%E4%BB%A5%20turn%20genes%20ON%20or%20OFF%20without%20changing%20DNA%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="蜜蜂蜂后，是环境决定哪只成为蜂后的（Kind of）" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E8%9C%9C%E8%9C%82%E8%9C%82%E5%90%8E%3C/span%3E%3Cspan%3E%EF%BC%8C%E6%98%AF%E7%8E%AF%E5%A2%83%E5%86%B3%E5%AE%9A%E5%93%AA%E5%8F%AA%E6%88%90%E4%B8%BA%E8%9C%82%E5%90%8E%E7%9A%84%EF%BC%88Kind%20of%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
        </outline>
        <outline text="Twins / Adoption / Family Studies 好好读题分析" _mubu_text="%3Cspan%3ETwins%20/%20Adoption%20/%20Family%20Studies%3C/span%3E%3Cspan%20class=%22text-color-purple%22%3E%20%E5%A5%BD%E5%A5%BD%E8%AF%BB%E9%A2%98%E5%88%86%E6%9E%90%3C/span%3E" _note="" _mubu_note=""/>
      </outline>
      <outline text="1.2 神经系统 Nervous System（神经系统结构，200字）" _mubu_text="%3Cspan%3E1.2%20%E7%A5%9E%E7%BB%8F%E7%B3%BB%E7%BB%9F%20Nervous%20System%EF%BC%88%E7%A5%9E%E7%BB%8F%E7%B3%BB%E7%BB%9F%E7%BB%93%E6%9E%84%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E200%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="The nervous system is the body&apos;s communication network" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3EThe%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3Enervous%20system%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%20is%20the%20body&apos;s%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3Ecommunication%20network%3C/span%3E" _note="" _mubu_note=""/>
        <outline text="结构" _mubu_text="%3Cspan%3E%E7%BB%93%E6%9E%84%3C/span%3E" _note="" _mubu_note="">
          <outline text="Central Nervous System CNS" _mubu_text="%3Cspan%3ECentral%20Nervous%20System%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3ECNS%3C/span%3E" _note="" _mubu_note="">
            <outline text="大脑和脊柱都是CNS的一部分" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E5%A4%A7%E8%84%91%E5%92%8C%E8%84%8A%E6%9F%B1%3C/span%3E%3Cspan%3E%E9%83%BD%E6%98%AFCNS%E7%9A%84%E4%B8%80%E9%83%A8%E5%88%86%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Peripheral Nervous System PNS" _mubu_text="%3Cspan%3EPeripheral%20Nervous%20System%20%3C/span%3E%3Cspan%20class=%22text-color-red%22%3EPNS%3C/span%3E" _note="" _mubu_note="">
            <outline text="分为两条路" _mubu_text="%3Cspan%3E%E5%88%86%E4%B8%BA%E4%B8%A4%E6%9D%A1%E8%B7%AF%3C/span%3E" _note="" _mubu_note="">
              <outline text="Sensory pathway - body to brain" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3ESensory%20%3C/span%3E%3Cspan%3Epathway%20-%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3Ebody%20to%20brain%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Motor pathway - brain to muscles / glands." _mubu_text="%3Cspan%20class=%22text-color-blue%22%3EMotor%20%3C/span%3E%3Cspan%3Epathway%20-%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3Ebrain%20to%20muscles%20/%20%3C/span%3E%3Cspan%20class=%22underline%20text-color-yellow%22%3Eglands%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E.%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="包含两大系统" _mubu_text="%3Cspan%3E%E5%8C%85%E5%90%AB%E4%B8%A4%E5%A4%A7%E7%B3%BB%E7%BB%9F%3C/span%3E" _note="" _mubu_note="">
              <outline text="Somatic Nervous System" _mubu_text="%3Cspan%3ESomatic%20Nervous%20System%3C/span%3E" _note="" _mubu_note="">
                <outline text="控制Voluntary Movement" _mubu_text="%3Cspan%3E%E6%8E%A7%E5%88%B6Voluntary%20Movement%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="Autonomic Nervous System ANS" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EAutonomic%20%3C/span%3E%3Cspan%3ENervous%20System%20ANS%3C/span%3E" _note="" _mubu_note="">
                <outline text="控制glands和internal organs" _mubu_text="%3Cspan%3E%E6%8E%A7%E5%88%B6glands%E5%92%8Cinternal%20organs%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="分成2个系统" _mubu_text="%3Cspan%3E%E5%88%86%E6%88%902%E4%B8%AA%E7%B3%BB%E7%BB%9F%3C/span%3E" _note="" _mubu_note="">
                  <outline text="Sympathetic Nervous System 交感神经系统" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ESympathetic%20%3C/span%3E%3Cspan%3ENervous%20System%20%E4%BA%A4%E6%84%9F%E7%A5%9E%E7%BB%8F%E7%B3%BB%E7%BB%9F%3C/span%3E" _note="" _mubu_note="">
                    <outline text="战逃僵 Fight / Flight / Freeze" _mubu_text="%3Cspan%3E%E6%88%98%E9%80%83%E5%83%B5%20%3C/span%3E%3Cspan%20class=%22underline%22%3EFight%20/%20Flight%20/%20Freeze%3C/span%3E" _note="" _mubu_note=""/>
                    <outline text="Arousing body" _mubu_text="%3Cspan%3EArousing%20body%3C/span%3E" _note="" _mubu_note=""/>
                    <outline text="增加心率，增加血糖，减少消化" _mubu_text="%3Cspan%3E%E5%A2%9E%E5%8A%A0%E5%BF%83%E7%8E%87%EF%BC%8C%E5%A2%9E%E5%8A%A0%E8%A1%80%E7%B3%96%EF%BC%8C%E5%87%8F%E5%B0%91%E6%B6%88%E5%8C%96%3C/span%3E" _note="" _mubu_note=""/>
                  </outline>
                  <outline text="Parasympathetic Nervous System 副交感神经系统" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EParasympathetic%20%3C/span%3E%3Cspan%3ENervous%20System%20%E5%89%AF%E4%BA%A4%E6%84%9F%E7%A5%9E%E7%BB%8F%E7%B3%BB%E7%BB%9F%3C/span%3E" _note="" _mubu_note="">
                    <outline text="Rest &amp; Digest, Calming" _mubu_text="%3Cspan%20class=%22underline%22%3ERest%20&amp;amp;%20Digest,%20Calming%3C/span%3E" _note="" _mubu_note=""/>
                    <outline text="减少心率，增加Digestion" _mubu_text="%3Cspan%3E%E5%87%8F%E5%B0%91%E5%BF%83%E7%8E%87%EF%BC%8C%E5%A2%9E%E5%8A%A0Digestion%3C/span%3E" _note="" _mubu_note=""/>
                  </outline>
                </outline>
              </outline>
            </outline>
          </outline>
        </outline>
        <outline text="总结结构" _mubu_text="%3Cspan%20class=%22bold%20text-color-yellow%22%3E%E6%80%BB%E7%BB%93%E7%BB%93%E6%9E%84%3C/span%3E" _note="" _mubu_note="">
          <outline text="NS 神经系统" _mubu_text="%3Cspan%3ENS%20%E7%A5%9E%E7%BB%8F%E7%B3%BB%E7%BB%9F%3C/span%3E" _note="" _mubu_note="">
            <outline text="CNS 中枢神经系统" _mubu_text="%3Cspan%3ECNS%20%E4%B8%AD%E6%9E%A2%E7%A5%9E%E7%BB%8F%E7%B3%BB%E7%BB%9F%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="PNS 周围神经系统" _mubu_text="%3Cspan%3EPNS%20%E5%91%A8%E5%9B%B4%E7%A5%9E%E7%BB%8F%E7%B3%BB%E7%BB%9F%3C/span%3E" _note="" _mubu_note="">
              <outline text="Somatic NS 躯体神经系统（控制的是意志可以自主操控的）" _mubu_text="%3Cspan%3ESomatic%20NS%20%E8%BA%AF%E4%BD%93%E7%A5%9E%E7%BB%8F%E7%B3%BB%E7%BB%9F%EF%BC%88%E6%8E%A7%E5%88%B6%E7%9A%84%E6%98%AF%E6%84%8F%E5%BF%97%E5%8F%AF%E4%BB%A5%E8%87%AA%E4%B8%BB%E6%93%8D%E6%8E%A7%E7%9A%84%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="ANS 自主神经系统（但是控制的是意志不能自主操控的）" _mubu_text="%3Cspan%3EANS%20%E8%87%AA%E4%B8%BB%E7%A5%9E%E7%BB%8F%E7%B3%BB%E7%BB%9F%EF%BC%88%E4%BD%86%E6%98%AF%E6%8E%A7%E5%88%B6%E7%9A%84%E6%98%AF%E6%84%8F%E5%BF%97%E4%B8%8D%E8%83%BD%E8%87%AA%E4%B8%BB%E6%93%8D%E6%8E%A7%E7%9A%84%EF%BC%89%3C/span%3E" _note="自主指的是站在神经系统的视角下是自主控制，不需要经过意识处理" _mubu_note="%3Cspan%3E%E8%87%AA%E4%B8%BB%E6%8C%87%E7%9A%84%E6%98%AF%E7%AB%99%E5%9C%A8%E7%A5%9E%E7%BB%8F%E7%B3%BB%E7%BB%9F%E7%9A%84%E8%A7%86%E8%A7%92%E4%B8%8B%E6%98%AF%E8%87%AA%E4%B8%BB%E6%8E%A7%E5%88%B6%EF%BC%8C%E4%B8%8D%E9%9C%80%E8%A6%81%E7%BB%8F%E8%BF%87%E6%84%8F%E8%AF%86%E5%A4%84%E7%90%86%3C/span%3E">
                <outline text="Sympathetic 战逃僵" _mubu_text="%3Cspan%3ESympathetic%20%E6%88%98%E9%80%83%E5%83%B5%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="Parasympathetic 舒缓下来" _mubu_text="%3Cspan%3EParasympathetic%20%E8%88%92%E7%BC%93%E4%B8%8B%E6%9D%A5%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
          </outline>
        </outline>
      </outline>
      <outline text="1.3 神经 Neuron &amp; Neuron Firing（神经、神经递质、内分泌系统，1050字）" _mubu_text="%3Cspan%3E1.3%20%E7%A5%9E%E7%BB%8F%20Neuron%20&amp;amp;%20Neuron%20Firing%EF%BC%88%E7%A5%9E%E7%BB%8F%E3%80%81%E7%A5%9E%E7%BB%8F%E9%80%92%E8%B4%A8%E3%80%81%E5%86%85%E5%88%86%E6%B3%8C%E7%B3%BB%E7%BB%9F%EF%BC%8C%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E1050%E5%AD%97%3C/span%3E%3Cspan%3E%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
        <outline text="Neurons" _mubu_text="%3Cspan%3ENeurons%3C/span%3E" _note="" _mubu_note="">
          <outline text="神经元：basic structural and functional unit -&gt; send messages using electrochemical signals" _mubu_text="%3Cspan%3E%E7%A5%9E%E7%BB%8F%E5%85%83%EF%BC%9Abasic%20structural%20and%20functional%20unit%20-&amp;gt;%20%3C/span%3E%3Cspan%20class=%22bold%22%3Esend%20messages%20using%20%3C/span%3E%3Cspan%20class=%22bold%20text-color-blue%22%3Eelectrochemical%20%3C/span%3E%3Cspan%20class=%22bold%22%3Esignals%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="三种神经元" _mubu_text="%3Cspan%3E%E4%B8%89%E7%A7%8D%E7%A5%9E%E7%BB%8F%E5%85%83%3C/span%3E" _note="" _mubu_note="">
            <outline text="Sensory Neuron 传入神经元" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ESensory%20%3C/span%3E%3Cspan%3ENeuron%20%E4%BC%A0%E5%85%A5%E7%A5%9E%E7%BB%8F%E5%85%83%3C/span%3E" _note="" _mubu_note="">
              <outline text="从周围的Sensory Receptor到CNS" _mubu_text="%3Cspan%3E%E4%BB%8E%E5%91%A8%E5%9B%B4%E7%9A%84%3C/span%3E%3Cspan%20class=%22underline%22%3ESensory%20Receptor%E5%88%B0CNS%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="负责感受，pain / light / sound ..." _mubu_text="%3Cspan%3E%E8%B4%9F%E8%B4%A3%E6%84%9F%E5%8F%97%EF%BC%8Cpain%20/%20light%20/%20sound%20...%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Motor Neuron 传出神经元" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EMotor%20%3C/span%3E%3Cspan%3ENeuron%20%E4%BC%A0%E5%87%BA%E7%A5%9E%E7%BB%8F%E5%85%83%3C/span%3E" _note="" _mubu_note="">
              <outline text="从CNS到周围的肌肉 / glands" _mubu_text="%3Cspan%3E%E4%BB%8E%3C/span%3E%3Cspan%20class=%22underline%22%3ECNS%E5%88%B0%E5%91%A8%E5%9B%B4%E7%9A%84%E8%82%8C%E8%82%89%20/%20%3C/span%3E%3Cspan%20class=%22bold%20underline%22%3Eglands%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="负责行动，movement" _mubu_text="%3Cspan%3E%E8%B4%9F%E8%B4%A3%E8%A1%8C%E5%8A%A8%EF%BC%8Cmovement%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Interneuron 中间神经元" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EInterneuron%20%3C/span%3E%3Cspan%3E%E4%B8%AD%E9%97%B4%E7%A5%9E%E7%BB%8F%E5%85%83%3C/span%3E" _note="" _mubu_note="">
              <outline text="在CNS中（Brain和Spinal Cord）" _mubu_text="%3Cspan%20class=%22text-color-red%22%3E%E5%9C%A8CNS%E4%B8%AD%3C/span%3E%3Cspan%3E%EF%BC%88Brain%E5%92%8CSpinal%20Cord%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="负责连接 sensory 和 motor" _mubu_text="%3Cspan%3E%E8%B4%9F%E8%B4%A3%E8%BF%9E%E6%8E%A5%20sensory%20%E5%92%8C%20motor%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="产生reflex（反射，碰到烫的手会收回来）" _mubu_text="%3Cspan%3E%E4%BA%A7%E7%94%9F%3C/span%3E%3Cspan%20class=%22text-color-red%22%3Ereflex%3C/span%3E%3Cspan%3E%EF%BC%88%E5%8F%8D%E5%B0%84%EF%BC%8C%E7%A2%B0%E5%88%B0%E7%83%AB%E7%9A%84%E6%89%8B%E4%BC%9A%E6%94%B6%E5%9B%9E%E6%9D%A5%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
                <outline text="reflex arc（反射弧）" _mubu_text="%3Cspan%3Ereflex%20arc%EF%BC%88%E5%8F%8D%E5%B0%84%E5%BC%A7%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="Receptor → Sensory → Interneuron (spinal cord) → Motor" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3EReceptor%20%3C/span%3E%3Cspan%3E%E2%86%92%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3ESensory%20%3C/span%3E%3Cspan%3E%E2%86%92%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EInterneuron%20%3C/span%3E%3Cspan%3E(spinal%20cord)%20%E2%86%92%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EMotor%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="不需要经过大脑" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3E%E4%B8%8D%E9%9C%80%E8%A6%81%3C/span%3E%3Cspan%20class=%22bold%22%3E%E7%BB%8F%E8%BF%87%E5%A4%A7%E8%84%91%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
          </outline>
          <outline text="Neuron的结构" _mubu_text="%3Cspan%3ENeuron%E7%9A%84%E7%BB%93%E6%9E%84%3C/span%3E" _note="" _mubu_note="">
            <outline text="图例" _mubu_text="%3Cspan%3E%E5%9B%BE%E4%BE%8B%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22duXlc98qt7%22%2C%22oh%22%3A425%2C%22ow%22%3A812%2C%22uri%22%3A%22document_image%2F33585682_20d6afbb-5b83-4108-d50f-810e73a54332.png%22%2C%22w%22%3A400%7D%5D"/>
            <outline text="Dendrites 树突" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EDendrites%20%3C/span%3E%3Cspan%3E%E6%A0%91%E7%AA%81%3C/span%3E" _note="" _mubu_note="">
              <outline text="接受别的神经元传来的信息" _mubu_text="%3Cspan%3E%E6%8E%A5%E5%8F%97%E5%88%AB%E7%9A%84%E7%A5%9E%E7%BB%8F%E5%85%83%E4%BC%A0%E6%9D%A5%E7%9A%84%E4%BF%A1%E6%81%AF%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Soma / Cell Body (Life Support) 胞体" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ESoma%20/%20Cell%20Body%3C/span%3E%3Cspan%3E%20(Life%20Support)%20%E8%83%9E%E4%BD%93%3C/span%3E" _note="" _mubu_note="">
              <outline text="维持该神经元的活性" _mubu_text="%3Cspan%3E%E7%BB%B4%E6%8C%81%E8%AF%A5%E7%A5%9E%E7%BB%8F%E5%85%83%E7%9A%84%E6%B4%BB%E6%80%A7%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="整合Neurotransmitters的信号（决定要不要传递下去）" _mubu_text="%3Cspan%3E%E6%95%B4%E5%90%88Neurotransmitters%E7%9A%84%E4%BF%A1%E5%8F%B7%EF%BC%88%E5%86%B3%E5%AE%9A%E8%A6%81%E4%B8%8D%E8%A6%81%E4%BC%A0%E9%80%92%E4%B8%8B%E5%8E%BB%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Axon 轴突" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3EAxon%20%3C/span%3E%3Cspan%3E%E8%BD%B4%E7%AA%81%3C/span%3E" _note="" _mubu_note="">
              <outline text="把信息传递下去" _mubu_text="%3Cspan%3E%E6%8A%8A%E4%BF%A1%E6%81%AF%E4%BC%A0%E9%80%92%E4%B8%8B%E5%8E%BB%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="carries messages OUT" _mubu_text="%3Cspan%3Ecarries%20messages%20OUT%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Myelin Sheath 髓鞘" _mubu_text="%3Cspan%20class=%22bold%20underline%20text-color-yellow%22%3EMyelin%20Sheath%3C/span%3E%3Cspan%3E%20%E9%AB%93%E9%9E%98%3C/span%3E" _note="" _mubu_note="">
              <outline text="很厚的绝缘层，同时可以加快传递速度" _mubu_text="%3Cspan%3E%E5%BE%88%E5%8E%9A%E7%9A%84%E7%BB%9D%E7%BC%98%E5%B1%82%EF%BC%8C%E5%90%8C%E6%97%B6%E5%8F%AF%E4%BB%A5%E5%8A%A0%E5%BF%AB%E4%BC%A0%E9%80%92%E9%80%9F%E5%BA%A6%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="如果受损 → Multiple Sclerosis（MS，多发性硬化症）" _mubu_text="%3Cspan%3E%E5%A6%82%E6%9E%9C%E5%8F%97%E6%8D%9F%20%E2%86%92%20%3C/span%3E%3Cspan%20class=%22text-color-green%22%3EMultiple%20Sclerosis%3C/span%3E%3Cspan%3E%EF%BC%88MS%EF%BC%8C%E5%A4%9A%E5%8F%91%E6%80%A7%E7%A1%AC%E5%8C%96%E7%97%87%EF%BC%89%3C/span%3E" _note="想想看，消息会从一个神经元跑到其他的神经元，造成混乱。其特征是大脑或脊髓中出现硬化斑块，并且常伴有部分或完全瘫痪以及肌肉抽搐震颤等症状。" _mubu_note="%3Cspan%3E%E6%83%B3%E6%83%B3%E7%9C%8B%EF%BC%8C%E6%B6%88%E6%81%AF%E4%BC%9A%E4%BB%8E%E4%B8%80%E4%B8%AA%E7%A5%9E%E7%BB%8F%E5%85%83%E8%B7%91%E5%88%B0%E5%85%B6%E4%BB%96%E7%9A%84%E7%A5%9E%E7%BB%8F%E5%85%83%EF%BC%8C%E9%80%A0%E6%88%90%E6%B7%B7%E4%B9%B1%E3%80%82%E5%85%B6%E7%89%B9%E5%BE%81%E6%98%AF%E5%A4%A7%E8%84%91%E6%88%96%E8%84%8A%E9%AB%93%E4%B8%AD%E5%87%BA%E7%8E%B0%E7%A1%AC%E5%8C%96%E6%96%91%E5%9D%97%EF%BC%8C%E5%B9%B6%E4%B8%94%E5%B8%B8%E4%BC%B4%E6%9C%89%E9%83%A8%E5%88%86%E6%88%96%E5%AE%8C%E5%85%A8%E7%98%AB%E7%97%AA%E4%BB%A5%E5%8F%8A%E8%82%8C%E8%82%89%E6%8A%BD%E6%90%90%E9%9C%87%E9%A2%A4%E7%AD%89%E7%97%87%E7%8A%B6%E3%80%82%3C/span%3E"/>
            </outline>
            <outline text="Axon Terminals 轴突末梢" _mubu_text="%3Cspan%3EAxon%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3ETerminals%20%3C/span%3E%3Cspan%3E%E8%BD%B4%E7%AA%81%E6%9C%AB%E6%A2%A2%3C/span%3E" _note="" _mubu_note="">
              <outline text="整个神经元的结尾" _mubu_text="%3Cspan%3E%E6%95%B4%E4%B8%AA%E7%A5%9E%E7%BB%8F%E5%85%83%E7%9A%84%E7%BB%93%E5%B0%BE%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="释放 Neurotransmitters" _mubu_text="%3Cspan%3E%E9%87%8A%E6%94%BE%20Neurotransmitters%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Glial Cells 胶质细胞" _mubu_text="%3Cspan%20class=%22bold%20text-color-red%22%3EGlial%20Cells%3C/span%3E%3Cspan%20class=%22bold%22%3E%20%E8%83%B6%E8%B4%A8%E7%BB%86%E8%83%9E%3C/span%3E" _note="" _mubu_note="">
              <outline text="支撑神经元，提供营养和绝缘效果" _mubu_text="%3Cspan%20class=%22bold%20underline%22%3E%E6%94%AF%E6%92%91%E7%A5%9E%E7%BB%8F%E5%85%83%EF%BC%8C%E6%8F%90%E4%BE%9B%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-blue%22%3E%E8%90%A5%E5%85%BB%E5%92%8C%E7%BB%9D%E7%BC%98%3C/span%3E%3Cspan%20class=%22bold%20underline%22%3E%E6%95%88%E6%9E%9C%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="do NOT transmit impluses" _mubu_text="%3Cspan%20class=%22bold%22%3Edo%20%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-red%22%3ENOT%3C/span%3E%3Cspan%20class=%22bold%20text-color-red%22%3E%20%3C/span%3E%3Cspan%20class=%22bold%22%3Etransmit%20impluses%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="Neural Transmission = 电 + 化学 (electrochemically)" _mubu_text="%3Cspan%3ENeural%20Transmission%20=%20%E7%94%B5%20+%20%E5%8C%96%E5%AD%A6%20(electrochemically)%3C/span%3E" _note="" _mubu_note="">
            <outline text="Electrical 发生在神经元内部" _mubu_text="%3Cspan%3EElectrical%20%E5%8F%91%E7%94%9F%E5%9C%A8%E7%A5%9E%E7%BB%8F%E5%85%83%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3E%E5%86%85%E9%83%A8%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Chemical 发生在 neuron 和 neuron 之间，通过 neurotransmitters" _mubu_text="%3Cspan%3EChemical%20%E5%8F%91%E7%94%9F%E5%9C%A8%20neuron%20%E5%92%8C%20neuron%20%E4%B9%8B%E9%97%B4%EF%BC%8C%E9%80%9A%E8%BF%87%20neurotransmitters%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Action Potential 动作电位（神经元如何交流？）" _mubu_text="%3Cspan%3EAction%20Potential%20%E5%8A%A8%E4%BD%9C%E7%94%B5%E4%BD%8D%EF%BC%88%E7%A5%9E%E7%BB%8F%E5%85%83%E5%A6%82%E4%BD%95%E4%BA%A4%E6%B5%81%EF%BC%9F%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
            <outline text="Timeline" _mubu_text="%3Cspan%3ETimeline%3C/span%3E" _note="" _mubu_note="">
              <outline text="1️⃣ Resting Potential（静息电位）" _mubu_text="%3Cspan%3E1%EF%B8%8F%E2%83%A3%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EResting%20%3C/span%3E%3Cspan%3EPotential%EF%BC%88%E9%9D%99%E6%81%AF%E7%94%B5%E4%BD%8D%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
                <outline text="neuron is polarized" _mubu_text="%3Cspan%3Eneuron%20is%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3Epolarized%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="about –70 mV" _mubu_text="%3Cspan%3Eabout%20%E2%80%9370%20mV%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="ready but not firing" _mubu_text="%3Cspan%3Eready%20but%20not%20firing%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="极化，像是拉开的弓，但没发射" _mubu_text="%3Cspan%3E%E6%9E%81%E5%8C%96%EF%BC%8C%E5%83%8F%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%8B%89%E5%BC%80%E7%9A%84%E5%BC%93%EF%BC%8C%E4%BD%86%E6%B2%A1%E5%8F%91%E5%B0%84%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="2️⃣ Threshold（阈值）" _mubu_text="%3Cspan%3E2%EF%B8%8F%E2%83%A3%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EThreshold%3C/span%3E%3Cspan%3E%EF%BC%88%E9%98%88%E5%80%BC%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
                <outline text="–55 mV" _mubu_text="%3Cspan%3E%E2%80%9355%20mV%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="reached → fire" _mubu_text="%3Cspan%3Ereached%20%E2%86%92%20fire%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="not reached → no fire" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3Enot%20reached%20%E2%86%92%20no%20fire%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="当刺激足够的时候，才会爆发动作电位" _mubu_text="%3Cspan%3E%E5%BD%93%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3E%E5%88%BA%E6%BF%80%E8%B6%B3%E5%A4%9F%3C/span%3E%3Cspan%3E%E7%9A%84%E6%97%B6%E5%80%99%EF%BC%8C%E6%89%8D%E4%BC%9A%E7%88%86%E5%8F%91%E5%8A%A8%E4%BD%9C%E7%94%B5%E4%BD%8D%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="3️⃣ Depolarization（去极化）" _mubu_text="%3Cspan%3E3%EF%B8%8F%E2%83%A3%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3EDepolarization%3C/span%3E%3Cspan%3E%EF%BC%88%E5%8E%BB%E6%9E%81%E5%8C%96%EF%BC%89%3C/span%3E" _note="" _mubu_note="">
                <outline text="Na⁺ rushes in" _mubu_text="%3Cspan%3ENa%E2%81%BA%20rushes%20in%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="electrical impulse travels down axon" _mubu_text="%3Cspan%3Eelectrical%20impulse%20travels%20down%20axon%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="钠通道打开，电压从-55mV变到+40mV" _mubu_text="%3Cspan%3E%E9%92%A0%E9%80%9A%E9%81%93%E6%89%93%E5%BC%80%EF%BC%8C%E7%94%B5%E5%8E%8B%E4%BB%8E-55mV%E5%8F%98%E5%88%B0+40mV%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="开火" _mubu_text="%3Cspan%20class=%22text-color-green%22%3E%E5%BC%80%E7%81%AB%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
              <outline text="4️⃣ Repolarization / Hyperpolarization" _mubu_text="%3Cspan%3E4%EF%B8%8F%E2%83%A3%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3ERepolarization%20%3C/span%3E%3Cspan%3E/%20Hyperpolarization%3C/span%3E" _note="" _mubu_note="">
                <outline text="K⁺ exits" _mubu_text="%3Cspan%3EK%E2%81%BA%20exits%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="neuron resets" _mubu_text="%3Cspan%3Eneuron%20resets%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="复极化，慢慢排出钾离子，" _mubu_text="%3Cspan%3E%E5%A4%8D%E6%9E%81%E5%8C%96%EF%BC%8C%E6%85%A2%E6%85%A2%E6%8E%92%E5%87%BA%E9%92%BE%E7%A6%BB%E5%AD%90%EF%BC%8C%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="超极化（排出的钾离子太多，-90mV）导致弓没有拉满" _mubu_text="%3Cspan%3E%E8%B6%85%E6%9E%81%E5%8C%96%EF%BC%88%E6%8E%92%E5%87%BA%E7%9A%84%E9%92%BE%E7%A6%BB%E5%AD%90%E5%A4%AA%E5%A4%9A%EF%BC%8C-90mV%EF%BC%89%E5%AF%BC%E8%87%B4%E5%BC%93%E6%B2%A1%E6%9C%89%E6%8B%89%E6%BB%A1%3C/span%3E" _note="" _mubu_note=""/>
                <outline text="导致了不应期：在这个阶段，不能发射" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3E%E5%AF%BC%E8%87%B4%E4%BA%86%E4%B8%8D%E5%BA%94%E6%9C%9F%3C/span%3E%3Cspan%3E%EF%BC%9A%E5%9C%A8%E8%BF%99%E4%B8%AA%E9%98%B6%E6%AE%B5%EF%BC%8C%E4%B8%8D%E8%83%BD%E5%8F%91%E5%B0%84%3C/span%3E" _note="" _mubu_note=""/>
              </outline>
            </outline>
            <outline text="全有或全无 All-or-None" _mubu_text="%3Cspan%20class=%22bold%20underline%22%3E%E5%85%A8%E6%9C%89%E6%88%96%E5%85%A8%E6%97%A0%20%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-red%22%3EAll-or-None%3C/span%3E" _note="" _mubu_note="">
              <outline text="像是扣动扳机，没有说只扣动一半" _mubu_text="%3Cspan%3E%E5%83%8F%E6%98%AF%3C/span%3E%3Cspan%20class=%22text-color-green%22%3E%E6%89%A3%E5%8A%A8%E6%89%B3%E6%9C%BA%EF%BC%8C%E6%B2%A1%E6%9C%89%E8%AF%B4%E5%8F%AA%E6%89%A3%E5%8A%A8%E4%B8%80%E5%8D%8A%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="strength ≠ size of action potential" _mubu_text="%3Cspan%20class=%22bold%20underline%20text-color-yellow%22%3Estrength%20%3C/span%3E%3Cspan%20class=%22bold%20underline%22%3E%E2%89%A0%20%3C/span%3E%3Cspan%20class=%22bold%20underline%20text-color-yellow%22%3Esize%20of%20action%20potential%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
            <outline text="Refractory Period 不应期" _mubu_text="%3Cspan%3ERefractory%20Period%20%E4%B8%8D%E5%BA%94%E6%9C%9F%3C/span%3E" _note="" _mubu_note="">
              <outline text="绝对不应期 无法发射" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E7%BB%9D%E5%AF%B9%3C/span%3E%3Cspan%3E%E4%B8%8D%E5%BA%94%E6%9C%9F%20%E6%97%A0%E6%B3%95%E5%8F%91%E5%B0%84%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="相对不应期 需要更强的刺激" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3E%E7%9B%B8%E5%AF%B9%3C/span%3E%3Cspan%3E%E4%B8%8D%E5%BA%94%E6%9C%9F%20%E9%9C%80%E8%A6%81%E6%9B%B4%E5%BC%BA%E7%9A%84%E5%88%BA%E6%BF%80%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
        </outline>
        <outline text="Neurotransmitters" _mubu_text="%3Cspan%3ENeurotransmitters%3C/span%3E" _note="" _mubu_note="">
          <outline text="Synapse &amp; Neurotransmitters 化学部分" _mubu_text="%3Cspan%3ESynapse%20&amp;amp;%20Neurotransmitters%20%E5%8C%96%E5%AD%A6%E9%83%A8%E5%88%86%3C/span%3E" _note="" _mubu_note="">
            <outline text="Synapse = gap between neurons" _mubu_text="%3Cspan%20class=%22text-color-red%22%3ESynapse%20%3C/span%3E%3Cspan%3E=%20gap%20between%20neurons%3C/span%3E" _note="" _mubu_note="" _mubu_images="%5B%7B%22id%22%3A%22PtZW5im8nv%22%2C%22oh%22%3A635%2C%22ow%22%3A578%2C%22uri%22%3A%22document_image%2F33585682_b7a9491a-1ae8-4f5c-8684-4f02a839447f.png%22%2C%22w%22%3A235%7D%5D"/>
            <outline text="Action potential → axon terminals → neurotransmitter release → synaptic cleft → receptor sites (lock &amp; the right key)" _mubu_text="%3Cspan%20class=%22text-color-blue%22%3EAction%20potential%20%3C/span%3E%3Cspan%3E%E2%86%92%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Eaxon%20terminals%3C/span%3E%3Cspan%3E%20%E2%86%92%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Eneurotransmitter%20release%3C/span%3E%3Cspan%3E%20%E2%86%92%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Esynaptic%20cleft%3C/span%3E%3Cspan%3E%20%E2%86%92%20%3C/span%3E%3Cspan%20class=%22text-color-blue%22%3Ereceptor%20sites%3C/span%3E%3Cspan%3E%20(lock%20&amp;amp;%20the%20right%20key)%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="Reuptake 再摄取" _mubu_text="%3Cspan%20class=%22text-color-red%22%3EReuptake%20%3C/span%3E%3Cspan%3E%E5%86%8D%E6%91%84%E5%8F%96%3C/span%3E" _note="" _mubu_note="">
              <outline text="SSRIs = block serotonin reuptake 抑郁症" _mubu_text="%3Cspan%3ESSRIs%20=%20block%20serotonin%20reuptake%20%E6%8A%91%E9%83%81%E7%97%87%3C/span%3E" _note="" _mubu_note=""/>
              <outline text="Reuptake 太快会导致情绪/功能不足" _mubu_text="%3Cspan%3EReuptake%20%E5%A4%AA%E5%BF%AB%E4%BC%9A%E5%AF%BC%E8%87%B4%E6%83%85%E7%BB%AA/%E5%8A%9F%E8%83%BD%E4%B8%8D%E8%B6%B3%3C/span%3E" _note="" _mubu_note=""/>
            </outline>
          </outline>
          <outline text="呜呜呜不想背表格呜呜" _mubu_text="%3Cspan%3E%E5%91%9C%E5%91%9C%E5%91%9C%E4%B8%8D%E6%83%B3%E8%83%8C%E8%A1%A8%E6%A0%BC%E5%91%9C%E5%91%9C%3C/span%3E" _note="" _mubu_note=""/>
          <outline text="| Neurotransmitter | 中文 | 主要作用 | 过多 | 不足 |
| --- | --- | --- | --- | --- |
| Acetylcholine (ACh) | 乙酰胆碱 | 肌肉收缩、学习、记忆 | 肌肉痉挛 | Alzheimer’s，记忆受损、肌肉无力 |
| Dopamine (DA) | 多巴胺 | 奖励、动机、运动、学习 | Schizophrenia，幻觉 | Parkinson’s，运动困难 |
| Serotonin (5-HT) | 血清素 | 情绪、睡眠、食欲 | 过度兴奋（少考） | Depression，焦虑 |
| Norepinephrine (NE) | 去甲肾上腺素 | 警觉、唤醒、情绪 | 焦虑、躁动 | 抑郁、低能量 |
| GABA | γ-氨基丁酸 | 主要抑制性，冷静、放松 | 过度镇静 | 焦虑、癫痫 |
| Glutamate | 谷氨酸 | 主要兴奋性，学习、记忆 | 偏头痛、癫痫 | 学习障碍、记忆下降 |
| Endorphins | 内啡肽 | 镇痛、快感 | 疼痛敏感度降低 | 疼痛感增强 |" _mubu_text="%3Cdiv%20class=%22table-container%22%3E%3Ctable%20class=%22auto-table%22%20border=%221%22%20cellspacing=%220%22%20style=%22border-collapse:%20collapse;%22%3E%3Cthead%3E%3Ctr%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%220%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cdiv%20class=%22row-select-btn%22%20data-row=%220%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E8%A1%8C%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3ENeurotransmitter%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%221%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E4%B8%AD%E6%96%87%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%222%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E4%B8%BB%E8%A6%81%E4%BD%9C%E7%94%A8%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%223%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E8%BF%87%E5%A4%9A%3C/span%3E%3C/th%3E%3Cth%20tabindex=%220%22%20contenteditable=%22false%22%3E%3Cdiv%20class=%22column-select-btn%22%20data-col=%224%22%20title=%22%E9%80%89%E6%8B%A9%E6%AD%A4%E5%88%97%22%20contenteditable=%22false%22%3E%3C/div%3E%3Cspan%20class=%22edit-area%22%20contenteditable=%22true%22%3E%E4%B8%8D%E8%B6%B3%3C/span%3E%3C/th%3E%3C/tr%3E%3C/thead%3E%3Ctbody%3E%3Ctr%3E%3Ctd%20tabinde