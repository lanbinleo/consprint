          </outline>
          <outline text="Sleep Apnea 反复呼吸停止" _mubu_text="%3Cspan%3ESleep%20%3C/span%3E%3Cspan%20class=%22text-color-yellow%22%3EApnea%20%3C/span%3E%3Cspan%3E%E5%8F%8D%E5%A4%8D%E5%91%BC%E5%90%B8%E5%81%9C%E6%AD%A2%3C/span%3E" _note="" _mubu_note="">
            <outline text="打鼾 - 白天疲劳" _mubu_text="%3Cspan%3E%E6%89%93%E9%BC%BE%20-%20%E7%99%BD%E5%A4%A9%E7%96%B2%E5%8A%B3%3C/span%3E" _note="" _mubu_note=""/>
            <outline text="和obesity有关（减肥）" _mubu_text="%3Cspan%3E%E5%92%8Cobesity%E6%9C%89%E5%85%B3%EF%BC%88%E5%87%8F%E8%82%A5%EF%BC%89%3C/span%3E" _note="" _mubu_note=""/>
          </outline>
          <outline text="Narcolepsy 白天突然进入REM" _mubu_text="%3Cspan%20class=%22text-color-yellow%22%3ENarcolepsy%20%3C/span%3E%3Cspan%3E%E7%99%BD%E5%A4%A9%E7%AA%81%E7%84%B6%E8%BF%9B%E5%85%A5REM%3C/span%3E" _note="" _mubu_note="">
            <outline text="sleep attack" _mubu_text="%3Cspan%3Esleep%20attack%3C/span%3E" _note="" _mubu_note=""/>
